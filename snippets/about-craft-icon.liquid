{% doc %}
  Renders a thin-stroke icon for the About craftsmanship section.

  @param {string} icon - Icon key for the corresponding craftsmanship or service value

  @example
  {% render 'about-craft-icon', icon: 'wood' %}
{% enddoc %}

{%- case icon -%}
  {%- when 'wood' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="3"/><path d="M12 3v18M3 12h18" opacity=".35"/></svg>
  {%- when 'handmade' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 21c1-4 3-6 7-7V5a1.5 1.5 0 0 1 3 0v6"/><path d="M15 10V4a1.5 1.5 0 0 1 3 0v8M18 10V6a1.5 1.5 0 0 1 3 0v8c0 4-3 7-7 7H9"/><path d="M9 14V7a1.5 1.5 0 0 1 3 0"/></svg>
  {%- when 'leaf' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 21c4-8 8-12 16-17-1 8-5 13-12 14"/><path d="M8 14c3 0 6-1 9-4"/></svg>
  {%- when 'eye' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 12s4-6 10-6 10 6 10 6-4 6-10 6S2 12 2 12Z"/><circle cx="12" cy="12" r="3"/></svg>
  {%- when 'responsible' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 19V8M12 13c-4 0-6-2-6-5 4 0 6 2 6 5ZM12 11c4 0 6-2 6-5-4 0-6 2-6 5Z"/></svg>
  {%- when 'vietnam' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m12 5 1.6 4.3 4.4.2-3.5 2.8 1.2 4.4-3.7-2.5-3.7 2.5 1.2-4.4L6 9.5l4.4-.2L12 5Z"/></svg>
  {%- when 'thoughtful' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="5"/><path d="M12 1v3M12 20v3M1 12h3M20 12h3M4.2 4.2l2.1 2.1M17.7 17.7l2.1 2.1M19.8 4.2l-2.1 2.1M6.3 17.7l-2.1 2.1"/></svg>
  {%- when 'chair' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 12V7a6 6 0 0 1 12 0v5M4 13v5h16v-5M6 18v3M18 18v3M8 10h8"/></svg>
  {%- when 'globe' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c3 3 4 6 4 9s-1 6-4 9c-3-3-4-6-4-9s1-6 4-9Z"/></svg>
  {%- when 'shield' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 2 8 3v6c0 5-3 9-8 11-5-2-8-6-8-11V5l8-3Z"/><path d="m9 12 2 2 4-5"/></svg>
  {%- when 'diamond' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 8 4-5h10l4 5-9 13L3 8Z"/><path d="M3 8h18M8 3l4 18 4-18"/></svg>
{%- endcase -%}
