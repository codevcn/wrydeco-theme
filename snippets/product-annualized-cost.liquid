{% comment %}
  Renders annualized cost if expected_lifespan_years metafield exists.
  @param {product} product - The product object
  @param {variant} current_variant - The active variant
{% endcomment %}

{% if product.metafields.custom.expected_lifespan_years != blank %}
  {% assign lifespan_years = product.metafields.custom.expected_lifespan_years | plus: 0 %}
  
  {% if lifespan_years > 0 %}
    {% style %}
      .product-annualized-cost {
        background-color: #f3eee1; /* Light beige from design */
        border-radius: 8px;
        padding: 16px 20px;
        margin: 8px 0 16px;
        color: #111;
        font-size: 15px;
        line-height: 1.4;
      }
      .product-annualized-cost__price {
        font-weight: 600;
      }
    {% endstyle %}

    <div class="product-annualized-cost" data-annualized-cost data-lifespan="{{ lifespan_years }}">
      {% assign annualized_amount = current_variant.price | divided_by: lifespan_years %}
      <span class="product-annualized-cost__price" data-annualized-price>{{ annualized_amount | money }}</span>/year &middot; {{ lifespan_years }}+ year lifespan &mdash; An heirloom piece, not fast furniture
    </div>
  {% endif %}
{% endif %}
