{% doc %}
  Renders product media gallery.

  @param {product} product - The product whose media is rendered
  @param {variant} current_variant - The selected product variant
  @param {string} section_id - The parent product section ID
{% enddoc %}

{% stylesheet %}
  .product-gallery {
    --product-gallery-main-max: calc(var(--sp-12) * 9.375);
    --product-gallery-thumb-size: clamp(calc(var(--sp-10) + var(--sp-2)), 8vw, calc(var(--sp-12) + var(--sp-7)));
    width: 100%;
    margin-block-end: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .product-gallery__main {
    aspect-ratio: 1 / 1;
    height: clamp(300px, 78vw, 600px);
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background-color: var(--bg-secondary);
    position: relative;
    z-index: 99;
    width: fit-content;
    margin-inline: auto;
  }
  /* Light-blue lens marking the area shown in the zoom popup. */
  .product-gallery__zoom-lens {
    position: absolute;
    z-index: 2;
    display: none;
    pointer-events: none;
    border: 1.5px solid rgba(90, 150, 230, 0.85);
    background-color: rgba(120, 170, 235, 0.22);
    border-radius: var(--radius-sm);
  }
  .product-gallery__zoom-lens.is-active {
    display: block;
  }
  .product-gallery__wishlist {
    position: absolute;
    inset-block-start: var(--sp-4);
    inset-inline-end: var(--sp-4);
    z-index: 3;
    display: grid;
    place-items: center;
    inline-size: var(--sp-6-bigger);
    block-size: var(--sp-6-bigger);
    padding: var(--sp-0);
    border: var(--border-width) solid var(--color-bark);
    border-radius: var(--radius-full);
    background-color: #ffffff63;
    box-shadow: var(--shadow-elevation-1);
    color: var(--color-bark);
    cursor: pointer;
    transition: var(--transition-fast);
  }
  .product-gallery__wishlist:hover,
  .product-gallery__wishlist:focus-visible,
  .product-gallery__wishlist.is-added {
    background-color: red;
    color: var(--color-milk);
  }
  .product-gallery__wishlist:focus-visible {
    outline: var(--border-width) solid var(--color-bark);
    outline-offset: var(--sp-1);
  }
  .product-gallery__wishlist:disabled {
    cursor: wait;
  }
  .product-gallery__wishlist-icon,
  .product-gallery__wishlist-icon svg {
    display: block;
    inline-size: var(--sp-5);
    block-size: var(--sp-5);
  }
  .product-gallery__main-item {
    display: none;
    width: fit-content;
    border-radius: 6px;
    overflow: hidden;
  }
  .product-gallery__main-item.is-active {
    display: block;
  }
  .product-gallery__main-media {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }
  .product-gallery__thumbnails {
    display: flex;
    overflow-x: auto;
    gap: var(--sp-2);
    scrollbar-width: none;
    -ms-overflow-style: none;
    user-select: none;
    -webkit-user-select: none;
    cursor: grab;
  }
  .product-gallery__thumbnails.is-active-drag {
    cursor: grabbing;
  }
  .product-gallery__thumbnails::-webkit-scrollbar {
    display: none;
  }
  .product-gallery__thumbnail {
    flex: 0 0 calc(35% - var(--sp-7));
    aspect-ratio: 1;
    min-width: 0;
    padding: 0;
    cursor: pointer;
    border: 3px solid transparent;
    border-radius: var(--radius-lg);
    overflow: hidden;
    opacity: 1;
    transition: border-color var(--timing-short) var(--ease-standard);
    background-color: var(--bg-secondary);
  }
  .product-gallery__thumbnail.is-active,
  .product-gallery__thumbnail:hover {
    border-color: var(--color-clay);
  }
  .product-gallery__thumbnail:focus-visible {
    outline: 2px solid var(--color-sage);
    outline-offset: var(--sp-1);
  }
  .product-gallery__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
    -webkit-user-drag: none;
  }

  @media screen and (max-width: 720px) {
    .product-gallery {
      margin-block-end: var(--sp-3);
    }
    .product-gallery__wishlist {
      inset-block-start: var(--sp-3);
      inset-inline-end: var(--sp-3);
    }
  }

  @media screen and (min-width: 720px) {
    .product-gallery__thumbnails {
      padding-inline: var(--sp-2);
    }
    .product-gallery__thumbnail {
      flex: 0 0 var(--product-gallery-thumb-size);
    }
    .product-gallery {
      margin-block-end: 0;
      gap: var(--sp-3);
      max-height: calc(100vh - var(--sp-3));
    }
    .product-gallery__main {
      border-radius: var(--radius-sm);
    }
    .product-gallery__main-item.is-active,
    .product-gallery__main-media {
      height: 100%;
    }
    .product-gallery__main-media iframe,
    .product-gallery__main-media video,
    .product-gallery__main-media model-viewer {
      width: 100%;
      height: 100%;
    }
    .product-gallery__thumbnails {
      padding-inline: 0;
    }
  }

  @media (hover: hover) and (pointer: fine) and (min-width: 990px) {
    .product-gallery__zoom-popup {
      position: fixed;
      top: var(--product-gallery-zoom-top, calc(var(--sp-12) + var(--sp-3)));
      bottom: var(--sp-6);
      left: calc(50% + (var(--sp-8, 40px) / 2));
      right: 64px;
      background-color: var(--bg-primary, #fff);
      z-index: 10000;
      border-radius: var(--radius-lg, 12px);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
      overflow: hidden;
      background-repeat: no-repeat;
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease, visibility 0.2s ease;
    }
    .product-gallery__zoom-popup.is-active {
      opacity: 1;
      visibility: visible;
    }
    .product-gallery__main:hover {
      cursor: crosshair;
    }
  }

  .product-lightbox {
    position: fixed;
    inset: 0;
    z-index: 10000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-6);
    background-color: var(--bg-overlay);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--timing-base) var(--ease-standard);
  }
  .product-lightbox[hidden] {
    display: none;
  }
  .product-lightbox.is-open {
    opacity: 1;
    pointer-events: auto;
  }
  .product-lightbox__img {
    max-width: calc(100vw - (var(--sp-6) * 2));
    max-height: calc(100vh - (var(--sp-6) * 2));
    width: auto;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-elevation-4);
    opacity: 0;
    transform: translateY(var(--sp-3)) scale(0.98);
    transition:
      opacity var(--timing-base) var(--ease-standard),
      transform var(--timing-base) var(--ease-standard);
  }
  .product-lightbox.is-open .product-lightbox__img {
    opacity: 1;
    transform: translateY(var(--sp-0)) scale(1);
  }
  .product-lightbox__close {
    position: absolute;
    top: max(var(--sp-5), env(safe-area-inset-top));
    right: max(var(--sp-5), env(safe-area-inset-right));
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: var(--radius-full);
    background-color: var(--surface-elevated);
    color: var(--text-primary);
    cursor: pointer;
    box-shadow: var(--shadow-elevation-2);
    opacity: 0;
    transform: translateY(calc(var(--sp-3) * -1));
    transition:
      opacity var(--timing-short) var(--ease-standard),
      transform var(--timing-short) var(--ease-standard);
  }
  .product-lightbox.is-open .product-lightbox__close {
    opacity: 1;
    transform: translateY(var(--sp-0));
  }
  .product-lightbox__close svg {
    width: 22px;
    height: 22px;
  }

  .product-lightbox-is-open #shopify-chat,
  .product-lightbox-is-open .shopify-chat,
  .product-lightbox-is-open #chat-widget-container,
  .product-lightbox-is-open iframe[title*='chat' i],
  .product-lightbox-is-open iframe[id*='chat' i],
  .product-lightbox-is-open .scroll-to-top {
    display: none !important;
  }

  @media screen and (max-width: 720px) {
    .product-lightbox {
      --product-lightbox-mobile-top-clear: calc(var(--sp-8) + var(--sp-2));
      align-items: center;
      padding: var(--sp-3);
    }

    .product-lightbox__img {
      max-width: calc(100vw - (var(--sp-3) * 2));
      max-height: calc(100vh - (var(--sp-3) * 2));
    }

    .product-lightbox__close {
      top: max(var(--product-lightbox-mobile-top-clear), env(safe-area-inset-top));
      right: max(var(--sp-3), env(safe-area-inset-right));
    }
  }
{% endstylesheet %}

<div class="product-gallery" data-product-gallery>
  <div class="product-gallery__main">
    {% assign wishlist_variant = current_variant | default: product.selected_or_first_available_variant %}
    <button
      type="button"
      class="product-gallery__wishlist"
      data-product-wishlist
      data-wishlist-product-id="{{ product.id }}"
      data-wishlist-variant-id="{{ wishlist_variant.id }}"
      data-wishlist-product-title="{{ product.title | escape }}"
      aria-label="Add {{ product.title | escape }} to wishlist"
      aria-pressed="false"
    >
      <span class="product-gallery__wishlist-icon" data-product-wishlist-icon aria-hidden="true"></span>
    </button>
    <div class="product-gallery__zoom-lens" data-zoom-lens aria-hidden="true"></div>
    {% assign featured_media = current_variant.featured_media | default: product.featured_media %}
    {% for media in product.media %}
      {% liquid
        assign is_active_media = false
        if media.id == featured_media.id
          assign is_active_media = true
        elsif featured_media == blank
          if forloop.first
            assign is_active_media = true
          endif
        endif
        assign media_alt = media.alt | default: product.title

        # Preload the first N gallery images (eager) so switching thumbnails is instant.
        # The active image keeps high priority (LCP); the rest of the preloaded set uses low.
        # Images beyond the cap stay lazy to save bandwidth on products with many images.
        assign gallery_preload_count = 5
        assign main_loading = 'lazy'
        assign main_fetchpriority = 'auto'
        if is_active_media
          assign main_loading = 'eager'
          assign main_fetchpriority = 'high'
        elsif forloop.index <= gallery_preload_count
          assign main_loading = 'eager'
          assign main_fetchpriority = 'low'
        endif
      %}
      <div
        id="ProductMedia-{{ section_id }}-{{ media.id }}"
        class="product-gallery__main-item{% if is_active_media %} is-active{% endif %}"
        data-main-media-id="{{ media.id }}"
        data-alt="{{ media.alt | escape }}"
      >
        {% case media.media_type %}
          {% when 'image' %}
            {% assign zoom_url = media | image_url: width: 2400 %}
            {{
              media
              | image_url: width: 1200
              | image_tag:
                class: 'product-gallery__main-media',
                loading: main_loading,
                fetchpriority: main_fetchpriority,
                widths: '360, 540, 720, 900, 1200',
                sizes: '(min-width: 1024px) 56vw, (min-width: 720px) 58vw, 100vw',
                alt: media_alt,
                data-zoom-src: zoom_url
            }}
          {% when 'external_video' %}
            <div class="product-gallery__main-media">
              {{ media | external_video_tag }}
            </div>
          {% when 'video' %}
            <div class="product-gallery__main-media">
              {{ media | video_tag: controls: true, autoplay: true }}
            </div>
          {% else %}
            <div class="product-gallery__main-media">
              {{ media | media_tag }}
            </div>
        {% endcase %}
      </div>
    {% endfor %}
  </div>

  {% if product.media.size > 1 %}
    <div class="product-gallery__thumbnails">
      {% for media in product.media %}
        {% liquid
          assign is_active_thumbnail = false
          if media.id == featured_media.id
            assign is_active_thumbnail = true
          elsif featured_media == blank
            if forloop.first
              assign is_active_thumbnail = true
            endif
          endif
          assign thumbnail_alt = media.alt | default: product.title
        %}
        <button
          type="button"
          class="product-gallery__thumbnail{% if is_active_thumbnail %} is-active{% endif %}"
          data-thumbnail-id="{{ media.id }}"
          data-alt="{{ media.alt | escape }}"
          aria-controls="ProductMedia-{{ section_id }}-{{ media.id }}"
          aria-pressed="{% if is_active_thumbnail %}true{% else %}false{% endif %}"
          aria-label="View {{ thumbnail_alt | escape }}, media {{ forloop.index }} of {{ product.media.size }}"
          onclick="
            const gallery = this.closest('[data-product-gallery]');
            gallery.querySelectorAll('.product-gallery__main-item').forEach(el => el.classList.remove('is-active'));
            gallery.querySelector('.product-gallery__main-item[data-main-media-id=\'{{ media.id }}\']').classList.add('is-active');
            gallery.querySelectorAll('.product-gallery__thumbnail').forEach(el => el.classList.remove('is-active'));
            gallery.querySelectorAll('.product-gallery__thumbnail').forEach(el => el.setAttribute('aria-pressed', 'false'));
            this.classList.add('is-active');
            this.setAttribute('aria-pressed', 'true');
          "
        >
          {{ media | image_url: width: 160 | image_tag: loading: 'lazy', alt: thumbnail_alt }}
        </button>
      {% endfor %}
    </div>
  {% endif %}

  <div class="product-lightbox" data-product-lightbox hidden>
    <button type="button" class="product-lightbox__close" data-lightbox-close aria-label="Close">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    {% # The source is assigned at runtime from the active gallery image (already optimized via image_url) %}
    {% # theme-check-disable ImgWidthAndHeight,RemoteAsset %}
    <img class="product-lightbox__img" data-lightbox-img src="" alt="">
    {% # theme-check-enable ImgWidthAndHeight,RemoteAsset %}
  </div>

  <div class="product-gallery__zoom-popup" data-zoom-popup></div>
</div>

<script>
  (function () {
    function initGalleryLightbox() {
      document.querySelectorAll('[data-product-gallery]').forEach(function (gallery) {
        if (gallery.dataset.lightboxInit === 'true') return;

        var zoomBtn = gallery.querySelector('[data-gallery-zoom]');
        var lightbox = gallery.querySelector('[data-product-lightbox]');
        if (!lightbox) return;

        var lightboxImg = lightbox.querySelector('[data-lightbox-img]');
        var closeBtn = lightbox.querySelector('[data-lightbox-close]');
        if (!lightboxImg || !closeBtn) return;

        gallery.dataset.lightboxInit = 'true';
        var originalParent = lightbox.parentNode;
        var originalNextSibling = lightbox.nextSibling;
        var closeTransitionHandler;

        function getActiveImage() {
          var activeItem = gallery.querySelector('.product-gallery__main-item.is-active');
          if (!activeItem) return null;
          return activeItem.querySelector('img.product-gallery__main-media');
        }

        function openLightbox() {
          var img = getActiveImage();
          if (!img) return;
          if (closeTransitionHandler) {
            lightbox.removeEventListener('transitionend', closeTransitionHandler);
            closeTransitionHandler = null;
          }
          lightboxImg.src = img.currentSrc || img.src;
          lightboxImg.alt = img.alt || '';
          if (lightbox.parentNode !== document.body) {
            document.body.appendChild(lightbox);
          }
          lightbox.hidden = false;
          lightbox.dataset.open = 'true';
          document.body.classList.add('product-lightbox-is-open');
          document.body.style.overflow = 'hidden';
          window.requestAnimationFrame(function () {
            if (lightbox.dataset.open !== 'true') return;
            lightbox.classList.add('is-open');
            closeBtn.focus();
          });
        }

        function closeLightbox() {
          if (lightbox.hidden || lightbox.dataset.open !== 'true') return;
          lightbox.dataset.open = 'false';
          lightbox.classList.remove('is-open');
          document.body.classList.remove('product-lightbox-is-open');
          document.body.style.overflow = '';

          var finishClose = function (event) {
            if (event && event.target !== lightbox) return;
            lightbox.removeEventListener('transitionend', finishClose);
            closeTransitionHandler = null;
            if (lightbox.dataset.open === 'true') return;
            lightbox.hidden = true;
            lightboxImg.src = '';
            if (originalParent && lightbox.parentNode !== originalParent) {
              originalParent.insertBefore(lightbox, originalNextSibling);
            }
          };

          if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            finishClose();
            return;
          }

          closeTransitionHandler = finishClose;
          lightbox.addEventListener('transitionend', finishClose);
        }

        if (zoomBtn) {
          zoomBtn.addEventListener('click', openLightbox);
        }

        var mainContainer = gallery.querySelector('.product-gallery__main');
        if (mainContainer) {
          mainContainer.addEventListener('click', function (event) {
            // Ignore if clicked on the zoom button itself to prevent duplicate handling
            if (event.target.closest('[data-gallery-zoom]')) return;
            openLightbox();
          });
        }

        closeBtn.addEventListener('click', closeLightbox);
        lightbox.addEventListener('click', function (event) {
          if (event.target === lightbox) closeLightbox();
        });
        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape' && !lightbox.hidden) closeLightbox();
        });

        var thumbnails = gallery.querySelector('.product-gallery__thumbnails');
        if (thumbnails) {
          var isDown = false;
          var startX;
          var scrollLeft;
          var isDragging = false;

          thumbnails.addEventListener('mousedown', function (e) {
            isDown = true;
            isDragging = false;
            thumbnails.classList.add('is-active-drag');
            startX = e.pageX - thumbnails.offsetLeft;
            scrollLeft = thumbnails.scrollLeft;
          });
          thumbnails.addEventListener('mouseleave', function () {
            isDown = false;
            thumbnails.classList.remove('is-active-drag');
          });
          thumbnails.addEventListener('mouseup', function () {
            isDown = false;
            thumbnails.classList.remove('is-active-drag');
          });
          thumbnails.addEventListener('mousemove', function (e) {
            if (!isDown) return;
            e.preventDefault();
            var x = e.pageX - thumbnails.offsetLeft;
            var walk = (x - startX) * 2; // scroll speed multiplier
            if (Math.abs(walk) > 5) {
              isDragging = true;
            }
            thumbnails.scrollLeft = scrollLeft - walk;
          });
          thumbnails.addEventListener(
            'click',
            function (e) {
              if (isDragging) {
                e.stopPropagation();
                e.preventDefault();
              }
            },
            true
          );
        }
      });
    }

    function initGalleryZoom() {
      if (!window.matchMedia('(hover: hover) and (pointer: fine) and (min-width: 990px)').matches) return;

      document.querySelectorAll('[data-product-gallery]').forEach(function (gallery) {
        if (gallery.dataset.zoomInit === 'true') return;
        gallery.dataset.zoomInit = 'true';

        var mainContainer = gallery.querySelector('.product-gallery__main');
        var zoomPopup = gallery.querySelector('[data-zoom-popup]');
        if (!mainContainer || !zoomPopup) return;
        var lens = gallery.querySelector('[data-zoom-lens]');
        var zoomPopupParent = zoomPopup.parentNode;
        var zoomPopupNextSibling = zoomPopup.nextSibling;

        // The popup zooms to 200% (background-size), so the lens covers half the
        // image in each dimension — the exact region shown in the popup.
        var ZOOM = 2;

        function getZoomTop() {
          var header = document.querySelector('.header');
          if (!header) return 24;

          var rect = header.getBoundingClientRect();
          return Math.max(24, Math.ceil(rect.bottom + 12));
        }

        function mountZoomPopup() {
          if (zoomPopup.parentNode !== document.body) {
            document.body.appendChild(zoomPopup);
          }

          zoomPopup.style.setProperty('--product-gallery-zoom-top', getZoomTop() + 'px');
        }

        function restoreZoomPopup() {
          if (zoomPopupParent && zoomPopup.parentNode !== zoomPopupParent) {
            zoomPopupParent.insertBefore(zoomPopup, zoomPopupNextSibling);
          }
        }

        mainContainer.addEventListener('mouseenter', function () {
          var activeItem = gallery.querySelector('.product-gallery__main-item.is-active');
          if (!activeItem) return;
          var img = activeItem.querySelector('img.product-gallery__main-media');
          if (!img) return;

          var zoomSrc = img.getAttribute('data-zoom-src');
          if (zoomSrc) {
            mountZoomPopup();
            zoomPopup.style.backgroundImage = 'url(' + zoomSrc + ')';
            zoomPopup.classList.add('is-active');
            if (lens) lens.classList.add('is-active');
          }
        });

        mainContainer.addEventListener('mousemove', function (e) {
          if (!zoomPopup.classList.contains('is-active')) return;

          var rect = mainContainer.getBoundingClientRect();
          var x = e.clientX - rect.left;
          var y = e.clientY - rect.top;

          var lensW = rect.width / ZOOM;
          var lensH = rect.height / ZOOM;

          // Center the lens on the cursor so it tracks the pointer 1:1, clamped
          // to stay inside the image.
          var lensLeft = Math.max(0, Math.min(rect.width - lensW, x - lensW / 2));
          var lensTop = Math.max(0, Math.min(rect.height - lensH, y - lensH / 2));

          if (lens) {
            lens.style.width = lensW + 'px';
            lens.style.height = lensH + 'px';
            lens.style.left = lensLeft + 'px';
            lens.style.top = lensTop + 'px';
          }

          // Keep the popup showing exactly the region under the lens.
          var rangeX = rect.width - lensW;
          var rangeY = rect.height - lensH;
          var posX = rangeX > 0 ? lensLeft / rangeX : 0;
          var posY = rangeY > 0 ? lensTop / rangeY : 0;
          zoomPopup.style.backgroundPosition = posX * 100 + '% ' + posY * 100 + '%';
          zoomPopup.style.backgroundSize = ZOOM * 100 + '%';
        });

        mainContainer.addEventListener('mouseleave', function () {
          zoomPopup.classList.remove('is-active');
          zoomPopup.style.backgroundImage = 'none';
          restoreZoomPopup();
          if (lens) lens.classList.remove('is-active');
        });
      });
    }

    function readCookie(name) {
      var cookies = document.cookie ? document.cookie.split('; ') : [];

      for (var index = 0; index < cookies.length; index += 1) {
        var separatorIndex = cookies[index].indexOf('=');
        if (separatorIndex === -1) continue;
        if (cookies[index].slice(0, separatorIndex) !== name) continue;

        try {
          return decodeURIComponent(cookies[index].slice(separatorIndex + 1));
        } catch (error) {
          return '';
        }
      }

      return '';
    }

    function createWishlistCustomerId() {
      if (!window.crypto || !window.crypto.getRandomValues) return '';

      var bytes = new Uint8Array(15);
      var binary = '';
      window.crypto.getRandomValues(bytes);

      bytes.forEach(function (byte) {
        binary += String.fromCharCode(byte);
      });

      return window.btoa(binary).replace(/\+/g, '-').replace(/\//g, '_').replace(/=+$/, '');
    }

    // Read the wishlist customer id WITHOUT creating one, so simply viewing a
    // product never sets a cookie. Returns '' when the shopper has no id yet.
    function resolveWishlistCustomerId() {
      var analytics = window.ShopifyAnalytics && window.ShopifyAnalytics.meta;
      var customerId = analytics && analytics.page && analytics.page.customerId;

      if (!customerId && window.meta && window.meta.page) {
        customerId = window.meta.page.customerId;
      }
      if (!customerId && window.__st) {
        customerId = window.__st.cid;
      }
      if (customerId) return String(customerId);

      return readCookie('__v__wl__c__') || '';
    }

    function getWishlistCustomerId() {
      var existingCustomerId = resolveWishlistCustomerId();
      if (existingCustomerId) return existingCustomerId;

      var generatedCustomerId = createWishlistCustomerId();
      if (!generatedCustomerId) return '';

      document.cookie = '__v__wl__c__=' + encodeURIComponent(generatedCustomerId) + '; path=/; max-age=31536000; samesite=strict';
      return generatedCustomerId;
    }

    // Locally mirror which variants this browser has added, so the heart shows
    // the correct state on load and when switching variants. This reflects adds
    // made in THIS browser only; it does not track removals or other devices —
    // the authoritative check is still the API response when the shopper clicks.
    var WISHLIST_ADDED_STORAGE_PREFIX = 'wrydeco_wishlist_added_';

    function wishlistStorageKey(customerId) {
      return WISHLIST_ADDED_STORAGE_PREFIX + (customerId || 'anon');
    }

    function readAddedVariants(customerId) {
      try {
        var raw = window.localStorage.getItem(wishlistStorageKey(customerId));
        if (!raw) return {};
        var parsed = JSON.parse(raw);
        return parsed && typeof parsed === 'object' ? parsed : {};
      } catch (error) {
        return {};
      }
    }

    function isVariantAdded(variantId) {
      if (!variantId) return false;
      return readAddedVariants(resolveWishlistCustomerId())[String(variantId)] === true;
    }

    function rememberAddedVariant(customerId, variantId) {
      if (!variantId) return;
      try {
        var map = readAddedVariants(customerId);
        map[String(variantId)] = true;
        window.localStorage.setItem(wishlistStorageKey(customerId), JSON.stringify(map));
      } catch (error) {
        // Non-fatal: the button still works without the local mirror.
      }
    }

    function applyWishlistButtonState(button, added) {
      var title = button.dataset.wishlistProductTitle || 'this piece';
      button.classList.toggle('is-added', added);
      button.setAttribute('aria-pressed', added ? 'true' : 'false');
      button.setAttribute('aria-label', added ? title + ' is in your wishlist' : 'Add ' + title + ' to wishlist');
    }

    function syncWishlistButtonForVariant(button) {
      applyWishlistButtonState(button, isVariantAdded(getWishlistVariantId(button)));
    }

    function syncWishlistIcon(button) {
      var iconTarget = button.querySelector('[data-product-wishlist-icon]');
      var sourceIcon = document.querySelector('#vitals-wishlist-header .Vtl-WishlistHeader__HeartIconWrapper');
      if (!iconTarget || !sourceIcon || iconTarget.firstElementChild) return false;

      var icon = sourceIcon.cloneNode(true);
      icon.removeAttribute('class');
      icon.removeAttribute('style');
      icon.setAttribute('aria-hidden', 'true');
      icon.style.setProperty('fill', 'currentColor', 'important');
      iconTarget.appendChild(icon);
      return true;
    }

    function getWishlistVariantId(button) {
      // The product form's hidden id is the live source of truth (it is what the
      // add-to-cart request submits), so trust it before the URL param, which can
      // lag behind the current selection.
      var selectedVariant = document.querySelector('form[action*="/cart/add"] [name="id"]');
      if (selectedVariant && selectedVariant.value) return selectedVariant.value;

      var urlVariantId = new URL(window.location.href).searchParams.get('variant');
      if (urlVariantId) return urlVariantId;

      return button.dataset.wishlistVariantId;
    }

    function updateWishlistHeaderCount() {
      var counter = document.querySelector('#vitals-wishlist-header .Vtl-WishlistHeader__HeartCounter');
      if (!counter) {
        var iconWrapper = document.querySelector('#vitals-wishlist-header .Vtl-WishlistHeader__IconWrapper');
        if (!iconWrapper) return;

        counter = document.createElement('span');
        counter.className = 'Vtl-WishlistHeader__HeartCounter';
        iconWrapper.appendChild(counter);
      }

      var count = Number.parseInt(counter.textContent, 10);
      counter.textContent = String(Number.isNaN(count) ? 1 : count + 1);
    }

    function showWishlistToast(message, type) {
      if (typeof window.showToast !== 'function') return;
      window.showToast({
        message: message,
        type: type,
        position: 'bottom-left',
        duration: 4000,
      });
    }

    function initProductWishlist() {
      document.querySelectorAll('[data-product-wishlist]').forEach(function (button) {
        if (button.dataset.wishlistInit === 'true') return;
        button.dataset.wishlistInit = 'true';

        if (!syncWishlistIcon(button)) {
          var observer = new MutationObserver(function () {
            if (syncWishlistIcon(button)) observer.disconnect();
          });
          observer.observe(document.body, { childList: true, subtree: true });
        }

        // Reflect the known state for the initial variant, and keep it in sync
        // when the shopper switches variants — wishlist membership is per-variant,
        // so a heart added for one variant must not stay lit for another.
        syncWishlistButtonForVariant(button);
        document.addEventListener('variant:change', function () {
          syncWishlistButtonForVariant(button);
        });

        button.addEventListener('click', function (event) {
          event.preventDefault();
          event.stopPropagation();
          if (button.disabled) return;

          var wishlistData = window.vtlsLiquidData || {};
          var appId = wishlistData.shopInfo && wishlistData.shopInfo.appId;
          var apiHost = appId && wishlistData.apiHosts && wishlistData.apiHosts[appId];
          var shopId = wishlistData.shopInfo && wishlistData.shopInfo.id;
          var variantId = getWishlistVariantId(button);
          var customerId = getWishlistCustomerId();

          if (!apiHost || !shopId || !customerId || !variantId) {
            showWishlistToast('We could not add this piece to your wishlist. Please try again.', 'error');
            return;
          }

          button.disabled = true;
          button.setAttribute('aria-busy', 'true');

          window
            .fetch(apiHost + '/bundle/api/v2/sf/ws', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                shop_id: shopId,
                customerId: customerId,
                productId: Number(button.dataset.wishlistProductId),
                variantId: Number(variantId),
              }),
            })
            .then(function (response) {
              if (response.status === 409) {
                rememberAddedVariant(customerId, variantId);
                applyWishlistButtonState(button, true);
                showWishlistToast('This piece is already in your wishlist.', 'info');
                return;
              }
              if (!response.ok) throw new Error('Wishlist request failed');

              rememberAddedVariant(customerId, variantId);
              applyWishlistButtonState(button, true);
              updateWishlistHeaderCount();
              showWishlistToast('Added to your wishlist.', 'success');
            })
            .catch(function () {
              showWishlistToast('We could not add this piece to your wishlist. Please try again.', 'error');
            })
            .finally(function () {
              button.disabled = false;
              button.removeAttribute('aria-busy');
            });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initGalleryLightbox();
        initGalleryZoom();
        initProductWishlist();
      });
    } else {
      initGalleryLightbox();
      initGalleryZoom();
      initProductWishlist();
    }
  })();
</script>
