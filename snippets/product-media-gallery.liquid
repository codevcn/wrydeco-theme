{% doc %}
  Renders product media gallery.

  @param {product} product - The product whose media is rendered
  @param {variant} current_variant - The selected product variant
  @param {string} section_id - The parent product section ID
{% enddoc %}

{% stylesheet %}
  .product-gallery {
    width: 100%;
    margin-block-end: var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .product-gallery__main {
    aspect-ratio: 1 / 1;
    height: clamp(300px, 78vw, 600px);
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background-color: var(--bg-secondary);
  }
  .product-gallery__zoom {
    position: absolute;
    top: var(--sp-3);
    left: var(--sp-3);
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    border: none;
    background-color: rgba(245, 241, 237, 0.85);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: var(--text-primary);
    box-shadow: var(--shadow-elevation-1);
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard),
      opacity var(--timing-short) var(--ease-standard);
    opacity: 0;
  }
  .product-gallery__zoom:hover {
    background-color: var(--surface-elevated);
  }
  .product-gallery__zoom svg {
    width: 18px;
    height: 18px;
  }
  /* Light-blue lens marking the area shown in the zoom popup. */
  .product-gallery__zoom-lens {
    position: absolute;
    z-index: 2;
    display: none;
    pointer-events: none;
    border: 1.5px solid rgba(90, 150, 230, 0.85);
    background-color: rgba(120, 170, 235, 0.22);
    border-radius: var(--radius-sm);
  }
  .product-gallery__zoom-lens.is-active {
    display: block;
  }
  .product-gallery__main-item {
    display: none;
    width: 100%;
    border-radius: 6px;
    overflow: hidden;
  }
  .product-gallery__main-item.is-active {
    display: block;
  }
  .product-gallery__main-media {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  .product-gallery__thumbnails {
    display: flex;
    overflow-x: auto;
    gap: var(--sp-2);
    scrollbar-width: none;
    -ms-overflow-style: none;
    user-select: none;
    -webkit-user-select: none;
    cursor: grab;
  }
  .product-gallery__thumbnails.is-active-drag {
    cursor: grabbing;
  }
  .product-gallery__thumbnails::-webkit-scrollbar {
    display: none;
  }
  .product-gallery__thumbnail {
    flex: 0 0 calc(35% - var(--sp-7));
    aspect-ratio: 1;
    min-width: 0;
    padding: 0;
    cursor: pointer;
    border: 1px solid transparent;
    border-radius: var(--radius-lg);
    overflow: hidden;
    opacity: 0.6;
    transition: opacity var(--timing-short) var(--ease-standard), border-color var(--timing-short) var(--ease-standard);
    background-color: var(--bg-secondary);
  }
  .product-gallery__thumbnail.is-active,
  .product-gallery__thumbnail:hover {
    opacity: 1;
    border-color: var(--color-clay);
  }
  .product-gallery__thumbnail:focus-visible {
    outline: 2px solid var(--color-sage);
    outline-offset: var(--sp-1);
  }
  .product-gallery__thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    pointer-events: none;
    -webkit-user-drag: none;
  }

  @media screen and (max-width: 720px) {
    .product-gallery {
      margin-block-end: var(--sp-3);
    }
  }

  @media screen and (min-width: 720px) {
    .product-gallery__thumbnails {
      padding-inline: var(--sp-2);
    }
    .product-gallery__thumbnail {
      flex: 0 0 calc(25% - var(--sp-7));
    }
    .product-gallery {
      margin-block-end: 0;
      gap: var(--sp-3);
    }
    .product-gallery__main {
      border-radius: var(--radius-sm);
    }
    .product-gallery__main:hover .product-gallery__zoom {
      opacity: 1;
    }
    .product-gallery__main-item.is-active,
    .product-gallery__main-media {
      height: 100%;
    }
    .product-gallery__main-media {
      object-fit: cover;
    }
    .product-gallery__main-media iframe,
    .product-gallery__main-media video,
    .product-gallery__main-media model-viewer {
      width: 100%;
      height: 100%;
    }
    .product-gallery__thumbnails {
      padding-inline: 0;
    }
  }

  @media (hover: hover) and (pointer: fine) and (min-width: 990px) {
    .product-gallery__zoom-popup {
      position: fixed;
      top: 50%;
      transform: translateY(-50%);
      left: calc(50% + (var(--sp-8, 40px) / 2));
      right: 64px;
      height: 85vh;
      background-color: var(--bg-primary, #fff);
      z-index: 9999;
      border-radius: var(--radius-lg, 12px);
      box-shadow: 0 16px 48px rgba(0, 0, 0, 0.4);
      overflow: hidden;
      background-repeat: no-repeat;
      pointer-events: none;
      opacity: 0;
      visibility: hidden;
      transition: opacity 0.2s ease, visibility 0.2s ease;
    }
    .product-gallery__zoom-popup.is-active {
      opacity: 1;
      visibility: visible;
    }
    .product-gallery__main:hover {
      cursor: crosshair;
    }
  }

  .product-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1200;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-6);
    background-color: var(--bg-overlay);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .product-lightbox[hidden] {
    display: none;
  }
  .product-lightbox__img {
    max-width: 95vw;
    max-height: 90vh;
    width: auto;
    height: auto;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-elevation-4);
  }
  .product-lightbox__close {
    position: absolute;
    top: var(--sp-5);
    right: var(--sp-5);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: var(--radius-full);
    background-color: var(--surface-elevated);
    color: var(--text-primary);
    cursor: pointer;
    box-shadow: var(--shadow-elevation-2);
  }
  .product-lightbox__close svg {
    width: 22px;
    height: 22px;
  }
{% endstylesheet %}

<div class="product-gallery" data-product-gallery>
  <div class="product-gallery__main">
    <button type="button" class="product-gallery__zoom" data-gallery-zoom aria-label="Zoom image">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        <line x1="11" y1="8" x2="11" y2="14"></line>
        <line x1="8" y1="11" x2="14" y2="11"></line>
      </svg>
    </button>
    <div class="product-gallery__zoom-lens" data-zoom-lens aria-hidden="true"></div>
    {% assign featured_media = current_variant.featured_media | default: product.featured_media %}
    {% for media in product.media %}
      {% liquid
        assign is_active_media = false
        if media.id == featured_media.id
          assign is_active_media = true
        elsif featured_media == blank
          if forloop.first
            assign is_active_media = true
          endif
        endif
        assign media_alt = media.alt | default: product.title
      %}
      <div
        id="ProductMedia-{{ section_id }}-{{ media.id }}"
        class="product-gallery__main-item{% if is_active_media %} is-active{% endif %}"
        data-main-media-id="{{ media.id }}"
        data-alt="{{ media.alt | escape }}"
      >
        {% case media.media_type %}
          {% when 'image' %}
            {% if is_active_media %}
              {% assign zoom_url = media | image_url: width: 2400 %}
              {{
                media
                | image_url: width: 1200
                | image_tag:
                  class: 'product-gallery__main-media',
                  loading: 'eager',
                  fetchpriority: 'high',
                  widths: '360, 540, 720, 900, 1200',
                  sizes: '(min-width: 1024px) 56vw, (min-width: 720px) 58vw, 100vw',
                  alt: media_alt,
                  data-zoom-src: zoom_url
              }}
            {% else %}
              {% assign zoom_url = media | image_url: width: 2400 %}
              {{
                media
                | image_url: width: 1200
                | image_tag:
                  class: 'product-gallery__main-media',
                  loading: 'lazy',
                  widths: '360, 540, 720, 900, 1200',
                  sizes: '(min-width: 1024px) 56vw, (min-width: 720px) 58vw, 100vw',
                  alt: media_alt,
                  data-zoom-src: zoom_url
              }}
            {% endif %}
          {% when 'external_video' %}
            <div class="product-gallery__main-media">
              {{ media | external_video_tag }}
            </div>
          {% when 'video' %}
            <div class="product-gallery__main-media">
              {{ media | video_tag: controls: true, autoplay: true }}
            </div>
          {% else %}
            <div class="product-gallery__main-media">
              {{ media | media_tag }}
            </div>
        {% endcase %}
      </div>
    {% endfor %}
  </div>

  {% if product.media.size > 1 %}
    <div class="product-gallery__thumbnails">
      {% for media in product.media %}
        {% liquid
          assign is_active_thumbnail = false
          if media.id == featured_media.id
            assign is_active_thumbnail = true
          elsif featured_media == blank
            if forloop.first
              assign is_active_thumbnail = true
            endif
          endif
          assign thumbnail_alt = media.alt | default: product.title
        %}
        <button
          type="button"
          class="product-gallery__thumbnail{% if is_active_thumbnail %} is-active{% endif %}"
          data-thumbnail-id="{{ media.id }}"
          data-alt="{{ media.alt | escape }}"
          aria-controls="ProductMedia-{{ section_id }}-{{ media.id }}"
          aria-pressed="{% if is_active_thumbnail %}true{% else %}false{% endif %}"
          aria-label="View {{ thumbnail_alt | escape }}, media {{ forloop.index }} of {{ product.media.size }}"
          onclick="
            const gallery = this.closest('[data-product-gallery]');
            gallery.querySelectorAll('.product-gallery__main-item').forEach(el => el.classList.remove('is-active'));
            gallery.querySelector('.product-gallery__main-item[data-main-media-id=\'{{ media.id }}\']').classList.add('is-active');
            gallery.querySelectorAll('.product-gallery__thumbnail').forEach(el => el.classList.remove('is-active'));
            gallery.querySelectorAll('.product-gallery__thumbnail').forEach(el => el.setAttribute('aria-pressed', 'false'));
            this.classList.add('is-active');
            this.setAttribute('aria-pressed', 'true');
          "
        >
          {{ media | image_url: width: 160 | image_tag: loading: 'lazy', alt: thumbnail_alt }}
        </button>
      {% endfor %}
    </div>
  {% endif %}

  <div class="product-lightbox" data-product-lightbox hidden>
    <button type="button" class="product-lightbox__close" data-lightbox-close aria-label="Close">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.6"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <line x1="18" y1="6" x2="6" y2="18"></line>
        <line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    {% # The source is assigned at runtime from the active gallery image (already optimized via image_url) %}
    {% # theme-check-disable ImgWidthAndHeight,RemoteAsset %}
    <img class="product-lightbox__img" data-lightbox-img src="" alt="">
    {% # theme-check-enable ImgWidthAndHeight,RemoteAsset %}
  </div>

  <div class="product-gallery__zoom-popup" data-zoom-popup></div>
</div>

<script>
  (function () {
    function initGalleryLightbox() {
      document.querySelectorAll('[data-product-gallery]').forEach(function (gallery) {
        if (gallery.dataset.lightboxInit === 'true') return;
        gallery.dataset.lightboxInit = 'true';

        var zoomBtn = gallery.querySelector('[data-gallery-zoom]');
        var lightbox = gallery.querySelector('[data-product-lightbox]');
        if (!zoomBtn || !lightbox) return;

        var lightboxImg = lightbox.querySelector('[data-lightbox-img]');
        var closeBtn = lightbox.querySelector('[data-lightbox-close]');

        function getActiveImage() {
          var activeItem = gallery.querySelector('.product-gallery__main-item.is-active');
          if (!activeItem) return null;
          return activeItem.querySelector('img.product-gallery__main-media');
        }

        function openLightbox() {
          var img = getActiveImage();
          if (!img) return;
          lightboxImg.src = img.currentSrc || img.src;
          lightboxImg.alt = img.alt || '';
          lightbox.hidden = false;
          document.body.style.overflow = 'hidden';
          closeBtn.focus();
        }

        function closeLightbox() {
          lightbox.hidden = true;
          lightboxImg.src = '';
          document.body.style.overflow = '';
        }

        zoomBtn.addEventListener('click', openLightbox);

        var mainContainer = gallery.querySelector('.product-gallery__main');
        if (mainContainer) {
          mainContainer.addEventListener('click', function (event) {
            // Ignore if clicked on the zoom button itself to prevent duplicate handling
            if (event.target.closest('[data-gallery-zoom]')) return;
            openLightbox();
          });
        }

        closeBtn.addEventListener('click', closeLightbox);
        lightbox.addEventListener('click', function (event) {
          if (event.target === lightbox) closeLightbox();
        });
        document.addEventListener('keydown', function (event) {
          if (event.key === 'Escape' && !lightbox.hidden) closeLightbox();
        });

        var thumbnails = gallery.querySelector('.product-gallery__thumbnails');
        if (thumbnails) {
          var isDown = false;
          var startX;
          var scrollLeft;
          var isDragging = false;

          thumbnails.addEventListener('mousedown', function (e) {
            isDown = true;
            isDragging = false;
            thumbnails.classList.add('is-active-drag');
            startX = e.pageX - thumbnails.offsetLeft;
            scrollLeft = thumbnails.scrollLeft;
          });
          thumbnails.addEventListener('mouseleave', function () {
            isDown = false;
            thumbnails.classList.remove('is-active-drag');
          });
          thumbnails.addEventListener('mouseup', function () {
            isDown = false;
            thumbnails.classList.remove('is-active-drag');
          });
          thumbnails.addEventListener('mousemove', function (e) {
            if (!isDown) return;
            e.preventDefault();
            var x = e.pageX - thumbnails.offsetLeft;
            var walk = (x - startX) * 2; // scroll speed multiplier
            if (Math.abs(walk) > 5) {
              isDragging = true;
            }
            thumbnails.scrollLeft = scrollLeft - walk;
          });
          thumbnails.addEventListener(
            'click',
            function (e) {
              if (isDragging) {
                e.stopPropagation();
                e.preventDefault();
              }
            },
            true
          );
        }
      });
    }

    function initGalleryZoom() {
      if (!window.matchMedia('(hover: hover) and (pointer: fine) and (min-width: 990px)').matches) return;

      document.querySelectorAll('[data-product-gallery]').forEach(function (gallery) {
        if (gallery.dataset.zoomInit === 'true') return;
        gallery.dataset.zoomInit = 'true';

        var mainContainer = gallery.querySelector('.product-gallery__main');
        var zoomPopup = gallery.querySelector('[data-zoom-popup]');
        if (!mainContainer || !zoomPopup) return;
        var lens = gallery.querySelector('[data-zoom-lens]');

        // The popup zooms to 200% (background-size), so the lens covers half the
        // image in each dimension — the exact region shown in the popup.
        var ZOOM = 2;

        mainContainer.addEventListener('mouseenter', function () {
          var activeItem = gallery.querySelector('.product-gallery__main-item.is-active');
          if (!activeItem) return;
          var img = activeItem.querySelector('img.product-gallery__main-media');
          if (!img) return;

          var zoomSrc = img.getAttribute('data-zoom-src');
          if (zoomSrc) {
            zoomPopup.style.backgroundImage = 'url(' + zoomSrc + ')';
            zoomPopup.classList.add('is-active');
            if (lens) lens.classList.add('is-active');
          }
        });

        mainContainer.addEventListener('mousemove', function (e) {
          if (!zoomPopup.classList.contains('is-active')) return;

          var rect = mainContainer.getBoundingClientRect();
          var x = e.clientX - rect.left;
          var y = e.clientY - rect.top;

          var lensW = rect.width / ZOOM;
          var lensH = rect.height / ZOOM;

          // Center the lens on the cursor so it tracks the pointer 1:1, clamped
          // to stay inside the image.
          var lensLeft = Math.max(0, Math.min(rect.width - lensW, x - lensW / 2));
          var lensTop = Math.max(0, Math.min(rect.height - lensH, y - lensH / 2));

          if (lens) {
            lens.style.width = lensW + 'px';
            lens.style.height = lensH + 'px';
            lens.style.left = lensLeft + 'px';
            lens.style.top = lensTop + 'px';
          }

          // Keep the popup showing exactly the region under the lens.
          var rangeX = rect.width - lensW;
          var rangeY = rect.height - lensH;
          var posX = rangeX > 0 ? lensLeft / rangeX : 0;
          var posY = rangeY > 0 ? lensTop / rangeY : 0;
          zoomPopup.style.backgroundPosition = posX * 100 + '% ' + posY * 100 + '%';
          zoomPopup.style.backgroundSize = ZOOM * 100 + '%';
        });

        mainContainer.addEventListener('mouseleave', function () {
          zoomPopup.classList.remove('is-active');
          zoomPopup.style.backgroundImage = 'none';
          if (lens) lens.classList.remove('is-active');
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initGalleryLightbox();
        initGalleryZoom();
      });
    } else {
      initGalleryLightbox();
      initGalleryZoom();
    }
  })();
</script>
