{% comment %}
  Renders the sale notice for the "Khai trương cửa hàng Sale Off" promotion.
  @param {product} product
  @param {variant} current_variant
{% endcomment %}

{% style %}
  .product-sale-notice {
    background-color: #fff4f4;
    border: 1px dashed #e51a3d;
    border-radius: 8px;
    padding: 16px;
    margin-bottom: 24px;
    display: none; /* Hidden by default, JS will show if conditions met */
  }
  .product-sale-notice.is-visible {
    display: block;
  }
  .product-sale-notice__title {
    color: #e51a3d;
    font-weight: 700;
    font-size: 16px;
    margin: 0 0 8px;
  }
  .product-sale-notice__text {
    font-size: 14px;
    color: #333;
    margin: 0;
    line-height: 1.5;
  }
{% endstyle %}

{%- assign is_target_collection = false -%}
{%- for collection in product.collections -%}
  {%- if collection.id == 475413217337 -%}
    {%- assign is_target_collection = true -%}
    {%- break -%}
  {%- endif -%}
{%- endfor -%}

<div class="product-sale-notice" 
     data-sale-notice 
     data-in-collection="{{ is_target_collection }}" 
     data-start-time="2026-06-27T14:02:06Z" 
     data-end-time="2026-07-09T03:59:59Z"
     data-min-subtotal="10000">
  <h4 class="product-sale-notice__title">🎉 Khai trương cửa hàng Sale Off</h4>
  <p class="product-sale-notice__text">
    Nhận ngay ưu đãi <strong>giảm 50%</strong> cho sản phẩm thuộc bộ sưu tập "A Home Shared with Life". 
    Chỉ áp dụng với đơn hàng có giá trị từ <strong>$100.00 USD</strong>.
  </p>
</div>
