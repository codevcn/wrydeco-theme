{% comment %}
  Renders the product variant picker as labelled card tiles (FINISH / SIZE).

  Colour/finish and surface options render thumbnail images from the first
  relevant metaobject entry; size options render text.
  Each tile is a <label> wrapping a native radio, so selecting one checks the
  matching radio and fires a `change` event — the existing variant logic
  (price + inventory + gallery below, and the Section Rendering API in
  product-info.js) keeps working unchanged.

  @param {product} product
  @param {variant} current_variant
  @param {string} section_id
{% endcomment %}

{% unless product.has_only_default_variant %}
  {% assign finish_color_entry = metaobjects.variant_finish_color.values | first %}
  {% assign wood_surface_entry = metaobjects.variant_wood_surface.values | first %}
  {% assign customization_url = pages.customization.url | default: '/pages/customization' %}

  {% style %}
    .product-variant-picker {
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--sp-5);
      font-family: var(--font-body);
    }

    .variant-group {
      padding: var(--sp-3) var(--sp-4);
      background: var(--color-milk);
      border: 1px solid var(--border-default);
      border-radius: calc(var(--radius-lg) * 2);
    }

    .variant-group__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--sp-2);
      margin-bottom: var(--sp-2);
    }
    .variant-group__label {
      font-size: var(--font-size-body-sm);
      font-weight: var(--font-weight-bold);
      letter-spacing: var(--letter-spacing-wide);
      text-transform: uppercase;
      color: var(--text-primary);
    }
    .variant-group__guide {
      display: flex;
      align-items: center;
      gap: var(--sp-2);
      font-size: var(--font-size-body-sm);
      color: var(--color-sage);
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
    }
    .variant-group__guide svg {
      display: flex;
    }
    .variant-group__guide:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .variant-group__list {
      display: flex;
      flex-wrap: nowrap;
      gap: var(--sp-4);
      overflow-x: auto;
      /* Room so selected borders / focus outlines aren't clipped by the scroll box */
      padding-block: var(--sp-1);
      -webkit-overflow-scrolling: touch;
      /* Scrollbar appearance comes from the shared `.custom-scrollbar` utility. */
      cursor: grab;
      user-select: none;
      -webkit-user-select: none;
    }
    .variant-group__list.is-active-drag,
    .variant-group__list.is-active-drag .variant-tile {
      cursor: grabbing;
    }

    .variant-tile {
      position: relative;
      display: flex;
      flex-direction: column;
      flex: 0 0 auto;
      min-width: 0;
      margin: 0;
      border: 1px solid var(--border-default);
      border-radius: var(--radius-lg);
      background-color: var(--color-milk);
      cursor: pointer;
      transition: border-color var(--timing-short) var(--ease-standard),
        box-shadow var(--timing-short) var(--ease-standard);
    }
    .variant-tile:hover {
      border-color: var(--border-dark);
    }

    .variant-tile__input {
      position: absolute;
      width: 1px;
      height: 1px;
      opacity: 0;
      pointer-events: none;
    }

    .variant-tile:has(.variant-tile__input:checked) {
      border-color: var(--color-earth-brown);
      box-shadow: inset 0 0 0 var(--border-width) var(--color-earth-brown);
    }

    .variant-tile.is-disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .variant-tile.is-disabled .variant-tile__label {
      text-decoration: line-through;
    }

    /* ---- Colour / finish tile ---- */
    .variant-tile--color {
      padding: var(--sp-2);
      align-items: center;
    }
    .variant-tile__media {
      display: block;
      overflow: hidden;
      border-radius: var(--radius-md);
      width: var(--sp-9);
      aspect-ratio: 4 / 3;
      min-height: 50px;
      background: var(--bg-secondary);
    }
    .variant-tile__media img,
    .variant-tile__swatch {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      /* Stop native image drag so press-and-hold only scrolls the list */
      pointer-events: none;
      -webkit-user-drag: none;
      user-select: none;
      -webkit-user-select: none;
    }
    .variant-tile--color .variant-tile__label {
      margin-top: var(--sp-3);
      text-align: center;
      font-family: var(--font-roboto);
      font-size: var(--font-size-body-md);
      color: var(--text-primary);
      white-space: nowrap;
    }

    /* ---- "Custom" call-to-action tile on size / surface (links to the
       customization page instead of selecting a variant) ---- */
    .variant-tile--custom-link {
      gap: var(--sp-2);
      text-decoration: none;
      color: inherit;
      margin-right: var(--sp-1);
    }
    .variant-tile__media--custom {
      display: grid;
      place-items: center;
      border: var(--border-width) dashed var(--color-clay);
      background: var(--color-milk);
    }
    .variant-tile__custom-plus {
      color: var(--color-clay);
      font-size: var(--font-size-body-2xl);
      font-weight: var(--font-weight-light);
      line-height: var(--line-height-tight);
    }

    .variant-tile--size .variant-tile__media--custom {
      min-height: auto;
      width: fit-content;
      padding-inline: 6px;
      aspect-ratio: unset;
    }

    /* ---- Custom color upload tile ---- */
    /* Keep [hidden] authoritative over the display rules below (icon/preview/file). */
    .variant-tile--upload [hidden] {
      display: none;
    }
    .variant-tile--upload .variant-tile__media {
      display: grid;
      place-items: center;
      border: var(--border-width) dashed var(--color-clay);
      background: var(--color-milk);
    }
    .variant-tile__upload-icon {
      display: flex;
      color: var(--color-clay);
    }
    .variant-tile__upload-icon svg {
      width: var(--sp-5);
      height: var(--sp-5);
    }
    .variant-tile__upload-spinner {
      width: var(--sp-5);
      height: var(--sp-5);
      border: calc(var(--border-width) * 2) solid var(--border-default);
      border-top-color: var(--color-earth-brown);
      border-radius: var(--radius-full);
      animation: variant-upload-spin 0.7s linear infinite;
    }
    @keyframes variant-upload-spin {
      to {
        transform: rotate(360deg);
      }
    }
    .variant-tile--upload.is-loading {
      cursor: progress;
    }
    /* Once an image is uploaded the dashed dropzone becomes a solid thumbnail.
       Selection styling (border + check) comes from the shared :has(:checked) rule. */
    .variant-tile--upload.is-uploaded .variant-tile__media {
      border-style: solid;
      border-color: var(--border-default);
    }
    @media (prefers-reduced-motion: reduce) {
      .variant-tile__upload-spinner {
        animation: none;
      }
    }

    /* ---- Size tile ---- */
    .variant-tile--size {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      width: max-content;
      padding: var(--sp-3) var(--sp-5);
      text-align: center;
    }
    .variant-tile--size .variant-tile__label {
      font-family: var(--font-roboto);
      font-size: var(--font-size-body-sm);
      color: var(--text-primary);
      white-space: nowrap;
    }

    /* ---- Selected checkmark badge ---- */
    .variant-tile__check {
      position: absolute;
      top: var(--sp-2);
      right: var(--sp-2);
      display: flex;
      align-items: center;
      justify-content: center;
      width: var(--sp-5);
      height: var(--sp-5);
      border-radius: var(--radius-full);
      background: var(--color-earth-brown);
      color: var(--color-cream);
      opacity: 0;
      transform: scale(0.6);
      transition: opacity var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
    }
    .variant-tile--color .variant-tile__check {
      top: var(--sp-2);
      right: var(--sp-2);
    }
    /* Smaller, corner-tucked check on size tiles so it never overlaps the
       vertically-centred dimension text. */
    .variant-tile--size .variant-tile__check {
      top: var(--sp-1);
      right: var(--sp-1);
      width: var(--sp-4);
      height: var(--sp-4);
    }
    .variant-tile__check svg {
      width: 14px;
      height: 14px;
    }
    .variant-tile--size .variant-tile__check svg {
      width: 11px;
      height: 11px;
    }
    .variant-tile:has(.variant-tile__input:checked) .variant-tile__check {
      opacity: 1;
      transform: scale(1);
    }

    @media (prefers-reduced-motion: reduce) {
      .variant-tile,
      .variant-tile__check {
        transition: none;
      }
    }
  {% endstyle %}

  <div class="product-variant-picker">
    {% for option in product.options_with_values %}
      {% assign downcased_option = option.name | downcase %}
      {% assign is_color = false %}
      {% assign is_surface = false %}
      {% assign is_size = false %}
      {% if downcased_option contains 'surface' %}
        {% assign is_surface = true %}
      {% endif %}
      {% if downcased_option contains 'size' %}
        {% assign is_size = true %}
      {% endif %}
      {% if downcased_option contains 'color'
        or downcased_option contains 'màu'
        or downcased_option contains 'canvas'
        or downcased_option contains 'finish'
      %}
        {% assign is_color = true %}
      {% endif %}
      {% assign is_finish = false %}
      {% if downcased_option contains 'finish' %}
        {% unless is_surface %}
          {% assign is_finish = true %}
        {% endunless %}
      {% endif %}
      {% assign option_prop = 'option' | append: option.position %}

      <div
        class="variant-group variant-group--{% if is_color %}color{% else %}size{% endif %}"
        data-variant-field
      >
        <div class="variant-group__head">
          <span class="variant-group__label">{{ option.name }}</span>
          {% if downcased_option == 'size' or downcased_option == 'kích thước' %}
            {% if product.metafields.custom.size_guide != blank %}
              <button
                type="button"
                class="variant-group__guide"
                aria-haspopup="dialog"
                onclick="window.openSizeGuidePopup && window.openSizeGuidePopup()"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="1.5em" height="1.5em" viewBox="0 0 24 24">
                  <path d="M0 0h24v24H0z" fill="none" />
                  <path fill="currentColor" d="M22 7H2c-.55 0-1 .45-1 1v8c0 .55.45 1 1 1h20c.55 0 1-.45 1-1V8c0-.55-.45-1-1-1m-1 8H3V9h2v3h2V9h2v4h2V9h2v3h2V9h2v4h2V9h2z" />
                </svg>
                <span>Size Guide</span>
              </button>
            {% endif %}
          {% endif %}
        </div>

        <div class="variant-group__list custom-scrollbar" role="radiogroup" aria-label="{{ option.name | escape }}">
          {% for value in option.values %}
            {% assign value_downcased = value | downcase | strip %}

            {% if value_downcased == 'custom' %}
              {% comment %}
                The "Custom" option value is never shown as a normal tile.
                On the wood finish it becomes the custom-colour upload tile (which
                still holds the real `Custom` radio so it selects the Custom variant
                and behaves as a single, mutually-exclusive choice). On the other
                options it stays hidden but present, keeping the variant matrix intact.
              {% endcomment %}
              {% if is_finish %}
                <div
                  class="variant-tile variant-tile--color variant-tile--upload{% unless value.available %} is-disabled{% endunless %}"
                  data-custom-color
                >
                  <input
                    type="radio"
                    class="variant-tile__input"
                    id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                    name="options[{{ option.name | escape }}]"
                    value="{{ value | escape }}"
                    data-index="option{{ option.position }}"
                    data-custom-color-radio
                    {% if option.selected_value == value %}
                      checked="checked"
                    {% endif %}
                    {% unless value.available %}
                      disabled
                    {% endunless %}
                  >

                  <span class="variant-tile__media">
                    <span class="variant-tile__upload-icon" data-custom-color-icon aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 48 48">
                        <path d="M0 0h48v48H0z" fill="none" />
                        <path fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 24L24 6l19 18H31v18H17V24z" />
                      </svg>
                    </span>
                    <span
                      class="variant-tile__upload-spinner"
                      data-custom-color-spinner
                      aria-hidden="true"
                      hidden
                    ></span>
                    <img
                      class="variant-tile__upload-preview"
                      data-custom-color-preview
                      alt="Custom color preview"
                      width="160"
                      height="100"
                      draggable="false"
                      hidden
                    >
                  </span>

                  <span class="variant-tile__label" data-custom-color-label>Custom color</span>

                  <span class="variant-tile__check" aria-hidden="true">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>

                  <input
                    type="file"
                    class="variant-tile__file"
                    accept="image/jpeg,image/png,image/webp,image/gif"
                    data-custom-color-input
                    hidden
                  >
                  <input
                    type="hidden"
                    name="properties[added_url_image]"
                    form="{{ 'ProductForm-' | append: section_id }}"
                    data-custom-color-property
                    disabled
                  >
                </div>
              {% else %}
                {% comment %}
                  On size and surface the "Custom" value is a call-to-action that
                  sends the shopper to the customization page rather than selecting
                  a variant.
                {% endcomment %}
                <a
                  class="variant-tile variant-tile--{% if is_color %}color{% else %}size{% endif %} variant-tile--custom-link"
                  href="{{ customization_url }}"
                >
                  {% if is_color or is_size %}
                    <span class="variant-tile__media variant-tile__media--custom" aria-hidden="true">
                      <svg
                        class="variant-tile__custom-plus"
                        xmlns="http://www.w3.org/2000/svg"
                        width="1em"
                        height="1em"
                        viewBox="0 0 24 24"
                      >
                        <path d="M0 0h24v24H0z" fill="none" />
                        <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6z" />
                      </svg>
                    </span>
                  {% endif %}
                  <span class="variant-tile__label">{{ value }}</span>
                </a>
              {% endif %}

            {% else %}
              {% assign color_image = '' %}
              {% if is_color %}
                {% capture value_str %}{{ value }}{% endcapture %}
                {% assign finish_key = value_str | handleize | replace: '-', '_' %}
                {% assign thumbnail_entry = finish_color_entry %}
                {% if is_surface %}
                  {% assign thumbnail_entry = wood_surface_entry %}
                {% endif %}
                {% if thumbnail_entry != blank %}
                  {% assign finish_field = thumbnail_entry[finish_key] %}
                  {% if finish_field != blank %}
                    {% assign color_image = finish_field.value | default: finish_field %}
                  {% endif %}
                {% endif %}
                {% if color_image == blank %}
                  {% assign matched_variant = product.variants | where: option_prop, value_str | first %}
                  {% assign color_image = matched_variant.metafields.custom.color_pattern %}
                {% endif %}
              {% endif %}

              <label
                class="variant-tile variant-tile--{% if is_color %}color{% else %}size{% endif %}{% unless value.available %} is-disabled{% endunless %}"
              >
                <input
                  type="radio"
                  class="variant-tile__input"
                  id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                  name="options[{{ option.name | escape }}]"
                  value="{{ value | escape }}"
                  data-index="option{{ option.position }}"
                  {% if option.selected_value == value %}
                    checked="checked"
                  {% endif %}
                  {% unless value.available %}
                    disabled
                  {% endunless %}
                >

                {% if is_color %}
                  <span class="variant-tile__media">
                    {% if color_image != blank %}
                      <img
                        src="{{ color_image }}"
                        alt="{{ value | escape }}"
                        width="160"
                        height="100"
                        loading="lazy"
                        draggable="false"
                      >
                    {% else %}
                      <span
                        class="variant-tile__swatch"
                        style="background-color: {{ value | downcase | remove: ' ' }};"
                      ></span>
                    {% endif %}
                  </span>
                {% endif %}

                <span class="variant-tile__label">{{ value }}</span>

                <span class="variant-tile__check" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </span>
              </label>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>

  <script>
    (function () {
      // Press-and-hold to scroll the variant lists horizontally — mirrors the
      // drag logic used by .product-gallery__thumbnails.
      function initVariantDragScroll() {
        document.querySelectorAll('.variant-group__list').forEach(function (list) {
          if (list.dataset.dragInit === 'true') return;
          list.dataset.dragInit = 'true';

          var isDown = false;
          var startX = 0;
          var scrollLeft = 0;
          var isDragging = false;

          // Never let a press-and-hold start a native image/element drag.
          list.addEventListener('dragstart', function (e) {
            e.preventDefault();
          });

          list.addEventListener('mousedown', function (e) {
            isDown = true;
            isDragging = false;
            list.classList.add('is-active-drag');
            startX = e.pageX - list.offsetLeft;
            scrollLeft = list.scrollLeft;
          });
          list.addEventListener('mouseleave', function () {
            isDown = false;
            list.classList.remove('is-active-drag');
          });
          list.addEventListener('mouseup', function () {
            isDown = false;
            list.classList.remove('is-active-drag');
          });
          list.addEventListener('mousemove', function (e) {
            if (!isDown) return;
            e.preventDefault();
            var x = e.pageX - list.offsetLeft;
            var walk = (x - startX) * 2; // scroll speed multiplier
            if (Math.abs(walk) > 5) isDragging = true;
            list.scrollLeft = scrollLeft - walk;
          });
          // Swallow the click that ends a drag so it doesn't select a variant.
          list.addEventListener(
            'click',
            function (e) {
              if (isDragging) {
                e.stopPropagation();
                e.preventDefault();
              }
            },
            true
          );
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initVariantDragScroll);
      } else {
        initVariantDragScroll();
      }
    })();
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const selectedOptions = {};

      // 1. Khởi tạo giá trị ban đầu dựa vào các input đã được check
      const checkedInputs = document.querySelectorAll('.product-variant-picker input[type="radio"]:checked');
      checkedInputs.forEach(input => {
        selectedOptions[input.dataset.index] = input.value;
      });

      const variantInputs = document.querySelectorAll('.product-variant-picker input[type="radio"]');
      const productVariants = {{ product.variants | json }};

      // 2. Bắt buộc: Tự map dữ liệu Metafield bằng Liquid vì bộ lọc `| json` của Shopify sẽ xóa mất Metafield
      const variantMetafieldsMap = {
        {% for v in product.variants %}
          "{{ v.id }}": {{ v.metafields.custom.variant_images.value | default: v.metafields.custom.variant_images | json }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      };

      // Tự map dữ liệu Inventory vì API/json đôi khi không trả về inventory_quantity
      const variantInventoryMap = {
        {% for v in product.variants %}
          "{{ v.id }}": {
             "qty": {{ v.inventory_quantity | default: 0 }},
             "policy": {{ v.inventory_policy | json }},
             "management": {{ v.inventory_management | json }},
             "available": {{ v.available | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      };

      const getSelectedOptions = () => {
        const nextSelectedOptions = {};
        document.querySelectorAll('.product-variant-picker input[type="radio"]:checked').forEach(input => {
          nextSelectedOptions[input.dataset.index] = input.value;
        });
        return nextSelectedOptions;
      };

      const findVariantForOptions = (options) => {
        return productVariants.find(variant => {
          return Object.keys(options).every(key => {
            return variant[key] === options[key];
          });
        });
      };

      const isOptionValuePickable = (input) => {
        const candidateOptions = Object.assign({}, selectedOptions);
        candidateOptions[input.dataset.index] = input.value;

        return productVariants.some(variant => {
          if (!variant.available) return false;

          return Object.keys(candidateOptions).every(key => {
            return variant[key] === candidateOptions[key];
          });
        });
      };

      const syncOptionAvailability = () => {
        Object.assign(selectedOptions, getSelectedOptions());

        variantInputs.forEach(input => {
          const tile = input.closest('.variant-tile');
          const isCurrentSelection = input.checked;
          const isPickable = isCurrentSelection || isOptionValuePickable(input);

          input.disabled = !isPickable;
          input.setAttribute('aria-disabled', isPickable ? 'false' : 'true');
          if (tile) tile.classList.toggle('is-disabled', !isPickable);
        });
      };

      syncOptionAvailability();

      for (const input of variantInputs) {
        input.addEventListener('change', function () {
          // 3. Cập nhật giá trị mới khi user chọn
          selectedOptions[input.dataset.index] = input.value;
          syncOptionAvailability();

          // 4. Tìm variant khớp với toàn bộ lựa chọn
          const selectedVariant = findVariantForOptions(selectedOptions);

          if (selectedVariant) {
            // Instant, no-API updates the moment a variant is picked:
            // price + compare + "Save", the hidden variant id used by the form,
            // the add-to-cart button state, and the ?variant= URL param.
            if (window.updateProductPrice) {
              window.updateProductPrice(selectedVariant.id);
            }

            const variantIdInput = document.querySelector('[data-variant-id]');
            if (variantIdInput) variantIdInput.value = selectedVariant.id;

            const addText = document.querySelector('[data-add-to-cart-text]');
            const addBtn = document.querySelector('form[data-type="add-to-cart-form"] button[name="add"]');
            if (addText) addText.textContent = selectedVariant.available ? 'ADD TO CART' : 'SOLD OUT';
            if (addBtn) addBtn.disabled = !selectedVariant.available;

            if (window.history && window.history.replaceState) {
              const nextUrl = new URL(window.location.href);
              nextUrl.searchParams.set('variant', selectedVariant.id);
              window.history.replaceState({}, '', nextUrl);
            }

            // Gắn thêm metafield vào selectedVariant để tiện sử dụng
            selectedVariant.metafields = {
              custom: {
                variant_images: variantMetafieldsMap[selectedVariant.id]
              }
            };

            // Logic lọc ảnh theo variant-images
            const variantImagesRaw = selectedVariant.metafields.custom.variant_images;
            if (variantImagesRaw) {
              // Phân tích ra thành 1 mảng variant-image[] (string[])
              const variantImages = variantImagesRaw.split('\n').map(s => s.trim().replace(/<br\s*\/?>/g, '')).filter(s => s !== '');

              if (variantImages.length > 0) {
                const thumbnails = document.querySelectorAll('.product-gallery__thumbnail');
                const mainItems = document.querySelectorAll('.product-gallery__main-item');

                let firstMatchedThumbnail = null;

                // Lọc thumbnails
                thumbnails.forEach(thumb => {
                  const alt = thumb.dataset.alt || '';
                  // Kiểm tra alt có chứa bất kỳ string nào trong mảng variantImages không
                  const isMatch = variantImages.some(vImg => alt.includes(vImg));

                  if (isMatch) {
                    thumb.style.display = ''; // Show
                    if (!firstMatchedThumbnail) firstMatchedThumbnail = thumb;
                  } else {
                    thumb.style.display = 'none'; // Hide
                    thumb.classList.remove('is-active');
                  }
                });

                // Xóa active khỏi các main items không khớp
                mainItems.forEach(item => {
                  const alt = item.dataset.alt || '';
                  const isMatch = variantImages.some(vImg => alt.includes(vImg));
                  if (!isMatch) {
                     item.classList.remove('is-active');
                  }
                });

                // Chọn ảnh đầu tiên trong pickedMediaList
                if (firstMatchedThumbnail) {
                  firstMatchedThumbnail.click();
                }
              } else {
                // Nếu mảng rỗng thì show hết
                document.querySelectorAll('.product-gallery__thumbnail').forEach(t => t.style.display = '');
              }
            } else {
              // Không có metafield -> show hết
              document.querySelectorAll('.product-gallery__thumbnail').forEach(t => t.style.display = '');
            }

            // Cập nhật Inventory Status
            const invInfo = variantInventoryMap[selectedVariant.id];
            const invStatusEl = document.querySelector('[data-inventory-status]');
            if (invStatusEl && invInfo) {
               let status = 'in-stock';
               let label = 'In stock';
               const threshold = 10;

               if (!invInfo.available) {
                 status = 'out';
                 label = 'Out of stock';
               } else if (!invInfo.management) {
                 status = 'in-stock';
                 label = 'In stock';
               } else {
                 if (invInfo.qty > 0) {
                   if (invInfo.qty <= threshold) {
                     status = 'low';
                     label = 'Only ' + invInfo.qty + ' left in stock';
                   } else {
                     status = 'in-stock';
                     label = invInfo.qty + ' in stock';
                   }
                 } else {
                   status = 'backorder';
                   label = 'Available to order';
                 }
               }

               invStatusEl.className = 'product-inventory product-inventory--' + status;
               const textEl = invStatusEl.querySelector('.product-inventory__text');
               if (textEl) textEl.textContent = label;
            }
          }
        });
      }
    });
  </script>

  <script>
    (function () {
      // The custom-colour tile IS the "Custom" wood-finish value. Uploading an
      // image selects that value (checking its real radio, so it stays a single,
      // mutually-exclusive choice) and attaches the uploaded URL to the product
      // form as the `added_url_image` line-item property, which travels into the
      // cart alongside the chosen size and surface.
      var UPLOAD_ENDPOINT = 'https://vnote.io.vn/api/upload-image';
      var MAX_BYTES = 10 * 1024 * 1024;

      function toast(message, type) {
        if (window.showToast) {
          window.showToast({ message: message, type: type, position: 'bottom-right', duration: 4000 });
        }
      }

      function initCustomColorUpload() {
        // Shared guidance popup — shown before the real file picker opens.
        var guide = document.querySelector('[data-custom-color-guide]');
        var pendingContinue = null;
        function closeGuide() {
          if (!guide) return;
          guide.classList.remove('is-open');
          document.documentElement.style.overflow = '';
          pendingContinue = null;
        }
        function openGuide(onContinue) {
          // No popup in the DOM → keep the original behaviour (open the file dialog directly).
          if (!guide) {
            if (onContinue) onContinue();
            return;
          }
          pendingContinue = onContinue;
          guide.classList.add('is-open');
          document.documentElement.style.overflow = 'hidden';
          var btn = guide.querySelector('[data-custom-color-guide-continue]');
          if (btn) btn.focus();
        }
        if (guide && guide.dataset.guideInit !== 'true') {
          guide.dataset.guideInit = 'true';
          guide.querySelectorAll('[data-custom-color-guide-close]').forEach(function (el) {
            el.addEventListener('click', closeGuide);
          });
          var continueBtn = guide.querySelector('[data-custom-color-guide-continue]');
          if (continueBtn) {
            continueBtn.addEventListener('click', function () {
              // Capture before closing (close clears it); running it here keeps the
              // user gesture, so the browser allows the file dialog to open.
              var next = pendingContinue;
              closeGuide();
              if (next) next();
            });
          }
          document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && guide.classList.contains('is-open')) closeGuide();
          });
        }

        document.querySelectorAll('[data-custom-color]:not([data-custom-color-init])').forEach(function (tile) {
          tile.dataset.customColorInit = 'true';

          var fileInput = tile.querySelector('[data-custom-color-input]');
          var radio = tile.querySelector('[data-custom-color-radio]');
          var icon = tile.querySelector('[data-custom-color-icon]');
          var spinner = tile.querySelector('[data-custom-color-spinner]');
          var preview = tile.querySelector('[data-custom-color-preview]');
          var label = tile.querySelector('[data-custom-color-label]');
          var property = tile.querySelector('[data-custom-color-property]');
          if (!fileInput || !radio) return;

          // The file input lives inside the tile, so a programmatic fileInput.click()
          // would bubble back to the tile's click handler and re-open the guide popup.
          // Stop it here so opening the file dialog never re-triggers the tile.
          fileInput.addEventListener('click', function (e) {
            e.stopPropagation();
          });

          var uploadedUrl = '';
          var defaultLabel = label ? label.textContent : 'Custom color';

          // Attach the URL only while the custom finish is the active choice.
          function syncProperty() {
            if (!property) return;
            if (radio.checked && uploadedUrl) {
              property.value = uploadedUrl;
              property.disabled = false;
            } else {
              property.value = '';
              property.disabled = true;
            }
          }

          function selectCustom() {
            radio.checked = true;
            radio.dispatchEvent(new Event('change', { bubbles: true }));
            syncProperty();
          }

          function setLoading(loading) {
            tile.classList.toggle('is-loading', loading);
            if (spinner) spinner.hidden = !loading;
            if (icon) icon.hidden = loading || tile.classList.contains('is-uploaded');
            if (label) label.textContent = loading ? 'Uploading…' : defaultLabel;
          }

          function upload(file) {
            if (file.size > MAX_BYTES) {
              toast('Image exceeds 10MB limit.', 'error');
              return;
            }

            setLoading(true);

            var formData = new FormData();
            formData.append('image', file);

            // Do not set Content-Type: let the browser add the multipart boundary.
            fetch(UPLOAD_ENDPOINT, { method: 'POST', body: formData })
              .then(function (response) {
                return response
                  .json()
                  .catch(function () {
                    return {};
                  })
                  .then(function (data) {
                    return { ok: response.ok, data: data };
                  });
              })
              .then(function (result) {
                if (result.ok && result.data && result.data.image_url) {
                  uploadedUrl = result.data.image_url;
                  if (preview) {
                    preview.src = uploadedUrl;
                    preview.hidden = false;
                  }
                  if (icon) icon.hidden = true;
                  tile.classList.add('is-uploaded');
                  selectCustom(); // the uploaded image becomes the selected custom finish
                  toast('Custom color uploaded.', 'success');
                } else {
                  var detail = (result.data && result.data.detail) || 'Upload failed. Please try again.';
                  toast(detail, 'error');
                }
              })
              .catch(function () {
                toast('Upload failed. Please try again.', 'error');
              })
              .finally(function () {
                setLoading(false);
                fileInput.value = ''; // allow re-picking the same file
              });
          }

          fileInput.addEventListener('change', function () {
            var file = fileInput.files && fileInput.files[0];
            if (file) upload(file);
          });

          // Empty → pick a file. Uploaded but not selected → select it.
          // Already the active choice → pick again to replace the image.
          // Unavailable for the current size/surface → behave like a disabled tile.
          tile.addEventListener('click', function () {
            if (tile.classList.contains('is-loading')) return;
            if (radio.disabled || tile.classList.contains('is-disabled')) return;
            if (!uploadedUrl || radio.checked) {
              // Show the guidance popup first; the file dialog opens only on "Continue".
              openGuide(function () {
                fileInput.click();
              });
            } else {
              selectCustom();
            }
          });

          // Keep the property in step when the finish selection changes elsewhere.
          var groupName = radio.getAttribute('name');
          document.querySelectorAll('input[name="' + groupName + '"]').forEach(function (r) {
            r.addEventListener('change', syncProperty);
          });

          syncProperty();
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCustomColorUpload);
      } else {
        initCustomColorUpload();
      }
    })();
  </script>

