{% comment %}
  All product-variant-picker JS, consolidated into the single compiled script
  tag Shopify allows per snippet. Compiled + deferred (not parser-blocking) and
  cached across page views. No Liquid is used here — the per-product variant data
  is read from the `[data-variant-picker-data]` JSON island rendered above.
{% endcomment %}
{% javascript %}
  (function () {
    // --- 1. Press-and-hold to scroll the variant lists horizontally ---
    // Mirrors the drag logic used by .product-gallery__thumbnails.
    function initVariantDragScroll() {
      document.querySelectorAll('.variant-group__list').forEach(function (list) {
        if (list.dataset.dragInit === 'true') return;
        list.dataset.dragInit = 'true';

        var isDown = false;
        var startX = 0;
        var scrollLeft = 0;
        var isDragging = false;

        // Never let a press-and-hold start a native image/element drag.
        list.addEventListener('dragstart', function (e) {
          e.preventDefault();
        });

        list.addEventListener('mousedown', function (e) {
          isDown = true;
          isDragging = false;
          list.classList.add('is-active-drag');
          startX = e.pageX - list.offsetLeft;
          scrollLeft = list.scrollLeft;
        });
        list.addEventListener('mouseleave', function () {
          isDown = false;
          list.classList.remove('is-active-drag');
        });
        list.addEventListener('mouseup', function () {
          isDown = false;
          list.classList.remove('is-active-drag');
        });
        list.addEventListener('mousemove', function (e) {
          if (!isDown) return;
          e.preventDefault();
          var x = e.pageX - list.offsetLeft;
          var walk = (x - startX) * 2; // scroll speed multiplier
          if (Math.abs(walk) > 5) isDragging = true;
          list.scrollLeft = scrollLeft - walk;
        });
        // Swallow the click that ends a drag so it doesn't select a variant.
        list.addEventListener(
          'click',
          function (e) {
            if (isDragging) {
              e.stopPropagation();
              e.preventDefault();
            }
          },
          true
        );
      });
    }

    // --- 2. Variant selection: instant price / gallery / URL updates ---
    function initVariantSelect() {
      var picker = document.querySelector('.product-variant-picker');
      if (!picker) return;

      // Variant data + per-variant images come from the JSON island (rendered
      // by Liquid) instead of a large inline `product.variants | json` dump.
      var dataEl = document.querySelector('[data-variant-picker-data]');
      var pickerData = {};
      try {
        pickerData = JSON.parse((dataEl && dataEl.textContent) || '{}');
      } catch (e) {
        pickerData = {};
      }
      var productVariants = pickerData.variants || [];
      var variantMetafieldsMap = pickerData.variantImages || {};

      var selectedOptions = {};

      // Initialise from the inputs that are already checked.
      document.querySelectorAll('.product-variant-picker input[type="radio"]:checked').forEach(function (input) {
        selectedOptions[input.dataset.index] = input.value;
      });

      var variantInputs = document.querySelectorAll('.product-variant-picker input[type="radio"]');

      var getSelectedOptions = function () {
        var nextSelectedOptions = {};
        document.querySelectorAll('.product-variant-picker input[type="radio"]:checked').forEach(function (input) {
          nextSelectedOptions[input.dataset.index] = input.value;
        });
        return nextSelectedOptions;
      };

      var findVariantForOptions = function (options) {
        return productVariants.find(function (variant) {
          return Object.keys(options).every(function (key) {
            return variant[key] === options[key];
          });
        });
      };

      var isOptionValuePickable = function (input) {
        var candidateOptions = Object.assign({}, selectedOptions);
        candidateOptions[input.dataset.index] = input.value;

        return productVariants.some(function (variant) {
          if (!variant.available) return false;

          return Object.keys(candidateOptions).every(function (key) {
            return variant[key] === candidateOptions[key];
          });
        });
      };

      var syncOptionAvailability = function () {
        Object.assign(selectedOptions, getSelectedOptions());

        variantInputs.forEach(function (input) {
          var tile = input.closest('.variant-tile');
          var isCurrentSelection = input.checked;
          var isPickable = isCurrentSelection || isOptionValuePickable(input);

          input.disabled = !isPickable;
          input.setAttribute('aria-disabled', isPickable ? 'false' : 'true');
          if (tile) tile.classList.toggle('is-disabled', !isPickable);
        });
      };

      syncOptionAvailability();

      variantInputs.forEach(function (input) {
        input.addEventListener('change', function () {
          // Update the newly-picked value.
          selectedOptions[input.dataset.index] = input.value;
          syncOptionAvailability();

          // Find the variant matching the full set of selected options.
          var selectedVariant = findVariantForOptions(selectedOptions);
          if (!selectedVariant) return;

          // Instant, no-API updates the moment a variant is picked:
          // price + compare + "Save", the hidden variant id used by the form,
          // the add-to-cart button state, and the ?variant= URL param.
          if (window.updateProductPrice) {
            window.updateProductPrice(selectedVariant.id);
          }

          var variantIdInput = document.querySelector('[data-variant-id]');
          if (variantIdInput) variantIdInput.value = selectedVariant.id;

          var addText = document.querySelector('[data-add-to-cart-text]');
          var addBtn = document.querySelector('form[data-type="add-to-cart-form"] button[name="add"]');
          if (addText) addText.textContent = selectedVariant.available ? 'ADD TO CART' : 'SOLD OUT';
          if (addBtn) addBtn.disabled = !selectedVariant.available;

          if (window.history && window.history.replaceState) {
            var nextUrl = new URL(window.location.href);
            nextUrl.searchParams.set('variant', selectedVariant.id);
            window.history.replaceState({}, '', nextUrl);
          }

          // Let other components (e.g. the gallery wishlist heart) react to the
          // newly-selected variant. Fired after the form id and URL are updated.
          document.dispatchEvent(new CustomEvent('variant:change', { detail: { variantId: selectedVariant.id } }));

          // Filter the gallery by the variant's `variant_images` metafield.
          var variantImagesRaw = variantMetafieldsMap[selectedVariant.id];
          if (variantImagesRaw) {
            var variantImages = variantImagesRaw
              .split('\n')
              .map(function (s) {
                return s.trim().replace(/<br\s*\/?>/g, '');
              })
              .filter(function (s) {
                return s !== '';
              });

            if (variantImages.length > 0) {
              var thumbnails = document.querySelectorAll('.product-gallery__thumbnail');
              var mainItems = document.querySelectorAll('.product-gallery__main-item');

              var firstMatchedThumbnail = null;

              thumbnails.forEach(function (thumb) {
                var alt = thumb.dataset.alt || '';
                var isMatch = variantImages.some(function (vImg) {
                  return alt.includes(vImg);
                });

                if (isMatch) {
                  thumb.style.display = '';
                  if (!firstMatchedThumbnail) firstMatchedThumbnail = thumb;
                } else {
                  thumb.style.display = 'none';
                  thumb.classList.remove('is-active');
                }
              });

              mainItems.forEach(function (item) {
                var alt = item.dataset.alt || '';
                var isMatch = variantImages.some(function (vImg) {
                  return alt.includes(vImg);
                });
                if (!isMatch) {
                  item.classList.remove('is-active');
                }
              });

              if (firstMatchedThumbnail) {
                firstMatchedThumbnail.click();
              }
            } else {
              document.querySelectorAll('.product-gallery__thumbnail').forEach(function (t) {
                t.style.display = '';
              });
            }
          } else {
            document.querySelectorAll('.product-gallery__thumbnail').forEach(function (t) {
              t.style.display = '';
            });
          }
        });
      });
    }

    // --- 3. Custom-colour upload tile ---
    // The custom-colour tile IS the "Custom" wood-finish value. Uploading an
    // image selects that value (checking its real radio, so it stays a single,
    // mutually-exclusive choice) and attaches the uploaded URL to the product
    // form as the `added_url_image` line-item property, which travels into the
    // cart alongside the chosen size and surface.
    function initCustomColorUpload() {
      var UPLOAD_ENDPOINT = 'https://vnote.io.vn/api/upload-image';
      var MAX_BYTES = 10 * 1024 * 1024;

      function toast(message, type) {
        if (window.showToast) {
          window.showToast({ message: message, type: type, position: 'bottom-left', duration: 4000 });
        }
      }

      // Shared guidance popup — shown before the real file picker opens.
      var guide = document.querySelector('[data-custom-color-guide]');
      var pendingContinue = null;
      function closeGuide() {
        if (!guide) return;
        guide.classList.remove('is-open');
        document.documentElement.style.overflow = '';
        pendingContinue = null;
      }
      function openGuide(onContinue) {
        // No popup in the DOM → keep the original behaviour (open the file dialog directly).
        if (!guide) {
          if (onContinue) onContinue();
          return;
        }
        pendingContinue = onContinue;
        guide.classList.add('is-open');
        document.documentElement.style.overflow = 'hidden';
        var btn = guide.querySelector('[data-custom-color-guide-continue]');
        if (btn) btn.focus();
      }
      if (guide && guide.dataset.guideInit !== 'true') {
        guide.dataset.guideInit = 'true';
        guide.querySelectorAll('[data-custom-color-guide-close]').forEach(function (el) {
          el.addEventListener('click', closeGuide);
        });
        var continueBtn = guide.querySelector('[data-custom-color-guide-continue]');
        if (continueBtn) {
          continueBtn.addEventListener('click', function () {
            // Capture before closing (close clears it); running it here keeps the
            // user gesture, so the browser allows the file dialog to open.
            var next = pendingContinue;
            closeGuide();
            if (next) next();
          });
        }
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && guide.classList.contains('is-open')) closeGuide();
        });
      }

      document.querySelectorAll('[data-custom-color]:not([data-custom-color-init])').forEach(function (tile) {
        tile.dataset.customColorInit = 'true';

        var fileInput = tile.querySelector('[data-custom-color-input]');
        var radio = tile.querySelector('[data-custom-color-radio]');
        var icon = tile.querySelector('[data-custom-color-icon]');
        var spinner = tile.querySelector('[data-custom-color-spinner]');
        var preview = tile.querySelector('[data-custom-color-preview]');
        var label = tile.querySelector('[data-custom-color-label]');
        var property = tile.querySelector('[data-custom-color-property]');
        if (!fileInput || !radio) return;

        // The file input lives inside the tile, so a programmatic fileInput.click()
        // would bubble back to the tile's click handler and re-open the guide popup.
        // Stop it here so opening the file dialog never re-triggers the tile.
        fileInput.addEventListener('click', function (e) {
          e.stopPropagation();
        });

        var uploadedUrl = '';
        var defaultLabel = label ? label.textContent : 'Custom color';

        // Attach the URL only while the custom finish is the active choice.
        function syncProperty() {
          if (!property) return;
          if (radio.checked && uploadedUrl) {
            property.value = uploadedUrl;
            property.disabled = false;
          } else {
            property.value = '';
            property.disabled = true;
          }
        }

        function selectCustom() {
          radio.checked = true;
          radio.dispatchEvent(new Event('change', { bubbles: true }));
          syncProperty();
        }

        function setLoading(loading) {
          tile.classList.toggle('is-loading', loading);
          if (spinner) spinner.hidden = !loading;
          if (icon) icon.hidden = loading || tile.classList.contains('is-uploaded');
          if (label) label.textContent = loading ? 'Uploading…' : defaultLabel;
        }

        function upload(file) {
          if (file.size > MAX_BYTES) {
            toast('Image exceeds 10MB limit.', 'error');
            return;
          }

          setLoading(true);

          var formData = new FormData();
          formData.append('image', file);

          // Do not set Content-Type: let the browser add the multipart boundary.
          fetch(UPLOAD_ENDPOINT, { method: 'POST', body: formData })
            .then(function (response) {
              return response
                .json()
                .catch(function () {
                  return {};
                })
                .then(function (data) {
                  return { ok: response.ok, data: data };
                });
            })
            .then(function (result) {
              if (result.ok && result.data && result.data.image_url) {
                uploadedUrl = result.data.image_url;
                if (preview) {
                  preview.src = uploadedUrl;
                  preview.hidden = false;
                }
                if (icon) icon.hidden = true;
                tile.classList.add('is-uploaded');
                selectCustom(); // the uploaded image becomes the selected custom finish
                toast('Custom color uploaded.', 'success');
              } else {
                var detail = (result.data && result.data.detail) || 'Upload failed. Please try again.';
                toast(detail, 'error');
              }
            })
            .catch(function () {
              toast('Upload failed. Please try again.', 'error');
            })
            .finally(function () {
              setLoading(false);
              fileInput.value = ''; // allow re-picking the same file
            });
        }

        fileInput.addEventListener('change', function () {
          var file = fileInput.files && fileInput.files[0];
          if (file) upload(file);
        });

        // Empty → pick a file. Uploaded but not selected → select it.
        // Already the active choice → pick again to replace the image.
        // Unavailable for the current size/surface → behave like a disabled tile.
        tile.addEventListener('click', function () {
          if (tile.classList.contains('is-loading')) return;
          if (radio.disabled || tile.classList.contains('is-disabled')) return;
          if (!uploadedUrl || radio.checked) {
            // Show the guidance popup first; the file dialog opens only on "Continue".
            openGuide(function () {
              fileInput.click();
            });
          } else {
            selectCustom();
          }
        });

        // Keep the property in step when the finish selection changes elsewhere.
        var groupName = radio.getAttribute('name');
        document.querySelectorAll('input[name="' + groupName + '"]').forEach(function (r) {
          r.addEventListener('change', syncProperty);
        });

        syncProperty();
      });
    }

    // --- 4. Hide a variant tile's media box when its image fails to load ---
    // Variants with no image never render a media box (handled in Liquid); this
    // covers the case where an image URL exists but 404s / errors, so the empty
    // grey placeholder is removed instead of shown.
    function initVariantMediaFallback() {
      function hideMedia(img) {
        var media = img.closest('.variant-tile__media');
        if (media) media.hidden = true;
      }
      document.querySelectorAll('[data-variant-media-img]').forEach(function (img) {
        if (img.dataset.mediaFallbackInit === 'true') return;
        img.dataset.mediaFallbackInit = 'true';

        if (img.complete) {
          // Already finished loading (e.g. cached) — naturalWidth 0 means it errored.
          if (img.naturalWidth === 0) hideMedia(img);
          return;
        }
        img.addEventListener('error', function () {
          hideMedia(img);
        });
      });
    }

    // --- 5. Size-guide popup custom element ---
    function initSizeGuide() {
      if (customElements.get('size-guide-popup')) return;
      customElements.define(
        'size-guide-popup',
        class extends HTMLElement {
          constructor() {
            super();
            this.overlay = this.querySelector('.size-guide-popup__overlay');
            this.closeBtn = this.querySelector('.size-guide-popup__close');

            if (this.closeBtn) this.closeBtn.addEventListener('click', this.close.bind(this));
            if (this.overlay) {
              this.overlay.addEventListener('click', (e) => {
                if (e.target === this.overlay) this.close();
              });
            }
            document.addEventListener('keydown', (e) => {
              if (e.key === 'Escape' && this.hasAttribute('open')) this.close();
            });

            window.openSizeGuidePopup = (e) => {
              if (e) e.preventDefault();
              this.open();
            };
          }

          open() {
            this.setAttribute('open', '');
            this.setAttribute('aria-hidden', 'false');
            this.removeAttribute('inert');
            document.body.style.overflow = 'hidden';
          }

          close() {
            this.removeAttribute('open');
            this.setAttribute('aria-hidden', 'true');
            this.setAttribute('inert', '');
            document.body.style.overflow = '';
          }
        }
      );
    }

    // --- 6. Size "Custom" request popup ---
    // Clicking the size "Custom" tile opens a popup where the shopper describes
    // the size they want and leaves a contact. Submitting POSTs a Custom Size
    // Request (multipart FormData) to the server — a lead for the production team.
    // It does not select a variant or add to cart.
    function initCustomSizeNote() {
      var REQUEST_ENDPOINT = 'https://vnote.io.vn/api/custom-size-requests';

      var popup = document.querySelector('[data-custom-size-popup]');
      var tiles = document.querySelectorAll('[data-custom-size]:not([data-custom-size-init])');
      if (!popup || tiles.length === 0) return;

      var textarea = popup.querySelector('[data-custom-size-note]');
      var contact = popup.querySelector('[data-custom-size-contact]');
      var saveBtn = popup.querySelector('[data-custom-size-save]');
      var saveLabel = popup.querySelector('[data-custom-size-save-label]');
      var defaultLabel = saveLabel ? saveLabel.textContent : 'Submit request';

      function toast(message, type) {
        if (window.showToast) {
          window.showToast({ message: message, type: type, position: 'bottom-left', duration: 4000 });
        }
      }

      // Per-field inline errors, keyed by the popup's field names.
      var fieldEls = { note: textarea, contact: contact };
      function setError(field, message) {
        var input = fieldEls[field];
        var el = popup.querySelector('[data-custom-size-error="' + field + '"]');
        if (input) input.setAttribute('aria-invalid', 'true');
        if (el) {
          el.textContent = message;
          el.hidden = false;
        }
      }
      function clearError(field) {
        var input = fieldEls[field];
        var el = popup.querySelector('[data-custom-size-error="' + field + '"]');
        if (input) input.removeAttribute('aria-invalid');
        if (el) {
          el.textContent = '';
          el.hidden = true;
        }
      }
      function clearAllErrors() {
        clearError('note');
        clearError('contact');
      }

      // Clear a field's error the moment the shopper starts fixing it.
      if (textarea) textarea.addEventListener('input', function () { clearError('note'); });
      if (contact) contact.addEventListener('input', function () { clearError('contact'); });

      var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      function isValidContact(value) {
        if (EMAIL_RE.test(value)) return true;
        var digits = value.replace(/\D/g, '');
        return digits.length >= 7 && digits.length <= 15 && /^[+()\d\s.-]+$/.test(value);
      }

      function validate() {
        clearAllErrors();
        var firstInvalid = null;
        var note = textarea ? textarea.value.trim() : '';
        var contactValue = contact ? contact.value.trim() : '';

        if (!note) {
          setError('note', 'Please describe the size you want.');
          firstInvalid = firstInvalid || textarea;
        } else if (note.length < 5) {
          setError('note', 'Please add a little more detail (at least 5 characters).');
          firstInvalid = firstInvalid || textarea;
        }

        if (!contactValue) {
          setError('contact', 'An email or phone number is required.');
          firstInvalid = firstInvalid || contact;
        } else if (!isValidContact(contactValue)) {
          setError('contact', 'Enter a valid email or phone number.');
          firstInvalid = firstInvalid || contact;
        }

        if (firstInvalid && firstInvalid.focus) firstInvalid.focus();
        return !firstInvalid;
      }

      function setLoading(loading) {
        if (saveBtn) saveBtn.disabled = loading;
        if (saveLabel) saveLabel.textContent = loading ? 'Sending…' : defaultLabel;
      }

      function closePopup() {
        popup.hidden = true;
        document.documentElement.style.overflow = '';
      }

      function openPopup() {
        clearAllErrors();
        popup.hidden = false;
        document.documentElement.style.overflow = 'hidden';
        if (textarea) textarea.focus();
      }

      popup.querySelectorAll('[data-custom-size-popup-close]').forEach(function (el) {
        el.addEventListener('click', closePopup);
      });
      document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape' && !popup.hidden) closePopup();
      });

      function submit() {
        if (!validate()) return;

        var formData = new FormData();
        formData.append('product_id', popup.dataset.productId || '');
        formData.append('product_handle', popup.dataset.productHandle || '');
        formData.append('product_name', popup.dataset.productName || '');
        formData.append('custom_size_description', textarea.value.trim());
        formData.append('customer_contact', contact.value.trim());

        setLoading(true);

        // Do not set Content-Type: let the browser add the multipart boundary.
        fetch(REQUEST_ENDPOINT, { method: 'POST', body: formData })
          .then(function (response) {
            if (response.ok) {
              toast("Thank you — we've received your request and will contact you shortly.", 'success');
              if (textarea) textarea.value = '';
              if (contact) contact.value = '';
              clearAllErrors();
              closePopup();
              return;
            }
            // Map the API's structured field errors back onto the inputs.
            return response.json().catch(function () { return null; }).then(function (data) {
              var mapped = false;
              if (data && Array.isArray(data.errors)) {
                data.errors.forEach(function (err) {
                  if (err.field === 'custom_size_description') { setError('note', err.message); mapped = true; }
                  else if (err.field === 'customer_contact') { setError('contact', err.message); mapped = true; }
                });
              }
              if (!mapped) {
                toast((data && data.message) || 'Something went wrong. Please try again.', 'error');
              }
            });
          })
          .catch(function () {
            toast('Something went wrong. Please try again.', 'error');
          })
          .finally(function () {
            setLoading(false);
          });
      }

      if (saveBtn) saveBtn.addEventListener('click', submit);

      tiles.forEach(function (tile) {
        tile.dataset.customSizeInit = 'true';
        tile.addEventListener('click', openPopup);
        // Keyboard support for the role="button" tile.
        tile.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') {
            e.preventDefault();
            openPopup();
          }
        });
      });
    }

    function init() {
      initVariantDragScroll();
      initVariantSelect();
      initCustomColorUpload();
      initVariantMediaFallback();
      initSizeGuide();
      initCustomSizeNote();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }
  })();
{% endjavascript %}
