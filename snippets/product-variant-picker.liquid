{% comment %}
  Renders product variant picker (options and values).
  @param {product} product
  @param {variant} current_variant
  @param {string} section_id
{% endcomment %}

{% unless product.has_only_default_variant %}
  {% style %}
    .product-variant-picker {
      margin-bottom: var(--sp-6, 24px);
      padding: 0 var(--sp-4, 14px);
      font-family: var(--font-body, inherit);
    }
    .variant-picker__color-value {
      font-size: 14px;
      font-weight: 700;
      color: #000;
    }
    .variant-picker__option-name {
      display: flex;
      gap: 6px;
      align-items: center;
      font-size: 14px;
      font-weight: 700;
      color: #000;
      margin-bottom: 12px;
    }
    .variant-picker__option-label {
      font-size: 14px;
      border-bottom: 1px solid #000;
      text-transform: uppercase;
    }
    .variant-picker__swatch-list {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      margin-bottom: 16px;
    }
    .variant-swatch--color input[type='radio'] {
      display: none;
    }
    .variant-swatch--color label {
      display: block;
      width: 36px;
      height: 36px;
      border-radius: 50%;
      border: 1px solid #e0e0e0;
      cursor: pointer;
      position: relative;
    }
    .variant-swatch--color input[type='radio']:checked + label::after {
      content: '';
      position: absolute;
      top: -4px;
      left: -4px;
      right: -4px;
      bottom: -4px;
      border: 1px solid #000;
      border-radius: 50%;
    }
    .variant-picker__size-header {
      font-size: 14px;
      font-weight: 700;
      color: #000;
      letter-spacing: 0.1em;
      margin-bottom: 16px;
      display: inline-block;
      border-bottom: 1px solid #000;
      padding-bottom: 2px;
    }
    .variant-picker__size-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
      margin-bottom: 24px;
    }
    .variant-swatch--size input[type='radio'] {
      display: none;
    }
    .variant-swatch--size label {
      display: flex;
      align-items: center;
      justify-content: center;
      height: 44px;
      border: 1px solid #e0e0e0;
      font-size: 14px;
      font-weight: 700;
      color: #000;
      cursor: pointer;
      background-color: #fff;
      transition: all 0.2s ease;
      position: relative;
      overflow: hidden;
      width: max-content;
      padding: 0 6px;
    }
    .variant-swatch--size input[type='radio']:checked + label {
      border-color: #000;
      border-width: 2px;
    }
    .variant-swatch--size input[type='radio']:disabled + label {
      color: #a0a0a0;
      cursor: not-allowed;
    }
    .variant-swatch--size input[type='radio']:disabled + label::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: linear-gradient(
        to top right,
        transparent calc(50% - 1px),
        #d1d1d1 calc(50%),
        transparent calc(50% + 1px)
      );
      pointer-events: none;
    }
    .visually-hidden {
      position: absolute !important;
      overflow: hidden;
      clip: rect(0 0 0 0);
      height: 1px;
      width: 1px;
      margin: -1px;
      padding: 0;
      border: 0;
    }

    @media (max-width: 768px) {
      .variant-picker__size-grid {
        grid-template-columns: repeat(4, 1fr);
      }
    }
  {% endstyle %}

  <div class="product-variant-picker">
    {% for option in product.options_with_values %}
      {% assign downcased_option = option.name | downcase %}
      {% assign is_color = false %}
      {% if downcased_option contains 'color'
        or downcased_option contains 'màu'
        or downcased_option contains 'canvas'
      %}
        {% assign is_color = true %}
      {% endif %}

      {% if is_color %}
        <div class="variant-option variant-option--color">
          <div class="variant-picker__option-name">
            <span class="variant-picker__option-label">{{ option.name -}}</span>
            <span
              class="variant-picker__color-value variant-option__selected-value"
              id="OptionLabel-{{ section_id }}-{{ forloop.index0 }}"
            >
              ({{ option.selected_value }})
            </span>
          </div>

          <div class="variant-picker__swatch-list">
            {% for value in option.values %}
              <div class="variant-swatch variant-swatch--color">
                <input
                  type="radio"
                  id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                  name="options[{{ option.name | escape }}]"
                  value="{{ value | escape }}"
                  data-index="option{{ option.position }}"
                  {% if option.selected_value == value %}
                    checked="checked" aria-pressed="true"
                  {% else %}
                    aria-pressed="false"
                  {% endif %}
                  {% unless value.available %}
                    disabled aria-disabled="true"
                  {% endunless %}
                >
                <label
                  for="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                  style="background-color: {{ value | downcase | remove: ' ' }};"
                  aria-label="{{ value | escape }}"
                >
                  <span class="visually-hidden">{{ value }}</span>
                </label>
              </div>
            {% endfor %}
          </div>
        </div>
      {% else %}
        <div class="variant-option variant-option--size">
          <div class="variant-picker__size-header">
            <span>SIZES</span>
          </div>

          <div class="variant-picker__size-grid">
            {% for value in option.values %}
              <div class="variant-swatch variant-swatch--size">
                <input
                  type="radio"
                  id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                  name="options[{{ option.name | escape }}]"
                  value="{{ value | escape }}"
                  data-index="option{{ option.position }}"
                  {% if option.selected_value == value %}
                    checked="checked" aria-pressed="true"
                  {% else %}
                    aria-pressed="false"
                  {% endif %}
                  {% unless value.available %}
                    disabled aria-disabled="true"
                  {% endunless %}
                >
                <label for="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}">
                  {{ value }}
                </label>
              </div>
            {% endfor %}
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const selectedOptions = {};
      
      // 1. Khởi tạo giá trị ban đầu dựa vào các input đã được check
      const checkedInputs = document.querySelectorAll('.product-variant-picker input[type="radio"]:checked');
      checkedInputs.forEach(input => {
        selectedOptions[input.dataset.index] = input.value;
      });

      const variantInputs = document.querySelectorAll('.product-variant-picker input[type="radio"]');
      const productVariants = {{ product.variants | json }};
      
      // 2. Bắt buộc: Tự map dữ liệu Metafield bằng Liquid vì bộ lọc `| json` của Shopify sẽ xóa mất Metafield
      const variantMetafieldsMap = {
        {% for v in product.variants %}
          "{{ v.id }}": {{ v.metafields.custom.variant_images.value | default: v.metafields.custom.variant_images | json }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      };
      
      for (const input of variantInputs) {
        input.addEventListener('change', function () {
          // 3. Cập nhật giá trị mới khi user chọn
          selectedOptions[input.dataset.index] = input.value;
          
          // 4. Tìm variant khớp với toàn bộ lựa chọn
          const selectedVariant = productVariants.find(variant => {
            return Object.keys(selectedOptions).every(key => {
              return variant[key] === selectedOptions[key];
            });
          });
          
          if (selectedVariant) {
            // Gắn thêm metafield vào selectedVariant để tiện sử dụng
            selectedVariant.metafields = {
              custom: {
                variant_images: variantMetafieldsMap[selectedVariant.id]
              }
            };
            
            // Logic lọc ảnh theo variant-images
            const variantImagesRaw = selectedVariant.metafields.custom.variant_images;
            if (variantImagesRaw) {
              // Phân tích ra thành 1 mảng variant-image[] (string[])
              const variantImages = variantImagesRaw.split('\n').map(s => s.trim().replace(/<br\s*\/?>/g, '')).filter(s => s !== '');
              
              if (variantImages.length > 0) {
                const thumbnails = document.querySelectorAll('.product-gallery__thumbnail');
                const mainItems = document.querySelectorAll('.product-gallery__main-item');
                
                let firstMatchedThumbnail = null;
                
                // Lọc thumbnails
                thumbnails.forEach(thumb => {
                  const alt = thumb.dataset.alt || '';
                  // Kiểm tra alt có chứa bất kỳ string nào trong mảng variantImages không
                  const isMatch = variantImages.some(vImg => alt.includes(vImg));
                  
                  if (isMatch) {
                    thumb.style.display = ''; // Show
                    if (!firstMatchedThumbnail) firstMatchedThumbnail = thumb;
                  } else {
                    thumb.style.display = 'none'; // Hide
                    thumb.classList.remove('is-active');
                  }
                });
                
                // Xóa active khỏi các main items không khớp
                mainItems.forEach(item => {
                  const alt = item.dataset.alt || '';
                  const isMatch = variantImages.some(vImg => alt.includes(vImg));
                  if (!isMatch) {
                     item.classList.remove('is-active');
                  }
                });
                
                // Chọn ảnh đầu tiên trong pickedMediaList
                if (firstMatchedThumbnail) {
                  firstMatchedThumbnail.click(); 
                }
              } else {
                // Nếu mảng rỗng thì show hết
                document.querySelectorAll('.product-gallery__thumbnail').forEach(t => t.style.display = '');
              }
            } else {
              // Không có metafield -> show hết
              document.querySelectorAll('.product-gallery__thumbnail').forEach(t => t.style.display = '');
            }
          }
          
    const productMedia = {{ product.media | json }};
    console.log("Danh sách tất cả Product Media: ", productMedia);
          console.log(">>> Variant được chọn:", selectedVariant);
          console.log(">>> Giá trị của metafields:", selectedVariant ? selectedVariant.metafields : undefined);
        });
      }
    });
  </script>
{% endunless %}
