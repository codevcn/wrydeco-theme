{% comment %}
  Renders product variant picker as labelled dropdowns (SIZE / FINISH).

  The custom dropdown UI is layered on top of hidden radio inputs. Selecting a
  dropdown item checks the matching radio and dispatches a `change` event, so
  the existing variant logic (image swap + inventory below, and the Section
  Rendering API in product-info.js) keeps working unchanged.

  @param {product} product
  @param {variant} current_variant
  @param {string} section_id
{% endcomment %}

{% unless product.has_only_default_variant %}
  {% style %}
    .product-variant-picker {
      margin: 0;
      font-family: var(--font-body);
    }
    .variant-options {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--sp-5);
    }
    .variant-field {
      min-width: 0;
    }
    .variant-field__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--sp-2);
      margin-bottom: var(--sp-2);
    }
    .variant-field__label {
      font-size: var(--font-size-body-sm);
      font-weight: var(--font-weight-bold);
      letter-spacing: var(--letter-spacing-wide);
      text-transform: uppercase;
      color: var(--text-primary);
    }
    .variant-field__guide {
      font-size: var(--font-size-body-sm);
      color: var(--color-sage);
      text-decoration: none;
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
    }
    .variant-field__guide:hover {
      color: var(--color-sage);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .variant-dropdown {
      position: relative;
    }
    .variant-dropdown__trigger {
      width: 100%;
      display: flex;
      align-items: center;
      gap: var(--sp-3);
      height: 52px;
      padding: 0 var(--sp-4);
      background-color: transparent;
      border: 1px solid var(--border-default);
      border-radius: var(--radius-lg);
      cursor: pointer;
      text-align: left;
      font-family: var(--font-body);
      font-size: var(--font-size-body-md);
      font-weight: var(--font-weight-regular);
      color: var(--text-primary);
      transition: border-color var(--timing-short) var(--ease-standard),
        box-shadow var(--timing-short) var(--ease-standard);
    }
    .variant-dropdown__trigger:hover {
      border-color: var(--border-dark);
    }
    .variant-dropdown__trigger[aria-expanded='true'] {
      border-color: var(--color-sage);
      box-shadow: var(--shadow-focus);
    }
    .variant-dropdown__swatch {
      flex: 0 0 auto;
      width: 20px;
      height: 20px;
      border-radius: var(--radius-full);
      border: 1px solid var(--border-light);
    }
    .variant-dropdown__value {
      flex: 1 1 auto;
      min-width: 0;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      font-family: var(--font-roboto);
      letter-spacing: 0.01rem;
    }
    .variant-dropdown__chevron {
      flex: 0 0 auto;
      width: 18px;
      height: 18px;
      color: var(--text-secondary);
      transition: transform var(--timing-short) var(--ease-standard);
    }
    .variant-dropdown__trigger[aria-expanded='true'] .variant-dropdown__chevron {
      transform: rotate(180deg);
    }

    .variant-dropdown__panel {
      position: absolute;
      top: calc(100% + 6px);
      left: 0;
      right: 0;
      z-index: 30;
      margin: 0;
      padding: var(--sp-1);
      list-style: none;
      background-color: var(--surface-elevated);
      border: 1px solid var(--border-default);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-dropdown);
      max-height: 280px;
      overflow-y: auto;
    }
    .variant-dropdown__panel[hidden] {
      display: none;
    }
    .variant-dropdown__item {
      display: flex;
      align-items: center;
      gap: var(--sp-3);
      margin: 0;
      padding: var(--sp-3);
      border-radius: var(--radius-md);
      cursor: pointer;
      font-size: var(--font-size-body-md);
      color: var(--text-primary);
      transition: background-color var(--timing-short) var(--ease-standard);
    }
    .variant-dropdown__item:hover {
      background-color: var(--bg-secondary);
    }
    .variant-dropdown__item.is-selected {
      background-color: var(--bg-secondary);
      font-weight: var(--font-weight-semibold);
    }
    .variant-dropdown__item.is-disabled {
      color: var(--text-disabled);
      cursor: not-allowed;
      text-decoration: line-through;
      opacity: 0.65;
    }
    .variant-dropdown__item.is-disabled:hover {
      background-color: transparent;
    }

    .variant-field__inputs {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
    }

    @media screen and (max-width: 768px) {
      .variant-options {
        grid-template-columns: 1fr 1fr;
        gap: var(--sp-4);
      }
    }
  {% endstyle %}

  <div class="product-variant-picker">
    <div class="variant-options">
      {% for option in product.options_with_values %}
        {% assign downcased_option = option.name | downcase %}
        {% assign is_color = false %}
        {% if downcased_option contains 'color'
          or downcased_option contains 'màu'
          or downcased_option contains 'canvas'
          or downcased_option contains 'finish'
        %}
          {% assign is_color = true %}
        {% endif %}

        <div
          class="variant-field variant-field--{% if is_color %}color{% else %}size{% endif %}"
          data-variant-field
        >
          <div class="variant-field__head">
            <span class="variant-field__label">{{ option.name }}</span>
            {% if downcased_option == 'size' or downcased_option == 'kích thước' %}
              {% if product.metafields.custom.size_guide != blank %}
                <button
                  type="button"
                  class="variant-field__guide"
                  aria-haspopup="dialog"
                  onclick="window.openSizeGuidePopup && window.openSizeGuidePopup()"
                >
                  Guide
                </button>
              {% endif %}
            {% endif %}
          </div>

          <div class="variant-dropdown" data-variant-dropdown>
            <button
              type="button"
              class="variant-dropdown__trigger"
              data-dropdown-trigger
              aria-haspopup="listbox"
              aria-expanded="false"
              aria-label="{{ option.name | escape }}"
            >
              {% if is_color %}
                <span
                  class="variant-dropdown__swatch"
                  data-dropdown-swatch
                  style="background-color: {{ option.selected_value | downcase | remove: ' ' }};"
                ></span>
              {% endif %}
              <span
                class="variant-dropdown__value variant-option__selected-value"
                id="OptionLabel-{{ section_id }}-{{ forloop.index0 }}"
                data-dropdown-value
              >
                {{- option.selected_value -}}
              </span>
              <svg
                class="variant-dropdown__chevron"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                aria-hidden="true"
              >
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>

            <ul class="variant-dropdown__panel" role="listbox" data-dropdown-panel hidden>
              {% for value in option.values %}
                <li
                  class="variant-dropdown__item{% if option.selected_value == value %} is-selected{% endif %}{% unless value.available %} is-disabled{% endunless %}"
                  role="option"
                  data-dropdown-item
                  data-value="{{ value | escape }}"
                  data-radio-id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                  {% if is_color %}
                    data-swatch="{{ value | downcase | remove: ' ' }}"
                  {% endif %}
                  aria-selected="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                  {% unless value.available %}
                    aria-disabled="true"
                  {% endunless %}
                >
                  {% if is_color %}
                    <span
                      class="variant-dropdown__swatch"
                      style="background-color: {{ value | downcase | remove: ' ' }};"
                    ></span>
                  {% endif %}
                  <span>{{ value }}</span>
                </li>
              {% endfor %}
            </ul>
          </div>

          {% comment %} Hidden radios drive the existing variant logic {% endcomment %}
          <div class="variant-field__inputs" aria-hidden="true">
            {% for value in option.values %}
              <span class="variant-swatch">
                <input
                  type="radio"
                  id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                  name="options[{{ option.name | escape }}]"
                  value="{{ value | escape }}"
                  data-index="option{{ option.position }}"
                  tabindex="-1"
                  {% if option.selected_value == value %}
                    checked="checked"
                  {% endif %}
                  {% unless value.available %}
                    disabled
                  {% endunless %}
                >
              </span>
            {% endfor %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <script>
    (function () {
      function initVariantDropdowns() {
        const dropdowns = document.querySelectorAll('[data-variant-dropdown]');

        const closeAll = (except) => {
          document.querySelectorAll('[data-dropdown-panel]').forEach((panel) => {
            if (panel === except || panel.hidden) return;
            panel.hidden = true;
            const trigger = panel.closest('[data-variant-dropdown]').querySelector('[data-dropdown-trigger]');
            if (trigger) trigger.setAttribute('aria-expanded', 'false');
          });
        };

        dropdowns.forEach((dd) => {
          if (dd.dataset.ddInit === 'true') return;
          dd.dataset.ddInit = 'true';

          const trigger = dd.querySelector('[data-dropdown-trigger]');
          const panel = dd.querySelector('[data-dropdown-panel]');
          const valueEl = dd.querySelector('[data-dropdown-value]');
          const swatchEl = dd.querySelector('[data-dropdown-swatch]');

          trigger.addEventListener('click', (event) => {
            event.stopPropagation();
            const willOpen = panel.hidden;
            closeAll(willOpen ? panel : null);
            panel.hidden = !willOpen;
            trigger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          });

          panel.addEventListener('click', (event) => {
            const item = event.target.closest('[data-dropdown-item]');
            if (!item || item.getAttribute('aria-disabled') === 'true') return;

            panel.querySelectorAll('[data-dropdown-item]').forEach((el) => {
              const selected = el === item;
              el.classList.toggle('is-selected', selected);
              el.setAttribute('aria-selected', selected ? 'true' : 'false');
            });

            valueEl.textContent = item.dataset.value;
            if (swatchEl && item.dataset.swatch) {
              swatchEl.style.backgroundColor = item.dataset.swatch;
            }

            const radio = document.getElementById(item.dataset.radioId);
            if (radio) {
              radio.checked = true;
              radio.dispatchEvent(new Event('change', { bubbles: true }));
            }

            panel.hidden = true;
            trigger.setAttribute('aria-expanded', 'false');
          });
        });

        if (!window.__variantDropdownGlobalBound) {
          window.__variantDropdownGlobalBound = true;
          document.addEventListener('click', () => closeAll(null));
          document.addEventListener('keydown', (event) => {
            if (event.key === 'Escape') closeAll(null);
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initVariantDropdowns);
      } else {
        initVariantDropdowns();
      }
    })();
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const selectedOptions = {};

      // 1. Khởi tạo giá trị ban đầu dựa vào các input đã được check
      const checkedInputs = document.querySelectorAll('.product-variant-picker input[type="radio"]:checked');
      checkedInputs.forEach(input => {
        selectedOptions[input.dataset.index] = input.value;
      });

      const variantInputs = document.querySelectorAll('.product-variant-picker input[type="radio"]');
      const productVariants = {{ product.variants | json }};

      // 2. Bắt buộc: Tự map dữ liệu Metafield bằng Liquid vì bộ lọc `| json` của Shopify sẽ xóa mất Metafield
      const variantMetafieldsMap = {
        {% for v in product.variants %}
          "{{ v.id }}": {{ v.metafields.custom.variant_images.value | default: v.metafields.custom.variant_images | json }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      };

      // Tự map dữ liệu Inventory vì API/json đôi khi không trả về inventory_quantity
      const variantInventoryMap = {
        {% for v in product.variants %}
          "{{ v.id }}": {
             "qty": {{ v.inventory_quantity | default: 0 }},
             "policy": {{ v.inventory_policy | json }},
             "management": {{ v.inventory_management | json }},
             "available": {{ v.available | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      };

      for (const input of variantInputs) {
        input.addEventListener('change', function () {
          // 3. Cập nhật giá trị mới khi user chọn
          selectedOptions[input.dataset.index] = input.value;

          // 4. Tìm variant khớp với toàn bộ lựa chọn
          const selectedVariant = productVariants.find(variant => {
            return Object.keys(selectedOptions).every(key => {
              return variant[key] === selectedOptions[key];
            });
          });

          if (selectedVariant) {
            // Instant, no-API updates the moment a variant is picked:
            // price + compare + "Save", the hidden variant id used by the form,
            // the add-to-cart button state, and the ?variant= URL param.
            if (window.updateProductPrice) {
              window.updateProductPrice(selectedVariant.id);
            }

            const variantIdInput = document.querySelector('[data-variant-id]');
            if (variantIdInput) variantIdInput.value = selectedVariant.id;

            const addText = document.querySelector('[data-add-to-cart-text]');
            const addBtn = document.querySelector('form[data-type="add-to-cart-form"] button[name="add"]');
            if (addText) addText.textContent = selectedVariant.available ? 'ADD TO CART' : 'SOLD OUT';
            if (addBtn) addBtn.disabled = !selectedVariant.available;

            if (window.history && window.history.replaceState) {
              const nextUrl = new URL(window.location.href);
              nextUrl.searchParams.set('variant', selectedVariant.id);
              window.history.replaceState({}, '', nextUrl);
            }

            // Gắn thêm metafield vào selectedVariant để tiện sử dụng
            selectedVariant.metafields = {
              custom: {
                variant_images: variantMetafieldsMap[selectedVariant.id]
              }
            };

            // Logic lọc ảnh theo variant-images
            const variantImagesRaw = selectedVariant.metafields.custom.variant_images;
            if (variantImagesRaw) {
              // Phân tích ra thành 1 mảng variant-image[] (string[])
              const variantImages = variantImagesRaw.split('\n').map(s => s.trim().replace(/<br\s*\/?>/g, '')).filter(s => s !== '');

              if (variantImages.length > 0) {
                const thumbnails = document.querySelectorAll('.product-gallery__thumbnail');
                const mainItems = document.querySelectorAll('.product-gallery__main-item');

                let firstMatchedThumbnail = null;

                // Lọc thumbnails
                thumbnails.forEach(thumb => {
                  const alt = thumb.dataset.alt || '';
                  // Kiểm tra alt có chứa bất kỳ string nào trong mảng variantImages không
                  const isMatch = variantImages.some(vImg => alt.includes(vImg));

                  if (isMatch) {
                    thumb.style.display = ''; // Show
                    if (!firstMatchedThumbnail) firstMatchedThumbnail = thumb;
                  } else {
                    thumb.style.display = 'none'; // Hide
                    thumb.classList.remove('is-active');
                  }
                });

                // Xóa active khỏi các main items không khớp
                mainItems.forEach(item => {
                  const alt = item.dataset.alt || '';
                  const isMatch = variantImages.some(vImg => alt.includes(vImg));
                  if (!isMatch) {
                     item.classList.remove('is-active');
                  }
                });

                // Chọn ảnh đầu tiên trong pickedMediaList
                if (firstMatchedThumbnail) {
                  firstMatchedThumbnail.click();
                }
              } else {
                // Nếu mảng rỗng thì show hết
                document.querySelectorAll('.product-gallery__thumbnail').forEach(t => t.style.display = '');
              }
            } else {
              // Không có metafield -> show hết
              document.querySelectorAll('.product-gallery__thumbnail').forEach(t => t.style.display = '');
            }

            // Cập nhật Inventory Status
            const invInfo = variantInventoryMap[selectedVariant.id];
            const invStatusEl = document.querySelector('[data-inventory-status]');
            if (invStatusEl && invInfo) {
               let status = 'in-stock';
               let label = 'In stock';
               const threshold = 10;

               if (!invInfo.available) {
                 status = 'out';
                 label = 'Out of stock';
               } else if (!invInfo.management) {
                 status = 'in-stock';
                 label = 'In stock';
               } else {
                 if (invInfo.qty > 0) {
                   if (invInfo.qty <= threshold) {
                     status = 'low';
                     label = 'Only ' + invInfo.qty + ' left in stock';
                   } else {
                     status = 'in-stock';
                     label = invInfo.qty + ' in stock';
                   }
                 } else {
                   status = 'backorder';
                   label = 'Available to order';
                 }
               }

               invStatusEl.className = 'product-inventory product-inventory--' + status;
               const textEl = invStatusEl.querySelector('.product-inventory__text');
               if (textEl) textEl.textContent = label;
            }
          }
        });
      }
    });
  </script>
{% endunless %}

{% if product.metafields.custom.size_guide != blank %}
  <size-guide-popup class="size-guide-popup-wrapper">
    <div class="size-guide-popup__overlay">
      <div class="size-guide-popup__content" role="dialog" aria-modal="true" aria-labelledby="SizeGuideTitle">
        <div class="size-guide-popup__header">
          <h2 class="size-guide-popup__heading" id="SizeGuideTitle">Product Size Guide</h2>
          <button class="size-guide-popup__close" type="button" aria-label="Close size guide">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
        <div class="size-guide-popup__body custom-scrollbar">
          <img
            src="{{ product.metafields.custom.size_guide }}"
            alt="Size Guide for {{ product.title | escape }}"
            loading="lazy"
            style="max-width: 100%; height: auto; display: block; margin: 0 auto;"
          >
        </div>
      </div>
    </div>
  </size-guide-popup>

  <script>
    class SizeGuidePopup extends HTMLElement {
      constructor() {
        super();
        this.overlay = this.querySelector('.size-guide-popup__overlay');
        this.closeBtn = this.querySelector('.size-guide-popup__close');

        if (this.closeBtn) this.closeBtn.addEventListener('click', this.close.bind(this));
        if (this.overlay) {
          this.overlay.addEventListener('click', (e) => {
            if (e.target === this.overlay) this.close();
          });
        }
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.hasAttribute('open')) this.close();
        });

        window.openSizeGuidePopup = (e) => {
          if (e) e.preventDefault();
          this.open();
        };
      }

      open() {
        this.setAttribute('open', '');
        document.body.style.overflow = 'hidden';
      }

      close() {
        this.removeAttribute('open');
        document.body.style.overflow = '';
      }
    }

    if (!customElements.get('size-guide-popup')) {
      customElements.define('size-guide-popup', SizeGuidePopup);
    }
  </script>

  <style>
    size-guide-popup {
      display: block;
    }
    .size-guide-popup__overlay {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--sp-6, 24px);
      background-color: rgba(23, 21, 21, 0.4);
      backdrop-filter: blur(4px);
      opacity: 0;
      visibility: hidden;
      transition: opacity var(--timing-short, 0.2s) ease, visibility var(--timing-short, 0.2s) ease;
    }
    size-guide-popup[open] .size-guide-popup__overlay {
      opacity: 1;
      visibility: visible;
    }
    .size-guide-popup__content {
      display: flex;
      flex-direction: column;
      width: min(100%, 800px);
      max-height: calc(100dvh - var(--sp-8, 32px));
      overflow: hidden;
      border: 1px solid var(--border-light, #e8e3df);
      border-radius: var(--radius-lg, 8px);
      background-color: var(--surface-elevated, #fff);
      box-shadow: 0 20px 40px rgba(0, 0, 0, 0.1);
      opacity: 0;
      transform: translateY(-8px);
      transition: transform var(--timing-short, 0.2s) ease, opacity var(--timing-short, 0.2s) ease;
    }
    size-guide-popup[open] .size-guide-popup__content {
      opacity: 1;
      transform: translateY(0);
    }
    .size-guide-popup__header {
      position: relative;
      padding: var(--sp-4, 16px) var(--sp-6, 24px);
      border-bottom: 1px solid var(--border-light, #e8e3df);
      display: flex;
      justify-content: space-between;
      align-items: center;
      background-color: var(--color-milk, #fdfaf7);
    }
    .size-guide-popup__heading {
      margin: 0;
      font-family: var(--font-display, 'Fraunces', serif);
      font-size: var(--font-size-body-xl, 20px);
      letter-spacing: 0.01rem;
      word-spacing: 0.02rem;
    }
    .size-guide-popup__close {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      padding: 0;
      border: 0;
      border-radius: 50%;
      background: transparent;
      cursor: pointer;
    }
    .size-guide-popup__close:hover {
      background-color: var(--surface-tertiary, #f5f1ed);
    }
    .size-guide-popup__close svg {
      width: 20px;
      height: 20px;
    }
    .size-guide-popup__body {
      padding: var(--sp-6, 24px);
      overflow-y: auto;
      text-align: center;
      background-color: var(--color-milk, #fdfaf7);
    }
  </style>
{% endif %}
