{% comment %}
  Renders the product variant picker as circular FINISH swatches + a SIZE button
  grid (made-to-order style).

  The visible controls are layered on top of hidden radio inputs. Selecting a
  swatch/size checks the matching radio and dispatches a `change` event, so the
  existing variant logic (image swap + inventory in this file, and the Section
  Rendering API in product-info.js) keeps working unchanged.

  Availability is combo-aware: a value is disabled (with a strike) when no
  AVAILABLE variant exists for it given the current selection of the other
  options.

  @param {product} product
  @param {variant} current_variant
  @param {string} section_id
{% endcomment %}

{% unless product.has_only_default_variant %}
  {% style %}
    .product-variant-picker {
      margin: 0;
      font-family: var(--font-body);
      display: flex;
      flex-direction: column;
      gap: var(--sp-6);
    }

    .pv__field {
      min-width: 0;
    }

    .pv__head {
      display: flex;
      align-items: baseline;
      gap: var(--sp-3);
      margin-bottom: var(--sp-3);
    }
    .pv__label {
      font-size: var(--font-size-body-sm);
      font-weight: var(--font-weight-bold);
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--text-secondary);
      margin: 0;
    }
    .pv__current {
      font-size: var(--font-size-body-md);
      font-weight: var(--font-weight-medium);
      color: var(--text-primary);
    }
    .pv__guide {
      margin-left: auto;
      font-size: var(--font-size-body-sm);
      color: var(--color-sage);
      text-decoration: none;
    }
    .pv__guide:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    /* --- Finish swatches --- */
    .pv__swatches {
      display: flex;
      flex-wrap: wrap;
      gap: var(--sp-3);
    }
    .pv__swatch {
      position: relative;
      width: 44px;
      height: 44px;
      padding: 0;
      border: none;
      border-radius: var(--radius-full);
      background: var(--swatch, var(--surface-tertiary));
      background-size: cover;
      background-position: center;
      cursor: pointer;
      outline: none;
      transition: transform var(--timing-short) var(--ease-standard);
    }
    .pv__swatch::after {
      content: '';
      position: absolute;
      inset: -5px;
      border-radius: var(--radius-full);
      border: 1.5px solid transparent;
      transition: border-color var(--timing-short) var(--ease-standard);
    }
    .pv__swatch:hover {
      transform: scale(1.05);
    }
    .pv__swatch.is-active::after {
      border-color: var(--color-earth-brown, #4a2c18);
    }
    .pv__swatch:focus-visible::after {
      border-color: var(--color-sage);
    }
    .pv__swatch.is-unavailable {
      cursor: not-allowed;
      opacity: 0.4;
    }
    .pv__swatch.is-unavailable::before {
      content: '';
      position: absolute;
      inset: 50% 0 auto 0;
      height: 1.5px;
      background: var(--text-primary);
      transform: rotate(-45deg);
    }

    /* --- Size grid --- */
    .pv__sizes {
      display: grid;
      grid-template-columns: repeat(5, minmax(56px, 92px));
      justify-content: start;
      gap: 10px;
    }
    .pv__size {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0 var(--sp-3);
      background: transparent;
      border: 1px solid var(--border-default);
      border-radius: var(--radius-md);
      font-family: var(--font-body);
      font-size: var(--font-size-body-md);
      font-weight: var(--font-weight-medium);
      color: var(--text-primary);
      cursor: pointer;
      transition: border-color var(--timing-short) var(--ease-standard),
        background-color var(--timing-short) var(--ease-standard);
    }
    .pv__size:hover {
      border-color: var(--border-dark);
    }
    .pv__size:focus-visible {
      border-color: var(--color-sage);
      box-shadow: var(--shadow-focus);
    }
    .pv__size.is-active {
      border-color: var(--color-earth-brown, #4a2c18);
      background-color: var(--color-earth-brown, #4a2c18);
      color: var(--color-cream, #f5f1ed);
    }
    .pv__size.is-unavailable {
      position: relative;
      color: var(--text-disabled);
      border-color: var(--border-light);
      cursor: not-allowed;
      overflow: hidden;
    }
    .pv__size.is-unavailable::after {
      content: '';
      position: absolute;
      left: -10%;
      top: 50%;
      width: 120%;
      height: 1px;
      background: var(--text-disabled);
      transform: rotate(-18deg);
    }

    .pv__inputs {
      position: absolute;
      width: 1px;
      height: 1px;
      overflow: hidden;
      clip: rect(0 0 0 0);
    }

    @media screen and (max-width: 600px) {
      .pv__sizes {
        grid-template-columns: repeat(4, minmax(52px, 1fr));
      }
    }
    @media screen and (max-width: 380px) {
      .pv__sizes {
        grid-template-columns: repeat(3, minmax(52px, 1fr));
      }
    }
  {% endstyle %}

  <div class="product-variant-picker">
    {% for option in product.options_with_values %}
      {% comment %} Skip Shopify's default placeholder option {% endcomment %}
      {% if option.values.size == 1 %}
        {% assign only_value = option.values.first %}
        {% if option.name == 'Title' or only_value == 'Default Title' %}
          {% continue %}
        {% endif %}
      {% endif %}
      {% assign downcased_option = option.name | downcase %}
      {% assign is_color = false %}
      {% if downcased_option contains 'color'
        or downcased_option contains 'colour'
        or downcased_option contains 'màu'
        or downcased_option contains 'finish'
        or downcased_option contains 'wood'
        or downcased_option contains 'canvas'
      %}
        {% assign is_color = true %}
      {% endif %}

      <div class="pv__field pv__field--{% if is_color %}color{% else %}size{% endif %}" data-vp-field>
        {% if is_color %}
          <div class="pv__head">
            <span class="pv__label">{{ option.name }}</span>
            <span
              class="pv__current variant-option__selected-value"
              data-vp-current
              data-pos="{{ option.position }}"
            >{{ option.selected_value }}</span>
          </div>

          <div class="pv__swatches" role="group" aria-label="{{ option.name | escape }}">
            {% for value in option.values %}
              {% liquid
                assign sc = ''
                assign sw_image = ''
                if value.swatch.color != blank
                  assign sc = value.swatch.color
                endif
                if value.swatch.image != blank
                  assign sw_image = value.swatch.image | image_url: width: 88
                endif
                assign v_down = value | downcase | strip
                if sc == ''
                  case v_down
                    when 'natural', 'natural oil', 'natural wood'
                      assign sc = '#d8b78a'
                    when 'light oak', 'oak'
                      assign sc = '#c8a165'
                    when 'ash'
                      assign sc = '#d9cbb3'
                    when 'maple'
                      assign sc = '#e3c795'
                    when 'cherry'
                      assign sc = '#8a4b32'
                    when 'walnut'
                      assign sc = '#5c3a21'
                    when 'dark walnut', 'dark brown', 'smoked', 'espresso'
                      assign sc = '#3d2817'
                    when 'matte black', 'black', 'ebony'
                      assign sc = '#1a1815'
                    when 'white', 'warm white', 'whitewash'
                      assign sc = '#efe9df'
                    else
                      assign sc = '#c8a165'
                  endcase
                endif
              %}
              <button
                type="button"
                class="pv__swatch{% if option.selected_value == value %} is-active{% endif %}{% unless value.available %} is-unavailable{% endunless %}"
                data-vp-btn
                data-option-position="{{ option.position }}"
                data-value="{{ value | escape }}"
                data-radio-id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                aria-label="{{ option.name | escape }}: {{ value | escape }}"
                aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                style="--swatch: {% if sw_image != blank %}url('{{ sw_image }}'){% else %}{{ sc }}{% endif %};"
                {% unless value.available %}aria-disabled="true"{% endunless %}
              ></button>
            {% endfor %}
          </div>
        {% else %}
          <div class="pv__head">
            <span class="pv__label">{{ option.name }}</span>
            <a class="pv__guide" href="#size-guide">Size guide</a>
          </div>

          <div class="pv__sizes" role="group" aria-label="{{ option.name | escape }}">
            {% for value in option.values %}
              <button
                type="button"
                class="pv__size{% if option.selected_value == value %} is-active{% endif %}{% unless value.available %} is-unavailable{% endunless %}"
                data-vp-btn
                data-option-position="{{ option.position }}"
                data-value="{{ value | escape }}"
                data-radio-id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                aria-pressed="{% if option.selected_value == value %}true{% else %}false{% endif %}"
                {% unless value.available %}aria-disabled="true"{% endunless %}
              >{{ value }}</button>
            {% endfor %}
          </div>
        {% endif %}

        {% comment %} Hidden radios drive the existing variant logic {% endcomment %}
        <div class="pv__inputs" aria-hidden="true">
          {% for value in option.values %}
            <span class="variant-swatch">
              <input
                type="radio"
                id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                name="options[{{ option.name | escape }}]"
                value="{{ value | escape }}"
                data-index="option{{ option.position }}"
                tabindex="-1"
                {% if option.selected_value == value %}checked="checked"{% endif %}
                {% unless value.available %}disabled{% endunless %}
              >
            </span>
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>

  <script type="application/json" data-vp-variants>
    {{ product.variants | json }}
  </script>

  <script>
    (function () {
      function initPicker(root) {
        if (!root || root.dataset.vpInit === '1') return;
        root.dataset.vpInit = '1';

        var dataEl = root.parentNode.querySelector('[data-vp-variants]') || document.querySelector('[data-vp-variants]');
        var variants = [];
        try { variants = JSON.parse(dataEl.textContent); } catch (e) { variants = []; }

        var buttons = Array.prototype.slice.call(root.querySelectorAll('[data-vp-btn]'));

        function selectedValues() {
          var map = {};
          root.querySelectorAll('.variant-swatch input[type="radio"]:checked').forEach(function (r) {
            var pos = (r.dataset.index || '').replace('option', '');
            if (pos) map[pos] = r.value;
          });
          return map;
        }

        function optionsMatch(vOptions, sel) {
          for (var pos in sel) {
            if (vOptions[pos - 1] !== sel[pos]) return false;
          }
          return true;
        }

        function comboAvailable(position, value) {
          var sel = selectedValues();
          return variants.some(function (v) {
            if (!v.available) return false;
            if (v.options[position - 1] !== value) return false;
            for (var pos in sel) {
              if (String(pos) === String(position)) continue;
              if (v.options[pos - 1] !== sel[pos]) return false;
            }
            return true;
          });
        }

        function setRadios(position, value) {
          root.querySelectorAll('input[data-index="option' + position + '"]').forEach(function (r) {
            r.checked = (r.value === value);
          });
        }

        function syncToVariant(variant) {
          variant.options.forEach(function (val, i) {
            setRadios(i + 1, val);
          });
        }

        function refresh() {
          var sel = selectedValues();
          buttons.forEach(function (btn) {
            var pos = parseInt(btn.dataset.optionPosition, 10);
            var val = btn.dataset.value;
            var active = sel[pos] === val;
            btn.classList.toggle('is-active', active);
            btn.setAttribute('aria-pressed', active ? 'true' : 'false');

            var ok = comboAvailable(pos, val);
            btn.classList.toggle('is-unavailable', !ok);
            if (!ok) {
              btn.setAttribute('aria-disabled', 'true');
            } else {
              btn.removeAttribute('aria-disabled');
            }
          });

          root.querySelectorAll('[data-vp-current]').forEach(function (el) {
            var pos = el.dataset.pos;
            if (sel[pos]) el.textContent = sel[pos];
          });
        }

        function dispatchChange() {
          var target = root.querySelector('.variant-swatch input[type="radio"]:checked');
          if (target) target.dispatchEvent(new Event('change', { bubbles: true }));
        }

        buttons.forEach(function (btn) {
          btn.addEventListener('click', function () {
            if (btn.getAttribute('aria-disabled') === 'true') return;
            var pos = parseInt(btn.dataset.optionPosition, 10);
            var val = btn.dataset.value;

            setRadios(pos, val);

            var sel = selectedValues();
            var exists = variants.some(function (v) {
              return v.available && optionsMatch(v.options, sel);
            });

            if (!exists) {
              var cand = variants.filter(function (v) { return v.available && v.options[pos - 1] === val; })[0];
              if (cand) syncToVariant(cand);
            }

            dispatchChange();
            refresh();
          });
        });

        root.querySelectorAll('.variant-swatch input[type="radio"]').forEach(function (r) {
          r.addEventListener('change', refresh);
        });

        refresh();
      }

      function initAll() {
        document.querySelectorAll('.product-variant-picker').forEach(initPicker);
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initAll);
      } else {
        initAll();
      }
    })();
  </script>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const selectedOptions = {};

      const checkedInputs = document.querySelectorAll('.product-variant-picker input[type="radio"]:checked');
      checkedInputs.forEach(input => {
        selectedOptions[input.dataset.index] = input.value;
      });

      const variantInputs = document.querySelectorAll('.product-variant-picker input[type="radio"]');
      const productVariants = {{ product.variants | json }};

      const variantMetafieldsMap = {
        {% for v in product.variants %}
          "{{ v.id }}": {{ v.metafields.custom.variant_images.value | default: v.metafields.custom.variant_images | json }}{% unless forloop.last %},{% endunless %}
        {% endfor %}
      };

      const variantInventoryMap = {
        {% for v in product.variants %}
          "{{ v.id }}": {
             "qty": {{ v.inventory_quantity | default: 0 }},
             "policy": {{ v.inventory_policy | json }},
             "management": {{ v.inventory_management | json }},
             "available": {{ v.available | json }}
          }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      };

      for (const input of variantInputs) {
        input.addEventListener('change', function () {
          selectedOptions[input.dataset.index] = input.value;

          const selectedVariant = productVariants.find(variant => {
            return Object.keys(selectedOptions).every(key => {
              return variant[key] === selectedOptions[key];
            });
          });

          if (selectedVariant) {
            selectedVariant.metafields = {
              custom: {
                variant_images: variantMetafieldsMap[selectedVariant.id]
              }
            };

            const variantImagesRaw = selectedVariant.metafields.custom.variant_images;
            if (variantImagesRaw) {
              const variantImages = variantImagesRaw.split('\n').map(s => s.trim().replace(/<br\s*\/?>/g, '')).filter(s => s !== '');

              if (variantImages.length > 0) {
                const thumbnails = document.querySelectorAll('.product-gallery__thumbnail');
                const mainItems = document.querySelectorAll('.product-gallery__main-item');

                let firstMatchedThumbnail = null;

                thumbnails.forEach(thumb => {
                  const alt = thumb.dataset.alt || '';
                  const isMatch = variantImages.some(vImg => alt.includes(vImg));

                  if (isMatch) {
                    thumb.style.display = '';
                    if (!firstMatchedThumbnail) firstMatchedThumbnail = thumb;
                  } else {
                    thumb.style.display = 'none';
                    thumb.classList.remove('is-active');
                  }
                });

                mainItems.forEach(item => {
                  const alt = item.dataset.alt || '';
                  const isMatch = variantImages.some(vImg => alt.includes(vImg));
                  if (!isMatch) {
                     item.classList.remove('is-active');
                  }
                });

                if (firstMatchedThumbnail) {
                  firstMatchedThumbnail.click();
                }
              } else {
                document.querySelectorAll('.product-gallery__thumbnail').forEach(t => t.style.display = '');
              }
            } else {
              document.querySelectorAll('.product-gallery__thumbnail').forEach(t => t.style.display = '');
            }

            const invInfo = variantInventoryMap[selectedVariant.id];
            const invStatusEl = document.querySelector('[data-inventory-status]');
            if (invStatusEl && invInfo) {
               let status = 'in-stock';
               let label = 'In stock';
               const threshold = 10;

               if (!invInfo.available) {
                 status = 'out';
                 label = 'Out of stock';
               } else if (!invInfo.management) {
                 status = 'in-stock';
                 label = 'In stock';
               } else {
                 if (invInfo.qty > 0) {
                   if (invInfo.qty <= threshold) {
                     status = 'low';
                     label = 'Only ' + invInfo.qty + ' left in stock';
                   } else {
                     status = 'in-stock';
                     label = invInfo.qty + ' in stock';
                   }
                 } else {
                   status = 'backorder';
                   label = 'Available to order';
                 }
               }

               invStatusEl.className = 'product-inventory product-inventory--' + status;
               const textEl = invStatusEl.querySelector('.product-inventory__text');
               if (textEl) textEl.textContent = label;
            }
          }
        });
      }
    });
  </script>
{% endunless %}
