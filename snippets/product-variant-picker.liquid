{% comment %}
  Renders the product variant picker as labelled card tiles (FINISH / SIZE).

  Colour/finish and surface options render thumbnail images from the first
  relevant metaobject entry; size options render text.
  Each tile is a <label> wrapping a native radio, so selecting one checks the
  matching radio and fires a `change` event — the existing variant logic
  (price + inventory + gallery below, and the Section Rendering API in
  product-info.js) keeps working unchanged.

  @param {product} product
  @param {variant} current_variant
  @param {string} section_id
{% endcomment %}

{% unless product.has_only_default_variant %}
  {% assign finish_color_entry = metaobjects.variant_finish_color.values | first %}
  {% assign wood_surface_entry = metaobjects.variant_wood_surface.values | first %}
  {% assign branches_decoration_entry = metaobjects.variant_branches_decoration.values | first %}
  {% assign customization_url = pages.customization.url | default: '/pages/customization' %}

  {% style %}
    .product-variant-picker {
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--sp-5);
      font-family: var(--font-body);
    }

    .variant-group {
      padding: var(--sp-3) var(--sp-4);
      background: var(--color-milk);
      border: 1px solid var(--border-default);
      border-radius: calc(var(--radius-lg) * 2);
    }

    .variant-group__head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--sp-2);
      margin-bottom: var(--sp-2);
    }
    .variant-group__label {
      font-size: var(--font-size-body-sm);
      font-weight: var(--font-weight-bold);
      letter-spacing: var(--letter-spacing-wide);
      text-transform: uppercase;
      color: var(--text-primary);
    }
    .variant-group__guide {
      display: flex;
      align-items: center;
      gap: var(--sp-2);
      font-size: var(--font-size-body-sm);
      color: var(--color-sage);
      background: none;
      border: 0;
      padding: 0;
      cursor: pointer;
    }
    .variant-group__guide svg {
      display: flex;
    }
    .variant-group__guide:hover {
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .variant-group__list {
      display: flex;
      flex-wrap: wrap;
      gap: var(--sp-4);
      padding-block: var(--sp-1);
      user-select: none;
      -webkit-user-select: none;
    }
    .variant-group__list.is-active-drag,
    .variant-group__list.is-active-drag .variant-tile {
      cursor: grabbing;
    }

    .variant-tile {
      position: relative;
      display: flex;
      flex-direction: column;
      flex: 0 0 auto;
      min-width: 0;
      margin: 0;
      border: 1px solid var(--border-default);
      border-radius: var(--radius-lg);
      background-color: var(--color-white-cream);
      cursor: pointer;
      transition: border-color var(--timing-short) var(--ease-standard),
        box-shadow var(--timing-short) var(--ease-standard);
    }
    .variant-tile:hover {
      border-color: var(--border-dark);
    }

    .variant-tile__input {
      position: absolute;
      width: 1px;
      height: 1px;
      opacity: 0;
      pointer-events: none;
    }

    .variant-tile:has(.variant-tile__input:checked) {
      border-color: var(--color-earth-brown);
      box-shadow: inset 0 0 0 var(--border-width) var(--color-earth-brown);
    }

    .variant-tile.is-disabled {
      opacity: 0.5;
      cursor: not-allowed;
    }
    .variant-tile.is-disabled .variant-tile__label {
      text-decoration: line-through;
    }

    /* ---- Colour / finish tile ---- */
    .variant-tile--color {
      padding: var(--sp-2);
      align-items: center;
    }
    .variant-tile__media {
      display: block;
      overflow: hidden;
      border-radius: var(--radius-md);
      aspect-ratio: 4 / 3;
      height: 60px;
      background: var(--bg-secondary);
    }
    /* Hidden when a variant image is missing or fails to load (see initVariantMediaFallback). */
    .variant-tile__media[hidden] {
      display: none;
    }
    .variant-tile__media img,
    .variant-tile__swatch {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      /* Stop native image drag so press-and-hold only scrolls the list */
      pointer-events: none;
      -webkit-user-drag: none;
      user-select: none;
      -webkit-user-select: none;
    }
    .variant-tile--color .variant-tile__label {
      display: flex;
      align-items: center;
      margin-top: var(--sp-3);
      text-align: center;
      font-family: var(--font-roboto);
      font-size: var(--font-size-body-md);
      color: var(--text-primary);
      white-space: pre-wrap;
      max-width: 250px;
    }

    /* ---- "Custom" call-to-action tile on size / surface (links to the
       customization page instead of selecting a variant) ---- */
    .variant-tile--custom-link {
      gap: var(--sp-2);
      text-decoration: none;
      color: inherit;
      margin-right: var(--sp-1);
    }
    .variant-tile__media--custom {
      display: grid;
      place-items: center;
      border: var(--border-width) dashed var(--color-clay);
      background: var(--color-milk);
    }
    .variant-tile__custom-plus {
      color: var(--color-clay);
      font-size: var(--font-size-body-2xl);
      font-weight: var(--font-weight-light);
      line-height: var(--line-height-tight);
    }

    .variant-tile--size .variant-tile__media--custom {
      min-height: auto;
      width: fit-content;
      padding-inline: 6px;
      aspect-ratio: unset;
      height: fit-content;
    }

    /* ---- Custom color upload tile ---- */
    /* Keep [hidden] authoritative over the display rules below (icon/preview/file). */
    .variant-tile--upload [hidden] {
      display: none;
    }
    .variant-tile--upload .variant-tile__media {
      display: grid;
      place-items: center;
      border: var(--border-width) dashed var(--color-clay);
      background: var(--color-milk);
    }
    .variant-tile__upload-icon {
      display: flex;
      color: var(--color-clay);
    }
    .variant-tile__upload-icon svg {
      width: var(--sp-5);
      height: var(--sp-5);
    }
    .variant-tile__upload-spinner {
      width: var(--sp-5);
      height: var(--sp-5);
      border: calc(var(--border-width) * 2) solid var(--border-default);
      border-top-color: var(--color-earth-brown);
      border-radius: var(--radius-full);
      animation: variant-upload-spin 0.7s linear infinite;
    }
    @keyframes variant-upload-spin {
      to {
        transform: rotate(360deg);
      }
    }
    .variant-tile--upload.is-loading {
      cursor: progress;
    }
    /* Once an image is uploaded the dashed dropzone becomes a solid thumbnail.
       Selection styling (border + check) comes from the shared :has(:checked) rule. */
    .variant-tile--upload.is-uploaded .variant-tile__media {
      border-style: solid;
      border-color: var(--border-default);
    }
    @media (prefers-reduced-motion: reduce) {
      .variant-tile__upload-spinner {
        animation: none;
      }
    }

    /* ---- Size tile ---- */
    .variant-tile--size {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      min-height: 42px;
      width: max-content;
      padding: var(--sp-3) var(--sp-5);
      text-align: center;
      gap: var(--sp-2);
    }
    .variant-tile--size .variant-tile__label {
      font-family: var(--font-roboto);
      font-size: var(--font-size-body-sm);
      color: var(--text-primary);
      white-space: nowrap;
    }

    /* ---- Selected checkmark badge ---- */
    .variant-tile__check {
      position: absolute;
      top: var(--sp-2);
      right: var(--sp-2);
      display: flex;
      align-items: center;
      justify-content: center;
      width: var(--sp-4);
      height: var(--sp-4);
      border-radius: var(--radius-full);
      background: var(--color-earth-brown);
      color: var(--color-cream);
      opacity: 0;
      transform: scale(0.6);
      transition: opacity var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
    }
    .variant-tile--color .variant-tile__check {
      top: var(--sp-2);
      right: var(--sp-2);
    }
    /* Smaller, corner-tucked check on size tiles so it never overlaps the
       vertically-centred dimension text. */
    .variant-tile--size .variant-tile__check {
      top: var(--sp-1);
      right: var(--sp-1);
      width: var(--sp-4);
      height: var(--sp-4);
    }
    .variant-tile__check svg {
      width: 12px;
      height: 12px;
    }
    .variant-tile--size .variant-tile__check svg {
      width: 12px;
      height: 12px;
    }
    .variant-tile:has(.variant-tile__input:checked) .variant-tile__check {
      opacity: 1;
      transform: scale(1);
    }

    @media screen and (max-width: 480px) {
      .variant-group__list {
        flex-wrap: nowrap;
        overflow-x: auto;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .variant-tile,
      .variant-tile__check {
        transition: none;
      }
    }
  {% endstyle %}

  <div class="product-variant-picker">
    {% for option in product.options_with_values %}
      {% assign downcased_option = option.name | downcase %}
      {% assign is_color = false %}
      {% assign is_surface = false %}
      {% assign is_size = false %}
      {% if downcased_option contains 'surface' %}
        {% assign is_surface = true %}
      {% endif %}
      {% if downcased_option contains 'size' %}
        {% assign is_size = true %}
      {% endif %}
      {% if downcased_option contains 'color'
        or downcased_option contains 'màu'
        or downcased_option contains 'canvas'
        or downcased_option contains 'finish'
      %}
        {% assign is_color = true %}
      {% endif %}
      {% comment %}
        Branches Decoration renders as media tiles (identical to Wood Finish / color),
        but its thumbnails come from the `variant_branches_decoration` metaobject.
        Marking it as `is_color` reuses all the color tile visuals; `is_branches`
        only redirects which metaobject entry and field-key prefix are used below.
      {% endcomment %}
      {% assign is_branches = false %}
      {% if downcased_option contains 'branch' %}
        {% assign is_branches = true %}
        {% assign is_color = true %}
      {% endif %}
      {% comment %}
        Custom-colour image upload applies to both Wood Finish and Colour options
        — for the customer they are the same "pick your own shade" concept. Surface
        and Branches keep their own "Custom" behaviour (a customization-page link),
        so they are excluded here.
      {% endcomment %}
      {% assign is_custom_upload = false %}
      {% if is_color %}
        {% unless is_surface %}
          {% unless is_branches %}
            {% assign is_custom_upload = true %}
          {% endunless %}
        {% endunless %}
      {% endif %}
      {% assign option_prop = 'option' | append: option.position %}

      <div
        class="variant-group variant-group--{% if is_color %}color{% else %}size{% endif %}"
        data-variant-field
      >
        <div class="variant-group__head">
          <span class="variant-group__label">{{ option.name }}</span>
          {% if downcased_option == 'size' or downcased_option == 'kích thước' %}
            {% if product.metafields.custom.size_guide != blank %}
              <button
                type="button"
                class="variant-group__guide"
                aria-haspopup="dialog"
                onclick="window.openSizeGuidePopup && window.openSizeGuidePopup()"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="1.5em" height="1.5em" viewBox="0 0 24 24">
                  <path d="M0 0h24v24H0z" fill="none" />
                  <path fill="currentColor" d="M22 7H2c-.55 0-1 .45-1 1v8c0 .55.45 1 1 1h20c.55 0 1-.45 1-1V8c0-.55-.45-1-1-1m-1 8H3V9h2v3h2V9h2v4h2V9h2v3h2V9h2v4h2V9h2z" />
                </svg>
                <span>Size Guide</span>
              </button>
            {% endif %}
          {% endif %}
        </div>

        <div class="variant-group__list custom-scrollbar" role="radiogroup" aria-label="{{ option.name | escape }}">
          {% for value in option.values %}
            {% assign value_downcased = value | downcase | strip %}

            {% if value_downcased == 'custom' %}
              {% comment %}
                The "Custom" option value is never shown as a normal tile.
                On the wood finish it becomes the custom-colour upload tile (which
                still holds the real `Custom` radio so it selects the Custom variant
                and behaves as a single, mutually-exclusive choice). On the other
                options it stays hidden but present, keeping the variant matrix intact.
              {% endcomment %}
              {% if is_custom_upload %}
                <div
                  class="variant-tile variant-tile--color variant-tile--upload{% unless value.available %} is-disabled{% endunless %}"
                  data-custom-color
                >
                  <input
                    type="radio"
                    class="variant-tile__input"
                    id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                    name="options[{{ option.name | escape }}]"
                    value="{{ value | escape }}"
                    aria-label="Custom {{ option.name | escape }}"
                    data-index="option{{ option.position }}"
                    data-custom-color-radio
                    {% if option.selected_value == value %}
                      checked="checked"
                    {% endif %}
                    {% unless value.available %}
                      disabled
                    {% endunless %}
                  >

                  <span class="variant-tile__media">
                    <span class="variant-tile__upload-icon" data-custom-color-icon aria-hidden="true">
                      <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 48 48">
                        <path d="M0 0h48v48H0z" fill="none" />
                        <path fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 24L24 6l19 18H31v18H17V24z" />
                      </svg>
                    </span>
                    <span
                      class="variant-tile__upload-spinner"
                      data-custom-color-spinner
                      aria-hidden="true"
                      hidden
                    ></span>
                    <img
                      class="variant-tile__upload-preview"
                      data-custom-color-preview
                      alt="Custom color preview"
                      width="160"
                      height="100"
                      draggable="false"
                      hidden
                    >
                  </span>

                  <span class="variant-tile__label" data-custom-color-label>Custom color</span>

                  <span class="variant-tile__check" aria-hidden="true">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="20 6 9 17 4 12"></polyline>
                    </svg>
                  </span>

                  <input
                    type="file"
                    class="variant-tile__file"
                    accept="image/jpeg,image/png,image/webp,image/gif"
                    aria-label="Upload a custom finish reference image"
                    data-custom-color-input
                    hidden
                  >
                  <input
                    type="hidden"
                    name="properties[added_url_image]"
                    form="{{ 'ProductForm-' | append: section_id }}"
                    data-custom-color-property
                    disabled
                  >
                </div>
              {% elsif is_size %}
                {% comment %}
                  Size "Custom": opens a request popup where the shopper describes
                  the size they want and leaves a contact. Submitting sends a Custom
                  Size Request to the server (a lead for the production team) — it
                  does not select a variant or add to cart, so no radio / line-item
                  property is rendered here.
                {% endcomment %}
                <div
                  class="variant-tile variant-tile--size variant-tile--custom-size"
                  data-custom-size
                  role="button"
                  tabindex="0"
                  aria-haspopup="dialog"
                >
                  <span class="variant-tile__media variant-tile__media--custom" aria-hidden="true">
                    <svg
                      class="variant-tile__custom-plus"
                      xmlns="http://www.w3.org/2000/svg"
                      width="1em"
                      height="1em"
                      viewBox="0 0 24 24"
                    >
                      <path d="M0 0h24v24H0z" fill="none" />
                      <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6z" />
                    </svg>
                  </span>

                  <span class="variant-tile__label">{{ value }}</span>
                </div>

              {% else %}
                {% comment %}
                  On surface (and any other non-finish, non-size option) the
                  "Custom" value is a call-to-action that sends the shopper to the
                  customization page rather than selecting a variant.
                {% endcomment %}
                <a
                  class="variant-tile variant-tile--{% if is_color %}color{% else %}size{% endif %} variant-tile--custom-link"
                  href="{{ customization_url }}"
                >
                  {% if is_color or is_size %}
                    <span class="variant-tile__media variant-tile__media--custom" aria-hidden="true">
                      <svg
                        class="variant-tile__custom-plus"
                        xmlns="http://www.w3.org/2000/svg"
                        width="1em"
                        height="1em"
                        viewBox="0 0 24 24"
                      >
                        <path d="M0 0h24v24H0z" fill="none" />
                        <path fill="currentColor" d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6z" />
                      </svg>
                    </span>
                  {% endif %}
                  <span class="variant-tile__label">{{ value }}</span>
                </a>
              {% endif %}

            {% else %}
              {% assign color_image = '' %}
              {% if is_color %}
                {% capture value_str %}{{ value }}{% endcapture %}
                {% assign finish_key = value_str | handleize | replace: '-', '_' %}
                {% assign thumbnail_entry = finish_color_entry %}
                {% if is_surface %}
                  {% assign thumbnail_entry = wood_surface_entry %}
                {% endif %}
                {% if is_branches %}
                  {% assign thumbnail_entry = branches_decoration_entry %}
                {% endif %}
                {% if thumbnail_entry != blank %}
                  {% assign finish_field = thumbnail_entry[finish_key] %}
                  {% if finish_field != blank %}
                    {% assign color_image = finish_field.value | default: finish_field %}
                  {% endif %}
                {% endif %}
                {% if color_image == blank %}
                  {% assign matched_variant = product.variants | where: option_prop, value_str | first %}
                  {% assign color_image = matched_variant.metafields.custom.color_pattern %}
                {% endif %}
              {% endif %}

              <label
                class="variant-tile variant-tile--{% if is_color %}color{% else %}size{% endif %}{% unless value.available %} is-disabled{% endunless %}"
              >
                <input
                  type="radio"
                  class="variant-tile__input"
                  id="Option-{{ section_id }}-{{ option.position }}-{{ forloop.index0 }}"
                  name="options[{{ option.name | escape }}]"
                  value="{{ value | escape }}"
                  data-index="option{{ option.position }}"
                  {% if option.selected_value == value %}
                    checked="checked"
                  {% endif %}
                  {% unless value.available %}
                    disabled
                  {% endunless %}
                >

                {% if is_color and color_image != blank %}
                  <span class="variant-tile__media">
                    <img
                      src="{{ color_image }}"
                      alt="{{ value | escape }}"
                      width="160"
                      height="100"
                      loading="lazy"
                      draggable="false"
                      data-variant-media-img
                    >
                  </span>
                {% endif %}

                <span class="variant-tile__label">{{ value }}</span>

                <span class="variant-tile__check" aria-hidden="true">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polyline points="20 6 9 17 4 12"></polyline>
                  </svg>
                </span>
              </label>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endfor %}
  </div>

  {% comment %}
    Trimmed variant data for the picker JS. Only the fields the script reads are
    emitted (id, availability, the three option values, and the per-variant
    `variant_images` metafield) instead of the full `product.variants | json`
    dump — a large HTML-weight saving on products with many variants. All picker
    JS logic now lives in the single compiled script block at the end of this
    file (deferred + compiled, no longer parser-blocking).
  {% endcomment %}
  <script type="application/json" data-variant-picker-data>
    {
      "variants": [
        {%- for v in product.variants -%}
          {%- unless forloop.first %},{% endunless -%}
          {"id":{{ v.id | json }},"available":{{ v.available | json }},"option1":{{ v.option1 | json }},"option2":{{ v.option2 | json }},"option3":{{ v.option3 | json }}}
        {%- endfor -%}
      ],
      "variantImages": {
        {%- for v in product.variants -%}
          {%- unless forloop.first %},{% endunless -%}
          "{{ v.id }}":{{ v.metafields.custom.variant_images.value | default: v.metafields.custom.variant_images | json }}
        {%- endfor -%}
      }
    }
  </script>

  {% comment %} Guidance popup shown before the real file picker (wired in the custom-colour upload script). {% endcomment %}
  <div class="custom-color-guide" data-custom-color-guide>
    <div class="custom-color-guide__backdrop" data-custom-color-guide-close></div>
    <div class="custom-color-guide__dialog" role="dialog" aria-modal="true" aria-labelledby="CustomColorGuideTitle">
      <button type="button" class="custom-color-guide__close" data-custom-color-guide-close aria-label="Close">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <span class="custom-color-guide__icon" aria-hidden="true">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="3" y="3" width="18" height="18" rx="2"></rect>
          <circle cx="8.5" cy="8.5" r="1.5"></circle>
          <path d="m21 15-5-5L5 21"></path>
        </svg>
      </span>
      <h2 class="custom-color-guide__title" id="CustomColorGuideTitle">Upload Your Custom Color</h2>
      <p class="custom-color-guide__text">
        Choose Custom Color to have your piece hand-finished in your preferred shade. In the next step, upload one
        clear, well-lit, unfiltered reference photo—such as a paint chip, fabric swatch, or wood sample—for the closest
        possible color match.
      </p>
      <button type="button" class="custom-color-guide__continue" data-custom-color-guide-continue>Continue</button>
    </div>
  </div>

  <style>
    .custom-color-guide {
      position: fixed;
      inset: 0;
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: var(--sp-5);
      opacity: 0;
      visibility: hidden;
      transition: opacity var(--timing-short) var(--ease-standard), visibility var(--timing-short) var(--ease-standard);
    }
    .custom-color-guide.is-open {
      opacity: 1;
      visibility: visible;
    }
    .custom-color-guide__backdrop {
      position: absolute;
      inset: 0;
      background: rgba(23, 21, 21, 0.45);
      backdrop-filter: blur(4px);
      cursor: pointer;
    }
    .custom-color-guide__dialog {
      position: relative;
      z-index: 1;
      width: min(100%, 440px);
      max-height: calc(100dvh - var(--sp-8));
      overflow-y: auto;
      padding: var(--sp-7) var(--sp-6) var(--sp-6);
      border: var(--border-width) solid var(--border-light);
      border-radius: var(--radius-lg);
      background: var(--color-milk);
      box-shadow: var(--shadow-modal);
      text-align: center;
      transform: translateY(-8px);
      transition: transform var(--timing-short) var(--ease-standard);
    }
    .custom-color-guide.is-open .custom-color-guide__dialog {
      transform: translateY(0);
    }
    .custom-color-guide__close {
      position: absolute;
      top: var(--sp-2);
      right: var(--sp-2);
      display: flex;
      align-items: center;
      justify-content: center;
