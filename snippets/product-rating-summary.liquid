{% comment %}
  Renders a placeholder for product reviews/rating.
  @param {product} product - The product object
{% endcomment %}

{% style %}
  .product-rating-summary {
    gap: 8px;
    font-size: 14px;
    color: #444;
    margin-bottom: 16px;
    padding: 0 14px;
  }
  .product-rating-summary__stars {
    color: #e51a3d; /* Red star color from design */
    font-size: 22px;
  }
  .product-rating-summary__score {
    font-weight: 700;
    font-size: 16px;
    margin: 0 4px;
  }
  .product-rating-summary__text {
    font-size: 16px;
  }
  .product-rating-summary__link {
    color: #666;
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 16px;
    margin-left: 4px;
  }
{% endstyle %}

<div class="product-rating-summary">
  {% comment %} Placeholder hardcoded based on image reference for demo {% endcomment %}
  <span class="product-rating-summary__stars">★★★★★</span>
  <span class="product-rating-summary__score">4.9</span>
  <span class="product-rating-summary__text">out of 5 stars with</span>
  <a href="#reviews" class="product-rating-summary__link">390+ reviews</a>
</div>
