{% doc %}
  Renders a small line icon used by hero feature chips and the trust bar.

  @param {string} icon - One of: wood, ruler, consult, truck, sourcing, artisan, made, warranty, support

  @example
  {% render 'hero-feature-icon', icon: 'wood' %}
{% enddoc %}

{%- case icon -%}
  {%- when 'wood' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9" stroke-dasharray="4 2"/>
      <circle cx="12" cy="12" r="5.5"/>
      <circle cx="12" cy="12" r="2"/>
    </svg>
  {%- when 'ruler' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="8" width="18" height="8" rx="1"/>
      <path d="M7 8v3M11 8v4M15 8v3M19 8v4"/>
    </svg>
  {%- when 'consult' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <path d="M21 11.5a8.38 8.38 0 0 1-8.5 8.5 8.5 8.5 0 0 1-3.8-.9L3 21l1.9-5.7A8.5 8.5 0 0 1 12.5 3 8.38 8.38 0 0 1 21 11.5z"/>
    </svg>
  {%- when 'truck' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <path d="M1 4h13v12H1zM14 8h4l3 3v5h-7"/>
      <circle cx="6" cy="18.5" r="1.6"/>
      <circle cx="17.5" cy="18.5" r="1.6"/>
    </svg>
  {%- when 'sourcing' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 21c5-2 8-6 8-11V5l-8-2-8 2v5c0 5 3 9 8 11z"/>
      <path d="M9 12l2 2 4-4"/>
    </svg>
  {%- when 'artisan' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <path d="M18 11V6a2 2 0 0 0-4 0M14 10V4a2 2 0 0 0-4 0v2M10 10.5V6a2 2 0 0 0-4 0v8"/>
      <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>
    </svg>
  {%- when 'made' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2v4M12 18v4M4.9 4.9l2.8 2.8M16.3 16.3l2.8 2.8M2 12h4M18 12h4M4.9 19.1l2.8-2.8M16.3 7.7l2.8-2.8"/>
      <circle cx="12" cy="12" r="3.5"/>
    </svg>
  {%- when 'warranty' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22c5-2 8-6 8-11V5l-8-2-8 2v6c0 5 3 9 8 11z"/>
    </svg>
  {%- when 'support' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4 13v-1a8 8 0 0 1 16 0v1"/>
      <path d="M4 13a2 2 0 0 1 2 2v2a2 2 0 0 1-4 0v-2a2 2 0 0 1 2-2zM20 13a2 2 0 0 1 2 2v2a2 2 0 0 1-4 0v-2a2 2 0 0 1 2-2z"/>
      <path d="M20 17v1a3 3 0 0 1-3 3h-3"/>
    </svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="9"/>
    </svg>
{%- endcase -%}
