{% doc %}
  Renders the first-paint loading state for the Wishlist by Square proxy page.

  @example
  {% render 'wishlist-page-initial' %}
{% enddoc %}

<script>
  if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
  window.scrollTo(0, 0);
</script>

<section
  class="wrydeco-wishlist__initial"
  data-wrydeco-wishlist-initial
  aria-label="Loading wishlist"
  style="align-items: center; display: flex; flex-direction: column; gap: var(--space-11, 24px); min-height: 28rem; padding: calc(var(--space-17-bigger, 124px) + var(--space-15, 64px)) var(--space-13, 32px) var(--space-13, 32px);"
>
  <div
    class="wrydeco-wishlist__initial-spinner"
    aria-hidden="true"
    style="animation: wrydeco-wishlist-spin var(--timing-extra-long, 600ms) linear infinite; border: 2px solid color-mix(in srgb, currentColor 16%, transparent); border-top-color: currentColor; border-radius: var(--radius-full, 9999px); color: var(--color-earth-brown); height: var(--space-14, 48px); width: var(--space-14, 48px);"
  ></div>
  <p class="wrydeco-wishlist__initial-text">Preparing your wishlist</p>

  <aside
    class="wrydeco-wishlist__assurance"
    data-wrydeco-wishlist-initial-assurance
    aria-label="Wishlist service assurances"
    style="align-items: stretch; border: 1px solid color-mix(in srgb, currentColor 14%, transparent); border-radius: var(--radius-lg, 8px); color: var(--color-earth-brown); display: grid; gap: 0; margin: var(--space-8, 16px) auto 0; max-width: 72rem; overflow: hidden; width: 100%;"
  >
    <div class="wrydeco-wishlist__assurance-item">
      <span class="wrydeco-wishlist__assurance-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
          <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
            <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2m10 0H9m10 0h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/>
            <circle cx="17" cy="18" r="2"/>
            <circle cx="7" cy="18" r="2"/>
          </g>
        </svg>
      </span>
      <p><strong>White-Glove Delivery</strong><span>Carefully delivered and placed in your home.</span></p>
    </div>
    <div class="wrydeco-wishlist__assurance-item">
      <span class="wrydeco-wishlist__assurance-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
          <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
            <path d="m9 12l2 2l4-4"/>
          </g>
        </svg>
      </span>
      <p><strong>Handcrafted to Last</strong><span>Timeless pieces built with integrity and intention.</span></p>
    </div>
    <div class="wrydeco-wishlist__assurance-item">
      <span class="wrydeco-wishlist__assurance-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
          <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8c0 5.5-4.78 10-10 10"/>
            <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
          </g>
        </svg>
      </span>
      <p><strong>Sustainably Minded</strong><span>Responsibly sourced wood. Consciously made.</span></p>
    </div>
    <div class="wrydeco-wishlist__assurance-item">
      <span class="wrydeco-wishlist__assurance-icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
          <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 14h3a2 2 0 0 1 2 2v3a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-7a9 9 0 0 1 18 0v7a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3"/>
        </svg>
      </span>
      <p><strong>Need Help Deciding?</strong><span>Book a complimentary consultation with our design experts.</span></p>
    </div>
  </aside>
</section>
