{% doc %}
  Renders the "Free Shipping" pill badge shown on product cards (truck icon +
  label). Mirrors the badge on the collection product card
  (see sections/collection.liquid).

  Absolutely positioned at the bottom-right of the nearest positioned ancestor,
  so place it inside a `position: relative` card info block.

  @example
  {% render 'free-shipping-badge' %}
{% enddoc %}

<span class="card-freeship">
  <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 24 24">
    <path d="M0 0h24v24H0z" fill="none" />
    <path fill="currentColor" d="M18 8h-2V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v10h2a3 3 0 1 0 6 0h4a3 3 0 1 0 6 0h2v-5zM7 18.5a1.5 1.5 0 1 1 .001-3.001A1.5 1.5 0 0 1 7 18.5M4 14V7h10v7zm13 4.5a1.5 1.5 0 1 1 .001-3.001A1.5 1.5 0 0 1 17 18.5" />
  </svg>
  <span class="card-freeship__text">Free Shipping</span>
</span>

{% stylesheet %}
  .card-freeship {
    position: absolute;
    bottom: var(--sp-2);
    right: var(--sp-1);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 2px var(--sp-3);
    border-radius: var(--radius-full);
    background-color: #f8e9cb;
  }
  .card-freeship__text {
    font-size: var(--font-size-body-sm);
  }
{% endstylesheet %}
