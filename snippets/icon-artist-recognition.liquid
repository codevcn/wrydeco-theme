{% doc %}
  Renders a thin-stroke artist recognition icon by key.

  @param {string} icon - One of: 'award', 'leaf', 'hand', 'check'. Falls back to 'award'.

  @example
  {% render 'icon-artist-recognition', icon: 'leaf' %}
{% enddoc %}

{%- liquid
  assign key = icon | default: 'award'
-%}

{%- case key -%}
  {%- when 'leaf' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
  {%- when 'hand' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19 8.7 22.3a1 1 0 0 1-1.4 0l-2.6-2.6a1 1 0 0 1 0-1.4L8 15"/><path d="M14.5 12.5 18 9"/><path d="m15 5 4 4"/><path d="m18.5 2.5 3 3-3.5 3.5-3-3Z"/></svg>
  {%- when 'check' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="m8.5 12 2.5 2.5 4.5-5"/></svg>
  {%- else -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="6"/><path d="M9 13.5 7.5 22l4.5-2.5L16.5 22 15 13.5"/></svg>
{%- endcase -%}
