{% doc %}
  Renders a thin-stroke icon for an FAQ category tab.

  @param {string} icon - One of: shipping, custom-orders, materials-care, returns, payments, production-timeline, consultation

  @example
  {% render 'faq-category-icon', icon: 'shipping' %}
{% enddoc %}

{%- case icon -%}
  {%- when 'shipping' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h11v10H3z"/><path d="M14 9h4l3 3v4h-7z"/><circle cx="7" cy="18" r="2"/><circle cx="18" cy="18" r="2"/></svg>
  {%- when 'custom-orders' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m4 20 7-7"/><path d="m13 11 7-7"/><path d="m14 3 7 7"/><path d="m3 14 7 7"/><path d="m6 11-3-3 5-5 3 3"/><path d="m13 18 3 3 5-5-3-3"/></svg>
  {%- when 'materials-care' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="3"/><path d="M12 3v18M3 12h18" opacity=".35"/></svg>
  {%- when 'returns' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 7H3v-5"/><path d="M3 7a9 9 0 1 1 2.6 10.4"/></svg>
  {%- when 'payments' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="5" width="20" height="14" rx="1"/><path d="M2 9h20M6 15h4"/></svg>
  {%- when 'production-timeline' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2M12 3V1M3 12H1M12 23v-2M23 12h-2"/></svg>
  {%- when 'consultation' -%}
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="7" r="4"/><path d="M4 21v-2a8 8 0 0 1 16 0v2z"/></svg>
{%- endcase -%}
