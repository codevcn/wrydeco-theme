{% doc %}
  Renders the mount target for the Wishlist by Square header icon.

  @example
  {% render 'wishlist-heart' %}
{% enddoc %}

<div
  id="vitals-wishlist-header"
  class="header__icon header__icon--wishlist"
  aria-label="Wishlist"
></div>

{% stylesheet %}
  .header__icon--wishlist {
    color: var(--color-cream);
  }

  .header__icon--wishlist .Vtl-WishlistHeaderWrapper,
  .header__icon--wishlist .Vtl-WishlistHeader {
    align-items: center;
    display: flex;
    height: 100%;
    justify-content: center;
    width: 100%;
  }

  .header__icon--wishlist .Vtl-WishlistHeader {
    color: currentColor;
    text-decoration: none;
  }

  .header__icon--wishlist svg {
    display: block;
  }

  body:has(.not-found-page) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
  body:has(.article-editorial) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-earth-brown) !important;
  }
  body:has(.blog-editorial) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
  body:has(.col-banner) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
  body:has(.collection-page) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
  body:has(.collections-page) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
  body:has(.col-banner) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
  body:has(.hero-new) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
  body:has(.not-found-page) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
  body:has(.main-product) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-earth-brown) !important;
  }
  body:has(.showroom-intro) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
  body:has(.author-profile-container) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-earth-brown) !important;
  }
  body:has(.srp) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }
{% endstylesheet %}
