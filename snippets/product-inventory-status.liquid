{% doc %}
  Renders an inventory status line for the selected variant.

  Server-rendered for the initial variant; the [data-inventory-status]
  wrapper is swapped client-side on variant change via the Section
  Rendering API (see product-info.js).

  @param {variant} current_variant - The currently selected variant

  @example
  {% render 'product-inventory-status', current_variant: current_variant %}
{% enddoc %}

{% liquid
  assign low_stock_threshold = 10
  assign variant = current_variant
  assign status = 'in-stock'
  assign label = 'In stock'

  if variant == blank or variant.available == false
    assign status = 'out'
    assign label = 'Out of stock'
  elsif variant.inventory_management == blank
    assign status = 'in-stock'
    assign label = 'In stock'
  else
    assign qty = variant.inventory_quantity
    if qty > 0
      if qty <= low_stock_threshold
        assign status = 'low'
        assign label = 'Only ' | append: qty | append: ' left in stock'
      else
        assign status = 'in-stock'
        assign label = qty | append: ' in stock'
      endif
    else
      assign status = 'backorder'
      assign label = 'Available to order'
    endif
  endif
%}

<div
  class="product-inventory product-inventory--{{ status }}"
  data-inventory-status
  role="status"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="16"
    height="16"
    fill="currentColor"
    class="bi bi-box-seam"
    viewBox="0 0 16 16"
    stroke-width="3"
  >
    <path d="M8.186 1.113a.5.5 0 0 0-.372 0L1.846 3.5l2.404.961L10.404 2zm3.564 1.426L5.596 5 8 5.961 14.154 3.5zm3.25 1.7-6.5 2.6v7.922l6.5-2.6V4.24zM7.5 14.762V6.838L1 4.239v7.923zM7.443.184a1.5 1.5 0 0 1 1.114 0l7.129 2.852A.5.5 0 0 1 16 3.5v8.662a1 1 0 0 1-.629.928l-7.185 2.874a.5.5 0 0 1-.372 0L.63 13.09a1 1 0 0 1-.63-.928V3.5a.5.5 0 0 1 .314-.464z"/>
  </svg>
  <span class="product-inventory__text">{{ label }}</span>
</div>

{% stylesheet %}
  .product-inventory {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 4px 12px;
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-normal);
    margin-right: 14px;
    background-color: var(--color-earth-brown);
    border-radius: 12px;
  }
  .product-inventory__text {
    font-weight: var(--font-weight-medium);
    color: #fff;
    font-size: 0.9rem;
  }
  .product-inventory svg {
    color: #fff;
  }

  .product-inventory--low .product-inventory__text {
    font-weight: var(--font-weight-medium);
    color: var(--text-primary);
  }

  .product-inventory--out .product-inventory__text {
    color: var(--color-error);
  }
{% endstylesheet %}
