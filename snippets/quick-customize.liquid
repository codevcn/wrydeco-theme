{% doc %}
  Renders a single, page-wide "quick customize" dialog: a variant picker with
  gallery, live price and add-to-cart. It is data-source agnostic — product data
  is fetched lazily from `/products/{handle}.js` the moment a trigger is clicked,
  so nothing is embedded in the page HTML.

  Render this once per page (any section/template that shows customizable product
  cards can render it). Rendering it more than once is safe — duplicate dialogs
  are de-duplicated at runtime.

  To open the dialog from a card, give the trigger element:
    - the `data-quick-customize` attribute, and
    - a product handle via its own `data-product-handle` OR any ancestor that
      carries `data-product-handle`.

  @param {string} [eyebrow] - Small label above the title. Default "Quick customize".
  @param {string} [add_label] - Add-to-cart button label. Default "Add to cart".
  @param {string} [details_label] - "View details" link label. Default "View details".
  @param {string} [toast_position] - Toast position for feedback. Default "bottom-left".

  @example
  {% render 'quick-customize' %}
  {% render 'quick-customize',
    eyebrow: section.settings.quick_eyebrow,
    add_label: section.settings.quick_add_label,
    details_label: section.settings.details_label
  %}
{% enddoc %}

<div
  class="sp-quick"
  data-quick-modal
  hidden
  aria-hidden="true"
  data-money-format="{{ shop.money_format | escape }}"
  data-toast-position="{{ toast_position | default: 'bottom-left' }}"
>
  <div class="sp-quick__overlay" data-quick-close></div>
  <div class="sp-quick__panel" role="dialog" aria-modal="true" aria-labelledby="QuickCustomizeTitle">
    <button type="button" class="sp-quick__close" aria-label="Close" data-quick-close>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path d="M6 6l12 12M18 6 6 18"></path>
      </svg>
    </button>

    <div class="sp-quick__loading" data-quick-loading hidden>
      <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" aria-hidden="true"><g stroke="currentColor"><circle cx="12" cy="12" r="9.5" fill="none" stroke-linecap="round" stroke-width="3"><animate attributeName="stroke-dasharray" calcMode="spline" dur="1.5s" keySplines="0.42,0,0.58,1;0.42,0,0.58,1;0.42,0,0.58,1" keyTimes="0;0.475;0.95;1" repeatCount="indefinite" values="0 150;42 150;42 150;42 150"/><animate attributeName="stroke-dashoffset" calcMode="spline" dur="1.5s" keySplines="0.42,0,0.58,1;0.42,0,0.58,1;0.42,0,0.58,1" keyTimes="0;0.475;0.95;1" repeatCount="indefinite" values="0;-16;-59;-59"/></circle><animateTransform attributeName="transform" dur="2s" repeatCount="indefinite" type="rotate" values="0 12 12;360 12 12"/></g></svg>
    </div>

    <div class="sp-quick__media" data-quick-media hidden>
      <div class="sp-quick__media-main">
        <img data-quick-image src="" alt="" width="800" height="800" loading="lazy">
      </div>
      <div class="sp-quick__thumbs" data-quick-thumbs hidden></div>
    </div>

    <div class="sp-quick__body custom-scrollbar" data-quick-body hidden>
      <p class="sp-quick__eyebrow">{{ eyebrow | default: 'Quick customize' | escape }}</p>
      <h3 class="sp-quick__title" id="QuickCustomizeTitle" data-quick-title></h3>

      <div class="sp-quick__options" data-quick-options></div>

      <div class="sp-quick__price">
        <span class="sp-quick__price-current" data-quick-price></span>
        <span class="sp-quick__price-compare" data-quick-compare hidden></span>
      </div>

      <div class="sp-quick__add-base">
        <button type="button" class="sp-quick__add" data-quick-add>
          <span class="sp-quick__add-icon" aria-hidden="true">
            <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 16 16"><path fill="currentColor" d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607l1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4a2 2 0 0 0 0-4h7a2 2 0 1 0 0 4a2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zM6 14a1 1 0 1 1-2 0a1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0a1 1 0 0 1 2 0M9 5.5V7h1.5a.5.5 0 0 1 0 1H9v1.5a.5.5 0 0 1-1 0V8H6.5a.5.5 0 0 1 0-1H8V5.5a.5.5 0 0 1 1 0"/></svg>
          </span>
          <span data-quick-add-text>{{ add_label | default: 'Add to cart' | escape }}</span>
        </button>
      </div>

      <a class="sp-quick__details" data-quick-details href="#">{{ details_label | default: 'View details' | escape }}</a>
    </div>
  </div>
</div>

{%- comment -%}
  Custom color upload: guidance popup shown before the device file picker, plus a
  hidden file input. Mirrors the PDP custom-colour flow (guide → pick → upload).
{%- endcomment -%}
<div class="sp-quick-guide" data-sp-color-guide hidden>
  <div class="sp-quick-guide__backdrop" data-sp-color-guide-close></div>
  <div class="sp-quick-guide__dialog" role="dialog" aria-modal="true" aria-labelledby="SpColorGuideTitle">
    <button type="button" class="sp-quick-guide__close" data-sp-color-guide-close aria-label="Close">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
      </svg>
    </button>
    <span class="sp-quick-guide__icon" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="3" width="18" height="18" rx="2"></rect>
        <circle cx="8.5" cy="8.5" r="1.5"></circle>
        <path d="m21 15-5-5L5 21"></path>
      </svg>
    </span>
    <h2 class="sp-quick-guide__title" id="SpColorGuideTitle">Upload Your Custom Color</h2>
    <p class="sp-quick-guide__text">
      Choose Custom Color to have your piece hand-finished in your preferred shade. In the next step, upload one
      clear, well-lit, unfiltered reference photo—such as a paint chip, fabric swatch, or wood sample—for the closest
      possible color match.
    </p>
    <button type="button" class="sp-quick-guide__continue" data-sp-color-guide-continue>Continue</button>
  </div>
</div>

<input
  type="file"
  class="sp-quick-file"
  accept="image/jpeg,image/png,image/webp,image/gif"
  aria-label="Upload a custom color reference image"
  data-sp-color-file
  hidden
>

{%- comment -%} Custom Size request form popup (note + contact → POST to the server). {%- endcomment -%}
<div class="sp-quick-size" data-sp-size-popup hidden>
  <div class="sp-quick-size__overlay" data-sp-size-close></div>
  <div class="sp-quick-size__dialog" role="dialog" aria-modal="true" aria-labelledby="SpSizeTitle">
    <div class="sp-quick-size__header">
      <h2 class="sp-quick-size__title" id="SpSizeTitle">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M0 0h24v24H0z" fill="none" />
          <path fill="currentColor" d="M22 7H2c-.55 0-1 .45-1 1v8c0 .55.45 1 1 1h20c.55 0 1-.45 1-1V8c0-.55-.45-1-1-1m-1 8H3V9h2v3h2V9h2v4h2V9h2v3h2V9h2v4h2V9h2z" />
        </svg>
        <span>Custom Size</span>
      </h2>
      <button type="button" class="sp-quick-size__close" data-sp-size-close aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="sp-quick-size__body">
      <p class="sp-quick-size__hint">
        Tell us the dimensions and proportions you have in mind, and how to reach you. Our design team will follow up to craft your piece.
      </p>
      <div class="sp-quick-size__field">
        <label class="sp-quick-size__label" for="SpSizeNote">Describe your desired size</label>
        <textarea
          id="SpSizeNote"
          class="sp-quick-size__textarea"
          data-sp-size-note
          rows="4"
          placeholder="e.g. 180 cm wide × 90 cm deep × 75 cm high, with a slightly thicker tabletop."
        ></textarea>
        <p class="sp-quick-size__error" data-sp-size-error="note" hidden></p>
      </div>
      <div class="sp-quick-size__field">
        <label class="sp-quick-size__label" for="SpSizeContact">Email or phone number</label>
        <input
          id="SpSizeContact"
          class="sp-quick-size__input"
          data-sp-size-contact
          type="text"
          autocomplete="email"
          placeholder="you@example.com or +1 555 000 1234"
        >
        <p class="sp-quick-size__error" data-sp-size-error="contact" hidden></p>
      </div>
    </div>
    <div class="sp-quick-size__footer">
      <button type="button" class="sp-quick-size__cancel" data-sp-size-close>Cancel</button>
      <button type="button" class="sp-quick-size__submit" data-sp-size-submit>
        <span data-sp-size-submit-label>Submit request</span>
      </button>
    </div>
  </div>
</div>

{% stylesheet %}
  html.sp-quick-open {
    overflow: hidden;
  }

  /* Hide the live-chat launcher while the popup is open so it doesn't overlap the
     dialog. The chat widget renders at a near-max z-index, so hiding it is more
     reliable than out-stacking it. */
  .sp-quick-open #shopify-chat,
  .sp-quick-open .shopify-chat,
  .sp-quick-open #chat-widget-container,
  .sp-quick-open iframe[title*='chat' i],
  .sp-quick-open iframe[id*='chat' i] {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }

  .sp-quick {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 1000);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-5);
  }

  .sp-quick[hidden] {
    display: none;
  }

  .sp-quick__overlay {
    position: absolute;
    inset: 0;
    background: var(--bg-overlay, rgba(30, 20, 12, 0.55));
    opacity: 0;
    transition: opacity var(--timing-base) var(--ease-standard);
  }

  .sp-quick.is-open .sp-quick__overlay {
    opacity: 1;
  }

  .sp-quick__panel {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    grid-template-rows: minmax(0, 1fr);
    max-width: 80vw;
    max-height: calc(100dvh - var(--sp-8));
    overflow: hidden;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--surface-elevated, #fffcf8);
    box-shadow: var(--shadow-modal, 0 30px 80px rgba(30, 20, 12, 0.28));
    opacity: 0;
    transform: translateY(var(--sp-3));
    transition: opacity var(--timing-base) var(--ease-standard), transform var(--timing-base) var(--ease-out);
  }

  .sp-quick.is-open .sp-quick__panel {
    opacity: 1;
    transform: none;
  }

  /* While product data is loading the media/body are hidden; keep a sensible box. */
  .sp-quick__panel.is-loading {
    display: block;
    min-width: min(360px, 90vw);
    min-height: 220px;
  }

  .sp-quick__loading {
    position: absolute;
    inset: 0;
    align-items: center;
    justify-content: center;
    color: var(--color-earth-brown, #4a2c18);
  }

  .sp-quick__loading[hidden] {
    display: none;
  }

  .sp-quick__panel.is-loading .sp-quick__loading {
    display: flex;
  }

  .sp-quick__loading svg {
    width: var(--sp-8);
    height: var(--sp-8);
  }

  .sp-quick__close {
    position: absolute;
    top: var(--sp-3);
    right: var(--sp-3);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-7);
    height: var(--sp-7);
    padding: 0;
    border: none;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--surface-elevated) 88%, transparent);
    color: var(--color-bark, #4a2c18);
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard);
  }

  .sp-quick__close:hover {
    background: var(--color-cream, #f0e9e1);
  }

  .sp-quick__close svg {
    width: var(--sp-5);
    height: var(--sp-5);
  }

  .sp-quick__media {
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
    background: var(--color-stone, #e5dbd0);
  }

  .sp-quick__media[hidden] {
    display: none;
  }

  .sp-quick__media-main {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
  }

  .sp-quick__media-main img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sp-quick__thumbs {
    display: flex;
    flex: 0 0 auto;
    gap: var(--sp-2);
    padding: var(--sp-2);
    background: var(--surface-elevated, #fffcf8);
    border-top: 1px solid var(--border-light);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .sp-quick__thumbs::-webkit-scrollbar {
    display: none;
  }

  .sp-quick__thumbs[hidden] {
    display: none;
  }

  .sp-quick__thumb {
    flex: 0 0 auto;
    width: var(--sp-8);
    height: var(--sp-8);
    padding: 0;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-stone, #e5dbd0);
    cursor: pointer;
    opacity: 0.7;
    transition: opacity var(--timing-short) var(--ease-standard), border-color var(--timing-short) var(--ease-standard);
  }

  .sp-quick__thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sp-quick__thumb:hover {
    opacity: 1;
  }

  .sp-quick__thumb[aria-current='true'] {
    opacity: 1;
    border-color: var(--color-earth-brown, #4a2c18);
  }

  .sp-quick__body {
    display: flex;
    flex-direction: column;
    padding: var(--sp-6);
    overflow-y: auto;
    min-height: 0;
    height: 100%;
  }

  .sp-quick__body[hidden] {
    display: none;
  }

  .sp-quick__eyebrow {
    margin: 0 0 var(--sp-2);
    color: var(--color-earth-brown, #4a2c18);
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.05rem;
    text-transform: uppercase;
  }

  .sp-quick__title {
    margin: 0 0 var(--sp-4);
    color: var(--color-text, #2e1d14);
    font-family: var(--font-heading);
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: var(--font-weight-semibold);
    line-height: 1.12;
  }

  .sp-quick__options {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    margin-bottom: var(--sp-5);
  }

  .sp-quick__option {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .sp-quick__option-label {
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .sp-quick__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .sp-quick__pill {
    min-height: var(--sp-7);
    padding: var(--sp-2) var(--sp-4);
    border: 1px solid var(--border-dark, rgba(74, 44, 24, 0.4));
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    cursor: pointer;
    transition: var(--transition-fast);
  }

  .sp-quick__pill:hover {
    border-color: var(--color-earth-brown, #4a2c18);
  }

  .sp-quick__pill[aria-pressed='true'] {
    border-color: var(--color-earth-brown, #4a2c18);
    background: var(--color-earth-brown, #4a2c18);
    color: var(--text-inverse, #fff8f0);
  }

  .sp-quick__price {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    margin-top: auto;
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border-light);
  }

  .sp-quick__price-current {
    color: var(--color-text, #2e1d14);
    font-family: var(--font-body);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-bold);
    font-variant-numeric: tabular-nums;
  }

  .sp-quick__price-compare {
    color: var(--text-secondary);
    font-size: var(--font-size-body-md);
    text-decoration: line-through;
    font-variant-numeric: tabular-nums;
  }

  .sp-quick__price-compare[hidden] {
    display: none;
  }

  /* Add-to-cart matches the PDP button exactly: a "3D pushable" button whose
     base (the wrapper) shows a soft shadow under the button's feet, and the
     button lifts on hover / presses down on active. Values mirror the PDP source
     (snippets/product-buy-buttons.liquid) so the two stay visually identical. */
  .sp-quick__add-base {
    width: 100%;
    margin-top: var(--sp-4);
    padding-bottom: 6px;
    border-radius: 8px;
    background-image: linear-gradient(
      to top,
      rgba(128, 128, 128, 0.9) 0%,
      rgba(0, 0, 0, 0.5) 28%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  .sp-quick__add {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    height: 48px;
    border: none;
    border-radius: 4px;
    background-color: #ff8233;
    color: #ffffff;
    font-family: var(--font-body, inherit);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    cursor: pointer;
    transition: transform 0.2s ease;
    box-sizing: content-box;
  }
  .sp-quick__add [data-quick-add-text] {
    font-size: 1rem;
    text-transform: uppercase;
  }

  .sp-quick__add-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .sp-quick__add-icon svg {
    width: 24px;
    height: 24px;
  }

  .sp-quick__add-base:hover .sp-quick__add {
    transform: translateY(-3px);
  }

  .sp-quick__add-base:active .sp-quick__add {
    transform: translateY(3px);
  }

  .sp-quick__add:disabled,
  .sp-quick__add.is-loading {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .sp-quick__details {
    margin-top: var(--sp-3);
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
    text-align: center;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sp-quick__details:hover {
    color: var(--color-earth-brown, #4a2c18);
  }

  .sp-quick :focus-visible {
    outline: 2px solid var(--color-sage, #7a8968);
    outline-offset: 2px;
  }

  @media screen and (max-width: 40rem) {
    .sp-quick {
      align-items: flex-end;
      padding: 0;
    }

    .sp-quick__panel {
      grid-template-columns: 1fr;
      grid-template-rows: auto;
      width: 100%;
      max-height: 92dvh;
      overflow-y: auto;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      transform: translateY(100%);
      max-width: 95vw;
    }

    .sp-quick.is-open .sp-quick__panel {
      transform: none;
    }

    .sp-quick__media {
      min-height: 0;
    }

    .sp-quick__media-main {
      flex: 0 0 auto;
      height: 42vh;
    }

    .sp-quick__body {
      min-height: 0;
      height: auto;
      overflow: visible;
      padding: var(--sp-5);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .sp-quick__overlay,
    .sp-quick__panel {
      transition-duration: 0s;
    }
  }

  /* ---- Custom color upload guide (stacks above the quick dialog) ---- */
  .sp-quick-guide {
    position: fixed;
    inset: 0;
    z-index: calc(var(--z-modal, 1000) + 10);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-5);
  }
  .sp-quick-guide[hidden] {
    display: none;
  }
  .sp-quick-guide__backdrop {
    position: absolute;
    inset: 0;
    background: var(--bg-overlay);
    backdrop-filter: blur(4px);
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--timing-base) var(--ease-standard);
  }
  .sp-quick-guide.is-open .sp-quick-guide__backdrop {
    opacity: 1;
  }
  .sp-quick-guide__dialog {
    position: relative;
    z-index: 1;
    width: min(100%, 440px);
    max-height: calc(100dvh - var(--sp-8));
    overflow-y: auto;
    padding: var(--sp-7) var(--sp-6) var(--sp-6);
    border: var(--border-width) solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--color-milk);
    box-shadow: var(--shadow-modal);
    text-align: center;
    opacity: 0;
    transform: translateY(var(--sp-3)) scale(0.98);
    transition: opacity var(--timing-base) var(--ease-standard), transform var(--timing-base) var(--ease-out);
  }
  .sp-quick-guide.is-open .sp-quick-guide__dialog {
    opacity: 1;
    transform: none;
  }
  .sp-quick-guide__close {
    position: absolute;
    top: var(--sp-2);
    right: var(--sp-2);
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-7);
    height: var(--sp-7);
    padding: 0;
    border: 0;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-secondary);
