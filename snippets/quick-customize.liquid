  .sp-quick-size__dialog {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    width: min(100%, 460px);
    max-height: calc(100dvh - var(--sp-8));
    overflow: hidden;
    border: var(--border-width) solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--surface-elevated);
    box-shadow: var(--shadow-modal);
    opacity: 0;
    transform: translateY(var(--sp-3)) scale(0.98);
    transition: opacity var(--timing-base) var(--ease-standard), transform var(--timing-base) var(--ease-out);
  }
  .sp-quick-size.is-open .sp-quick-size__dialog {
    opacity: 1;
    transform: none;
  }
  .sp-quick-size__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-4) var(--sp-5);
    border-bottom: var(--border-width) solid var(--border-light);
    background: var(--color-milk);
  }
  .sp-quick-size__title {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-regular);
    color: var(--text-primary);
  }
  .sp-quick-size__title svg {
    width: var(--sp-5);
    height: var(--sp-5);
    color: var(--color-earth-brown);
  }
  .sp-quick-size__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-6);
    height: var(--sp-6);
    padding: 0;
    border: 0;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard);
  }
  .sp-quick-size__close:hover {
