    height: 18px;
  }
  .sp-quick-size__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    padding: var(--sp-5);
    overflow-y: auto;
  }
  .sp-quick-size__hint {
    margin: 0;
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }
  .sp-quick-size__field {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .sp-quick-size__label {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--text-primary);
  }
  .sp-quick-size__textarea,
  .sp-quick-size__input {
    width: 100%;
    padding: var(--sp-3) var(--sp-4);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    background: var(--color-white-cream);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-relaxed);
    transition: border-color var(--timing-short) var(--ease-standard);
  }
  .sp-quick-size__textarea {
    min-height: 120px;
    resize: vertical;
  }
  .sp-quick-size__textarea:focus,
  .sp-quick-size__input:focus {
    outline: none;
    border-color: var(--color-earth-brown);
  }
  .sp-quick-size__textarea[aria-invalid='true'],
  .sp-quick-size__input[aria-invalid='true'] {
