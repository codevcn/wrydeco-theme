  }
  .sp-quick-size__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-4) var(--sp-5);
    border-top: var(--border-width) solid var(--border-light);
    background: var(--color-milk);
  }
  .sp-quick-size__cancel {
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: underline;
    text-underline-offset: 4px;
    cursor: pointer;
  }
  .sp-quick-size__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--sp-7);
    padding-inline: var(--sp-6);
    border: 0;
    border-radius: var(--radius-md);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard);
  }
  .sp-quick-size__submit:hover:not(:disabled) {
    background: var(--color-charcoal);
  }
  .sp-quick-size__submit:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .sp-quick-guide :focus-visible,
  .sp-quick-size :focus-visible {
    outline: 2px solid var(--color-sage);
    outline-offset: 2px;
  }
  @media screen and (max-width: 40rem) {
    .sp-quick-size__dialog {
      width: 100%;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .sp-quick-guide__backdrop,
    .sp-quick-guide__dialog,
    .sp-quick-size__overlay,
    .sp-quick-size__dialog {
      transition-duration: 0s;
    }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var cartRoot = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
    var cache = {}; // handle -> product JSON from /products/{handle}.js
    var requestId = 0; // guards against out-of-order fetches
    var bound = false; // whether global (document) listeners are attached

    var modal = null; // the single active dialog element
    var els = null; // cached child references of `modal`
    var state = null; // { product, selected: [], variant, optionNames: [] }
    var addLabel = 'Add to cart';
    var moneyFormat = '${{amount}}';
    var toastPosition = 'bottom-left';
    var lastFocused = null; // element to restore focus to on close

    // Custom "Custom" handling (mirrors the PDP variant picker).
    var UPLOAD_ENDPOINT = 'https://vnote.io.vn/api/upload-image';
    var REQUEST_ENDPOINT = 'https://vnote.io.vn/api/custom-size-requests';
    var MAX_UPLOAD_BYTES = 10 * 1024 * 1024;

    // Sub-dialogs rendered once alongside the main dialog; cached in wireModal().
    var guide = null; // custom-colour upload guidance popup
    var fileInput = null; // hidden device file input
    var sizePopup = null; // custom size request form
    var pendingGuideContinue = null; // runs when the guide's "Continue" is pressed
    var pendingColorCommit = null; // commits the "Custom" colour/finish selection once its reference image uploads

    // Sub-dialog open/close animation: mirror the main dialog's `is-open` pattern
    // (unhide → next frame add `is-open`; remove `is-open` → hide after the fade).
    var SUBDIALOG_HIDE_MS = 240;

    function showSubDialog(el, timerRef) {
      if (!el) return;
      if (timerRef.id) {
        clearTimeout(timerRef.id);
        timerRef.id = null;
      }
      el.hidden = false;
      window.requestAnimationFrame(function () {
        el.classList.add('is-open');
      });
    }

    function hideSubDialog(el, timerRef) {
      if (!el) return;
      el.classList.remove('is-open');
      if (timerRef.id) clearTimeout(timerRef.id);
      timerRef.id = window.setTimeout(function () {
        el.hidden = true;
        timerRef.id = null;
      }, SUBDIALOG_HIDE_MS);
    }

    // Small holders so the timer id is shared by reference across show/hide.
    var guideTimer = { id: null };
    var sizeTimer = { id: null };
    var customImage = { url: '', optionIndex: -1 }; // uploaded URL + which option it belongs to

    function toast(message, type) {
      if (window.showToast) window.showToast({ message: message, type: type, position: toastPosition });
    }

    // --- Money formatting (mirrors Shopify's `money` filter, fed by shop.money_format) ---
    function formatWithDelimiters(cents, precision, thousands, decimal) {
      precision = precision == null ? 2 : precision;
      thousands = thousands == null ? ',' : thousands;
      decimal = decimal == null ? '.' : decimal;
      if (isNaN(cents) || cents == null) return '0';
      var number = (cents / 100.0).toFixed(precision);
      var parts = number.split('.');
      var dollars = parts[0].replace(/(\d)(?=(\d\d\d)+(?!\d))/g, '$1' + thousands);
      var rest = parts[1] ? decimal + parts[1] : '';
      return dollars + rest;
    }

    function money(cents) {
      var format = moneyFormat || '${{amount}}';
      var match = format.match(/\{\{\s*(\w+)\s*\}\}/);
      var placeholder = match ? match[1] : 'amount';
      var value;
      switch (placeholder) {
        case 'amount_no_decimals':
          value = formatWithDelimiters(cents, 0);
          break;
        case 'amount_with_comma_separator':
          value = formatWithDelimiters(cents, 2, '.', ',');
          break;
        case 'amount_no_decimals_with_comma_separator':
          value = formatWithDelimiters(cents, 0, '.', ',');
          break;
        case 'amount_with_space_separator':
          value = formatWithDelimiters(cents, 2, ' ', ',');
          break;
        case 'amount_no_decimals_with_space_separator':
          value = formatWithDelimiters(cents, 0, ' ', '');
          break;
        case 'amount_with_apostrophe_separator':
          value = formatWithDelimiters(cents, 2, "'", '.');
          break;
        default:
          value = formatWithDelimiters(cents, 2);
      }
      // Strip any HTML the money format may carry so it's safe as textContent.
      return format.replace(/\{\{\s*\w+\s*\}\}/, value).replace(/<[^>]*>/g, '');
    }

    // Ask the Shopify CDN for a right-sized image without breaking existing params.
    function sizeImg(url, w) {
      if (!url) return url;
      return url + (url.indexOf('?') > -1 ? '&' : '?') + 'width=' + w;
    }

    function optionNamesOf(product) {
      return (product.options || []).map(function (o) {
        return typeof o === 'string' ? o : o.name;
      });
    }

    function fetchProduct(handle) {
      if (cache[handle]) return Promise.resolve(cache[handle]);
      return fetch(cartRoot + 'products/' + handle + '.js', { headers: { Accept: 'application/json' } })
        .then(function (res) {
          if (!res.ok) throw new Error('Could not load product');
          return res.json();
        })
        .then(function (product) {
          cache[handle] = product;
          return product;
        });
    }

    function addVariantToCart(variantId, properties, onDone) {
      var payload = { id: variantId, quantity: 1 };
      if (properties && Object.keys(properties).length) payload.properties = properties;
      fetch(cartRoot + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/javascript' },
        body: JSON.stringify(payload),
      })
        .then(function (res) {
          return res.json();
        })
        .then(function (data) {
          if (data.status) throw new Error(data.description || 'Could not add to cart');
          toast('Item added to your cart.', 'success');
          document.dispatchEvent(new CustomEvent('cart:updated', { detail: { open: true } }));
          if (onDone) onDone(true);
        })
        .catch(function (err) {
          toast(err.message, 'error');
          if (onDone) onDone(false);
        });
    }

    // --- Variant resolution + live price ---
    function findVariant(product, selected) {
      for (var i = 0; i < product.variants.length; i++) {
        var v = product.variants[i];
        var match = true;
        for (var j = 0; j < v.options.length; j++) {
          if (v.options[j] !== selected[j]) {
            match = false;
            break;
          }
        }
        if (match) return v;
      }
      return null;
    }

    function updateSelection() {
      var variant = findVariant(state.product, state.selected);
      state.variant = variant;
      if (variant) {
        els.price.textContent = money(variant.price);
        if (variant.compare_at_price && variant.compare_at_price > variant.price) {
          els.compare.textContent = money(variant.compare_at_price);
          els.compare.hidden = false;
        } else {
          els.compare.hidden = true;
        }
        els.add.disabled = !variant.available;
        els.addText.textContent = variant.available ? addLabel : 'Sold out';
      } else {
        els.price.textContent = '';
        els.compare.hidden = true;
        els.add.disabled = true;
        els.addText.textContent = 'Unavailable';
      }
    }

    // --- Option classification (mirrors the PDP variant picker) ---
    function classifyOption(name) {
      var n = String(name || '').toLowerCase();
      var isSurface = n.indexOf('surface') > -1;
      var isSize = n.indexOf('size') > -1;
      var isColor = n.indexOf('color') > -1 || n.indexOf('finish') > -1;
      return { isColorOrFinish: isColor && !isSurface, isSize: isSize };
    }

    function isCustomValue(val) {
      return String(val == null ? '' : val).trim().toLowerCase() === 'custom';
    }

    // --- Custom colour upload: guide → device picker → upload ---
    function closeColorGuide() {
      hideSubDialog(guide, guideTimer);
      pendingGuideContinue = null;
      // Backing out of the guide abandons the pending "Custom" selection, so it
      // is never committed (no dangling selected pill without an image).
      pendingColorCommit = null;
    }

    function openColorGuide(optionIndex, onContinue, onCommit) {
      customImage.optionIndex = optionIndex;
      pendingColorCommit = onCommit || null;
      // No popup in the DOM → open the file dialog directly (keeps the gesture).
      if (!guide) {
        if (onContinue) onContinue();
        return;
      }
      pendingGuideContinue = onContinue;
      showSubDialog(guide, guideTimer);
      var btn = guide.querySelector('[data-sp-color-guide-continue]');
      if (btn) btn.focus();
    }

    function uploadColorFile(file) {
      if (file.size > MAX_UPLOAD_BYTES) {
        toast('Image exceeds 10MB limit.', 'error');
        return;
      }
      toast('Uploading…', 'info');

      var fd = new FormData();
      fd.append('image', file);

      // Do not set Content-Type: let the browser add the multipart boundary.
      fetch(UPLOAD_ENDPOINT, { method: 'POST', body: fd })
        .then(function (res) {
          return res
            .json()
            .catch(function () { return {}; })
            .then(function (data) { return { ok: res.ok, data: data }; });
        })
        .then(function (r) {
          if (r.ok && r.data && r.data.image_url) {
            customImage.url = r.data.image_url;
            // Only now that a reference image exists do we commit the "Custom"
            // selection (select the pill + update price/variant).
            if (pendingColorCommit) {
              pendingColorCommit();
              pendingColorCommit = null;
            }
            toast('Custom color uploaded.', 'success');
          } else {
            toast((r.data && r.data.detail) || 'Upload failed. Please try again.', 'error');
          }
        })
        .catch(function () {
          toast('Upload failed. Please try again.', 'error');
        })
        .finally(function () {
          if (fileInput) fileInput.value = ''; // allow re-picking the same file
        });
    }

    // --- Custom size request form ---
    function sizeEl(sel) {
      return sizePopup ? sizePopup.querySelector(sel) : null;
    }
    function fieldInput(field) {
      return sizeEl(field === 'note' ? '[data-sp-size-note]' : '[data-sp-size-contact]');
    }
    function setSizeError(field, message) {
      var input = fieldInput(field);
      var el = sizeEl('[data-sp-size-error="' + field + '"]');
      if (input) input.setAttribute('aria-invalid', 'true');
      if (el) { el.textContent = message; el.hidden = false; }
    }
    function clearSizeError(field) {
      var input = fieldInput(field);
      var el = sizeEl('[data-sp-size-error="' + field + '"]');
      if (input) input.removeAttribute('aria-invalid');
      if (el) { el.textContent = ''; el.hidden = true; }
    }
    function clearSizeErrors() {
      clearSizeError('note');
      clearSizeError('contact');
    }
    function openSizePopup() {
      if (!sizePopup) return;
      clearSizeErrors();
      showSubDialog(sizePopup, sizeTimer);
      var ta = sizeEl('[data-sp-size-note]');
      if (ta) ta.focus();
    }
    function closeSizePopup() {
      hideSubDialog(sizePopup, sizeTimer);
    }
    function isValidContact(value) {
      var EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (EMAIL_RE.test(value)) return true;
      var digits = value.replace(/\D/g, '');
      return digits.length >= 7 && digits.length <= 15 && /^[+()\d\s.-]+$/.test(value);
    }
    function submitSizeRequest() {
      if (!sizePopup || !state || !state.product) return;

      var ta = sizeEl('[data-sp-size-note]');
      var contactEl = sizeEl('[data-sp-size-contact]');
      var submitBtn = sizeEl('[data-sp-size-submit]');
      var submitLabel = sizeEl('[data-sp-size-submit-label]');
      var note = ta ? ta.value.trim() : '';
      var contactValue = contactEl ? contactEl.value.trim() : '';

      clearSizeErrors();
      var firstInvalid = null;
      if (!note) {
        setSizeError('note', 'Please describe the size you want.');
        firstInvalid = firstInvalid || ta;
      } else if (note.length < 5) {
        setSizeError('note', 'Please add a little more detail (at least 5 characters).');
        firstInvalid = firstInvalid || ta;
      }
      if (!contactValue) {
        setSizeError('contact', 'An email or phone number is required.');
        firstInvalid = firstInvalid || contactEl;
      } else if (!isValidContact(contactValue)) {
        setSizeError('contact', 'Enter a valid email or phone number.');
        firstInvalid = firstInvalid || contactEl;
      }
      if (firstInvalid) {
        if (firstInvalid.focus) firstInvalid.focus();
        return;
      }

      var fd = new FormData();
      fd.append('product_id', String(state.product.id || ''));
      fd.append('product_handle', state.product.handle || '');
      fd.append('product_name', state.product.title || '');
      fd.append('custom_size_description', note);
      fd.append('customer_contact', contactValue);

      if (submitBtn) submitBtn.disabled = true;
      if (submitLabel) submitLabel.textContent = 'Sending…';

      fetch(REQUEST_ENDPOINT, { method: 'POST', body: fd })
        .then(function (response) {
          if (response.ok) {
            toast("Thank you — we've received your request and will contact you shortly.", 'success');
            if (ta) ta.value = '';
            if (contactEl) contactEl.value = '';
            clearSizeErrors();
            closeSizePopup();
            return;
          }
          return response.json().catch(function () { return null; }).then(function (data) {
            var mapped = false;
            if (data && Array.isArray(data.errors)) {
              data.errors.forEach(function (err) {
                if (err.field === 'custom_size_description') { setSizeError('note', err.message); mapped = true; }
                else if (err.field === 'customer_contact') { setSizeError('contact', err.message); mapped = true; }
              });
            }
            if (!mapped) toast((data && data.message) || 'Something went wrong. Please try again.', 'error');
          });
        })
        .catch(function () {
          toast('Something went wrong. Please try again.', 'error');
        })
        .finally(function () {
          if (submitBtn) submitBtn.disabled = false;
          if (submitLabel) submitLabel.textContent = 'Submit request';
        });
    }

    function renderOptions() {
      els.options.innerHTML = '';
      var product = state.product;
      var names = state.optionNames;
      var isSingleDefault = product.variants.length === 1 && names.length === 1 && names[0] === 'Title';
      if (isSingleDefault) return;

      names.forEach(function (optName, oi) {
        var group = document.createElement('div');
        group.className = 'sp-quick__option';

        var label = document.createElement('span');
        label.className = 'sp-quick__option-label';
        label.textContent = optName;
        group.appendChild(label);

        var pills = document.createElement('div');
        pills.className = 'sp-quick__pills';

        var cls = classifyOption(optName);

        var values = [];
        product.variants.forEach(function (v) {
          if (values.indexOf(v.options[oi]) === -1) values.push(v.options[oi]);
        });

        values.forEach(function (val) {
          var pill = document.createElement('button');
          pill.type = 'button';
          pill.className = 'sp-quick__pill';
          pill.textContent = val;
          var custom = isCustomValue(val);
          if (state.selected[oi] === val) pill.setAttribute('aria-pressed', 'true');
          function commitSelection() {
            state.selected[oi] = val;
            Array.prototype.forEach.call(pills.children, function (c) {
              c.removeAttribute('aria-pressed');
            });
            pill.setAttribute('aria-pressed', 'true');
            updateSelection();
          }

          pill.addEventListener('click', function () {
            // Size "Custom": open the request form. It is a lead, not a purchase,
            // so it never becomes the selected variant.
            if (custom && cls.isSize) {
              openSizePopup();
              return;
            }

            // Colour / Wood Finish "Custom": don't select the pill yet. The
            // selection is committed only after a reference image is actually
            // uploaded (guide → device picker → upload). Backing out of the
            // guide therefore leaves the previous choice untouched.
            if (custom && cls.isColorOrFinish) {
              openColorGuide(oi, function () {
                if (fileInput) fileInput.click();
              }, commitSelection);
              return;
            }

            // Normal selection.
            commitSelection();
          });
          pills.appendChild(pill);
        });

        group.appendChild(pills);
        els.options.appendChild(group);
      });
    }

    // --- Focus trap helpers ---
    function getFocusable() {
      var panel = modal.querySelector('.sp-quick__panel');
      if (!panel) return [];
      var nodes = panel.querySelectorAll('a[href], button, input, select, textarea, [tabindex]:not([tabindex="-1"])');
      return Array.prototype.filter.call(nodes, function (el) {
        return !el.disabled && el.offsetParent !== null;
      });
    }

    function openModal(loading) {
      var panel = modal.querySelector('.sp-quick__panel');
      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('sp-quick-open');
      if (loading) {
        panel.classList.add('is-loading');
        els.loading.hidden = false;
        els.media.hidden = true;
        els.body.hidden = true;
      }
      window.requestAnimationFrame(function () {
        modal.classList.add('is-open');
      });
    }

    function closeModal() {
      closeColorGuide();
      closeSizePopup();
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('sp-quick-open');
      window.setTimeout(function () {
        modal.hidden = true;
      }, 240);
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    function populate(product) {
      var panel = modal.querySelector('.sp-quick__panel');
      panel.classList.remove('is-loading');
      els.loading.hidden = true;
      els.body.hidden = false;

      var names = optionNamesOf(product);
      var initial = null;
      for (var i = 0; i < product.variants.length; i++) {
        if (product.variants[i].available) {
          initial = product.variants[i];
          break;
        }
      }
      if (!initial) initial = product.variants[0];
      state = { product: product, selected: initial.options.slice(), variant: initial, optionNames: names };

      // Fresh product → drop any custom-colour image / open sub-dialogs from a
      // previous product.
      customImage = { url: '', optionIndex: -1 };
      closeColorGuide();
      closeSizePopup();

      els.title.textContent = product.title;

      // Gallery: one large image + a row of thumbnails.
      var raw = product.images && product.images.length ? product.images : product.featured_image ? [product.featured_image] : [];
      var gallery = raw.map(function (src) {
        return sizeImg(src, 800);
      });
      els.thumbs.innerHTML = '';
      if (gallery.length) {
        els.image.src = gallery[0];
        els.image.alt = product.title;
        els.media.hidden = false;
      } else {
        els.media.hidden = true;
      }

      if (gallery.length > 1) {
        gallery.forEach(function (src, idx) {
          var thumb = document.createElement('button');
          thumb.type = 'button';
          thumb.className = 'sp-quick__thumb';
          thumb.setAttribute('aria-label', 'View image ' + (idx + 1));
          if (idx === 0) thumb.setAttribute('aria-current', 'true');
          var timg = document.createElement('img');
          timg.src = src;
          timg.alt = '';
          timg.loading = 'lazy';
          thumb.appendChild(timg);
          thumb.addEventListener('click', function () {
            els.image.src = src;
            Array.prototype.forEach.call(els.thumbs.children, function (c) {
              c.removeAttribute('aria-current');
            });
            thumb.setAttribute('aria-current', 'true');
          });
          els.thumbs.appendChild(thumb);
        });
        els.thumbs.hidden = false;
      } else {
        els.thumbs.hidden = true;
      }

      els.details.setAttribute('href', product.url || '#');

      renderOptions();
      updateSelection();

      var firstPill = els.options.querySelector('.sp-quick__pill');
      (firstPill || els.add).focus();
    }

    function openFor(trigger) {
      var handle = trigger.getAttribute('data-product-handle');
      if (!handle) {
        var host = trigger.closest('[data-product-handle]');
        handle = host && host.getAttribute('data-product-handle');
      }
      if (!handle) return;

      lastFocused = trigger;
      var reqId = ++requestId;
      openModal(true);

      fetchProduct(handle)
        .then(function (product) {
          if (reqId !== requestId) return; // a newer open superseded this one
          if (!product.variants || !product.variants.length) {
            closeModal();
            return;
          }
          populate(product);
        })
        .catch(function (err) {
          if (reqId !== requestId) return;
          closeModal();
          toast((err && err.message) || 'Could not load product', 'error');
        });
    }

    // --- Global (document-level) listeners: one set, via event delegation ---
    function onDocClick(e) {
      if (!modal) return;
      var trigger = e.target.closest('[data-quick-customize]');
      if (!trigger) return;
      e.preventDefault();
      openFor(trigger);
    }

    function onKeydown(e) {
      if (!modal || modal.hidden) return;
      if (e.key === 'Escape') {
        // Close an open sub-dialog first; only then the main dialog.
        if (guide && !guide.hidden) { closeColorGuide(); return; }
        if (sizePopup && !sizePopup.hidden) { closeSizePopup(); return; }
        closeModal();
        return;
      }
      if (e.key !== 'Tab') return;
      // While a sub-dialog is open, let it own the tab order.
      if ((guide && !guide.hidden) || (sizePopup && !sizePopup.hidden)) return;

      var focusable = getFocusable();
      if (!focusable.length) {
        e.preventDefault();
        return;
      }
      var first = focusable[0];
      var last = focusable[focusable.length - 1];
      var panel = modal.querySelector('.sp-quick__panel');
      var active = document.activeElement;

      if (!panel || !panel.contains(active)) {
        e.preventDefault();
        first.focus();
      } else if (e.shiftKey && active === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && active === last) {
        e.preventDefault();
        first.focus();
      }
    }

    function onAdd() {
      if (!state || !state.variant || els.add.disabled || els.add.classList.contains('is-loading')) return;

      // PDP parity: attach the uploaded custom-colour image as a line-item property
      // while the option it belongs to is still set to "Custom".
      var properties = {};
      if (customImage.url && customImage.optionIndex > -1 && state.selected[customImage.optionIndex] === 'Custom') {
        properties['added_url_image'] = customImage.url;
      }

      els.add.classList.add('is-loading');
      els.addText.textContent = 'Adding…';
      addVariantToCart(state.variant.id, properties, function (ok) {
        els.add.classList.remove('is-loading');
        if (ok) closeModal();
        else updateSelection();
      });
    }

    // Cache the active dialog + its children. De-dupes if rendered more than once.
    function wireModal() {
      var modals = document.querySelectorAll('[data-quick-modal]');
      if (!modals.length) {
        modal = null;
        return;
      }
      // Keep the first, drop any duplicates so ids stay unique.
      for (var i = 1; i < modals.length; i++) {
        if (modals[i].parentNode) modals[i].parentNode.removeChild(modals[i]);
      }
      modal = modals[0];
      els = {
        title: modal.querySelector('[data-quick-title]'),
        media: modal.querySelector('[data-quick-media]'),
        image: modal.querySelector('[data-quick-image]'),
        thumbs: modal.querySelector('[data-quick-thumbs]'),
        options: modal.querySelector('[data-quick-options]'),
        price: modal.querySelector('[data-quick-price]'),
        compare: modal.querySelector('[data-quick-compare]'),
        add: modal.querySelector('[data-quick-add]'),
        addText: modal.querySelector('[data-quick-add-text]'),
        details: modal.querySelector('[data-quick-details]'),
        loading: modal.querySelector('[data-quick-loading]'),
        body: modal.querySelector('[data-quick-body]'),
      };
      moneyFormat = modal.getAttribute('data-money-format') || '${{amount}}';
      toastPosition = modal.getAttribute('data-toast-position') || 'bottom-left';

      if (modal.dataset.wired !== 'true') {
        modal.dataset.wired = 'true';
        addLabel = els.addText.textContent.trim();
        modal.querySelectorAll('[data-quick-close]').forEach(function (el) {
          el.addEventListener('click', closeModal);
        });
        els.add.addEventListener('click', onAdd);
      }

      // Cache the sub-dialogs (rendered once alongside the modal), de-duping any
      // extras if the snippet was rendered more than once.
      function firstDedup(sel) {
        var nodes = document.querySelectorAll(sel);
        for (var i = 1; i < nodes.length; i++) {
          if (nodes[i].parentNode) nodes[i].parentNode.removeChild(nodes[i]);
        }
        return nodes[0] || null;
      }
      guide = firstDedup('[data-sp-color-guide]');
      fileInput = firstDedup('[data-sp-color-file]');
      sizePopup = firstDedup('[data-sp-size-popup]');

      if (guide && guide.dataset.wired !== 'true') {
        guide.dataset.wired = 'true';
        guide.querySelectorAll('[data-sp-color-guide-close]').forEach(function (el) {
          el.addEventListener('click', closeColorGuide);
        });
        var cont = guide.querySelector('[data-sp-color-guide-continue]');
        if (cont) {
          cont.addEventListener('click', function () {
            // Capture before hiding; running it here keeps the user gesture so
            // the browser allows the file dialog to open. Only hide the guide —
            // keep `pendingColorCommit` alive so a successful upload can commit
            // the "Custom" selection (closeColorGuide would clear it).
            var next = pendingGuideContinue;
            hideSubDialog(guide, guideTimer);
            pendingGuideContinue = null;
            if (next) next();
          });
        }
      }

      if (fileInput && fileInput.dataset.wired !== 'true') {
        fileInput.dataset.wired = 'true';
        fileInput.addEventListener('change', function () {
          var f = fileInput.files && fileInput.files[0];
          if (f) uploadColorFile(f);
        });
      }

      if (sizePopup && sizePopup.dataset.wired !== 'true') {
        sizePopup.dataset.wired = 'true';
        sizePopup.querySelectorAll('[data-sp-size-close]').forEach(function (el) {
          el.addEventListener('click', closeSizePopup);
        });
        var sub = sizePopup.querySelector('[data-sp-size-submit]');
        if (sub) sub.addEventListener('click', submitSizeRequest);
        var noteEl = sizePopup.querySelector('[data-sp-size-note]');
        var contactEl = sizePopup.querySelector('[data-sp-size-contact]');
        if (noteEl) noteEl.addEventListener('input', function () { clearSizeError('note'); });
        if (contactEl) contactEl.addEventListener('input', function () { clearSizeError('contact'); });
      }
    }

    function init() {
      wireModal();
      if (!bound) {
        bound = true;
        document.addEventListener('click', onDocClick);
        document.addEventListener('keydown', onKeydown);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init);
    } else {
      init();
    }

    // Theme editor: a re-rendered section may ship a fresh dialog — re-cache it.
    document.addEventListener('shopify:section:load', wireModal);
  })();
{% endjavascript %}
