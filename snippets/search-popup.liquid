{% doc %}
  Renders the global product search dialog with recent searches and predictive results.
{% enddoc %}

<search-popup
  class="search-popup-wrapper"
  data-currency-code="{{ localization.country.currency.iso_code | default: cart.currency.iso_code | default: shop.currency | escape }}"
  data-locale="{{ request.locale.iso_code | default: 'en' | escape }}"
>
  <div class="search-popup__overlay">
    <div class="search-popup__content" role="dialog" aria-modal="true" aria-labelledby="SearchPopupTitle">
      <div class="search-popup__header">
        <h2 class="search-popup__heading" id="SearchPopupTitle">Search the Collection</h2>
        <p class="search-popup__subtitle">
          Discover handcrafted pieces crafted by nature, designed to last for generations.
        </p>
        <form
          action="{{ routes.search_url }}"
          method="get"
          role="search"
          class="search-popup__form"
          onsubmit="event.preventDefault();"
        >
          <input type="hidden" name="type" value="product">
          <div class="search-popup__input-group">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="search-popup__icon"
            >
              <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
            <input
              type="search"
              name="q"
              value=""
              placeholder="Search for products, collections, or inspiration..."
              class="search-popup__input"
              aria-label="Search"
              autocomplete="off"
            >
          </div>
        </form>
        <button class="search-popup__close" type="button" aria-label="Close search">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>

      <div class="search-popup__body">
        <div class="search-popup__initial" style="display: none;">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="48"
            height="48"
            fill="currentColor"
            class="bi bi-search search-popup__initial-icon"
            viewBox="0 0 16 16"
          >
            <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
          </svg>
          <p>Search product name...</p>
        </div>

        <div class="search-popup__recent" style="display: none;">
          <h3 class="search-popup__title">Recent Searches</h3>
          <div class="search-popup__recent-list"></div>
        </div>

        <div class="search-popup__top-results" style="display: none;">
          <div class="search-popup__results-header">
            <h3 class="search-popup__title">Top Results</h3>
            <div class="search-popup__view-all">
              <a href="{{ routes.search_url }}" class="search-popup__view-all-btn">
                <span>View all results</span><span aria-hidden="true">&rarr;</span>
              </a>
            </div>
          </div>
          <div class="search-popup__predictive-list search-popup__grid">
            {% for default_product in collections.all.products limit: 4 %}
              <a
                href="{{ default_product.url }}"
                class="search-product-card"
                data-title="{{ default_product.title | escape }}"
                data-url="{{ default_product.url }}"
                data-image="{{ default_product.featured_image | image_url: width: 480 }}"
              >
                <div class="search-product-card__image">
                  {{
                    default_product.featured_image
                    | image_url: width: 480
                    | image_tag:
                      loading: 'lazy',
                      widths: '240,360,480',
                      sizes: '(min-width: 769px) 190px, 44vw',
                      alt: default_product.title
                  }}
                </div>
                <div class="search-product-card__info">
                  <span class="search-product-card__type">
                    {{- default_product.type | default: 'Handcrafted furniture' | escape -}}
                  </span>
                  <span class="search-product-card__title">{{ default_product.title | escape }}</span>
                  <span class="search-product-card__price">{{ default_product.price | money_without_trailing_zeros }}</span>
                </div>
              </a>
            {% endfor %}
          </div>
        </div>

        <div class="search-popup__loading" style="display: none;">
          <div class="search-popup__spinner"></div>
        </div>

        <div class="search-popup__empty">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="search-popup__empty-icon"
          >
            <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <p>No products found.</p>
        </div>
      </div>

      <div class="search-popup__footer">
        <span class="search-popup__footer-note">Handcrafted. Timeless. Yours.</span>
        <span>Need help finding something? <a href="{{ routes.root_url }}pages/contact">Contact our team</a></span>
      </div>
    </div>
  </div>
</search-popup>

<script src="{{ 'search-popup.js' | file_url }}" defer></script>
<script>
  window.addEventListener('DOMContentLoaded', () => {
    customElements.whenDefined('search-popup').then(() => {
      const SearchPopup = customElements.get('search-popup');
      if (!SearchPopup || SearchPopup.prototype.localizedPricePatched) return;

      const getCurrencyMeta = (element) => {
        const root = element?.closest?.('search-popup') || document.querySelector('search-popup');
        return {
          code: root?.dataset.currencyCode || window.Shopify?.currency?.active || 'VND',
          locale: root?.dataset.locale || document.documentElement.lang || 'en',
        };
      };

      const formatPrice = (rawPrice, element) => {
        const value = String(rawPrice || '').trim();
        if (!value) return '';

        const { code, locale } = getCurrencyMeta(element);
        const isVnd = code.toUpperCase() === 'VND' || value.includes('₫');
        const digits = value.replace(/[^\d]/g, '');

        if (isVnd && digits) {
          return `${Number(digits).toLocaleString('vi-VN')}₫`;
        }

        const numericValue = Number(value.replace(/[^\d.]/g, ''));
        if (!Number.isFinite(numericValue)) return value;

        return new Intl.NumberFormat(locale, {
          style: 'currency',
          currency: code,
          maximumFractionDigits: code.toUpperCase() === 'VND' ? 0 : 2,
        }).format(numericValue);
      };

      const normalizeRenderedPrices = (root) => {
        root.querySelectorAll('.search-product-card__price').forEach((price) => {
          price.textContent = formatPrice(price.textContent, price);
        });
      };

      const originalCreateProductCardHtml = SearchPopup.prototype.createProductCardHtml;
      SearchPopup.prototype.createProductCardHtml = function (product, index = 0, query = '') {
        const html = originalCreateProductCardHtml.call(this, product, index, query);
        const formattedPrice = formatPrice(product?.price, this);
        if (!formattedPrice) return html;

        return html.replace(
          /<span class="search-product-card__price">[\s\S]*?<\/span>/,
          `<span class="search-product-card__price">${this.escapeHtml(formattedPrice)}</span>`
        );
      };

      SearchPopup.prototype.localizedPricePatched = true;
      document.querySelectorAll('search-popup').forEach(normalizeRenderedPrices);
    });
  });
</script>

{% stylesheet %}
  search-popup {
    display: block;
  }

  .search-popup__overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-6);
    background-color: var(--bg-overlay);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--timing-short) var(--ease-standard), visibility var(--timing-short) var(--ease-standard);
  }

  search-popup[open] .search-popup__overlay {
    opacity: 1;
    visibility: visible;
  }

  .search-popup__content {
    display: flex;
    flex-direction: column;
    width: min(100%, calc(var(--sp-8) * 14));
    height: min(calc(100dvh - var(--sp-8)), calc(var(--sp-8) * 14));
    max-height: calc(100dvh - var(--sp-8));
    overflow: hidden;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: radial-gradient(circle at top, var(--color-milk) 0%, var(--surface-elevated) 72%);
    box-shadow: var(--shadow-modal);
    contain: layout paint;
    will-change: transform, opacity;
    opacity: 0;
    transform: translateY(calc(var(--sp-2) * -1));
    transition: transform var(--timing-short) var(--ease-out), opacity var(--timing-short) var(--ease-standard);
  }

  search-popup[open] .search-popup__content {
    opacity: 1;
    transform: translateY(0);
  }

  .search-popup__header {
    position: relative;
    flex: 0 0 auto;
    padding: var(--sp-6) var(--sp-7) var(--sp-5);
    text-align: center;
  }

  .search-popup__heading {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }

  .search-popup__subtitle {
    margin: var(--sp-2) 0 var(--sp-5);
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
  }

  .search-popup__form {
    width: 100%;
  }

  .search-popup__input-group {
    position: relative;
    display: flex;
    align-items: center;
  }

  .search-popup__icon {
    position: absolute;
    left: var(--sp-3);
    width: var(--sp-5);
    height: var(--sp-5);
    color: var(--color-bark);
    pointer-events: none;
  }

  .search-popup__input {
    width: 100%;
    min-height: var(--sp-7);
    padding: var(--sp-3) var(--sp-5) var(--sp-3) calc(var(--sp-6) + var(--sp-3));
    border: 1px solid var(--border-dark);
    border-radius: var(--radius-md);
    background-color: var(--surface-elevated);
    outline: none;
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    color: var(--text-primary);
  }

  .search-popup__input:focus {
    border-color: var(--color-earth-brown);
    box-shadow: var(--shadow-focus);
  }

  .search-popup__input::placeholder {
    color: var(--text-tertiary);
  }

  .search-popup__input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .search-popup__close {
    position: absolute;
    top: var(--sp-5);
    right: var(--sp-5);
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-7);
    height: var(--sp-7);
    padding: 0;
    border: 0;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--color-bark);
    cursor: pointer;
  }

  .search-popup__close:hover {
    background-color: var(--surface-tertiary);
  }

  .search-popup__close svg {
    width: var(--sp-5);
    height: var(--sp-5);
  }

  .search-popup__body {
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    padding: 0 var(--sp-7) var(--sp-5);
    scrollbar-width: thin;
    scrollbar-color: var(--border-default) transparent;
  }

  .search-popup__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-earth-brown);
  }

  .search-popup__recent {
    margin-bottom: var(--sp-5);
  }

  .search-popup__recent-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    margin-top: var(--sp-3);
  }

  .search-popup__recent-chip {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--sp-7);
    padding: var(--sp-1) var(--sp-3) var(--sp-1) var(--sp-1);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    background-color: var(--surface-elevated);
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    color: var(--text-primary);
    cursor: pointer;
    max-width: calc(var(--sp-8) * 3);
  }

  .search-popup__recent-chip img {
    width: var(--sp-6);
    height: var(--sp-6);
    border-radius: var(--radius-full);
    object-fit: cover;
  }

  .search-popup__recent-chip i {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-5);
    height: var(--sp-5);
    font-style: normal;
    color: var(--text-secondary);
  }

  .search-popup__recent-chip span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .search-popup__top-results {
    padding-top: var(--sp-2);
    border-top: 1px solid var(--border-light);
  }

  .search-popup__results-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    margin-bottom: var(--sp-2);
  }

  .search-popup__view-all {
    display: block;
  }

  .search-popup__view-all-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    min-height: var(--sp-7);
    font-size: var(--font-size-caption);
    color: var(--text-secondary);
    text-decoration: none;
  }

  .search-popup__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--sp-4);
  }

  .search-product-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    background-color: var(--surface-elevated);
    color: var(--text-primary);
    text-decoration: none;
    transition: transform var(--timing-short) var(--ease-standard), box-shadow var(--timing-short) var(--ease-standard);
  }

  .search-product-card:hover {
    transform: translateY(calc(var(--sp-1) * -1));
    box-shadow: var(--shadow-card);
  }

  .search-product-card__image {
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: var(--surface-tertiary);
  }

  .search-product-card__image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .search-product-card__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    font-size: var(--font-size-caption);
    color: var(--text-tertiary);
  }

  .search-product-card__info {
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-2);
    padding: var(--sp-3);
  }

  .search-product-card__type {
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .search-product-card__title {
    display: -webkit-box;
    overflow: hidden;
    font-family: var(--font-display);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-normal);
    color: var(--text-primary);
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .search-product-card__price {
    margin-top: auto;
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .search-product-card__title mark {
    background-color: var(--color-stone);
    color: inherit;
  }

  .search-popup__loading,
  .search-popup__empty,
  .search-popup__initial {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    min-height: calc(var(--sp-8) * 3);
    color: var(--text-secondary);
    text-align: center;
  }

  .search-popup__empty {
    height: 100%;
    display: none; /* Default hidden */
  }

  .search-popup__spinner {
    width: var(--sp-5);
    height: var(--sp-5);
    border: 2px solid var(--border-default);
    border-top-color: var(--color-earth-brown);
    border-radius: var(--radius-full);
    animation: search-popup-spin var(--timing-extra-long) linear infinite;
  }

  @keyframes search-popup-spin {
    to {
      transform: rotate(360deg);
    }
  }

  .search-popup__empty-icon,
  .search-popup__initial-icon {
    margin-inline: auto;
    width: var(--sp-7);
    height: var(--sp-7);
    margin-bottom: var(--sp-4);
    color: var(--text-tertiary);
  }

  .search-popup__footer {
    display: flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    min-height: var(--sp-6);
    padding-inline: var(--sp-7);
    border-top: 1px solid var(--border-light);
    background-color: var(--surface-default);
    font-size: var(--font-size-caption);
    color: var(--text-secondary);
  }

  .search-popup__footer-note {
    color: var(--color-bark);
  }

  .search-popup__footer a {
    color: var(--text-primary);
  }

  @media (max-width: 768px) {
    .search-popup__close {
      top: var(--sp-2);
      right: var(--sp-2);
    }

    .search-popup__footer-note {
      display: none;
    }

    .search-popup__overlay {
      padding: var(--sp-4);
    }

    .search-popup__content {
      height: calc(100dvh - (var(--sp-4) * 2));
      max-height: calc(100dvh - (var(--sp-4) * 2));
    }

    .search-popup__header {
      padding: var(--sp-6) var(--sp-5) var(--sp-4);
    }

    .search-popup__heading {
      font-size: var(--font-size-display-sm);
    }

    .search-popup__subtitle {
      padding-inline: var(--sp-5);
    }

    .search-popup__body {
      padding-inline: var(--sp-5);
    }

    .search-popup__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .search-popup__footer {
      padding-inline: var(--sp-5);
    }
  }

  @media (max-width: 480px) {
    .search-popup__overlay {
      padding: var(--sp-2);
    }

    .search-popup__content {
      height: calc(100dvh - (var(--sp-2) * 2));
      max-height: calc(100dvh - (var(--sp-2) * 2));
    }

    .search-popup__header {
      padding: var(--sp-6) var(--sp-4) var(--sp-4);
    }

    .search-popup__subtitle {
      margin-bottom: var(--sp-4);
      padding-inline: var(--sp-4);
      font-size: var(--font-size-caption);
    }

    .search-popup__input {
      font-size: var(--font-size-body-sm);
    }

    .search-popup__body {
      padding-inline: var(--sp-4);
    }

    .search-popup__footer {
      align-items: flex-start;
      flex-direction: column;
      justify-content: center;
      padding-block: var(--sp-1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .search-popup__content,
    .search-product-card {
      transition: none;
      animation: none;
      opacity: 1;
      transform: none;
    }

    .search-popup__spinner {
      animation: none;
    }
  }
{% endstylesheet %}
