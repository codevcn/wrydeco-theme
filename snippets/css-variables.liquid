{% style %}
  @font-face {
    font-family: 'Plus Jakarta Sans';
    src: url('{{ "Plus-Jakarta-Sans.woff2" | file_url }}') format('woff2');
    font-weight: 400 800;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --font-primary--family: 'Plus Jakarta Sans', Fraunces, Arial, sans-serif;
    --font-primary--style: normal;
    --font-primary--weight: 400;
    --page-width: {{ settings.max_page_width }};
    --page-margin: {{ settings.min_page_margin }}px;
    --color-background: {{ settings.background_color }};
    --color-foreground: {{ settings.foreground_color }};
    --color-pure-red: #ff000d;
    --color-shipping-green: #185c3d;
    --style-border-radius-inputs: {{ settings.input_corner_radius }}px;
  }
{% endstyle %}
