{% comment %}
  Renders buy buttons, quantity input, and product form.
  @param {product} product
  @param {variant} current_variant
  @param {string} product_form_id
{% endcomment %}

{% style %}
  .product-buy-buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
    padding: 10px 0 0;
  }
  .product-buy-buttons__primary {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    width: 100%;
  }
  .product-buy-buttons__primary [data-add-to-cart-text] {
    font-family: var(--font-roboto);
  }
  .quantity-wrapper {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .quantity-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #111;
    font-family: var(--font-body, inherit);
  }
  .quantity-input-shell {
    display: flex;
    align-items: center;
    border: 1px solid #dcdcdc;
    border-radius: 2px;
    height: 48px;
    width: 120px;
    background-color: transparent;
  }
  .quantity-input__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    width: 40px;
    height: 100%;
    cursor: pointer;
    color: #111;
    transition: background-color 0.2s;
  }
  .quantity-input__btn:hover {
    background-color: rgba(0, 0, 0, 0.03);
  }
  .quantity-input__input {
    flex: 1;
    min-width: 0;
    text-align: center;
    border: none;
    background: none;
    font-size: 16px;
    font-family: var(--font-body, inherit);
    font-weight: 400;
    color: #111;
    padding: 0;
  }
  /* Remove number arrows */
  .quantity-input__input::-webkit-outer-spin-button,
  .quantity-input__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .quantity-input__input[type='number'] {
    -moz-appearance: textfield;
  }

  .flat-btn {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 48px;
    background-color: #3b281f; /* Dark wood color */
    color: #ffffff;
    font-family: var(--font-body, inherit);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  .flat-btn:hover {
    background-color: #2a1c15;
  }
  .flat-btn[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .flat-btn .btn-icon svg {
    width: 20px;
    height: 20px;
  }

  .product-buy-buttons__secondary {
    width: 100%;
  }
  .custom-buy-it-now-btn {
    display: none;
    width: 100%;
    margin-top: 12px;
  }
  .shopify-payment-button__button {
    border-radius: 3px !important;
    height: 48px !important;
  }
{% endstyle %}

{%- form 'product',
  product,
  id: product_form_id,
  class: 'form',
  novalidate: 'novalidate',
  data-type: 'add-to-cart-form'
-%}
  <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>

  <div class="product-buy-buttons">
    <div class="product-buy-buttons__primary">
      <div class="quantity-wrapper">
        <label class="quantity-label">QUANTITY</label>
        <div class="quantity-input-shell" data-quantity-selector>
          <button type="button" class="quantity-input__btn" aria-label="Decrease quantity" data-action="decrease">
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <line x1="4" y1="12" x2="20" y2="12"></line>
            </svg>
          </button>
          <input
            type="number"
            name="quantity"
            class="quantity-input__input"
            value="1"
            min="0"
            aria-label="Quantity"
          >
          <button type="button" class="quantity-input__btn" aria-label="Increase quantity" data-action="increase">
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <line x1="12" y1="4" x2="12" y2="20"></line><line x1="4" y1="12" x2="20" y2="12"></line>
            </svg>
          </button>
        </div>
      </div>

      <button type="submit" name="add" class="flat-btn" {% if current_variant.available == false %}disabled{% endif %}>
        <span class="btn-icon">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-cart-plus-fill" viewBox="0 0 16 16">
            <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0M9 5.5V7h1.5a.5.5 0 0 1 0 1H9v1.5a.5.5 0 0 1-1 0V8H6.5a.5.5 0 0 1 0-1H8V5.5a.5.5 0 0 1 1 0"/>
          </svg>
        </span>
        <span data-add-to-cart-text>
          {%- if current_variant.available -%}
            ADD TO CART
          {%- else -%}
            SOLD OUT
          {%- endif -%}
        </span>
      </button>
    </div>

    <div class="product-buy-buttons__secondary">
      <div class="custom-buy-it-now-wrapper">
        <button type="button" class="flat-btn custom-buy-it-now-btn">BUY IT NOW</button>
      </div>
      <div class="original-payment-button-wrapper" style="display: none;">
        {{ form | payment_button }}
      </div>
    </div>
  </div>

  <div class="product-form__error-message-wrapper" role="alert" hidden data-error-message-wrapper>
    <svg
      aria-hidden="true"
      focusable="false"
      width="16"
      height="16"
      viewBox="0 0 16 16"
      fill="none"
      style="margin-right: 8px;"
    >
      <circle cx="8" cy="8" r="7.5" fill="none" stroke="#e51a3d" stroke-width="1.5"></circle>
      <path d="M8 4V8.5" stroke="#e51a3d" stroke-width="1.5" stroke-linecap="round"></path>
      <circle cx="8" cy="11.5" r="1" fill="#e51a3d"></circle>
    </svg>
    <span class="product-form__error-message" data-error-message></span>
  </div>
{%- endform -%}

<script>
  if (!window.customBuyNowInitialized) {
    window.customBuyNowInitialized = true;
    document.addEventListener('click', (e) => {
      const customBtn = e.target.closest('.custom-buy-it-now-btn');
      if (customBtn) {
        e.preventDefault();
        const wrapper = customBtn.closest('.product-buy-buttons__secondary');
        const dynamicButton = wrapper.querySelector('.shopify-payment-button__button');
        if (dynamicButton) {
          dynamicButton.click();
        } else {
          const form = customBtn.closest('form');
          if (form) {
            let returnInput = form.querySelector('input[name="return_to"]');
            if (!returnInput) {
              returnInput = document.createElement('input');
              returnInput.type = 'hidden';
              returnInput.name = 'return_to';
              form.appendChild(returnInput);
            }
            returnInput.value = '/checkout';
            form.submit();
          }
        }
      }
    });
  }

  if (!window.quantityInputBlurInitialized) {
    window.quantityInputBlurInitialized = true;
    document.addEventListener('focusout', (e) => {
      if (e.target && e.target.classList.contains('quantity-input__input')) {
        if (e.target.value.trim() === '') {
          e.target.value = '0';
        }
      }
    });
  }
</script>
