{% comment %}
  Renders buy buttons, quantity input, and product form.
  @param {product} product
  @param {variant} current_variant
  @param {string} product_form_id
{% endcomment %}

{% style %}
  .product-buy-buttons {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 32px;
  }
  .product-buy-buttons__primary {
    display: flex;
    align-items: flex-end;
    gap: 16px;
    width: 100%;
  }
  .product-buy-buttons__primary [data-add-to-cart-text] {
    font-family: var(--font-roboto);
  }
  .quantity-wrapper {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .quantity-label {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #111;
    font-family: var(--font-body, inherit);
  }
  .quantity-input-shell {
    display: flex;
    align-items: center;
    border: 1px solid #dcdcdc;
    border-radius: 2px;
    height: 48px;
    width: 120px;
    background-color: transparent;
  }
  .quantity-input__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    width: 40px;
    height: 100%;
    cursor: pointer;
    color: #111;
    transition: background-color 0.2s;
  }
  .quantity-input__btn:hover {
    background-color: rgba(0, 0, 0, 0.03);
  }
  .quantity-input__input {
    flex: 1;
    min-width: 0;
    text-align: center;
    border: none;
    background: none;
    font-size: 16px;
    font-family: var(--font-body, inherit);
    font-weight: 400;
    color: #111;
    padding: 0;
  }
  /* Remove number arrows */
  .quantity-input__input::-webkit-outer-spin-button,
  .quantity-input__input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .quantity-input__input[type='number'] {
    -moz-appearance: textfield;
  }

  .add-to-cart-wrapper {
    width: 100%;
  }
  .add-to-cart-wrapper .flat-btn {
    width: 100%;
  }
  .product-note-wrapper {
    display: flex;
    justify-content: flex-end;
    width: 100%;
    transform: translateY(-8px);
  }
  .product-note-button {
    display: flex;
    align-items: center;
    gap: 10px;
    background: none;
    border: none;
    cursor: pointer;
  }
  .product-note-button svg {
    width: 18px;
    height: 18px;
    fill: #111;
  }
  .write-note-text {
    font-size: 14px;
    font-weight: 600;
    letter-spacing: 0rem;
    color: #111;
    font-family: var(--font-body, inherit);
  }
  .product-note-button:hover .write-note-text {
    text-decoration: underline;
  }

  .flat-btn {
    flex: 1;
    min-width: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 48px;
    background-color: #3b281f; /* Dark wood color */
    color: #ffffff;
    font-family: var(--font-body, inherit);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.15em;
    border: none;
    border-radius: 3px;
    cursor: pointer;
    transition: background-color 0.2s;
  }
  .flat-btn:hover {
    background-color: #2a1c15;
  }
  .flat-btn[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .flat-btn .btn-icon svg {
    width: 20px;
    height: 20px;
  }

  .product-buy-buttons__secondary {
    width: 100%;
  }
  .custom-buy-it-now-btn {
    display: none;
    width: 100%;
    margin-top: 12px;
  }
  .shopify-payment-button__button {
    border-radius: 3px !important;
    height: 48px !important;
  }
{% endstyle %}

{%- form 'product',
  product,
  id: product_form_id,
  class: 'form',
  novalidate: 'novalidate',
  data-type: 'add-to-cart-form'
-%}
  <input type="hidden" name="id" value="{{ current_variant.id }}" data-variant-id>
  {%- comment -%} Customer note attached as a line item property; disabled while empty so no blank property is sent. {%- endcomment -%}
  <input type="hidden" name="properties[Note]" data-note-input disabled>

  <div class="product-buy-buttons">
    <div class="product-buy-buttons__primary">
      <div class="quantity-wrapper">
        <label class="quantity-label">QUANTITY</label>
        <div class="quantity-input-shell" data-quantity-selector>
          <button type="button" class="quantity-input__btn" aria-label="Decrease quantity" data-action="decrease">
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <line x1="4" y1="12" x2="20" y2="12"></line>
            </svg>
          </button>
          <input
            type="number"
            name="quantity"
            class="quantity-input__input"
            value="1"
            min="0"
            aria-label="Quantity"
          >
          <button type="button" class="quantity-input__btn" aria-label="Increase quantity" data-action="increase">
            <svg
              width="12"
              height="12"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
            >
              <line x1="12" y1="4" x2="12" y2="20"></line><line x1="4" y1="12" x2="20" y2="12"></line>
            </svg>
          </button>
        </div>
      </div>

      <div class="add-to-cart-wrapper">
        <div class="product-note-wrapper">
          <button class="product-note-button" type="button" data-note-open aria-haspopup="dialog">
            <svg xmlns="http://www.w3.org/2000/svg" width="800" height="800" fill="none" viewBox="0 0 24 24">
              <path fill="#0f0f0f" d="M1 22a1 1 0 0 1 1-1h20a1 1 0 1 1 0 2H2a1 1 0 0 1-1-1"/><path fill="#0f0f0f" fill-rule="evenodd" d="M18.306 1.879a3 3 0 0 0-4.243 0L3.389 12.553a3 3 0 0 0-.807 1.47l-.533 2.398a2 2 0 0 0 2.386 2.386l2.398-.533a3 3 0 0 0 1.47-.807L18.977 6.793a3 3 0 0 0 0-4.243zm-2.829 1.414a1 1 0 0 1 1.414 0l.672.671a1 1 0 0 1 0 1.415L15.641 7.3l-2.085-2.086zm-3.336 3.336-7.338 7.338a1 1 0 0 0-.269.49l-.533 2.398 2.398-.533a1 1 0 0 0 .49-.27l7.338-7.338z" clip-rule="evenodd"/>
            </svg>
            <span class="write-note-text" data-note-label>Write a note</span>
          </button>
        </div>
        <button
          type="submit"
          name="add"
          class="flat-btn"
          {% if current_variant.available == false %}
            disabled
          {% endif %}
        >
          <span class="btn-icon">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              fill="currentColor"
              class="bi bi-cart-plus-fill"
              viewBox="0 0 16 16"
            >
              <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0M9 5.5V7h1.5a.5.5 0 0 1 0 1H9v1.5a.5.5 0 0 1-1 0V8H6.5a.5.5 0 0 1 0-1H8V5.5a.5.5 0 0 1 1 0"/>
            </svg>
          </span>
          <span data-add-to-cart-text>
            {%- if current_variant.available -%}
              ADD TO CART
            {%- else -%}
              SOLD OUT
            {%- endif -%}
          </span>
        </button>
      </div>
    </div>

    <div class="product-buy-buttons__secondary">
      <div class="custom-buy-it-now-wrapper">
        <button type="button" class="flat-btn custom-buy-it-now-btn">BUY IT NOW</button>
      </div>
      <div class="original-payment-button-wrapper" style="display: none;">
        {{ form | payment_button }}
      </div>
    </div>
  </div>

  <div class="product-form__error-message-wrapper" role="alert" hidden data-error-message-wrapper>
    <svg
      aria-hidden="true"
      focusable="false"
      width="16"
      height="16"
      viewBox="0 0 16 16"
      fill="none"
      style="margin-right: 8px;"
    >
      <circle cx="8" cy="8" r="7.5" fill="none" stroke="#e51a3d" stroke-width="1.5"></circle>
      <path d="M8 4V8.5" stroke="#e51a3d" stroke-width="1.5" stroke-linecap="round"></path>
      <circle cx="8" cy="11.5" r="1" fill="#e51a3d"></circle>
    </svg>
    <span class="product-form__error-message" data-error-message></span>
  </div>
{%- endform -%}

<div class="product-note-popup" data-note-popup hidden>
  <div class="product-note-popup__overlay" data-note-close></div>
  <div
    class="product-note-popup__dialog"
    role="dialog"
    aria-modal="true"
    aria-labelledby="ProductNoteTitle-{{ product_form_id }}"
  >
    <div class="product-note-popup__header">
      <h2 id="ProductNoteTitle-{{ product_form_id }}" class="product-note-popup__title">Add a note</h2>
      <button type="button" class="product-note-popup__close" data-note-close aria-label="Close note">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="product-note-popup__body">
      <label class="product-note-popup__label" for="ProductNoteField-{{ product_form_id }}">Your note</label>
      <textarea
        id="ProductNoteField-{{ product_form_id }}"
        class="product-note-popup__textarea"
        data-note-field
        rows="4"
        maxlength="500"
        placeholder="Add any special requests or details for this piece…"
      ></textarea>
    </div>
    <div class="product-note-popup__footer">
      <button type="button" class="product-note-popup__clear" data-note-clear>Clear</button>
      <button type="button" class="product-note-popup__save" data-note-save>Save note</button>
    </div>
  </div>
</div>

{% style %}
  .product-note-popup[hidden] {
    display: none;
  }
  .product-note-popup {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-5);
  }
  .product-note-popup__overlay {
    position: absolute;
    inset: 0;
    border: 0;
    padding: 0;
    background: rgba(23, 21, 21, 0.4);
    backdrop-filter: blur(4px);
    cursor: pointer;
  }
  .product-note-popup__dialog {
    position: relative;
    display: flex;
    flex-direction: column;
    width: min(100%, 460px);
    max-height: calc(100dvh - var(--sp-8));
    overflow: hidden;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--surface-elevated);
    box-shadow: var(--shadow-modal);
  }
  .product-note-popup__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--sp-4) var(--sp-5);
    border-bottom: 1px solid var(--border-light);
    background: var(--color-milk);
  }
  .product-note-popup__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-regular);
    color: var(--text-primary);
  }
  .product-note-popup__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-6);
    height: var(--sp-6);
    padding: 0;
    border: 0;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-primary);
    cursor: pointer;
  }
  .product-note-popup__close:hover {
    background: var(--surface-tertiary);
  }
  .product-note-popup__close svg {
    width: 18px;
    height: 18px;
  }
  .product-note-popup__body {
    padding: var(--sp-5);
    overflow-y: auto;
  }
  .product-note-popup__label {
    display: block;
    margin-bottom: var(--sp-2);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .product-note-popup__textarea {
    width: 100%;
    min-height: calc(var(--sp-8) * 2);
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-md);
    background: var(--surface-elevated);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-normal);
    resize: vertical;
  }
  .product-note-popup__textarea:focus {
    outline: none;
    border-color: var(--color-sage);
    box-shadow: var(--shadow-focus);
  }
  .product-note-popup__footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-5);
    border-top: 1px solid var(--border-light);
  }
  .product-note-popup__clear {
    margin-right: auto;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
  }
  .product-note-popup__save {
    min-height: var(--sp-7);
    padding: 0 var(--sp-6);
    border: 0;
    border-radius: var(--radius-md);
    background: var(--color-earth-brown);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard);
  }
  .product-note-popup__save:hover {
    background: var(--color-charcoal);
  }
  /* Indicate a saved note on the trigger */
  .product-note-button.has-note .write-note-text {
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  @media screen and (max-width: 480px) {
    .product-note-popup {
      padding: 0;
      align-items: flex-end;
    }
    .product-note-popup__dialog {
      width: 100%;
      max-height: 88dvh;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }
  }
{% endstyle %}

<script>
  if (!window.productNoteInitialized) {
    window.productNoteInitialized = true;
    (function () {
      var popup = document.querySelector('[data-note-popup]');
      var form = document.querySelector('form[data-type="add-to-cart-form"]');
      if (!popup || !form) return;

      var noteInput = form.querySelector('[data-note-input]');
      var field = popup.querySelector('[data-note-field]');
      var label = document.querySelector('[data-note-label]');
      var trigger = document.querySelector('[data-note-open]');
      var lastFocused = null;

      function reflectState() {
        var hasNote = noteInput && !noteInput.disabled && noteInput.value.trim() !== '';
        if (label) label.textContent = hasNote ? 'Edit note' : 'Write a note';
        if (trigger) trigger.classList.toggle('has-note', hasNote);
      }

      function openPopup() {
        lastFocused = document.activeElement;
        field.value = noteInput && !noteInput.disabled ? noteInput.value : '';
        popup.hidden = false;
        document.documentElement.style.overflow = 'hidden';
        window.requestAnimationFrame(function () { field.focus(); });
      }

      function closePopup() {
        popup.hidden = true;
        document.documentElement.style.overflow = '';
        if (lastFocused && lastFocused.focus) lastFocused.focus();
      }

      function saveNote() {
        var value = field.value.trim();
        if (noteInput) {
          if (value === '') {
            noteInput.value = '';
            noteInput.disabled = true;
          } else {
            noteInput.value = value;
            noteInput.disabled = false;
          }
        }
        reflectState();
        closePopup();
      }

      if (trigger) trigger.addEventListener('click', openPopup);
      popup.querySelectorAll('[data-note-close]').forEach(function (el) {
        el.addEventListener('click', closePopup);
      });
      var saveBtn = popup.querySelector('[data-note-save]');
      if (saveBtn) saveBtn.addEventListener('click', saveNote);
      var clearBtn = popup.querySelector('[data-note-clear]');
      if (clearBtn) clearBtn.addEventListener('click', function () { field.value = ''; field.focus(); });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape' && !popup.hidden) closePopup();
      });

      reflectState();
    })();
  }
</script>

<script>
  if (!window.customBuyNowInitialized) {
    window.customBuyNowInitialized = true;
    document.addEventListener('click', (e) => {
      const customBtn = e.target.closest('.custom-buy-it-now-btn');
      if (customBtn) {
        e.preventDefault();
        const wrapper = customBtn.closest('.product-buy-buttons__secondary');
        const dynamicButton = wrapper.querySelector('.shopify-payment-button__button');
        if (dynamicButton) {
          dynamicButton.click();
        } else {
          const form = customBtn.closest('form');
          if (form) {
            let returnInput = form.querySelector('input[name="return_to"]');
            if (!returnInput) {
              returnInput = document.createElement('input');
              returnInput.type = 'hidden';
              returnInput.name = 'return_to';
              form.appendChild(returnInput);
            }
            returnInput.value = '/checkout';
            form.submit();
          }
        }
      }
    });
  }

  if (!window.quantityInputBlurInitialized) {
    window.quantityInputBlurInitialized = true;
    document.addEventListener('focusout', (e) => {
      if (e.target && e.target.classList.contains('quantity-input__input')) {
        if (e.target.value.trim() === '') {
          e.target.value = '0';
        }
      }
    });
  }
</script>
