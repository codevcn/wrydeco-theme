{% comment %}
  Renders a line item property checkbox for Private design consultation.
  @param {product} product
{% endcomment %}

{% style %}
  .product-consultation {
    border: 1px solid #e0e0e0;
    border-radius: 4px;
    padding: 16px;
    margin-bottom: 24px;
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .product-consultation__checkbox {
    width: 20px;
    height: 20px;
    margin-top: 2px;
    cursor: pointer;
    accent-color: #111;
  }
  .product-consultation__content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .product-consultation__header {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .product-consultation__title {
    font-size: 16px;
    font-weight: 600;
    color: #111;
    margin: 0;
  }
  .product-consultation__badge {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: 1px solid #dcb588;
    color: #a4763e;
    padding: 2px 6px;
    border-radius: 2px;
  }
  .product-consultation__desc {
    font-size: 14px;
    color: #666;
    margin: 0;
    line-height: 1.4;
  }
{% endstyle %}

<div class="product-consultation">
  <!-- We use form attribute to associate with the product form outside of it -->
  <!-- Note: HTML5 allows form attribute, but we'll include it directly in the form later if possible. 
       Wait, since this snippet is outside the form in main-product.liquid, we MUST use the form="" attribute. -->
  <input type="hidden" name="properties[Private design consultation]" value="No" form="{{ 'ProductForm-' | append: section.id }}">
  <input type="checkbox" 
         id="Consultation-{{ section.id }}" 
         name="properties[Private design consultation]" 
         value="Yes" 
         class="product-consultation__checkbox"
         form="{{ 'ProductForm-' | append: section.id }}">
  <div class="product-consultation__content">
    <div class="product-consultation__header">
      <label for="Consultation-{{ section.id }}" class="product-consultation__title">
        Private design consultation
      </label>
      <span class="product-consultation__badge">PRIORITY</span>
    </div>
    <p class="product-consultation__desc">
      Complimentary for buyers &middot; 30 minutes &middot; Senior designer
    </p>
  </div>
</div>
