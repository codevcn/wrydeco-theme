{% comment %}
  Renders the "Private design guidance" card.

  Visually an informational card matching the design; functionally it still
  carries the consultation line-item property and opens the scheduling popup.
  The hidden checkbox keeps the existing popup trigger logic
  ([data-consultation-trigger]) and the line-item property untouched.

  @param {product} product
{% endcomment %}

{% style %}
  .product-guidance {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-5);
    background-color: transparent;
    border: 1px solid #33333329;
    border-radius: var(--radius-lg);
  }
  .product-guidance__trigger {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }
  .product-guidance__icon {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    background-color: var(--bg-secondary);
    color: var(--color-clay);
  }
  .product-guidance__icon svg {
    width: 26px;
    height: 26px;
  }
  .product-guidance__content {
    flex: 1 1 auto;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }
  .product-guidance__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--text-primary);
  }
  .product-guidance__desc {
    margin: 0;
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }
  .product-guidance__cta {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    background: none;
    border: none;
    padding: var(--sp-1) 0;
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-clay);
    cursor: pointer;
    transition: color var(--timing-short) var(--ease-standard);
    margin-left: var(--sp-2);
  }
  .product-guidance__cta:hover {
    color: var(--color-charcoal);
  }
  .product-guidance__cta svg {
    width: 14px;
    height: 14px;
  }

  @media screen and (max-width: 768px) {
    .product-guidance {
      flex-wrap: wrap;
      justify-content: center;
      gap: 5px;
    }
    .product-guidance__cta {
      width: 100%;
      justify-content: flex-start;
      padding-left: calc(48px + var(--sp-4));
    }
    .product-guidance__content {
      margin-top: 5px;
    }
    .product-guidance__title {
      text-align: center;
    }
    .product-guidance__desc {
      text-align: center;
    }
  }
{% endstyle %}

<div class="product-guidance">
  {% comment %} Hidden field keeps the consultation line-item property on the product form {% endcomment %}
  <input
    type="hidden"
    name="properties[Private design consultation]"
    value="No"
    form="{{ 'ProductForm-' | append: section.id }}"
  >
  <input
    type="checkbox"
    id="Consultation-{{ section.id }}"
    name="properties[Private design consultation]"
    value="Yes"
    class="product-guidance__trigger"
    aria-label="Add private design guidance"
    data-consultation-trigger="true"
    form="{{ 'ProductForm-' | append: section.id }}"
  >

  <span class="product-guidance__icon" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
      <path d="M0 0h24v24H0z" fill="none" />
      <path fill="currentColor" d="M19.95 21q-3.125 0-6.175-1.362t-5.55-3.863t-3.862-5.55T3 4.05q0-.45.3-.75t.75-.3H8.1q.35 0 .625.238t.325.562l.65 3.5q.05.4-.025.675T9.4 8.45L6.975 10.9q.5.925 1.187 1.787t1.513 1.663q.775.775 1.625 1.438T13.1 17l2.35-2.35q.225-.225.588-.337t.712-.063l3.45.7q.35.1.575.363T21 15.9v4.05q0 .45-.3.75t-.75.3" />
    </svg>
  </span>

  <div class="product-guidance__content">
    <h3 class="product-guidance__title">Private design guidance</h3>
    <p class="product-guidance__desc">
      Work with our design concierge to customize dimensions, finish, and layout for your space.
    </p>
  </div>

  <a href="/pages/customization#custom-inquiry__story-telling" class="product-guidance__cta">
    Schedule a call
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="5" y1="12" x2="19" y2="12"></line>
      <polyline points="12 5 19 12 12 19"></polyline>
    </svg>
  </a>
</div>
