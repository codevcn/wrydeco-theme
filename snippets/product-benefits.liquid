{% comment %}
  Renders product benefits accordion or list from section blocks.
  @param {product} product
  @param {section} section
{% endcomment %}

{% style %}
  .product-benefits {
    margin-bottom: 24px;
    border-top: 1px solid #f0f0f0;
    border-bottom: 1px solid #f0f0f0;
    padding: 16px 0;
    background-color: #fff; /* Light red/pinkish from design */
    border-radius: 8px;
    margin: 0 12px; /* Adjusted margin to match design */
    margin-top: 20px;
  }
  .product-benefits__item {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 12px 0;
  }
  .product-benefits__icon-wrap {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background-color: #fff4f4; /* Light red/pinkish from design */
    display: flex;
    align-items: center;
    justify-content: center;
    color: #e51a3d;
    flex-shrink: 0;
  }
  .product-benefits__text {
    flex: 1;
    font-size: 15px;
    color: #333;
  }
  .product-benefits__arrow {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f4f4f4;
    border-radius: 50%;
    color: #666;
  }
  .product-benefits__arrow svg {
    width: 12px;
    height: 12px;
  }
{% endstyle %}

<div class="product-benefits">
  {% if section.blocks.size > 0 %}
    {% for block in section.blocks %}
      {% if block.type == 'benefit' %}
        <div class="product-benefits__item" {{ block.shopify_attributes }}>
          <div class="product-benefits__icon-wrap">
            {% if block.settings.icon != blank %}
              {{ block.settings.icon }}
            {% else %}
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline>
              </svg>
            {% endif %}
          </div>
          <div class="product-benefits__text">
            {{ block.settings.title }}
          </div>
          <div class="product-benefits__arrow">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polygon points="5 3 19 12 5 21 5 3"></polygon>
            </svg>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  {% else %}
    {% comment %} Default hardcoded benefits based on design if no blocks added yet {% endcomment %}
    <div class="product-benefits__item">
      <div class="product-benefits__icon-wrap">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>
        </svg>
      </div>
      <div class="product-benefits__text">Express Delivery & Easy Setup</div>
      <div class="product-benefits__arrow">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon points="5 3 19 12 5 21 5 3"></polygon>
        </svg>
      </div>
    </div>
    <div class="product-benefits__item">
      <div class="product-benefits__icon-wrap">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
      </div>
      <div class="product-benefits__text">30-Day Returns</div>
      <div class="product-benefits__arrow">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon points="5 3 19 12 5 21 5 3"></polygon>
        </svg>
      </div>
    </div>
    <div class="product-benefits__item">
      <div class="product-benefits__icon-wrap">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        </svg>
      </div>
      <div class="product-benefits__text">1-Year Warranty</div>
      <div class="product-benefits__arrow">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon points="5 3 19 12 5 21 5 3"></polygon>
        </svg>
      </div>
    </div>
    <div class="product-benefits__item">
      <div class="product-benefits__icon-wrap">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      </div>
      <div class="product-benefits__text">Shipping Insurance</div>
      <div class="product-benefits__arrow">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polygon points="5 3 19 12 5 21 5 3"></polygon>
        </svg>
      </div>
    </div>
  {% endif %}
</div>
