      "blocks": {
        "orders_payment": {
          "type": "category",
          "settings": {
            "heading": "Orders & payment",
            "open_by_default": true,
            "open_first_question": true,
            "question_1": "Can I customize the size of a piece?",
            "answer_1": "<p>WRYDECO focuses on solid natural wood selected for its grain, form, strength, and suitability for each design. Product details identify the material chosen for the individual piece.</p>",
            "question_2": "What wood options and finishes do you offer?",
            "answer_2": "<p>Depending on the design, we can explore dimensions, wood selection, finish, and proportions. Feasibility is confirmed after we understand your space and intended use.</p>",
            "question_3": "How long does it take to receive a custom piece?",
            "answer_3": "<p>Timing depends on design complexity, material selection, workshop capacity, finishing, and destination. We provide a project-specific estimate once the scope is confirmed.</p>"
          }
        },
        "shipping_delivery": {
          "type": "category",
          "settings": {
            "heading": "Shipping & delivery",
            "open_by_default": false,
            "open_first_question": false,
            "question_1": "Do you offer worldwide shipping?",
            "answer_1": "<p>Availability depends on the piece, destination, access conditions, and installation needs. Share your location and site details so our team can confirm the appropriate delivery plan.</p>",
            "question_2": "How is the wood protected and finished?",
            "answer_2": "<p>Each finish is selected to complement the wood and intended use. Your product details or proposal identifies the finish and provides care guidance for that specific surface.</p>",
            "question_3": "Will the grain vary from the photos?",
            "answer_3": "<p>Yes. Natural grain, knots, tone shifts, and organic edges vary from one piece of wood to another. These differences give every WRYDECO work its individual character.</p>"
          }
        },
        "returns_exchanges": {
          "type": "category",
          "settings": {
            "heading": "Returns & refunds",
            "open_by_default": false,
            "open_first_question": false,
            "question_1": "What is your deposit and payment process?",
            "answer_1": "<p>Bespoke commissions follow the payment schedule documented in the project proposal. The schedule is reviewed with you before sourcing or fabrication begins.</p>",
            "question_2": "What is your return and refund policy?",
            "answer_2": "<p>Our products are non-returnable. If your product arrives damaged or defective, you may request a refund or replacement. Please contact us promptly with clear photographs so our team can assess the issue.</p>",
            "question_3": "Are grain and color variations defects?",
            "answer_3": "<p>No. Natural grain, knots, tone shifts, and organic edges are part of each piece's character. If you are concerned about structure or workmanship, send clear photographs for assessment.</p>"
          }
        },
        "materials_craftsmanship": {
          "type": "category",
          "settings": {
            "heading": "Materials & craftsmanship",
            "open_by_default": false,
            "open_first_question": false,
            "question_1": "What materials do you use?",
            "answer_1": "<p>WRYDECO focuses on solid natural wood selected for grain, form, and suitability for the design. The product page or project proposal identifies the material and finish specified for your piece.</p>",
            "question_2": "Will my piece look exactly like the photograph?",
            "answer_2": "<p>Its design language will be consistent, but no two pieces of natural wood share identical grain, tone, knots, or edge character. Those differences make each work singular.</p>",
            "question_3": "How is the furniture made?",
            "answer_3": "<p>Skilled artisans shape, join, finish, and inspect each work with close attention to the wood's natural form. The process balances sculptural expression with everyday function and long-term use.</p>"
          }
        },
        "custom_orders": {
          "type": "category",
          "settings": {
            "heading": "Custom orders",
            "open_by_default": false,
            "open_first_question": false,
            "question_1": "What can be customized?",
            "answer_1": "<p>Depending on the design, we can explore dimensions, wood selection, finish, proportions, and project-specific forms. Feasibility is confirmed after we understand the space and intended use.</p>",
            "question_2": "How does a bespoke commission begin?",
            "answer_2": "<p>Start with a consultation and share your room, approximate dimensions, preferred product type, budget range, timeline, and reference images. We then define the scope before production is approved.</p>",
            "question_3": "How long does a custom project take?",
            "answer_3": "<p>The timeline depends on design development, material selection, scale, workshop capacity, finishing, and destination. A project-specific estimate is provided once the scope is clear.</p>"
          }
        },
        "care_instructions": {
          "type": "category",
          "settings": {
            "heading": "Care instructions",
            "open_by_default": false,
            "open_first_question": false,
            "question_1": "How should I care for my wooden furniture?",
            "answer_1": "<p>Dust with a soft, dry cloth and wipe spills promptly. Avoid abrasive pads, harsh household chemicals, and prolonged moisture unless your piece's care guide states otherwise.</p>",
            "question_2": "Where should I place my furniture?",
            "answer_2": "<p>Keep natural wood away from sustained direct sunlight, heating vents, and abrupt humidity changes. A stable interior environment helps the material age more evenly.</p>",
            "question_3": "Can a WRYDECO piece be refinished or repaired?",
            "answer_3": "<p>Many solid wood surfaces can be professionally maintained or restored. Contact us with photographs before using oils, waxes, fillers, or refinishing products so we can advise based on the original finish.</p>"
          }
        },
        "consultation": {
          "type": "category",
          "settings": {
            "heading": "Consultation",
            "open_by_default": false,
            "open_first_question": false,
            "question_1": "When should I request a consultation?",
            "answer_1": "<p>A consultation is useful when you are choosing between pieces, planning a high-value purchase, working with unusual dimensions, or considering a bespoke commission.</p>",
            "question_2": "What should I prepare?",
            "answer_2": "<p>Bring room photographs, approximate dimensions, access notes, your preferred piece or product type, budget range, timeline, and any visual references that clarify the atmosphere you want.</p>",
            "question_3": "Do you work with interior designers?",
            "answer_3": "<p>Yes. Designers and studios can contact us about specifications, custom sizing, finish options, project timelines, and furniture for residential or boutique commercial spaces.</p>"
          }
        }
      },
