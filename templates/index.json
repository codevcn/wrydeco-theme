    "customer_reviews": {
      "type": "customer-reviews",
      "settings": {
        "accessible_label": "Customer reviews",
        "autoplay": false,
        "autoplay_delay": 5
      },
      "blocks": {
        "review_1": {
          "type": "review",
          "settings": {
            "fallback_image": "eff-1.jpg",
            "image_alt": "Organic wood vanity in a serene bathroom",
            "rating": 5,
            "review_text": "Love the table and the craftsmanship. Two things to be aware of: the piece is substantial and beautifully made.",
            "author_name": "David N.",
            "verified": true
          }
        },
        "review_2": {
          "type": "review",
          "settings": {
            "fallback_image": "eff-2.jpg",
            "image_alt": "Handcrafted branch console beneath a wood-framed mirror",
            "rating": 5,
            "review_text": "The grain and hand-shaped edges are even more beautiful in person. It changed the whole room.",
            "author_name": "Melissa O.",
            "verified": true
          }
        },
        "review_3": {
          "type": "review",
          "settings": {
            "fallback_image": "eff-3.jpg",
            "image_alt": "Sculptural branch lamp beside a cream sofa",
            "rating": 5,
            "review_text": "Every guest asks who made it. The craftsmanship feels personal, thoughtful, and built to last.",
            "author_name": "Ryan C.",
            "verified": true
          }
        },
        "review_4": {
          "type": "review",
          "settings": {
            "fallback_image": "eff-4.jpg",
            "image_alt": "Large handcrafted tree bookshelf in a warm living room",
            "rating": 5,
            "review_text": "Our shelf looks like it grew into the room. Installation was clear and the finish is flawless.",
            "author_name": "Nicole P.",
            "verified": true
          }
        },
        "review_5": {
          "type": "review",
          "settings": {
            "fallback_image": "eff-5.jpg",
            "image_alt": "Organic tree bookshelf styled with books and plants",
            "rating": 5,
            "review_text": "A functional piece of art. The scale, warmth, and natural form are exactly what the space needed.",
            "author_name": "Jasmine W.",
            "verified": true
          }
        }
      },
      "block_order": ["review_1", "review_2", "review_3", "review_4", "review_5"]
    },
