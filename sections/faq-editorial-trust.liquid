{% comment %}
  Standalone "Why choose WRYDECO" trust bar.

  Extracted from the faq-editorial-page section so it can sit near the top of the
  homepage (right below the hero) instead of at the very bottom.

  The trust styling still lives in the faq-editorial-page section's global
  {% raw %}{% stylesheet %}{% endraw %} block — all Shopify section CSS compiles
  into one bundle, so `.faq-editorial-trust*` rules apply wherever the markup is.
  Those rules depend on the `faq-editorial` container context and the
  `--faq-max-width` / `--faq-line` custom properties (originally provided by the
  `.faq-editorial` parent), so the host wrapper below re-establishes both — the
  bar renders pixel-identically to when it lived inside faq-editorial.
{% endcomment %}

<div class="faq-editorial-trust-host">
  <section class="faq-editorial-trust" aria-label="Why choose WRYDECO">
    <div class="faq-editorial-trust__inner">
      <div class="faq-editorial-trust__item">
        <span class="faq-editorial-trust__icon" aria-hidden="true">
          <img src="{{ 'ic-footer-1.png' | file_url }}" width="64" height="64" alt="Handcrafted Solid Wood">
        </span>
        <div class="faq-editorial-trust__item-content">
          <h3>Handcrafted Solid Wood</h3>
          <p>Sustainably sourced, premium hardwoods built to last.</p>
        </div>
      </div>
      <div class="faq-editorial-trust__item">
        <span class="faq-editorial-trust__icon" aria-hidden="true">
          <img src="{{ 'ic-footer-2.png' | file_url }}" width="64" height="64" alt="Made to Order">
        </span>
        <div class="faq-editorial-trust__item-content">
          <h3>Made to Order</h3>
          <p>Every piece is custom-crafted to your space and style.</p>
        </div>
      </div>
      <div class="faq-editorial-trust__item">
        <span class="faq-editorial-trust__icon" aria-hidden="true">
          <img src="{{ 'ic-footer-3.png' | file_url }}" width="64" height="64" alt="Thoughtfully Finished">
        </span>
        <div class="faq-editorial-trust__item-content">
          <h3>Thoughtfully Finished</h3>
          <p>Refined by hand with natural oils and lasting care.</p>
        </div>
      </div>
      <div class="faq-editorial-trust__item">
        <span class="faq-editorial-trust__icon" aria-hidden="true">
          <img src="{{ 'ic-footer-4.png' | file_url }}" width="64" height="64" alt="White-Glove Delivery">
        </span>
        <div class="faq-editorial-trust__item-content">
          <h3>White-Glove Delivery</h3>
          <p>Carefully delivered and placed with the utmost attention.</p>
        </div>
      </div>
    </div>
  </section>
</div>

{% stylesheet %}
  /* Re-establish the exact context the (globally-compiled) .faq-editorial-trust
     rules rely on, so the relocated bar renders identically to when it was a
     child of .faq-editorial. */
  .faq-editorial-trust-host {
    --faq-max-width: calc(var(--layout-max-width) + var(--sp-8) + var(--sp-8));
    --faq-line: color-mix(in srgb, var(--color-linen) 72%, transparent);
    container: faq-editorial / inline-size;
    background: var(--bg-primary);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust bar",
  "class": "section section-faq-editorial-trust",
  "settings": [],
  "presets": [{ "name": "Trust bar" }]
}
{% endschema %}
