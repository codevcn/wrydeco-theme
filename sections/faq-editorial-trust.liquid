<div class="trust-statistics-host">
  <section class="trust-statistics" aria-label="WRYDECO at a glance">
    <ul class="trust-statistics__list" role="list">
      {%- for stat_index in (1..5) -%}
        {%- liquid
          assign value_setting = 'stat_' | append: stat_index | append: '_value'
          assign label_setting = 'stat_' | append: stat_index | append: '_label'
        -%}
        <li class="trust-statistics__item{% if forloop.first %} trust-statistics__item--featured{% endif %}">
          <strong class="trust-statistics__value">{{ section.settings[value_setting] | escape }}</strong>
          <span class="trust-statistics__label">{{ section.settings[label_setting] | escape }}</span>
        </li>
      {%- endfor -%}
    </ul>
  </section>
</div>

{% stylesheet %}
  .trust-statistics-host {
    padding: var(--sp-3);
    background: var(--surface-elevated);
  }

  .trust-statistics {
    border: 0;
    background: transparent;
  }

  .trust-statistics__list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: var(--sp-2);
    inline-size: min(100%, var(--layout-showcase-max-width));
    min-block-size: var(--sp-10);
    margin: var(--sp-0) auto;
    padding: var(--sp-3);
    border-radius: 8px;
    background: var(--color-cream);
    list-style: none;
  }

  .trust-statistics__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-inline-size: var(--sp-0);
    text-align: center;
  }

  .trust-statistics__value {
    color: var(--color-clay);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-2xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-normal);
    line-height: var(--line-height-tight);
  }

  .trust-statistics__item--featured .trust-statistics__value {
    color: var(--color-clay);
  }

  .trust-statistics__label {
    margin-block-start: var(--sp-2);
    color: var(--text-primary);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-normal);
    line-height: var(--line-height-normal);
    overflow-wrap: anywhere;
  }

  @media screen and (max-width: 61.8125rem) {
    .trust-statistics__list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--sp-4) var(--sp-4);
    }

    .trust-statistics__item:last-child:nth-child(odd) {
      grid-column: 1 / -1;
    }
  }

  @media screen and (max-width: 40rem) {
    .trust-statistics-host {
      padding: var(--sp-3);
    }

    .trust-statistics__list {
      padding: var(--sp-5) var(--sp-3);
    }
  }
{% endstylesheet %}

