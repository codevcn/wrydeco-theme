{%- style -%}
  .hero-banner--{{ section.id }} {
    padding-block-start: 6px;
    padding-block-end: 6px;
  }

  @media screen and (min-width: 750px) {
    .hero-banner--{{ section.id }} {
      padding-block-start: 6px;
      padding-block-end: 6px;
    }
  }
{%- endstyle -%}

<div class="hero-banner hero-banner--{{ section.id }} hero-banner--{{ section.settings.layout }}">
  <div class="hero-banner__container {% if section.settings.layout == 'full-width' %}full-width{% else %}page-width{% endif %}">
    <div class="hero-banner__media">
      {%- if section.settings.image != blank -%}
        {%- liquid
          assign image_height = section.settings.image.width | divided_by: section.settings.image.aspect_ratio
          assign sizes = '100vw'
          if section.settings.layout == 'card'
            assign sizes = '(min-width: 1200px) 1200px, 100vw'
          endif
        -%}
        <picture>
          {%- if section.settings.image_mobile != blank -%}
            <source
              media="(max-width: 749px)"
              srcset="{{ section.settings.image_mobile | image_url: width: 750 }} 750w"
            >
          {%- endif -%}
          {{
            section.settings.image
            | image_url: width: 1500
            | image_tag:
              loading: 'eager',
              fetchpriority: 'high',
              sizes: sizes,
              widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000',
              alt: section.settings.image.alt
            | escape
          }}
        </picture>
      {%- elsif section.settings.asset_image != blank -%}
        <img
          src="{{ section.settings.asset_image | asset_url }}"
          alt="Hero Banner"
          loading="eager"
          fetchpriority="high"
        >
      {%- else -%}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .hero-banner {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .hero-banner__container {
    position: relative;
    display: flex;
    flex-direction: column;
    width: 100%;
    max-width: 100%;
  }

  .hero-banner__container.page-width {
    padding-inline: var(--space-4, 10px);
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
  }

  .hero-banner__media {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .hero-banner--card .hero-banner__media {
    border-radius: 6px;
  }

  .hero-banner__media img,
  .hero-banner__media svg {
    width: 100%;
    aspect-ratio: 16/9;
    object-fit: cover;
  }

  /* Overlay Box */
  .hero-banner__content-box {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: var(--space-6, 12px);
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 6px);
    color: var(--color-10, #fff);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.7), transparent);
    z-index: 1;
  }

  .hero-banner--card .hero-banner__content-box {
    border-radius: 0 0 var(--radius-lg, 16px) var(--radius-lg, 16px);
  }

  .hero-banner__subheading {
    font-size: var(--text-sm, 14px);
    text-transform: uppercase;
    font-weight: var(--font-weight-600, 600);
    letter-spacing: 1px;
    margin: 0;
  }

  .hero-banner__heading {
    font-size: var(--text-xl, 46px);
    line-height: 1.1;
    font-weight: var(--font-weight-700, 700);
    margin: 0;
    /* Adjusting to italic if we want it to look like the design screenshot, or keeping it configurable */
  }

  .hero-banner__text {
    font-size: var(--text-base, 15px);
    line-height: 1.4;
    margin: var(--space-2, 6px) 0 0 0;
    max-width: 400px;
  }

  .hero-banner__button {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2, 6px);
    margin-top: var(--space-4, 10px);
    color: var(--color-10, #fff);
    text-decoration: none;
    font-weight: var(--font-weight-600, 600);
    font-size: var(--text-base, 15px);
  }

  .hero-banner__button .icon-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full, 50%);
    background-color: var(--color-10, #fff);
    color: var(--color-1, #000);
    font-weight: bold;
    transition: transform var(--duration-fast, 0.15s) ease;
  }

  .hero-banner__button:hover .icon-arrow {
    transform: translateX(4px);
  }

  @media screen and (min-width: 750px) {
    .hero-banner__container.page-width {
      padding-inline: var(--space-8, 16px);
    }

    .hero-banner__content-box {
      padding: var(--space-12, 25px) var(--space-13, 32px);
    }

    .hero-banner__heading {
      font-size: var(--text-2xl, 64px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout Style",
      "options": [
        {
          "value": "full-width",
          "label": "Full Width"
        },
        {
          "value": "card",
          "label": "Rounded Card"
        }
      ],
      "default": "full-width"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Image (Optional)"
    },
    {
      "type": "text",
      "id": "asset_image",
      "label": "Local Asset Image",
      "info": "Filename of an image in the assets folder"
    }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": []
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Escape The Everyday",
          "label": "Subheading"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text",
      "limit": 1,
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Experience true luxury handcrafted for your space.</p>",
          "label": "Description"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Shop the Collection",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        },
        {
          "type": "checkbox",
          "id": "show_arrow",
          "default": true,
          "label": "Show arrow icon"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        {
          "type": "subheading"
        },
        {
          "type": "heading"
        },
        {
          "type": "text"
        },
        {
          "type": "button"
        }
      ]
    }
  ]
}
{% endschema %}
