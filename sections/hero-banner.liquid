{%- liquid
  assign hero_image_alt = section.settings.hero_image_alt | default: 'Handcrafted solid wood furniture in a refined interior'
  assign primary_link = routes.all_products_collection_url
  assign secondary_link = pages.customization.url | default: '/pages/customization'
-%}

<div class="hero-new" id="homepage-hero-new">
  <div class="hero-new__background" aria-hidden="true">
    <picture class="hero-new__picture">
      <source media="(max-width: 640px)" srcset="{{ 'hero-section-ver-new-mobile.png' | file_url }}">
      <img
        class="hero-new__image"
        src="{{ 'hero-section-ver-new.png' | file_url }}"
        alt=""
        width="2880"
        height="1620"
        loading="eager"
        fetchpriority="high"
      >
    </picture>
  </div>

  <div class="hero-new__shade" aria-hidden="true"></div>
  <div class="hero-new__shade-front" aria-hidden="true"></div>

  <div class="hero-new__inner">
    <div class="hero-new__content">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'heading' -%}
            <h1 class="hero-new__heading" {{ block.shopify_attributes }}>
              {{-
                block.settings.text
                | escape
                | replace: 'Wooden Furniture,', 'Wooden Furniture,'
                | replace: ' Sculpted for ', ' Sculpted for '
              -}}
            </h1>
          {%- when 'subtext' -%}
            <p class="hero-new__subtext" {{ block.shopify_attributes }}>
              {{-
                block.settings.text
                | escape
                | replace: 'custom dimensions, finishes, and forms for refined interiors.',
                  'custom dimensions, finishes, and forms-<br>designed to last for generations.'
              -}}
            </p>
          {%- when 'buttons' -%}
            {%- assign primary_link = block.settings.primary_link | default: routes.all_products_collection_url -%}
            {%- assign secondary_link = block.settings.secondary_link
              | default: pages.customization.url
              | default: '/pages/customization'
            -%}
            <div class="hero-new__actions" {{ block.shopify_attributes }}>
              <a class="hero-new__button hero-new__button--primary" href="{{ primary_link }}">
                <span>{{ block.settings.primary_label | escape }}</span>
                <span class="hero-new__button-arrow" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 1024 1024">
                    <path d="M0 0h1024v1024H0z" fill="none" />
                    <path fill="currentColor" d="M754.8 480H160a32 32 0 1 0 0 64h594.8L521.3 777.3a32 32 0 0 0 45.4 45.4l288-288a32 32 0 0 0 0-45.4l-288-288a32 32 0 1 0-45.4 45.4z" />
                  </svg>
                </span>
              </a>
            </div>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  body:has(.hero-new) .header__heading-logo {
    filter: brightness(0) invert(1);
  }

  body:has(.hero-new) .header__heading-link,
  body:has(.hero-new) .header__nav-item,
  body:has(.hero-new) .header__icon,
  body:has(.hero-new) .header__icon--search,
  body:has(.hero-new) .header__icon--cart,
  body:has(.hero-new) .header__icon--account,
  body:has(.hero-new) .header__icon--menu {
    color: var(--color-cream);
  }

  body:has(.hero-new) .header__nav-item:hover,
  body:has(.hero-new) .header__icon:hover {
    color: var(--color-stone);
  }

  body:has(.hero-new) .header__consultation-link {
    border-color: color-mix(in srgb, var(--color-cream) 64%, transparent);
    background-color: transparent;
    color: var(--color-cream);
  }

  body:has(.hero-new) .header__consultation-link:hover {
    background-color: var(--color-cream);
    color: var(--color-earth-brown);
  }

  .hero-new {
    position: relative;
    isolation: isolate;
    display: block;
    min-height: 100svh;
    overflow: hidden;
    background-color: var(--color-ebony);
    color: var(--color-cream);
  }

  .hero-new__background,
  .hero-new__shade,
  .hero-new__shade-front {
    position: relative;
    inset: 0;
    z-index: -2;
  }
  .hero-new__shade {
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image: linear-gradient(to bottom, rgba(0, 0, 0, 0.9) 0%, rgba(0, 0, 0, 0.22) 24%, rgba(0, 0, 0, 0) 100%);
  }
  .hero-new__shade-front {
    position: absolute;
    inset: 0;
    z-index: 2;
    background-color: rgba(0, 0, 0, 0.1);
  }

  .hero-new__picture {
    display: block;
    width: 100%;
    height: 100%;
  }

  .hero-new__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .hero-new__inner {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 100svh;
    max-width: none;
    margin-inline: auto;
    padding: var(--sp-12) clamp(var(--sp-7), 7vw, calc(var(--sp-12) + var(--sp-2))) var(--sp-12);
    z-index: 10;
    position: absolute;
    inset: 0;
  }

  .hero-new__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    width: min(100%, calc((var(--sp-12) * 6) + var(--sp-8)));
    margin: 0 auto;
    padding-inline: var(--sp-5);
    text-align: center;
  }

  .hero-new__heading {
    margin: 0;
    font-family: var(--font-display-light);
    font-size: clamp(var(--font-size-display-lg), 3.45vw, var(--font-size-display-2xl));
    font-weight: var(--font-weight-light);
    line-height: 1.1;
    letter-spacing: var(--letter-spacing-normal);
    color: var(--color-cream);
    text-wrap: balance;
    text-shadow: 0 2px 18px color-mix(in srgb, var(--color-ebony) 62%, transparent);
  }

  .hero-new__subtext {
    display: none;
    width: min(100%, calc((var(--sp-12) * 3) + var(--sp-7)));
    margin: var(--sp-5) 0 0;
    padding-top: var(--sp-5);
    position: relative;
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-generous);
    color: var(--color-cream);
    text-align: center;
  }

  .hero-new__subtext::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    width: var(--sp-10);
    height: var(--border-width);
    background-color: var(--color-star-rating);
    transform: translateX(-50%);
  }

  .hero-new__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    margin-top: var(--sp-6);
  }

  .hero-new__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    min-width: calc(var(--sp-12) + var(--sp-8) + var(--sp-5));
    min-height: var(--sp-8);
    padding-inline: var(--sp-5);
    border: var(--border-width) solid color-mix(in srgb, var(--color-cream) 74%, transparent);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.1em;
    line-height: var(--line-height-snug);
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard), border-color var(--timing-short) var(--ease-standard);
  }

  .hero-new__button--primary {
    background-color: var(--color-transparent);
    color: var(--color-cream);
    border-color: var(--color-cream);
    position: relative;
  }
  .hero-new__button--primary::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: var(--radius-sm);
    background-color: rgba(74, 44, 24, 0.41);
    transition: opacity var(--timing-short) var(--ease-standard);
  }

  .hero-new__button--primary:hover {
    background-color: var(--color-stone);
    border-color: var(--color-stone);
    color: var(--color-ebony);
  }

  .hero-new__button-arrow {
    font-size: var(--font-size-body-lg);
    line-height: 1;
  }

  @media screen and (max-width: 1180px) {
    .hero-new__content {
      width: min(100%, calc((var(--sp-12) * 5) + var(--sp-7)));
    }

    .hero-new__heading {
      font-size: clamp(var(--font-size-display-lg), 6.4vw, var(--font-size-display-2xl));
    }
  }

  @media screen and (max-width: 900px) {
    .hero-new__image {
      object-position: 60% center;
    }

    .hero-new__inner {
      padding-top: var(--sp-11);
      padding-bottom: var(--sp-11);
    }
  }

  @media screen and (max-width: 640px) {
    .hero-new {
      min-height: unset;
    }

    .hero-new__image {
      object-position: 68% center;
    }

    .hero-new__inner {
      min-height: 100svh;
      padding: var(--sp-10) var(--layout-padding-mobile) var(--sp-5);
    }

    .hero-new__content {
      width: 100%;
    }

    .hero-new__heading {
      font-size: clamp(var(--font-size-display-sm), 8vw, var(--font-size-display-md));
      line-height: 1;
    }

    .hero-new__subtext {
      width: min(100%, calc((var(--sp-12) * 2) + var(--sp-11)));
      margin-top: var(--sp-4);
      padding-top: var(--sp-4);
      font-size: var(--font-size-body-md);
    }

    .hero-new__actions {
      flex-direction: column;
      align-items: stretch;
      gap: var(--sp-3);
      margin-top: var(--sp-5);
    }

    .hero-new__button {
      width: 100%;
      min-height: var(--sp-7);
      min-width: 0;
    }

    body:has(.hero-new) .header__consultation-link {
      border-color: color-mix(in srgb, var(--color-earth-brown) 64%, transparent);
      background-color: transparent;
      color: var(--color-earth-brown);
    }

    body:has(.hero-new) .header__consultation-link:hover {
      background-color: var(--color-cream);
      color: var(--color-earth-brown);
    }
  }

  @media screen and (max-width: 380px) {
    .hero-new__inner {
      padding-top: var(--sp-9);
    }
  }

  @media screen and (max-height: 720px) and (min-width: 641px) {
    .hero-new__inner {
      padding-block: var(--sp-9);
    }

    .hero-new__actions {
      margin-top: var(--sp-5);
    }
  }

  /* --- Hero Entrance Animations --- */
  @keyframes heroReveal {
    0% {
      opacity: 0;
      transform: translateY(30px);
    }
    100% {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-new__heading {
    opacity: 0;
    animation: heroReveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
  }

  .hero-new__subtext {
    opacity: 0;
    animation: heroReveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: 0.15s;
  }

  .hero-new__actions {
    opacity: 0;
    animation: heroReveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) forwards;
    animation-delay: 0.3s;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-new__heading,
    .hero-new__subtext,
    .hero-new__actions {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section section-hero-new",
  "settings": [
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Hero image alt text",
      "default": "Handcrafted solid wood furniture in a refined interior"
    },
    {
      "type": "header",
      "content": "Trust badge"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badge",
      "label": "Show trust badge",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "trust_avatars",
      "label": "Avatars image (small cluster)"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust text",
      "default": "Trusted by designers and homeowners worldwide"
    },
    {
      "type": "text",
      "id": "trust_rating",
      "label": "Rating",
      "default": "4.9/5"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Nature wrote the prologue. You write the legacy." }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading",
          "default": "Bespoke Wooden Furniture, Sculpted for Refined Homes"
        }
      ]
    },
    {
      "type": "subtext",
      "name": "Subtext",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Subtext",
          "default": "Handcrafted from solid wood. Made to order in custom dimensions, finishes, and forms-designed to last for generations."
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Explore Now" },
        { "type": "url", "id": "primary_link", "label": "Primary link" },
        { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Book Consultation" },
        { "type": "url", "id": "secondary_link", "label": "Secondary link" }
      ]
    },
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "wood", "label": "Wood" },
            { "value": "ruler", "label": "Ruler / measure" },
            { "value": "consult", "label": "Consultation" },
            { "value": "truck", "label": "Delivery" }
          ],
          "default": "wood"
        },
        { "type": "text", "id": "text", "label": "Text", "default": "Solid Wood Only" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subtext" },
        { "type": "buttons" },
        { "type": "feature", "settings": { "icon": "wood", "text": "Solid Wood Only" } },
        { "type": "feature", "settings": { "icon": "ruler", "text": "Made to Measure" } },
        { "type": "feature", "settings": { "icon": "truck", "text": "White-Glove Delivery US" } }
      ]
    }
  ]
}
{% endschema %}
