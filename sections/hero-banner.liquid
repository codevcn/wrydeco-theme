<div class="hero-premium">
  <div class="hero-premium__background">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, image_size: '1500x' }}
    {%- elsif section.settings.asset_video != blank -%}
      <video src="{{ section.settings.asset_video | asset_url }}" autoplay loop muted playsinline class="hero-premium__video"></video>
    {%- else -%}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg hero-premium__video' }}
    {%- endif -%}
    <div class="hero-premium__overlay"></div>
  </div>

  <div class="hero-premium__content page-width">
    <div class="hero-premium__text-box">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'eyebrow' -%}
            <span class="hero-premium__eyebrow">{{ block.settings.text }}</span>
          {%- when 'heading' -%}
            <h1 class="hero-premium__heading">{{ block.settings.text }}</h1>
          {%- when 'subtext' -%}
            <p class="hero-premium__subtext">{{ block.settings.text }}</p>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  /* Reset and base styles for the premium hero */
  .hero-premium {
    position: relative;
    width: 100%;
    min-height: 100dvh;
    display: flex;
    align-items: flex-end; /* Editorial split style - text at the bottom */
    overflow: hidden;
    color: var(--color-cream, #FDFCF0);
  }

  .hero-premium__background {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
  }

  .hero-premium__background video,
  .hero-premium__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Dark overlay for contrast */
  .hero-premium__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 50%, rgba(0,0,0,0.1) 100%);
    z-index: 1;
    pointer-events: none;
  }

  .hero-premium__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--page-width, 1400px);
    margin: 0 auto;
    padding: var(--space-8, 32px) var(--space-4, 16px);
    padding-bottom: var(--space-12, 64px);
    display: flex;
    flex-direction: column;
  }

  @media screen and (min-width: 768px) {
    .hero-premium__content {
      padding: var(--space-12, 64px) var(--space-8, 32px);
      padding-bottom: var(--space-20, 100px);
    }
  }

  .hero-premium__text-box {
    max-width: 720px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  /* Animations */
  @keyframes cinematicFadeUp {
    from {
      opacity: 0;
      transform: translateY(40px);
      filter: blur(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
      filter: blur(0);
    }
  }

  .hero-premium__eyebrow {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 9999px;
    background-color: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    font-weight: 500;
    margin-bottom: var(--space-6, 24px);
    
    animation: cinematicFadeUp 1.2s cubic-bezier(0.32, 0.72, 0, 1) forwards;
    opacity: 0;
  }

  .hero-premium__heading {
    font-size: 48px;
    line-height: 1.05;
    font-weight: 400; /* Sophisticated clean weight */
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-6, 24px) 0;
    color: #fff;
    
    animation: cinematicFadeUp 1.2s cubic-bezier(0.32, 0.72, 0, 1) forwards;
    animation-delay: 0.15s;
    opacity: 0;
  }

  @media screen and (min-width: 768px) {
    .hero-premium__heading {
      font-size: clamp(64px, 6vw, 96px);
    }
  }

  .hero-premium__subtext {
    font-size: 18px;
    line-height: 1.5;
    color: rgba(255, 255, 255, 0.85);
    max-width: 500px;
    margin: 0 0 var(--space-8, 32px) 0;
    
    animation: cinematicFadeUp 1.2s cubic-bezier(0.32, 0.72, 0, 1) forwards;
    animation-delay: 0.3s;
    opacity: 0;
  }

  @media screen and (min-width: 768px) {
    .hero-premium__subtext {
      font-size: 20px;
    }
  }

  /* High-end Button-in-Button Architecture */
  .hero-premium__btn {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    background-color: #ffffff;
    color: #000000;
    padding: 6px;
    padding-left: 24px;
    border-radius: 9999px;
    text-decoration: none;
    font-weight: 500;
    font-size: 15px;
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
    
    animation: cinematicFadeUp 1.2s cubic-bezier(0.32, 0.72, 0, 1) forwards;
    animation-delay: 0.45s;
    opacity: 0;
  }

  .hero-premium__btn:active {
    transform: scale(0.98);
  }

  .hero-premium__btn-label {
    margin-right: 16px;
  }

  .hero-premium__btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: rgba(0, 0, 0, 0.05);
    border-radius: 50%;
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1), background-color 0.4s ease;
  }

  .hero-premium__btn:hover .hero-premium__btn-icon {
    transform: translate(4px, -1px) scale(1.05);
    background-color: rgba(0, 0, 0, 0.08);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Video (Premium)",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "video",
      "id": "video",
      "label": "Shopify Video"
    },
    {
      "type": "text",
      "id": "asset_video",
      "label": "Local Asset Video",
      "info": "Filename of an mp4 in the assets folder. Ex: 'hero-family-vid.mp4'",
      "default": "hero-family-vid.mp4"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow Tag",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Wrydeco Heritage",
          "label": "Text"
        }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "Raw Nature, Refined for Living.",
          "label": "Heading"
        }
      ]
    },
    {
      "type": "subtext",
      "name": "Storytelling Text",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "default": "Every grain tells a story. We shape sustainably sourced timber into timeless centerpieces for your sanctuary.",
          "label": "Subtext"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_label",
          "default": "Shop the Collection",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Video (Premium)",
      "blocks": [
        { "type": "eyebrow" },
        { "type": "heading" },
        { "type": "subtext" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
