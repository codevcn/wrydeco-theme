<div class="hero-split" id="homepage-hero-split">
  <div class="hero-split__inner page-width">
    <div class="hero-split__text">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'eyebrow' -%}
            <span class="hero-split__eyebrow" {{ block.shopify_attributes }}>{{ block.settings.text }}</span>
          {%- when 'heading' -%}
            <h1 class="hero-split__heading" {{ block.shopify_attributes }}>{{ block.settings.text }}</h1>
          {%- when 'subtext' -%}
            <p class="hero-split__subtext" {{ block.shopify_attributes }}>{{ block.settings.text | newline_to_br }}</p>
          {%- when 'buttons' -%}
            <div class="hero-split__buttons" {{ block.shopify_attributes }}>
              {%- if block.settings.primary_label != blank -%}
                <a
                  href="{{ block.settings.primary_link | default: '#' }}"
                  class="hero-split__btn hero-split__btn--primary"
                >
                  {{ block.settings.primary_label }}
                </a>
              {%- endif -%}
              {%- if block.settings.secondary_label != blank -%}
                <a
                  href="{{ block.settings.secondary_link | default: '#' }}"
                  class="hero-split__btn hero-split__btn--secondary"
                >
                  {{ block.settings.secondary_label }}
                </a>
              {%- endif -%}
            </div>
        {%- endcase -%}
      {%- endfor -%}

      {%- assign features = section.blocks | where: 'type', 'feature' -%}
      {%- if features.size > 0 -%}
        <ul class="hero-split__features">
          {%- for block in features -%}
            <li class="hero-split__feature" {{ block.shopify_attributes }}>
              <span class="hero-split__feature-icon" aria-hidden="true">
                {%- render 'hero-feature-icon', icon: block.settings.icon -%}
              </span>
              <span class="hero-split__feature-text">{{ block.settings.text | newline_to_br }}</span>
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>

    <div class="hero-split__media">
      <div class="hero-split__media-frame">
        {%- if section.settings.hero_image != blank -%}
          {{
            section.settings.hero_image
            | image_url: width: 1400
            | image_tag:
              class: 'hero-split__img',
              fetchpriority: 'high',
              sizes: '(min-width: 1024px) 55vw, 100vw',
              widths: '600, 900, 1200, 1400'
          }}
        {%- else -%}
          <img
            src="{{ 'hero.png' | file_url }}"
            alt="{{ section.settings.hero_image_alt | default: 'Handcrafted solid wood furniture in a refined interior' }}"
            class="hero-split__img"
            fetchpriority="high"
            width="1400"
            height="1000"
          >
        {%- endif -%}

        {%- if section.settings.show_trust_badge -%}
          <div class="hero-split__badge">
            {%- if section.settings.trust_avatars != blank -%}
              <div class="hero-split__badge-avatars">
                {{ section.settings.trust_avatars | image_url: width: 200 | image_tag: loading: 'lazy', alt: '' }}
              </div>
            {%- endif -%}
            <div class="hero-split__badge-body">
              <span class="hero-split__badge-text">{{ section.settings.trust_text }}</span>
              <span class="hero-split__badge-meta">
                <span class="hero-split__badge-stars" aria-hidden="true">
                  {%- for i in (1..5) -%}
                    <svg viewBox="0 0 24 24" fill="currentColor" width="13" height="13">
                      <path d="M12 2l2.9 6.26L21.5 9l-5 4.7L18 21l-6-3.3L6 21l1.5-7.3-5-4.7 6.6-.74L12 2z"/>
                    </svg>
                  {%- endfor -%}
                </span>
                {%- if section.settings.trust_rating != blank -%}
                  <span class="hero-split__badge-rating">{{ section.settings.trust_rating }}</span>
                {%- endif -%}
              </span>
            </div>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  const mainProductSection = document.getElementById('homepage-hero-split');
  if (mainProductSection) {
    mainProductSection.closest('body').querySelector('.header__icon--search').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header__icon--cart').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header__icon--menu').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header__icon--account').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header').style.border = '1px solid #cfcbc7b4';
  }
</script>
{% stylesheet %}
  .hero-split {
    display: grid;
    align-items: center;
    min-height: 100svh;
    background-color: var(--bg-primary, #f5f1ed);
    color: var(--text-primary, #1a1815);
    overflow: hidden;
    /* Clear the absolutely-positioned overlay header (~88px) */
    --hero-header-clear: 96px;
    padding: calc(var(--hero-header-clear) + var(--sp-5, 24px)) 0 var(--sp-7, 48px);
  }

  .hero-split__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    align-items: center;
    gap: clamp(32px, 4vw, 80px);
    width: 100%;
    max-width: var(--page-max-width, 1440px);
    margin: 0 auto;
    padding-inline: var(--container-padding-x, 48px);
  }

  /* --- Text column --- */
  .hero-split__text {
    max-width: 620px;
  }

  .hero-split__eyebrow {
    display: block;
    font-size: var(--font-size-caption, 12px);
    text-transform: uppercase;
    letter-spacing: 0.22em;
    font-weight: var(--font-weight-medium, 500);
    color: var(--text-secondary, #6b5d52);
    margin-bottom: var(--sp-4, 16px);
  }

  .hero-split__heading {
    font-family: var(--font-display);
    font-size: clamp(40px, 3.9vw, 58px);
    line-height: var(--line-height-display, 1.08);
    font-weight: var(--font-weight-regular, 400);
    letter-spacing: var(--letter-spacing-tight, -0.04em);
    color: var(--text-primary, #1a1815);
    margin: 0 0 var(--sp-5, 24px) 0;
  }

  .hero-split__subtext {
    font-family: var(--font-body);
    font-size: clamp(16px, 1.2vw, 19px);
    line-height: var(--line-height-relaxed, 1.5);
    color: var(--text-secondary, #6b5d52);
    max-width: 460px;
    margin: 0 0 var(--sp-6, 32px) 0;
  }

  .hero-split__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4, 16px);
    align-items: center;
  }

  .hero-split__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--btn-height, 52px);
    padding: 0 var(--btn-padding-x, 32px);
    font-family: var(--font-body);
    font-weight: var(--font-weight-medium, 500);
    font-size: var(--btn-font-size, 14px);
    letter-spacing: 0.01em;
    text-decoration: none;
    border-radius: var(--btn-radius, 4px);
    transition: all var(--timing-short, 0.2s) var(--ease-standard, ease);
  }

  .hero-split__btn--primary {
    background-color: var(--color-brown, #4a2c18);
    color: var(--color-cream, #f5f1ed);
    border: 1px solid var(--color-brown, #4a2c18);
  }

  .hero-split__btn--primary:hover {
    background-color: var(--color-brown-dark, #2f1a0d);
    border-color: var(--color-brown-dark, #2f1a0d);
    color: var(--color-cream, #f5f1ed);
  }

  .hero-split__btn--secondary {
    background-color: transparent;
    color: var(--text-primary, #1a1815);
    border: 1px solid var(--border-dark, #6b5d52);
  }

  .hero-split__btn--secondary:hover {
    background-color: rgba(0, 0, 0, 0.03);
    border-color: var(--text-primary, #1a1815);
  }

  /* --- Feature chips --- */
  .hero-split__features {
    list-style: none;
    margin: clamp(24px, 3.2vh, 44px) 0 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4, 16px) var(--sp-6, 32px);
  }

  .hero-split__feature {
    display: flex;
    align-items: center;
    gap: var(--sp-3, 12px);
    margin: 0;
  }

  .hero-split__feature-icon {
    color: var(--color-bark, #6b5d52);
    flex-shrink: 0;
    display: flex;
  }

  .hero-split__feature-icon svg {
    width: 22px;
    height: 22px;
  }

  .hero-split__feature-text {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm, 14px);
    line-height: var(--line-height-snug, 1.3);
    color: var(--text-secondary, #6b5d52);
  }

  /* --- Media column --- */
  .hero-split__media-frame {
    position: relative;
    width: 100%;
  }

  .hero-split__img {
    width: 100%;
    height: min(72svh, 640px);
    object-fit: cover;
    border-radius: var(--radius-lg, 8px);
    display: block;
  }

  .hero-split__badge {
    position: absolute;
    right: var(--sp-5, 24px);
    bottom: var(--sp-5, 24px);
    display: flex;
    align-items: center;
    gap: var(--sp-3, 12px);
    max-width: 300px;
    padding: var(--sp-3, 12px) var(--sp-4, 16px);
    background-color: rgba(26, 24, 21, 0.82);
    backdrop-filter: blur(6px);
    border-radius: var(--radius-md, 4px);
    box-shadow: var(--shadow-elevation-3);
  }

  .hero-split__badge-avatars img {
    width: 68px;
    height: auto;
    border-radius: var(--radius-full, 9999px);
  }

  .hero-split__badge-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .hero-split__badge-text {
    font-family: var(--font-body);
    font-size: var(--font-size-caption, 12px);
    line-height: var(--line-height-snug, 1.3);
    color: var(--color-cream, #f5f1ed);
  }

  .hero-split__badge-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-2, 8px);
  }

  .hero-split__badge-stars {
    display: inline-flex;
    gap: 1px;
    color: var(--color-warning, #c9913d);
  }

  .hero-split__badge-rating {
    font-family: var(--font-body);
    font-size: var(--font-size-caption, 12px);
    font-weight: var(--font-weight-semibold, 600);
    color: var(--color-cream, #f5f1ed);
  }

  /* --- Responsive (desktop-first overrides) --- */

  /* Large laptop / small desktop */
  @media screen and (max-width: 1200px) {
    .hero-split__inner {
      gap: clamp(24px, 3vw, 48px);
    }
    .hero-split__img {
      height: min(66svh, 560px);
    }
  }

  /* Tablet & below: stack, release the one-screen lock so nothing clips */
  @media screen and (max-width: 900px) {
    .hero-split {
      min-height: auto;
      align-items: start;
      padding: calc(var(--hero-header-clear) + var(--sp-4, 16px)) 0 var(--sp-7, 48px);
    }
    .hero-split__inner {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-6, 32px);
    }
    .hero-split__text {
      max-width: 640px;
      order: 1;
    }
    .hero-split__media {
      order: 2;
    }
    .hero-split__img {
      height: clamp(300px, 52vw, 460px);
    }
  }

  @media screen and (max-width: 768px) {
    .hero-split__text {
      grid-column: 1;
      grid-row: 2;
      padding-inline: var(--sp-4, 16px);
    }
    .hero-split__media {
      grid-column: 1;
      grid-row: 1;
    }
  }

  /* Mobile */
  @media screen and (max-width: 600px) {
    .hero-split {
      --hero-header-clear: 72px;
      padding-bottom: var(--sp-6, 32px);
    }
    .hero-split__features {
      gap: var(--sp-3, 12px) var(--sp-4, 16px);
    }
    .hero-split__feature {
      flex: 0 0 calc(50% - var(--sp-4, 16px));
    }
    .hero-split__buttons .hero-split__btn {
      flex: 1 1 100%;
    }
    .hero-split__img {
      height: clamp(260px, 64vw, 380px);
    }
    .hero-split__badge {
      right: var(--sp-3, 12px);
      bottom: var(--sp-3, 12px);
      max-width: calc(100% - var(--sp-6, 32px));
    }

    .hero-split {
      padding-top: 65px;
    }
    .hero-split__img {
      border-radius: 0;
    }
    .hero-split__inner {
      padding-inline: 0;
    }
    .hero-split__eyebrow {
      text-align: center;
    }
    .hero-split__heading {
      text-align: center;
    }
    .hero-split__subtext {
      text-align: center;
    }
    .hero-split__features {
      align-items: center;
      justify-content: center;
    }
  }

  /* Small mobile: features full-width for tap comfort */
  @media screen and (max-width: 400px) {
    .hero-split__feature {
    }
  }

  /* Short/landscape viewports: don't force a full screen that clips content */
  @media screen and (max-height: 640px) and (min-width: 901px) {
    .hero-split {
      min-height: auto;
    }
    .hero-split__img {
      height: clamp(340px, 60svh, 480px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section section-hero-split",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Hero image alt text",
      "default": "Handcrafted solid wood furniture in a refined interior"
    },
    {
      "type": "header",
      "content": "Trust badge"
    },
    {
      "type": "checkbox",
      "id": "show_trust_badge",
      "label": "Show trust badge",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "trust_avatars",
      "label": "Avatars image (small cluster)"
    },
    {
      "type": "text",
      "id": "trust_text",
      "label": "Trust text",
      "default": "Trusted by designers and homeowners worldwide"
    },
    {
      "type": "text",
      "id": "trust_rating",
      "label": "Rating",
      "default": "4.9/5"
    }
  ],
  "blocks": [
    {
      "type": "eyebrow",
      "name": "Eyebrow",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Crafted by nature. Designed to endure." }
      ]
    },
    {
      "type": "heading",
      "name": "Heading",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Heading",
          "default": "Bespoke Wooden Furniture, Sculpted for Your Home"
        }
      ]
    },
    {
      "type": "subtext",
      "name": "Subtext",
      "limit": 1,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Subtext",
          "default": "Handcrafted solid wood pieces, made to order in custom dimensions, finishes, and forms for refined interiors."
        }
      ]
    },
    {
      "type": "buttons",
      "name": "Buttons",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Start a Custom Commission" },
        { "type": "url", "id": "primary_link", "label": "Primary link" },
        { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "View Signature Pieces" },
        { "type": "url", "id": "secondary_link", "label": "Secondary link" }
      ]
    },
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "wood", "label": "Wood" },
            { "value": "ruler", "label": "Ruler / measure" },
            { "value": "consult", "label": "Consultation" },
            { "value": "truck", "label": "Delivery" }
          ],
          "default": "wood"
        },
        { "type": "text", "id": "text", "label": "Text", "default": "Solid Wood Only" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "blocks": [
        { "type": "heading" },
        { "type": "subtext" },
        { "type": "buttons" },
        { "type": "feature", "settings": { "icon": "wood", "text": "Solid Wood Only" } },
        { "type": "feature", "settings": { "icon": "ruler", "text": "Made to Measure" } },
        { "type": "feature", "settings": { "icon": "consult", "text": "Design Consultation" } },
        { "type": "feature", "settings": { "icon": "truck", "text": "White-Glove Delivery US & EU" } }
      ]
    }
  ]
}
{% endschema %}
