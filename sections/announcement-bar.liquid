{%- comment -%}
  Top Bar Announcement (slim, static)

  Content is driven by the "Top Bar Announcement" metaobject (type: top_bar_announcement):
    - html_message : raw HTML injected straight into the bar (server-rendered for SEO/SSR)
    - active       : integer, > 0 shows the bar
    - except_pages : list of page keys on which the bar is hidden. Each entry is matched
                     against template.name (e.g. "index", "product", "cart") and request.path
                     (exact or partial, e.g. "/cart", "/products").

  The bar renders on every page because this section belongs to the header-group.
  The message sits still, centered in the bar (no scrolling marquee).
{%- endcomment -%}

{%- liquid
  assign ann = null
  for entry in metaobjects.top_bar_announcement.values
    if entry.active.value > 0
      assign ann = entry
      break
    endif
  endfor
-%}

{%- if ann != null and ann.html_message.value != blank -%}
  {%- liquid
    assign show_bar = true
    assign except = ann.except_pages.value
    if except != blank and except.size > 0
      assign tpl = template.name | downcase
      assign path = request.path | downcase
      for raw in except
        assign key = raw | downcase | strip
        if key == blank
          continue
        endif
        if key == tpl or key == path
          assign show_bar = false
          break
        endif
        if path contains key
          assign show_bar = false
          break
        endif
      endfor
    endif
  -%}

  {%- if show_bar -%}
    <wd-announcement-bar
      class="wd-topbar"
      role="region"
      aria-label="Announcement"
    >
      <div class="wd-topbar__viewport">
        <div class="wd-topbar__track">
          <div class="wd-topbar__group">{{ ann.html_message.value }}</div>
        </div>
      </div>
    </wd-announcement-bar>
  {%- endif -%}
{%- endif -%}

{% stylesheet %}
  .wd-topbar {
    display: block;
    width: 100%;
    overflow: hidden;
    background-color: var(--color-earth-brown, #4a2c18);
    color: var(--color-milk, #f7f2ec);
    font-family: var(--font-primary--family, sans-serif);
  }

  .wd-topbar__viewport {
    width: 100%;
    overflow: hidden;
  }

  .wd-topbar__track {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding-block: var(--space-1, 4px);
  }

  .wd-topbar__group {
    flex: 0 0 auto;
    display: flex;
    align-items: center;
    white-space: nowrap;
    padding-block: var(--space-2, 6px);
    font-size: var(--text-xs, 12px);
    line-height: 1.2;
    letter-spacing: 0.08em;
  }

  /* Normalise the merchant-authored html_message so it flows inline for the ticker.
     Width/background are neutralised so the bar stays one uniform espresso colour. */
  .wd-topbar__group > * {
    width: auto !important;
    max-width: none !important;
    margin: 0 !important;
    background: transparent !important;
  }

  /* Desktop-first: tighten spacing on smaller screens (rule #1) */
  @media (max-width: 749px) {
    .wd-topbar__group {
      font-size: var(--text-xs, 11px);
      letter-spacing: 0.05em;
    }

    .wd-topbar__group .announce-bar .announce-bar-item {
      font-size: 12px;
      font-weight: 400;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [],
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text (unused — content comes from the metaobject)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (unused)"
        }
      ]
    }
  ]
}
{% endschema %}
