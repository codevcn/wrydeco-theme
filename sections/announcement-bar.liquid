{%- if section.blocks.size > 0 -%}
  <div class="announcement-bar" role="region" aria-label="{{ 'general.announcement_bar' | t | default: 'Announcement' }}">
    <div class="announcement-bar__inner">
      {%- for block in section.blocks -%}
        <div class="announcement-bar__message" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}
            <a href="{{ block.settings.link }}" class="announcement-bar__link">
              {{ block.settings.text | escape }}
            </a>
          {%- else -%}
            <p>{{ block.settings.text | escape }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
{%- endif -%}

{% stylesheet %}
  .announcement-bar {
    /* Using design token for dark background and light text */
    background-color: var(--color-1, #000);
    color: var(--color-10, #fff);
    text-align: center;
    padding: var(--space-2, 6px) var(--space-4, 10px);
    font-size: var(--text-xs, 12px);
    font-weight: var(--font-weight-600, 600);
    line-height: 1.2;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .announcement-bar__inner {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-4, 10px);
  }

  .announcement-bar__message p,
  .announcement-bar__link {
    margin: 0;
    color: inherit;
    text-decoration: none;
    padding: 0;
  }

  .announcement-bar__link:hover {
    text-decoration: underline;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Announcement Bar",
  "max_blocks": 3,
  "blocks": [
    {
      "type": "announcement",
      "name": "Announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "default": "5% Off Code: ASHDECO5",
          "label": "Text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "default": {
    "blocks": [
      {
        "type": "announcement"
      }
    ]
  }
}
{% endschema %}
