{% comment %}
  Product Artist Section

  Renders the product's artist/craftsperson as a standalone, gallery-style
  section. Author data is sourced ONLY from the new metaobject reference
  (product.metafields.custom.author_info) — no legacy metafield fallback.

  The role label, "view profile" link and the recognition list are not part of
  the author metaobject, so they are exposed as section settings / blocks for
  merchants to configure in the theme editor.
{% endcomment %}

{% liquid
  assign author = blank
  assign author_name = blank
  assign author_bio = blank
  assign author_image_url = blank
  assign has_author_info = false

  if product != blank
    assign author = product.metafields.custom.author_info.value | first
  endif

  if author != blank
    assign author_name = author.author_name.value
    assign author_bio = author.author_bio.value
    assign author_image_url = author.author_image_url.value

    if author_name != blank or author_bio != blank or author_image_url != blank
      assign has_author_info = true
    endif
  endif
%}

<div class="product-artist">
  <div class="product-artist__card">
    {% if has_author_info %}
      <section
        class="product-artist__inner"
        aria-labelledby="ProductArtistHeading-{{ section.id }}"
        data-product-author
      >
        <div class="product-artist__profile">
          {% if section.settings.heading != blank %}
            <p class="product-artist__eyebrow" id="ProductArtistHeading-{{ section.id }}">
              {{ section.settings.heading | escape }}
            </p>
          {% endif %}

          <div class="product-artist__identity">
            {% if author_image_url != blank %}
              <div class="product-artist__avatar">
                <img
                  class="product-artist__avatar-img"
                  src="{{ author_image_url | escape }}"
                  alt="{{ author_name | default: 'Product artist' | escape }}"
                  width="160"
                  height="160"
                  loading="lazy"
                >
              </div>
            {% endif %}

            <div class="product-artist__meta">
              {% if author_name != blank %}
                <h2 class="product-artist__name">{{ author_name | escape }}</h2>
              {% endif %}
              {% if section.settings.role_label != blank %}
                <p class="product-artist__role">{{ section.settings.role_label | escape }}</p>
              {% endif %}
            </div>
          </div>

          {% if section.settings.show_view_profile and section.settings.view_profile_link != blank %}
            <a class="product-artist__profile-btn" href="{{ section.settings.view_profile_link }}">
              {{ section.settings.view_profile_label | default: 'View profile' | escape }}
            </a>
          {% endif %}

          {% if author_bio != blank %}
            <div class="product-artist__bio">
              {{ author_bio | escape | newline_to_br }}
            </div>
          {% endif %}
        </div>

        {% if section.blocks.size > 0 %}
          <div class="product-artist__recognition-panel">
            <hr class="product-artist__divider">

            {% if section.settings.recognition_heading != blank %}
              <p class="product-artist__eyebrow product-artist__eyebrow--sub">
                {{ section.settings.recognition_heading | escape }}
              </p>
            {% endif %}

            <ul class="product-artist__recognition" role="list">
              {% for block in section.blocks %}
                {% if block.type == 'recognition' %}
                  <li class="product-artist__recognition-item" {{ block.shopify_attributes }}>
                    <span class="product-artist__recognition-icon" aria-hidden="true">
                      {% render 'icon-artist-recognition', icon: block.settings.icon %}
                    </span>
                    <span class="product-artist__recognition-text">{{ block.settings.text | escape }}</span>
                  </li>
                {% endif %}
              {% endfor %}
            </ul>
          </div>
        {% endif %}
      </section>
    {% else %}
      <p class="product-artist__empty" data-product-author-empty>Chưa có thông tin tác giả cho sản phẩm này</p>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .product-artist {
    padding: var(--section-spacing-mobile) var(--layout-gutter-mobile);
  }

  .product-artist__card {
    max-width: 30rem;
    margin-inline: auto;
    padding: var(--card-padding-mobile) var(--card-padding-mobile) var(--sp-3);
    background-color: var(--surface-elevated);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }

  .product-artist__eyebrow {
    margin: 0 0 var(--sp-4);
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .product-artist__eyebrow--sub {
    margin-top: var(--sp-5);
    margin-bottom: var(--sp-3);
  }

  .product-artist__identity {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }

  .product-artist__avatar {
    flex: 0 0 calc(var(--sp-8) + var(--sp-2));
    width: 2rem;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius-full);
    background-color: var(--color-stone);
  }

  .product-artist__avatar-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-artist__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-display-sm);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-tight);
    color: var(--text-primary);
  }

  .product-artist__role {
    margin: var(--sp-1) 0 0;
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    color: var(--text-secondary);
  }

  .product-artist__profile-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(var(--sp-7) + var(--sp-1));
    margin-top: var(--sp-5);
    padding: var(--button-padding-vertical) var(--button-padding-horizontal);
    border: 1px solid var(--color-ebony);
    border-radius: var(--radius-md);
    background-color: transparent;
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-ebony);
    transition: var(--transition-fast);
  }

  .product-artist__profile-btn:hover {
    background-color: var(--color-ebony);
    color: var(--color-cream);
  }

  .product-artist__bio {
    margin-top: var(--sp-5);
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
    color: var(--text-secondary);
  }

  .product-artist__divider {
    margin: var(--sp-5) 0 0;
    border: 0;
    border-top: 1px solid var(--border-light);
  }

  .product-artist__recognition {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    margin: 0;
    padding: 0;
    list-style: none;
    border-top: 1px solid var(--border-light);
    border-left: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .product-artist__recognition-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    aspect-ratio: 1 / 1;
    padding: var(--sp-4);
    text-align: center;
    border-right: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
    transition: var(--transition-fast);
    margin: 0;
  }

  .product-artist__recognition-item:hover {
    background-color: var(--color-cream);
  }

  .product-artist__recognition-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: calc(var(--sp-5) + var(--sp-5) - var(--sp-1));
    height: calc(var(--sp-5) + var(--sp-5) - var(--sp-1));
    border-radius: var(--radius-full);
    border: 1px solid var(--border-light);
    background-color: var(--color-cream);
    color: var(--color-clay);
    transition: var(--transition-fast);
  }

  .product-artist__recognition-item:hover .product-artist__recognition-icon {
    background-color: var(--surface-elevated);
    border-color: var(--color-clay);
  }

  .product-artist__recognition-icon svg {
    width: var(--font-size-body-2xl);
    height: var(--font-size-body-2xl);
  }

  .product-artist__recognition-text {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-normal);
    color: var(--text-primary);
  }

  .product-artist__empty {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    color: var(--text-secondary);
  }

  @media (min-width: 720px) {
    .product-artist {
      padding: var(--section-spacing-tablet) var(--layout-padding-tablet);
    }

    .product-artist__card {
      max-width: var(--layout-max-width);
      padding: var(--sp-6);
    }

    .product-artist__inner {
      display: grid;
      grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
      align-items: start;
      gap: var(--sp-6);
    }

    .product-artist__avatar {
      flex: none;
      width: 8rem;
    }

    .product-artist__divider {
      display: none;
    }

    .product-artist__eyebrow--sub {
      margin-top: 0;
      margin-bottom: var(--sp-4);
    }

    .product-artist__recognition-item {
      aspect-ratio: auto;
      min-height: calc(var(--sp-8) * 2);
    }
  }

  @media (min-width: 1024px) {
    .product-artist {
      padding-top: 10px;
      padding-bottom: 10px;
    }

    .product-artist__inner {
      gap: var(--sp-7);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Artist",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Eyebrow heading",
      "default": "About artist"
    },
    {
      "type": "text",
      "id": "role_label",
      "label": "Artist role label",
      "info": "Shown under the artist name. Not part of the author metaobject.",
      "default": "Master Craftsman"
    },
    {
      "type": "header",
      "content": "View profile button"
    },
    {
      "type": "checkbox",
      "id": "show_view_profile",
      "label": "Show view profile button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_profile_label",
      "label": "Button label",
      "default": "View profile"
    },
    {
      "type": "url",
      "id": "view_profile_link",
      "label": "Button link",
      "info": "Button is hidden until a link is set."
    },
    {
      "type": "header",
      "content": "Recognition"
    },
    {
      "type": "text",
      "id": "recognition_heading",
      "label": "Recognition heading",
      "default": "Artist recognition"
    }
  ],
  "blocks": [
    {
      "type": "recognition",
      "name": "Recognition",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "award", "label": "Award" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "hand", "label": "Hand" },
            { "value": "check", "label": "Check" }
          ],
          "default": "award"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Recognition"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Artist",
      "blocks": [
        { "type": "recognition", "settings": { "icon": "award", "text": "Carved with precision" } },
        { "type": "recognition", "settings": { "icon": "leaf", "text": "One of a kind, every time" } },
        { "type": "recognition", "settings": { "icon": "hand", "text": "Made entirely by hand" } },
        { "type": "recognition", "settings": { "icon": "check", "text": "Direct from the workshop" } }
      ]
    }
  ]
}
{% endschema %}
