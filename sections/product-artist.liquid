{% comment %}
  Product Artist Section

  Renders the product's artist/craftsperson as a standalone, gallery-style
  section. Author data is sourced ONLY from the new metaobject reference
  (product.metafields.custom.author_info) â€” no legacy metafield fallback.

  The role label, "view profile" link and the recognition list are not part of
  the author metaobject, so they are exposed as section settings / blocks for
  merchants to configure in the theme editor.
{% endcomment %}

{% liquid
  assign author = blank
  assign author_name = blank
  assign author_bio = blank
  assign author_image_url = blank
  assign has_author_info = false

  if product != blank
    assign author = product.metafields.custom.author_info.value | first
  endif

  if author != blank
    assign author_name = author.author_name.value
    assign author_bio = author.author_bio.value
    assign author_image_url = author.author_image_url.value

    if author_name != blank or author_bio != blank or author_image_url != blank
      assign has_author_info = true
    endif
  endif
%}

<div class="product-artist">
  <div class="product-artist__card">
    {% if has_author_info %}
      <section
        class="product-artist__inner{% if author_image_url == blank %} product-artist__inner--no-media{% endif %}"
        aria-labelledby="ProductArtistHeading-{{ section.id }}"
        data-product-author
      >
        {% if author_image_url != blank %}
          <div class="product-artist__media">
            <img
              class="product-artist__portrait"
              src="{{ author_image_url | escape }}"
              alt="{{ author_name | default: 'Product artist' | escape }}"
              width="800"
              height="1200"
              loading="lazy"
            >
          </div>
        {% endif %}

        <div class="product-artist__profile">
          <div class="product-artist__profile-main">
            {% if section.settings.heading != blank %}
              <p class="product-artist__eyebrow">{{ section.settings.heading | escape }}</p>
            {% endif %}

            {% if author_name != blank %}
              <h2 class="product-artist__name" id="ProductArtistHeading-{{ section.id }}">
                {{ author_name | escape }}
              </h2>
            {% else %}
              <h2 class="product-artist__name" id="ProductArtistHeading-{{ section.id }}">
                {{ section.settings.heading | default: 'Product artist' | escape }}
              </h2>
            {% endif %}

            {% if section.settings.role_label != blank %}
              <p class="product-artist__role">{{ section.settings.role_label | escape }}</p>
            {% endif %}

            {% if author_bio != blank %}
              <div class="product-artist__bio">
                {{ author_bio | escape | newline_to_br }}
              </div>
            {% endif %}
          </div>

          {% if author_name != blank %}
            <div class="product-artist__signature" aria-hidden="true">
              <span class="product-artist__signature-mark">&ldquo;</span>
              <span>{{ author_name | escape }}</span>
            </div>
          {% endif %}

          {% if section.settings.show_view_profile %}
            {%- assign author_handle = author_name | handleize -%}
            {%- assign default_profile_link = '/pages/product-author/' | append: author_handle -%}
            {%- assign final_profile_link = default_profile_link -%}
            {%- if section.settings.view_profile_link != blank and section.settings.view_profile_link != '#' -%}
              {%- assign final_profile_link = section.settings.view_profile_link -%}
            {%- endif -%}

            {% if final_profile_link != '/pages/product-author/' %}
              <a class="product-artist__profile-link" href="{{ final_profile_link }}">
                <span>{{ section.settings.view_profile_label | default: 'View profile' | escape }}</span>
                <span aria-hidden="true">&rarr;</span>
              </a>
            {% endif %}
          {% endif %}
        </div>

        {% if section.blocks.size > 0 %}
          <div
            class="product-artist__recognition-panel"
            {% if section.settings.recognition_heading != blank %}
              aria-label="{{ section.settings.recognition_heading | escape }}"
            {% endif %}
          >
            <ul class="product-artist__recognition" role="list">
              {% for block in section.blocks %}
                {% if block.type == 'recognition' %}
                  <li class="product-artist__recognition-item" {{ block.shopify_attributes }}>
                    <span class="product-artist__recognition-icon" aria-hidden="true">
                      {% render 'icon-artist-recognition', icon: block.settings.icon %}
                    </span>
                    <span class="product-artist__recognition-text">{{ block.settings.text | escape }}</span>
                    {% if block.settings.description != blank %}
                      <span class="product-artist__recognition-description">
                        {{ block.settings.description | escape }}
                      </span>
                    {% endif %}
                  </li>
                {% endif %}
              {% endfor %}
            </ul>

            <div class="product-artist__recognition-summary">
              <div class="product-artist__summary-cell">
                <span class="product-artist__summary-value">18+</span>
                {% if section.settings.recognition_heading != blank %}
                  <span class="product-artist__summary-label">
                    {{ section.settings.recognition_heading | escape }}
                  </span>
                {% endif %}
              </div>

              <div class="product-artist__summary-cell product-artist__summary-cell--maker">
                {% if author_name != blank %}
                  <span class="product-artist__summary-signature">{{ author_name | escape }}</span>
                {% endif %}
                {% if section.settings.role_label != blank %}
                  <span class="product-artist__summary-label">{{ section.settings.role_label | escape }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        {% endif %}
      </section>
    {% else %}
      <p class="product-artist__empty" data-product-author-empty>No author information is available for this product</p>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .product-artist {
    width: 100%;
    padding: var(--section-spacing-desktop) var(--layout-padding-desktop);
    overflow: clip;
    background-color: var(--surface-default);
  }

  .product-artist__card {
    width: 100%;
    max-width: var(--layout-max-width);
    margin-inline: auto;
    background-color: var(--surface-default);
  }

  .product-artist__inner {
    display: grid;
    grid-template-columns: minmax(0, 4.2fr) minmax(0, 4.8fr) minmax(0, 6.5fr);
    min-height: clamp(
      calc(var(--sp-8) * 7),
      calc(100dvh - (var(--section-spacing-desktop) * 2)),
      calc(var(--sp-8) * 12)
    );
    height: auto;
  }

  .product-artist__inner--no-media {
    grid-template-columns: minmax(0, 5fr) minmax(0, 7fr);
  }

  .product-artist__media {
    min-width: 0;
    height: 100%;
    margin-right: var(--sp-6);
    overflow: hidden;
    border-radius: var(--radius-lg);
    background-color: var(--surface-tertiary);
  }

  .product-artist__portrait {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .product-artist__profile {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-width: 0;
    padding: var(--sp-7);
    border-right: 1px solid #33333329;
  }

  .product-artist__profile-main {
    min-width: 0;
  }

  .product-artist__eyebrow {
    margin: 0 0 var(--sp-3);
    font-family: var(--font-display);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-normal);
    color: var(--text-primary);
  }

  .product-artist__name {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-display-lg);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-normal);
    letter-spacing: var(--letter-spacing-normal);
    color: var(--text-primary);
    text-wrap: balance;
  }

  .product-artist__role {
    margin: var(--sp-1) 0 0;
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-bark);
  }

  .product-artist__bio {
    margin-top: var(--sp-6);
    padding-top: var(--sp-5);
    border-top: 1px solid var(--border-default);
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
    color: var(--text-primary);
    text-wrap: pretty;
  }

  .product-artist__profile-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    margin-top: var(--sp-5);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    text-decoration: none;
    transition: color var(--timing-short) var(--ease-standard);
    width: fit-content;
    padding: 10px 22px;
    margin-inline: auto;
    border-radius: 33px;
    background-color: #333;
    color: #fff;
  }

  .product-artist__profile-link:hover {
    color: var(--color-clay);
  }

  .product-artist__profile-link:focus-visible {
    outline: 2px solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  .product-artist__signature {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--sp-1);
    margin-top: var(--sp-5);
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-style: italic;
    color: var(--color-bark);
  }

  .product-artist__signature-mark {
    height: var(--sp-4);
    font-size: var(--font-size-display-md);
    line-height: var(--line-height-tight);
    color: var(--color-clay);
  }

  .product-artist__recognition-panel {
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    min-width: 0;
    padding-left: var(--sp-6);
  }

  .product-artist__recognition {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    grid-template-rows: repeat(2, minmax(0, 1fr));
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .product-artist__recognition-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    padding: var(--sp-4);
    text-align: center;
    border-bottom: 1px solid var(--border-default);
    transition: background-color var(--timing-short) var(--ease-standard);
    margin: 0;
  }

  .product-artist__recognition-item:nth-child(odd) {
    border-right: 1px solid var(--border-default);
  }

  .product-artist__recognition-item:nth-last-child(-n + 2) {
    border-bottom: 0;
  }

  .product-artist__recognition-item:hover {
    background-color: var(--surface-elevated);
  }

  .product-artist__recognition-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: var(--sp-8);
    height: var(--sp-8);
    border-radius: var(--radius-full);
    border: 1px solid var(--border-dark);
    color: var(--color-bark);
    transition: border-color var(--timing-short) var(--ease-standard), color var(--timing-short) var(--ease-standard);
  }

  .product-artist__recognition-item:hover .product-artist__recognition-icon {
    border-color: var(--color-clay);
    color: var(--color-clay);
  }

  .product-artist__recognition-icon svg {
    width: var(--font-size-body-2xl);
    height: var(--font-size-body-2xl);
  }

  .product-artist__recognition-text {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-normal);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .product-artist__recognition-description {
    max-width: 26ch;
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
    color: var(--text-primary);
    text-wrap: pretty;
  }

  .product-artist__recognition-summary {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    min-height: calc(var(--sp-8) * 2);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
  }

  .product-artist__summary-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    min-width: 0;
    padding: var(--sp-4);
    text-align: center;
  }

  .product-artist__summary-cell + .product-artist__summary-cell {
    border-left: 1px solid var(--border-default);
  }

  .product-artist__summary-value {
    font-family: var(--font-roboto);
    font-size: var(--font-size-display-md);
    line-height: var(--line-height-tight);
    color: var(--color-bark);
  }

  .product-artist__summary-signature {
    overflow: hidden;
    max-width: 100%;
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-style: italic;
    color: var(--color-bark);
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .product-artist__summary-label {
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-normal);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--text-primary);
    text-wrap: balance;
  }

  .product-artist__empty {
    max-width: var(--layout-max-width);
    margin: 0;
    margin-inline: auto;
    padding: var(--card-padding);
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    color: var(--text-secondary);
  }

  @media (max-width: 1024px) {
    .product-artist {
      padding: var(--section-spacing-tablet) var(--layout-padding-tablet);
    }

    .product-artist__inner {
      grid-template-columns: minmax(0, 4.2fr) minmax(0, 4.8fr) minmax(0, 6.5fr);
      min-height: clamp(
        calc(var(--sp-8) * 7),
        calc(100dvh - (var(--section-spacing-tablet) * 2)),
        calc(var(--sp-8) * 11)
      );
      height: auto;
    }

    .product-artist__media {
      margin-right: var(--sp-5);
    }

    .product-artist__profile {
      padding: var(--sp-5);
    }

    .product-artist__recognition-panel {
      padding-left: var(--sp-5);
    }

    .product-artist__recognition-item {
      padding: var(--sp-3);
    }
  }

  @media (max-width: 768px) {
    .product-artist__role {
      text-align: center;
    }

    .product-artist {
      padding: var(--section-spacing-mobile) var(--layout-padding-mobile);
    }

    .product-artist__inner {
      grid-template-columns: minmax(0, 1fr);
      height: auto;
    }

    .product-artist__media {
      height: auto;
      max-height: calc(var(--sp-8) * 4);
      margin-right: 0;
      aspect-ratio: 16 / 10;
    }

    .product-artist__profile {
      padding: var(--sp-5) 0;
      border-right: 0;
      border-bottom: 1px solid var(--border-default);
    }

    /* Decorative pull-quote is redundant on mobile — the maker name is already
       repeated in the recognition summary below. */
    .product-artist__signature {
      display: none;
    }

    .product-artist__bio {
      margin-top: var(--sp-2);
      padding-top: var(--sp-4);
    }

    .product-artist__recognition-panel {
      padding-top: var(--sp-2);
      padding-left: 0;
    }

    .product-artist__recognition-item {
      min-height: calc(var(--sp-8) * 3);
    }

    .product-artist__recognition-summary {
      margin-top: var(--sp-2);
    }
  }

  @media (max-width: 480px) {
    .product-artist__eyebrow {
      font-family: var(--font-body);
      font-size: var(--font-size-caption);
      font-weight: var(--font-weight-bold);
      letter-spacing: var(--letter-spacing-wide);
      text-transform: uppercase;
      color: var(--text-secondary);
      margin-bottom: var(--sp-1);
      text-align: center;
    }

    .product-artist__name {
      font-size: var(--font-size-display-sm);
      text-align: center;
    }

    .product-artist__recognition-icon {
      width: var(--sp-7);
      height: var(--sp-7);
    }

    .product-artist__recognition-icon svg {
      width: var(--font-size-body-xl);
      height: var(--font-size-body-xl);
    }

    .product-artist__recognition-item {
      min-height: calc(var(--sp-8) * 2);
      padding-inline: var(--sp-2);
    }

    .product-artist__summary-cell {
      padding-inline: var(--sp-2);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Artist",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Eyebrow heading",
      "default": "About artist"
    },
    {
      "type": "text",
      "id": "role_label",
      "label": "Artist role label",
      "info": "Shown under the artist name. Not part of the author metaobject.",
      "default": "Master Craftsman"
    },
    {
      "type": "header",
      "content": "View profile button"
    },
    {
      "type": "checkbox",
      "id": "show_view_profile",
      "label": "Show view profile button",
      "default": true
    },
    {
      "type": "text",
      "id": "view_profile_label",
      "label": "Button label",
      "default": "View profile"
    },
    {
      "type": "url",
      "id": "view_profile_link",
      "label": "Button link",
      "info": "Leave empty to automatically link to the artist's profile page."
    },
    {
      "type": "header",
      "content": "Recognition"
    },
    {
      "type": "text",
      "id": "recognition_heading",
      "label": "Recognition heading",
      "default": "Artist recognition"
    }
  ],
  "blocks": [
    {
      "type": "recognition",
      "name": "Recognition",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "award", "label": "Award" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "hand", "label": "Hand" },
            { "value": "check", "label": "Check" }
          ],
          "default": "award"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Recognition"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Artist",
      "blocks": [
        {
          "type": "recognition",
          "settings": {
            "icon": "award",
            "text": "Carved with precision",
            "description": "Each detail is shaped with patient, practiced attention."
          }
        },
        {
          "type": "recognition",
          "settings": {
            "icon": "leaf",
            "text": "One of a kind, every time",
            "description": "Natural variation gives every finished piece its own character."
          }
        },
        {
          "type": "recognition",
          "settings": {
            "icon": "hand",
            "text": "Made entirely by hand",
            "description": "Made by skilled hands with close attention to form and finish."
          }
        },
        {
          "type": "recognition",
          "settings": {
            "icon": "check",
            "text": "Direct from the workshop",
            "description": "Crafted in the workshop and prepared with care for its destination."
          }
        }
      ]
    }
  ]
}
{% endschema %}
