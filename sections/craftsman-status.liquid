<div class="craftsman-status-section">
  <div class="craftsman-status-card">
    <div class="cs-header">
      <span class="cs-header-text">{{ section.settings.status_text }}</span>
    </div>

    <div class="cs-profile">
      <div class="cs-avatar">
        {%- if section.settings.avatar != blank -%}
          <img
            src="{{ section.settings.avatar | image_url: width: 160 }}"
            alt="{{ section.settings.name }}"
            loading="lazy"
          >
        {%- else -%}
          <!-- Placeholder avatar if not selected -->
          <img src="{{ 'fouder_wrydeco.webp' | asset_url }}" alt="Craftsman" loading="lazy">
        {%- endif -%}
      </div>
      <div class="cs-profile-info">
        <h3 class="cs-name">{{ section.settings.name }}</h3>
        <p class="cs-title">{{ section.settings.title }}</p>
        <p class="cs-subtitle">— {{ section.settings.subtitle }} —</p>
      </div>
    </div>

    <hr class="cs-divider">

    <div class="cs-quote">"{{ section.settings.quote }}"</div>

    <hr class="cs-divider">

    <div class="cs-stats">
      <div class="cs-stat">
        <div class="cs-stat-value">
          {{ section.settings.stat1_value_pre -}}
          <span class="cs-stat-value-italic">{{ section.settings.stat1_value_italic }}</span>
        </div>
        <div class="cs-stat-label">{{ section.settings.stat1_label }}</div>
      </div>
      <div class="cs-stat">
        <div class="cs-stat-value">{{ section.settings.stat2_value }}</div>
        <div class="cs-stat-label">{{ section.settings.stat2_label }}</div>
      </div>
      <div class="cs-stat">
        <div class="cs-stat-value">{{ section.settings.stat3_value }}</div>
        <div class="cs-stat-label">{{ section.settings.stat3_label }}</div>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
  .craftsman-status-section {
    width: 100%;
    display: flex;
    justify-content: center;
    padding: var(--space-12, 64px) var(--space-4, 16px);
    background-color: var(--color-background, #f5f1ed); /* Matches page background */
  }

  .craftsman-status-card {
    background-color: #312111; /* Deep espresso/brown */
    border-radius: 8px;
    padding: 32px;
    max-width: 440px;
    width: 100%;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    color: #e3cca6; /* Cream/gold */
  }

  /* Header */
  .cs-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
  }

  .cs-status-dot {
    width: 8px;
    height: 8px;
    background-color: #6ab054;
    border-radius: 50%;
  }

  .cs-header-text {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #e3cca6;
  }

  /* Profile */
  .cs-profile {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .cs-avatar {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
  }

  .cs-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cs-profile-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs-name {
    font-family: var(--font-heading, 'Times New Roman', serif);
    font-size: 26px;
    font-weight: 400;
    font-style: italic;
    margin: 0;
    color: #f2e2c4;
  }

  .cs-title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 4px 0;
  }

  .cs-subtitle {
    font-family: var(--font-heading, 'Times New Roman', serif);
    font-size: 15px;
    font-style: italic;
    color: rgba(227, 204, 166, 0.7); /* Slightly muted */
    margin: 0;
  }

  /* Divider */
  .cs-divider {
    border: 0;
    height: 1px;
    background-color: rgba(227, 204, 166, 0.15);
    margin: 24px 0;
  }

  /* Quote */
  .cs-quote {
    font-family: var(--font-heading, 'Times New Roman', serif);
    font-size: 20px;
    line-height: 1.5;
    font-style: italic;
    color: #f2e2c4;
    text-align: left;
  }

  /* Stats */
  .cs-stats {
    display: flex;
    justify-content: space-between;
    margin-top: 24px;
  }

  .cs-stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cs-stat-value {
    font-family: var(--font-heading, 'Times New Roman', serif);
    font-size: 22px;
    color: #f2e2c4;
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .cs-stat-value-italic {
    font-style: italic;
    font-size: 18px;
  }

  .cs-stat-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(227, 204, 166, 0.7);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Craftsman Status",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "status_text",
      "label": "Status Text",
      "default": "3 CRAFTSMEN ON DUTY · AVG REPLY 14 MIN"
    },
    {
      "type": "image_picker",
      "id": "avatar",
      "label": "Craftsman Avatar"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Craftsman Name",
      "default": "Mr Nguyen"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "MASTER CARVER · FOUNDER"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "On duty today until 18:00 GMT+7"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "A cabinet that does not fit your room is a cabinet you will resent for life. Measure twice, build once."
    },
    {
      "type": "text",
      "id": "stat1_value_pre",
      "label": "Stat 1 Value (Normal)",
      "default": "22"
    },
    {
      "type": "text",
      "id": "stat1_value_italic",
      "label": "Stat 1 Value (Italic)",
      "default": "yrs"
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Stat 1 Label",
      "default": "CARVING"
    },
    {
      "type": "text",
      "id": "stat2_value",
      "label": "Stat 2 Value",
      "default": "4.98 ★"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Stat 2 Label",
      "default": "CONSULT RATING"
    },
    {
      "type": "text",
      "id": "stat3_value",
      "label": "Stat 3 Value",
      "default": "0%"
    },
    {
      "type": "text",
      "id": "stat3_label",
      "label": "Stat 3 Label",
      "default": "SALES PRESSURE"
    }
  ],
  "presets": [
    {
      "name": "Craftsman Status"
    }
  ]
}
{% endschema %}
