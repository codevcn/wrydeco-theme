{% javascript %}
  (() => {
    if (window.WrydecoCartDrawerInitialized) return;
    window.WrydecoCartDrawerInitialized = true;

    let lastFocusedElement = null;
    let updateController = null;

    const getShell = () => document.querySelector('[data-cart-drawer-shell]');
    const getPanel = () => getShell()?.querySelector('[data-cart-drawer-panel]');

    const floatingWidgetSelectors = [
      '#shopify-chat',
      '#ShopifyChat',
      '#chat-widget-container',
      '.shopify-chat',
      '.shopify-chat-launcher',
      '.intercom-lightweight-app',
      '.crisp-client',
      '[id*="chat" i]',
      '[class*="chat" i]',
      '[id*="inbox" i]',
      '[class*="inbox" i]',
      '[id*="sidekick" i]',
      '[class*="sidekick" i]',
      'iframe[title*="chat" i]',
      'iframe[id*="chat" i]',
      'iframe[src*="chat" i]',
      'iframe[src*="inbox" i]',
      'iframe[src*="sidekick" i]'
    ];

    const shouldHideFloatingWidget = (element) => {
      if (!(element instanceof HTMLElement)) return false;
      if (element.closest('[data-cart-drawer-shell], .cart-drawer__note-popup, #global-toast-container')) return false;

      const style = window.getComputedStyle(element);
      if (style.display === 'none' || style.visibility === 'hidden') return false;

      const rect = element.getBoundingClientRect();
      const isBottomRightFloating =
        style.position === 'fixed' &&
        rect.width > 0 &&
        rect.height > 0 &&
        rect.right > window.innerWidth - 180 &&
        rect.bottom > window.innerHeight - 260;

      return isBottomRightFloating;
    };

    const hideCartDrawerFloatingWidgets = () => {
      const candidates = new Set();

      floatingWidgetSelectors.forEach((selector) => {
        document.querySelectorAll(selector).forEach((element) => candidates.add(element));
      });

      Array.from(document.body.children).forEach((element) => {
        if (shouldHideFloatingWidget(element)) candidates.add(element);
      });

      candidates.forEach((element) => {
        if (!(element instanceof HTMLElement)) return;
        if (element.dataset.cartDrawerHiddenFloating === 'true') return;
        if (!shouldHideFloatingWidget(element) && !element.matches(floatingWidgetSelectors.join(','))) return;

        element.dataset.cartDrawerPreviousStyle = element.getAttribute('style') || '';
        element.dataset.cartDrawerHiddenFloating = 'true';
        element.style.setProperty('display', 'none', 'important');
        element.style.setProperty('visibility', 'hidden', 'important');
        element.style.setProperty('opacity', '0', 'important');
        element.style.setProperty('pointer-events', 'none', 'important');
      });
    };

    const restoreCartDrawerFloatingWidgets = () => {
      document.querySelectorAll('[data-cart-drawer-hidden-floating="true"]').forEach((element) => {
        const previousStyle = element.dataset.cartDrawerPreviousStyle || '';
        if (previousStyle) {
          element.setAttribute('style', previousStyle);
        } else {
          element.removeAttribute('style');
        }

        delete element.dataset.cartDrawerPreviousStyle;
        delete element.dataset.cartDrawerHiddenFloating;
      });
    };

    const updateCartBubble = (count) => {
      document.querySelectorAll('.header__icon--cart').forEach((cartIcon) => {
        let bubble = cartIcon.querySelector('.cart-count-bubble');
        if (count > 0) {
          if (!bubble) {
            bubble = document.createElement('div');
            bubble.className = 'cart-count-bubble';
            bubble.innerHTML = '<span></span>';
            cartIcon.appendChild(bubble);
          }
          bubble.querySelector('span').textContent = count;
        } else if (bubble) {
          bubble.remove();
        }
      });
    };

    const openDrawer = () => {
      const shell = getShell();
      const panel = getPanel();
      if (!shell || !panel) return;
      lastFocusedElement = document.activeElement;
      shell.classList.add('is-open');
      shell.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('cart-drawer-is-open');
      document.body.classList.add('cart-drawer-is-open');
      hideCartDrawerFloatingWidgets();
      syncPendingDiscount();
      window.requestAnimationFrame(() => panel.focus());
    };

    const closeDrawer = () => {
      const shell = getShell();
      if (!shell) return;
      shell.classList.remove('is-open');
      shell.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('cart-drawer-is-open');
      document.body.classList.remove('cart-drawer-is-open');
      restoreCartDrawerFloatingWidgets();
      if (lastFocusedElement instanceof HTMLElement) lastFocusedElement.focus();
    };

    const refreshDrawer = async ({ open = false } = {}) => {
      const shell = getShell();
      if (!shell) return;
      const sectionId = shell.dataset.sectionId || 'cart-drawer';
      const root = window.Shopify?.routes?.root || '/';
      const separator = root.includes('?') ? '&' : '?';
      const response = await fetch(`${root}${separator}section_id=${encodeURIComponent(sectionId)}`, {
        headers: { 'X-Requested-With': 'XMLHttpRequest' },
      });
      if (!response.ok) throw new Error('Unable to refresh your cart.');
      const html = await response.text();
      const parsed = new DOMParser().parseFromString(html, 'text/html');
      const replacement = parsed.querySelector('[data-cart-drawer-shell]');
      if (!replacement) throw new Error('Unable to refresh your cart.');
      const wasOpen = shell.classList.contains('is-open') || open;
      shell.replaceWith(replacement);
      if (wasOpen) openDrawer();
      // Read the exact item count from a clean numeric attribute — the visible
      // "(N pieces added" text starts with "(", so parseInt on it returned NaN
      // and wiped the header badge.
      const count = Number.parseInt(replacement.dataset.cartCount, 10);
      updateCartBubble(Number.isNaN(count) ? 0 : count);
      syncPendingDiscount();
    };

    const changeLine = async (lineItem, quantity) => {
      const shell = getShell();
      const loader = shell?.querySelector('[data-cart-drawer-loading]');
      const lineKey = lineItem?.dataset.lineKey;
      if (!lineKey || !loader) return;
      if (updateController) updateController.abort();
      updateController = new AbortController();
      loader.hidden = false;
      try {
        const root = window.Shopify?.routes?.root || '/';
        const response = await fetch(`${root}cart/change.js`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ id: lineKey, quantity }),
          signal: updateController.signal,
        });
        const cart = await response.json();
        if (!response.ok || cart.status) throw new Error(cart.description || 'Unable to update your cart.');
        updateCartBubble(cart.item_count);
        await refreshDrawer({ open: true });
      } catch (error) {
        if (error.name === 'AbortError') return;
        loader.hidden = true;
        if (window.showToast) {
          window.showToast({ message: error.message, type: 'error', position: 'bottom-right' });
        }
      }
    };

    // Persist the entered code so it is applied at checkout even when the in-cart
    // /discount endpoint can't confirm it (e.g. the Shopify theme dev preview
    // blocks /discount and /checkout with a 401 — they only work on the live store).
    const CHECKOUT_DISCOUNT_KEY = 'wrydeco:pending-discount';
    const rememberCheckoutDiscount = (code) => {
      try {
        window.sessionStorage.setItem(CHECKOUT_DISCOUNT_KEY, code);
      } catch (error) {
        /* sessionStorage unavailable — checkout carry simply won't persist */
      }
    };
    const forgetCheckoutDiscount = () => {
      try {
        window.sessionStorage.removeItem(CHECKOUT_DISCOUNT_KEY);
      } catch (error) {
        /* no-op */
      }
    };
    const getCheckoutDiscount = () => {
      try {
        return window.sessionStorage.getItem(CHECKOUT_DISCOUNT_KEY);
      } catch (error) {
        return null;
      }
    };

    const applyDiscount = async (form) => {
      const input = form.querySelector('[data-cart-discount-input]');
      const code = (input?.value || '').trim();
      const shell = getShell();
      const loader = shell?.querySelector('[data-cart-drawer-loading]');
      if (!loader) return;
      if (!code) {
        input?.focus();
        return;
      }
      loader.hidden = false;
      const root = window.Shopify?.routes?.root || '/';
      const toast = (options) => {
        if (window.showToast) window.showToast(Object.assign({ position: 'bottom-right' }, options));
      };

      try {
        // Shopify's AJAX cart API can't apply discount codes; visiting /discount/CODE
        // applies the code to the cart session server-side (302 -> storefront).
        let response = null;
        try {
          response = await fetch(`${root}discount/${encodeURIComponent(code)}`, { redirect: 'follow' });
        } catch (error) {
          response = null;
        }

        if (response && response.ok) {
          // Confirm via /cart.js: entered codes appear in `discount_codes`, each
          // with an `applicable` flag (Shopify's validity signal). There is no
          // top-level `discount_applications` in /cart.js — that's Liquid-only.
          const cart = await (
            await fetch(`${root}cart.js`, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
          ).json();
          const entry = (cart.discount_codes || []).find(
            (discount) => (discount.code || '').toLowerCase() === code.toLowerCase()
          );
          const applied = entry ? entry.applicable !== false : (cart.total_discount || 0) > 0;

          if (applied) {
            rememberCheckoutDiscount(code);
            await refreshDrawer({ open: true });
            toast({ message: `Discount “${code}” applied.`, type: 'success' });
          } else if (entry) {
            // The code is recognized but doesn't apply to the current cart — usually
            // an unmet minimum spend, or it isn't active/eligible yet. Keep it: it
            // stays on the cart and Shopify applies it automatically once the cart
            // qualifies (so raising the quantity can make it kick in).
            rememberCheckoutDiscount(code);
            loader.hidden = true;
            syncPendingDiscount();
            toast({
              message: `“${code}” can’t be applied to your cart yet — it may require a higher order total or other conditions.`,
              type: 'info',
            });
          } else {
            // The code isn't recognized at all.
            forgetCheckoutDiscount();
            loader.hidden = true;
            toast({ message: `“${code}” isn’t a valid discount code.`, type: 'error' });
          }
          return;
        }

        // /discount isn't reachable here (theme dev preview blocks it). We can't
        // validate in-page, so carry the code to checkout where it gets applied.
        rememberCheckoutDiscount(code);
        loader.hidden = true;
        syncPendingDiscount();
        toast({ message: `“${code}” will be applied at checkout.`, type: 'info' });
      } catch (error) {
        loader.hidden = true;
        toast({ message: 'We couldn’t apply that code. Please try again.', type: 'error' });
      }
    };

    const escapeHtml = (value) =>
      String(value).replace(
        /[&<>"']/g,
        (char) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[char])
      );

    // Renders a "pending" discount chip from the code carried to checkout, but only
    // when no discount is actually applied in-cart (e.g. theme dev preview). This
    // gives the shopper a way to cancel a code they entered but that hasn't reduced
    // the cart yet. Applied discounts are rendered server-side by Liquid instead.
    const syncPendingDiscount = () => {
      const shell = getShell();
      const container = shell?.querySelector('[data-cart-pending-discount]');
      if (!container) return;
      const code = getCheckoutDiscount();
      const hasApplied = !!shell.querySelector(
        '.cart-drawer__summary-row--discount:not(.cart-drawer__pending-discount)'
      );
      if (code && !hasApplied) {
        container.hidden = false;
        container.innerHTML =
          '<span class="cart-drawer__discount-tag">' +
          '<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20.5 12.5 12 21l-8.5-8.5V4h8.5z"></path><circle cx="8" cy="8" r="1.4"></circle></svg>' +
          escapeHtml(code) +
          '</span>' +
          '<span class="cart-drawer__discount-end">' +
          '<span class="cart-drawer__pending-note">At checkout</span>' +
          '<button type="button" class="cart-drawer__discount-remove" data-cart-pending-remove aria-label="Remove discount ' +
          escapeHtml(code) +
          '"><svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 6l12 12M18 6 6 18"></path></svg></button>' +
          '</span>';
      } else {
        container.hidden = true;
        container.innerHTML = '';
      }
    };

    // Removing a discount clears the cart's discount codes via the Cart AJAX API
    // (POST /cart/update.js with an empty `discount`) — this works on both the live
    // store and the theme dev preview — and also drops the code carried to checkout.
    const removeDiscount = async () => {
      const shell = getShell();
      const loader = shell?.querySelector('[data-cart-drawer-loading]');
      if (!loader) return;
      loader.hidden = false;
      const root = window.Shopify?.routes?.root || '/';
      try {
        await fetch(`${root}cart/update.js`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
          body: JSON.stringify({ discount: '' }),
        });
        forgetCheckoutDiscount();
        await refreshDrawer({ open: true });
        if (window.showToast) {
          window.showToast({ message: 'Discount removed.', type: 'info', position: 'bottom-right' });
        }
      } catch (error) {
        loader.hidden = true;
        if (window.showToast) {
          window.showToast({
            message: 'We couldn’t remove the discount. Please try again.',
            type: 'error',
            position: 'bottom-right',
          });
        }
      }
    };

    document.addEventListener('submit', (event) => {
      const discountForm = event.target.closest('[data-cart-discount-form]');
      if (discountForm) {
        event.preventDefault();
        applyDiscount(discountForm);
        return;
      }

      // Carry any entered discount code through to checkout so it applies there.
      const checkoutForm = event.target.closest('.cart-drawer__checkout-form');
      if (checkoutForm) {
        const pending = getCheckoutDiscount();
        if (pending) {
          event.preventDefault();
          const root = window.Shopify?.routes?.root || '/';
          window.location.href = `${root}checkout?discount=${encodeURIComponent(pending)}`;
        }
      }
    });

    document.addEventListener('click', (event) => {
      const opener = event.target.closest('[data-cart-drawer-open]');
      if (opener) {
        event.preventDefault();
        openDrawer();
        return;
      }

      if (event.target.closest('[data-cart-drawer-close]')) {
        closeDrawer();
        return;
      }

      if (event.target.closest('[data-cart-discount-remove]')) {
        removeDiscount();
        return;
      }

      if (event.target.closest('[data-cart-pending-remove]')) {
        forgetCheckoutDiscount();
        syncPendingDiscount();
        if (window.showToast) {
          window.showToast({ message: 'Discount removed.', type: 'info', position: 'bottom-right' });
        }
        return;
      }

      const quantityButton = event.target.closest('[data-cart-quantity-change]');
      if (quantityButton) {
        const lineItem = quantityButton.closest('[data-cart-line-item]');
        changeLine(lineItem, Number(quantityButton.dataset.cartQuantityChange));
        return;
      }

      const removeButton = event.target.closest('[data-cart-remove]');
      if (removeButton) {
        const lineItem = removeButton.closest('[data-cart-line-item]');
        const popup = document.querySelector('[data-cart-remove-popup]');
        if (popup && lineItem) {
          popup.dataset.lineKey = lineItem.dataset.lineKey;
          popup.hidden = false;
          document.documentElement.style.overflow = 'hidden';
        } else if (lineItem) {
          changeLine(lineItem, 0);
        }
        return;
      }

      const removeCancelBtn = event.target.closest('[data-cart-remove-cancel]');
      if (removeCancelBtn) {
        const popup = document.querySelector('[data-cart-remove-popup]');
        if (popup) {
          popup.hidden = true;
          document.documentElement.style.overflow = '';
        }
        return;
      }

      const removeConfirmBtn = event.target.closest('[data-cart-remove-confirm]');
      if (removeConfirmBtn) {
        const popup = document.querySelector('[data-cart-remove-popup]');
        if (popup && popup.dataset.lineKey) {
          changeLine({ dataset: { lineKey: popup.dataset.lineKey } }, 0);
          popup.hidden = true;
          document.documentElement.style.overflow = '';
        }
        return;
      }
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') {
        const removePopup = document.querySelector('[data-cart-remove-popup]');
        if (removePopup && !removePopup.hidden) {
          removePopup.hidden = true;
          document.documentElement.style.overflow = '';
          return;
        }
      }
      const shell = getShell();
      if (!shell?.classList.contains('is-open')) return;
      if (event.key === 'Escape') {
        closeDrawer();
        return;
      }
      if (event.key !== 'Tab') return;
      const focusable = [
        ...getPanel().querySelectorAll(
          'a[href], button:not([disabled]), input:not([disabled]), [tabindex]:not([tabindex="-1"])'
        ),
      ];
      if (!focusable.length) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (event.shiftKey && document.activeElement === first) {
        event.preventDefault();
        last.focus();
      } else if (!event.shiftKey && document.activeElement === last) {
        event.preventDefault();
        first.focus();
      }
    });

    document.addEventListener('cart:updated', (event) => {
      refreshDrawer({ open: event.detail?.open !== false }).catch((error) => {
        if (window.showToast) {
          window.showToast({ message: error.message, type: 'error', position: 'bottom-right' });
        }
      });
    });

    window.WrydecoCartDrawer = { open: openDrawer, close: closeDrawer, refresh: refreshDrawer };
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Cart drawer",
  "settings": []
}
{% endschema %}
