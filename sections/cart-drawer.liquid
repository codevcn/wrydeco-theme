<div
  id="CartDrawer"
  class="cart-drawer"
  data-cart-drawer-shell
  data-section-id="{{ section.id }}"
  data-cart-count="{{ cart.item_count }}"
  aria-hidden="true"
>
  <button
    type="button"
    class="cart-drawer__overlay"
    aria-label="Close cart"
    data-cart-drawer-close
  ></button>

  <aside
    class="cart-drawer__panel"
    role="dialog"
    aria-modal="true"
    aria-labelledby="CartDrawerTitle"
    tabindex="-1"
    data-cart-drawer-panel
  >
    <header class="cart-drawer__header">
      <div class="cart-drawer__header-title-wrapper">
        <h2 id="CartDrawerTitle" class="cart-drawer__title">Your Cart</h2>
        <p class="cart-drawer__count" data-cart-drawer-count>
          <span>(</span>{{ cart.item_count }}
          {% if cart.item_count == 1 %}piece{% else %}pieces{% endif %} added
          <span>)</span>
        </p>
      </div>
      <button
        type="button"
        class="cart-drawer__close"
        aria-label="Close cart"
        data-cart-drawer-close
      >
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 5l14 14M19 5L5 19"></path>
        </svg>
      </button>
    </header>

    {% if cart.item_count > 0 %}
      <div class="cart-drawer__body custom-scrollbar" data-cart-drawer-body>
        <ul class="cart-drawer__items" role="list">
          {% for item in cart.items %}
            {% liquid
              assign maker_name = item.product.vendor
              assign author = item.product.metafields.custom.author_info.value | first
              if author != blank
                if author.author_name.value != blank
                  assign maker_name = author.author_name.value
                endif
              endif
            %}
            <li class="cart-drawer__item" data-cart-line-item data-line-key="{{ item.key | escape }}">
              <a class="cart-drawer__image-link" href="{{ item.url }}" tabindex="-1" aria-hidden="true">
                {% if item.image != blank %}
                  {{
                    item.image
                    | image_url: width: 480
                    | image_tag:
                      class: 'cart-drawer__image',
                      loading: 'lazy',
                      widths: '224, 340, 480',
                      sizes: '(max-width: 719px) 112px, 170px',
                      alt: item.image.alt
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'cart-drawer__image placeholder-svg' }}
                {% endif %}
              </a>

              <div class="cart-drawer__item-details">
                <div class="cart-drawer__item-copy">
                  <a class="cart-drawer__item-title" href="{{ item.url }}" title="{{ item.product.title | escape }}">
                    {{- item.product.title | escape -}}
                  </a>
                  {% if maker_name != blank %}
                    <p class="cart-drawer__maker">By {{ maker_name | escape }}</p>
                  {% endif %}

                  {% if item.variant.title != 'Default Title' %}
                    <dl class="cart-drawer__options">
                      {% for option in item.options_with_values %}
                        {% if option.value != 'Default Title' %}
                          {% liquid
                            assign option_down = option.name | downcase
                            assign is_color_option = false
                            if option_down contains 'color' or option_down contains 'màu' or option_down contains 'canvas' or option_down contains 'finish'
                              assign is_color_option = true
                            endif
                          %}
                          <div class="cart-drawer__option{% if is_color_option %} cart-drawer__option--color{% endif %}">
                            <dt>{{ option.name | escape }}:</dt>
                            <dd>
                              {% if is_color_option and item.variant.metafields.custom.color_pattern != blank %}
                                <img
                                  class="cart-drawer__option-swatch"
                                  src="{{ item.variant.metafields.custom.color_pattern }}"
                                  alt=""
                                  width="20"
                                  height="20"
                                  loading="lazy"
                                >
                              {% endif %}
                              <span>{{ option.value | escape }}</span>
                            </dd>
                          </div>
                        {% endif %}
                      {% endfor %}
                    </dl>
                  {% endif %}

                  {% if item.selling_plan_allocation != blank %}
                    <p class="cart-drawer__selling-plan">
                      {{ item.selling_plan_allocation.selling_plan.name | escape }}
                    </p>
                  {% endif %}

                  {% for property in item.properties %}
                    {% assign property_first_character = property.first | slice: 0 %}
                    {% if property.last != blank and property_first_character != '_' and property.first != 'Note' %}
                      <p class="cart-drawer__property">{{ property.first | escape }}: {{ property.last | escape }}</p>
                    {% endif %}
                  {% endfor %}

                  {% assign line_note = item.properties.Note %}
                  {% assign note_action = 'Write a note' %}
                  {% if line_note != blank %}
                    {% assign note_action = 'Edit note' %}
                  {% endif %}
                  <button
                    type="button"
                    class="cart-drawer__note-button{% if line_note != blank %} cart-drawer__note-button--has-note{% endif %}"
                    data-cart-note-view
                    data-note="{{ line_note | escape }}"
                    aria-haspopup="dialog"
                    aria-label="{{ note_action }} for {{ item.product.title | escape }}"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 256 256">
                      <path d="M0 0h256v256H0z" fill="none" />
                      <g fill="currentColor">
                      	<path d="m216 160l-56 56v-56Z" opacity=".2" />
                      	<path d="M88 96a8 8 0 0 1 8-8h64a8 8 0 0 1 0 16H96a8 8 0 0 1-8-8m8 40h64a8 8 0 0 0 0-16H96a8 8 0 0 0 0 16m32 16H96a8 8 0 0 0 0 16h32a8 8 0 0 0 0-16m96-104v108.69a15.86 15.86 0 0 1-4.69 11.31L168 219.31a15.86 15.86 0 0 1-11.31 4.69H48a16 16 0 0 1-16-16V48a16 16 0 0 1 16-16h160a16 16 0 0 1 16 16M48 208h104v-48a8 8 0 0 1 8-8h48V48H48Zm120-40v28.7l28.69-28.7Z" />
                      </g>
                    </svg>

                    <span>{{ note_action }}</span>
                  </button>
                </div>

                <p class="cart-drawer__price">
                  {% if item.original_line_price != item.final_line_price %}
                    <s>{{ item.original_line_price | money }}</s>
                  {% endif %}
                  {{ item.final_line_price | money }}
                </p>

                <div class="cart-drawer__actions">
                  <div class="cart-drawer__quantity" aria-label="Quantity for {{ item.product.title | escape }}">
                    <button
                      type="button"
                      class="cart-drawer__quantity-button"
                      aria-label="Decrease quantity"
                      data-cart-quantity-change="{{ item.quantity | minus: 1 }}"
                    >
                      −
                    </button>
                    <span class="cart-drawer__quantity-value" aria-live="polite">{{ item.quantity }}</span>
                    <button
                      type="button"
                      class="cart-drawer__quantity-button"
                      aria-label="Increase quantity"
                      data-cart-quantity-change="{{ item.quantity | plus: 1 }}"
                    >
                      +
                    </button>
                  </div>
                  <button type="button" class="cart-drawer__remove" aria-label="Remove" data-cart-remove>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      fill="currentColor"
                      class="bi bi-trash3-fill"
                      viewBox="0 0 16 16"
                    >
                      <path d="M11 1.5v1h3.5a.5.5 0 0 1 0 1h-.538l-.853 10.66A2 2 0 0 1 11.115 16h-6.23a2 2 0 0 1-1.994-1.84L2.038 3.5H1.5a.5.5 0 0 1 0-1H5v-1A1.5 1.5 0 0 1 6.5 0h3A1.5 1.5 0 0 1 11 1.5m-5 0v1h4v-1a.5.5 0 0 0-.5-.5h-3a.5.5 0 0 0-.5.5M4.5 5.029l.5 8.5a.5.5 0 1 0 .998-.06l-.5-8.5a.5.5 0 1 0-.998.06m6.53-.528a.5.5 0 0 0-.528.47l-.5 8.5a.5.5 0 0 0 .998.058l.5-8.5a.5.5 0 0 0-.47-.528M8 4.5a.5.5 0 0 0-.5.5v8.5a.5.5 0 0 0 1 0V5a.5.5 0 0 0-.5-.5"/>
                    </svg>
                  </button>
                </div>
              </div>
            </li>
          {% endfor %}
        </ul>
      </div>

      <footer class="cart-drawer__footer">
        <form class="cart-drawer__discount-form" data-cart-discount-form novalidate>
          <label class="cart-drawer__visually-hidden" for="CartDiscountInput">Discount code</label>
          <input
            id="CartDiscountInput"
            type="text"
            name="discount"
            class="cart-drawer__discount-input"
            placeholder="Discount code"
            autocomplete="off"
            autocapitalize="characters"
            autocorrect="off"
            spellcheck="false"
            data-cart-discount-input
          >
          <button type="submit" class="cart-drawer__discount-apply" data-cart-discount-apply>Apply</button>
        </form>

        <div class="cart-drawer__summary">
          {% if cart.cart_level_discount_applications.size > 0 %}
            {% for discount in cart.cart_level_discount_applications %}
              <div class="cart-drawer__summary-row cart-drawer__summary-row--discount">
                <span class="cart-drawer__discount-tag">
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M20.5 12.5 12 21l-8.5-8.5V4h8.5z"></path>
                    <circle cx="8" cy="8" r="1.4"></circle>
                  </svg>
                  {{ discount.title | escape }}
                </span>
                <span class="cart-drawer__discount-end">
                  <span class="cart-drawer__discount-amount">−{{ discount.total_allocated_amount | money }}</span>
                  <button
                    type="button"
                    class="cart-drawer__discount-remove"
                    data-cart-discount-remove
                    aria-label="Remove discount {{ discount.title | escape }}"
                  >
                    <svg viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M6 6l12 12M18 6 6 18"></path>
                    </svg>
                  </button>
                </span>
              </div>
            {% endfor %}
          {% endif %}

          {% comment %} Populated by JS when a code is pending for checkout but not yet applied in-cart. {% endcomment %}
          <div
            class="cart-drawer__summary-row cart-drawer__summary-row--discount cart-drawer__pending-discount"
            data-cart-pending-discount
            hidden
          ></div>

          <div class="cart-drawer__summary-row cart-drawer__summary-row--total">
            <span>Subtotal</span>
            <strong>{{ cart.total_price | money }}</strong>
          </div>
          <div class="cart-drawer__summary-row cart-drawer__summary-row--shipping">
            <span class="cart-drawer__shipping-label">
              Shipping
              <span
                class="cart-drawer__info"
                title="Shipping is calculated at checkout"
                aria-label="Shipping is calculated at checkout"
                >i</span
              >
            </span>
            <span>Calculated at checkout</span>
          </div>
        </div>

        <form action="{{ routes.cart_url }}" method="post" class="cart-drawer__checkout-form">
          <button type="submit" name="checkout" class="cart-drawer__checkout">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <rect x="6" y="10" width="12" height="10" rx="1"></rect>
              <path d="M9 10V7a3 3 0 0 1 6 0v3"></path>
            </svg>
            Checkout Securely
          </button>
        </form>
      </footer>
    {% else %}
      <div class="cart-drawer__empty" data-cart-drawer-body>
        <svg viewBox="0 0 64 64" aria-hidden="true">
          <path d="M16 20h36l-4 24H20l-4-24Z"></path>
          <path d="M16 20l-2-8H8M25 52h.01M44 52h.01"></path>
        </svg>
        <h3>Your cart is waiting</h3>
        <p>Discover pieces shaped by nature and made to last.</p>
        <button type="button" class="cart-drawer__checkout" data-cart-drawer-close>Continue shopping</button>
      </div>
    {% endif %}

    <div class="cart-drawer__loading" data-cart-drawer-loading hidden aria-live="polite">
      <span class="cart-drawer__spinner"></span>
      <span class="cart-drawer__visually-hidden">Updating cart</span>
    </div>
  </aside>
</div>

{%- comment -%} Note viewer — kept outside the shell so it survives the section refresh and its position:fixed is relative to the viewport. {%- endcomment -%}
<div class="cart-drawer__note-popup" data-cart-note-popup hidden>
  <div class="cart-drawer__note-overlay" data-cart-note-close></div>
  <div class="cart-drawer__note-dialog" role="dialog" aria-modal="true" aria-labelledby="CartNoteTitle">
    <div class="cart-drawer__note-header">
      <h2 id="CartNoteTitle" class="cart-drawer__note-title" data-cart-note-title>Write a note</h2>
      <button type="button" class="cart-drawer__note-close" data-cart-note-close aria-label="Close note">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="cart-drawer__note-body">
      <label class="cart-drawer__note-label" for="CartNoteField">Your note</label>
      <textarea
        id="CartNoteField"
        class="cart-drawer__note-field"
        data-cart-note-field
        rows="4"
        maxlength="500"
        placeholder="Add any special requests or details for this piece…"
      ></textarea>
    </div>
    <div class="cart-drawer__note-footer">
      <button type="button" class="cart-drawer__note-clear" data-cart-note-clear>Clear</button>
      <button type="button" class="cart-drawer__note-save" data-cart-note-save>Save note</button>
    </div>
  </div>
</div>

{%- comment -%} Remove confirmation viewer {%- endcomment -%}
<div class="cart-drawer__note-popup" data-cart-remove-popup hidden>
  <div class="cart-drawer__note-overlay" data-cart-remove-cancel></div>
  <div class="cart-drawer__note-dialog" role="dialog" aria-modal="true" aria-labelledby="CartRemoveTitle">
    <div class="cart-drawer__note-header">
      <h2 id="CartRemoveTitle" class="cart-drawer__note-title">Remove piece</h2>
      <button type="button" class="cart-drawer__note-close" data-cart-remove-cancel aria-label="Cancel">
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="cart-drawer__note-body">
      <p class="cart-drawer__note-label" style="text-transform: none; margin-bottom: 0;">
        Are you sure you want to remove this piece from your cart?
      </p>
    </div>
    <div class="cart-drawer__note-footer">
      <button type="button" class="cart-drawer__note-clear" data-cart-remove-cancel>Cancel</button>
      <button type="button" class="cart-drawer__note-save" data-cart-remove-confirm>Remove</button>
    </div>
  </div>
</div>

<script>
  if (!window.cartNotePopupInitialized) {
    window.cartNotePopupInitialized = true;
    (function () {
      var saving = false;

      function popup() {
        return document.querySelector('[data-cart-note-popup]');
      }
      function field() {
        var p = popup();
        return p ? p.querySelector('[data-cart-note-field]') : null;
      }

      function openNote(text, lineKey) {
        var p = popup();
        if (!p) return;
        var f = field();
        var title = p.querySelector('[data-cart-note-title]');
        var hasNote = text.trim() !== '';
        if (f) f.value = text;
        if (title) title.textContent = hasNote ? 'Edit note' : 'Write a note';
        p.dataset.lineKey = lineKey || '';
        p.hidden = false;
        document.documentElement.style.overflow = 'hidden';
        window.requestAnimationFrame(function () {
          if (f) f.focus();
        });
      }

      function closeNote() {
        var p = popup();
        if (!p) return;
        p.hidden = true;
        document.documentElement.style.overflow = '';
      }

      function toast(message, type) {
        if (window.showToast) window.showToast({ message: message, type: type, position: 'bottom-right' });
      }

      async function saveNote() {
        var p = popup();
        if (!p || saving) return;
        var lineKey = p.dataset.lineKey;
        if (!lineKey) {
          closeNote();
          return;
        }
        var f = field();
        var value = (f ? f.value : '').trim();
        var root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';
        var saveBtn = p.querySelector('[data-cart-note-save]');
        var loader = document.querySelector('[data-cart-drawer-loading]');

        saving = true;
        if (saveBtn) saveBtn.disabled = true;
        if (loader) loader.hidden = false;
        try {
          // Read the line's current properties so other properties are preserved
          // (cart/change.js replaces the whole properties object of the line).
          var cartRes = await fetch(root + 'cart.js', { headers: { 'X-Requested-With': 'XMLHttpRequest' } });
          var cart = await cartRes.json();
          var line = (cart.items || []).filter(function (i) {
            return i.key === lineKey;
          })[0];
          var props = Object.assign({}, (line && line.properties) || {});
          if (value === '') {
            delete props.Note;
          } else {
            props.Note = value;
          }

          var res = await fetch(root + 'cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify({ id: lineKey, properties: props }),
          });
          var updated = await res.json();
          if (!res.ok || updated.status) throw new Error(updated.description || 'Unable to update the note.');

          closeNote();
          document.dispatchEvent(new CustomEvent('cart:updated', { detail: { open: true } }));
          toast(value === '' ? 'Note removed.' : 'Note updated.', 'success');
        } catch (error) {
          if (loader) loader.hidden = true;
          toast(error.message || 'Unable to update the note.', 'error');
        } finally {
          saving = false;
          if (saveBtn) saveBtn.disabled = false;
        }
      }

      document.addEventListener('click', function (event) {
        var viewBtn = event.target.closest('[data-cart-note-view]');
        if (viewBtn) {
          var lineItem = viewBtn.closest('[data-cart-line-item]');
          openNote(viewBtn.getAttribute('data-note') || '', lineItem ? lineItem.dataset.lineKey : '');
          return;
        }
        if (event.target.closest('[data-cart-note-save]')) {
          saveNote();
          return;
        }
        if (event.target.closest('[data-cart-note-clear]')) {
          var f = field();
          if (f) {
            f.value = '';
            f.focus();
          }
          return;
        }
        if (event.target.closest('[data-cart-note-close]')) {
          closeNote();
        }
      });

      document.addEventListener('keydown', function (event) {
        var p = popup();
        if (event.key === 'Escape' && p && !p.hidden) closeNote();
      });
    })();
  }
</script>

{% stylesheet %}
  .cart-drawer {
    position: fixed;
    inset: var(--sp-0);
    z-index: var(--z-overlay);
    pointer-events: none;
    opacity: 0;
    transition: opacity var(--timing-base) var(--ease-standard);
  }

  .cart-drawer.is-open {
    pointer-events: auto;
    opacity: 1;
  }

  .cart-drawer__overlay {
    position: absolute;
    inset: var(--sp-0);
    inline-size: 100%;
    block-size: 100%;
    padding: var(--sp-0);
    border: var(--sp-0);
    background: var(--color-ebony);
    opacity: var(--sp-0);
    cursor: pointer;
    transition: opacity var(--timing-base) var(--ease-standard);
  }

  .cart-drawer.is-open .cart-drawer__overlay {
    opacity: var(--cart-drawer-overlay-opacity);
  }

  .cart-drawer__panel {
    position: absolute;
    z-index: var(--z-drawer);
    inset-block: var(--sp-0);
    inset-inline-end: var(--sp-0);
    display: flex;
    flex-direction: column;
    inline-size: min(var(--cart-drawer-width), var(--cart-drawer-max-width));
    max-inline-size: 100%;
    min-inline-size: min(var(--cart-drawer-width), var(--cart-drawer-max-width));
    background: var(--surface-elevated);
    color: var(--text-primary);
    box-shadow: var(--shadow-modal);
    transform: translateX(100%);
    transition: transform var(--timing-long) var(--ease-out);
    outline: none;
  }

  .cart-drawer.is-open .cart-drawer__panel {
    transform: translateX(var(--sp-0));
  }

  .cart-drawer__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex: none;
    margin-inline: var(--sp-6);
    padding-block: var(--sp-4) var(--sp-3);
    border-block-end: var(--border-width) solid var(--border-light);
  }
  .cart-drawer__header-title-wrapper {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }

  .cart-drawer__title,
  .cart-drawer__empty h3 {
    margin: var(--sp-0);
    font: var(--type-display-medium);
    font-weight: var(--font-weight-light);
    font-size: var(--font-size-display-sm);
    letter-spacing: var(--letter-spacing-tight);
  }

  .cart-drawer__count {
    margin: var(--sp-0) var(--sp-0) var(--sp-0);
    color: var(--text-secondary);
    font: var(--type-body-small);
  }

  .cart-drawer__close {
    display: grid;
    place-items: center;
    inline-size: var(--sp-6);
    block-size: var(--sp-6);
    padding: var(--sp-0);
    border: var(--sp-0);
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
  }

  .cart-drawer__close svg {
    inline-size: var(--sp-5);
    block-size: var(--sp-5);
    fill: none;
    stroke: currentColor;
    stroke-width: var(--border-width);
  }

  .cart-drawer__body {
    flex: 1 1 auto;
    min-block-size: var(--sp-0);
    overflow-y: auto;
    padding-inline: var(--sp-6);
  }

  .cart-drawer__items {
    margin: var(--sp-0);
    padding: var(--sp-0);
    list-style: none;
  }

  .cart-drawer__item {
    display: grid;
    grid-template-columns: var(--cart-drawer-image-size) minmax(var(--sp-0), 1fr);
    gap: var(--sp-5);
    padding-block: var(--sp-4);
    border-block-end: var(--border-width) solid var(--border-light);
  }

  .cart-drawer__image-link {
    display: block;
    aspect-ratio: 1 / 1.06;
    overflow: hidden;
    border-radius: var(--radius-lg);
    background: var(--bg-secondary);
  }

  .cart-drawer__image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .cart-drawer__item-details {
    display: flex;
    flex-direction: column;
    min-inline-size: var(--sp-0);
  }

  .cart-drawer__item-copy {
    flex: 1 1 auto;
  }

  .cart-drawer__item-title {
    display: -webkit-box;
    overflow: hidden;
    color: var(--text-primary);
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-light);
    line-height: var(--line-height-tight);
    text-decoration: none;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
  }

  .cart-drawer__maker,
  .cart-drawer__selling-plan,
