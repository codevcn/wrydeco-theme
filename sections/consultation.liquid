{% doc %}
  Renders the Consultation section with a title, description, and list of features.

  @example
  {% section 'consultation' %}
{% enddoc %}

{% stylesheet %}
  .consultation-section {
    padding: 1rem var(--layout-padding-mobile) var(--layout-padding-mobile);
    display: block; /* Keeping section wrapper as block per rules */
    background-color: var(--color-background, #f4ebd9);
  }

  .consultation-container {
    max-width: 500px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .consultation-heading {
    font-family: var(--font-display);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-regular);
    color: var(--text-primary);
    line-height: var(--line-height-tight);
    margin: 0 0 var(--sp-4) 0;
  }

  .consultation-text {
    font-family: var(--font-display);
    font-size: var(--font-size-body-lg);
    font-style: italic;
    color: var(--text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }

  .consultation-features {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-top: var(--sp-5);
  }

  .consultation-feature {
    display: flex;
    gap: var(--sp-4);
    padding: var(--sp-5) var(--sp-4);
    background-color: var(--color-cream, #f4ebd9);
    border-radius: 4px;
    border: 1px solid transparent;
  }

  .consultation-feature--bordered {
    border-color: var(--border-default);
  }

  .consultation-feature__icon {
    flex-shrink: 0;
    color: var(--text-primary);
    display: flex;
    align-items: flex-start;
  }

  .consultation-feature__icon svg {
    width: 24px;
    height: 24px;
    stroke-width: 1.5;
  }

  .consultation-feature__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .consultation-feature__title {
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    margin: 0;
  }

  .consultation-feature__description {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
    margin: 0;
    line-height: var(--line-height-relaxed);
  }

  .consultation-button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    background-color: var(--color-ebony);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: var(--sp-4) var(--sp-5);
    border-radius: 2px;
    width: 100%;
    margin-top: var(--sp-5);
    transition: background-color 0.2s ease;
  }

  .consultation-button:hover {
    background-color: var(--color-charcoal);
  }

  @media screen and (min-width: 768px) {
    .consultation-section {
      padding: var(--section-spacing-tablet) var(--layout-padding-tablet);
    }
  }

  @media screen and (min-width: 1024px) {
    .consultation-section {
      padding: var(--section-spacing-desktop) var(--layout-padding-desktop);
    }
  }
{% endstylesheet %}

<section class="consultation-section">
  <div class="consultation-container">
    <div class="consultation-header">
      <h2 class="consultation-heading">{{ section.settings.heading }}</h2>
      <p class="consultation-text">{{ section.settings.text }}</p>
    </div>

    <div class="consultation-features">
      {% for block in section.blocks %}
        <div class="consultation-feature {% if block.settings.show_border %}consultation-feature--bordered{% endif %}" {{ block.shopify_attributes }}>
          <div class="consultation-feature__icon">
            {% case block.settings.icon %}
              {% when 'image' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline></svg>
              {% when 'video' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
              {% when 'bag' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="6" width="16" height="16" rx="2"></rect><path d="M8 6V4a4 4 0 0 1 8 0v2"></path><polyline points="9 13 11 15 15 10"></polyline></svg>
            {% endcase %}
          </div>
          <div class="consultation-feature__content">
            <h3 class="consultation-feature__title">{{ block.settings.title }}</h3>
            <p class="consultation-feature__description">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.settings.button_label != blank %}
      <a href="{{ section.settings.button_link | default: '#' }}" class="consultation-button">
        <span>{{ section.settings.button_label }}</span>
        <span>&rarr;</span>
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Consultation",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unsure what will fit your room?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Before you decide, talk with one of our master craftsmen. A free, no-pressure conversation about size, wood, light, and your space."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "BOOK A FREE CONSULTATION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" },
            { "value": "bag", "label": "Bag" }
          ],
          "default": "image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "checkbox",
          "id": "show_border",
          "label": "Show border",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Consultation",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "image",
            "title": "Send photos of your space",
            "description": "We will sketch dimensions that fit and reply within 24 hours. Free of charge.",
            "show_border": false
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "video",
            "title": "Video consultation",
            "description": "Send a video of your space, or schedule a 20-minute call with a master craftsman. No sales pitch.",
            "show_border": true
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "bag",
            "title": "Trade-in",
            "description": "Trade in",
            "show_border": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
