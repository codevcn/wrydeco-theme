{% doc %}
  Renders the Consultation section with a title, description, and list of features, 
  alongside a craftsman status card on desktop.

  @example
  {% section 'consultation' %}
{% enddoc %}

{% stylesheet %}
  .consultation-section {
    padding: 1rem var(--layout-padding-mobile) var(--layout-padding-mobile);
    display: block;
    background-color: var(--color-background, #f4ebd9);
  }

  .consultation-inner {
    display: flex;
    flex-direction: column;
    gap: 32px;
    margin: 0 auto;
  }

  /* Consultation Left Side */
  .consultation-container {
    max-width: 500px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .consultation-heading {
    font-family: var(--font-display);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-regular);
    color: var(--text-primary);
    line-height: var(--line-height-tight);
    margin: 0 0 var(--sp-4) 0;
  }

  .consultation-text {
    font-family: var(--font-display);
    font-size: var(--font-size-body-lg);
    font-style: italic;
    color: var(--text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0;
  }

  .consultation-features {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    margin-top: var(--sp-5);
  }

  .consultation-feature {
    display: flex;
    gap: var(--sp-4);
    padding: var(--sp-5) var(--sp-4);
    background-color: var(--color-cream, #f4ebd9);
    border-radius: 4px;
    border: 1px solid transparent;
  }

  .consultation-feature--bordered {
    border-color: var(--border-default);
  }

  .consultation-feature__icon {
    flex-shrink: 0;
    color: var(--text-primary);
    display: flex;
    align-items: flex-start;
  }

  .consultation-feature__icon svg {
    width: 24px;
    height: 24px;
    stroke-width: 1.5;
  }

  .consultation-feature__content {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
  }

  .consultation-feature__title {
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    margin: 0;
  }

  .consultation-feature__description {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
    margin: 0;
    line-height: var(--line-height-relaxed);
  }

  .consultation-button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    background-color: var(--color-ebony);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    padding: var(--sp-4) var(--sp-5);
    border-radius: 2px;
    width: 100%;
    margin-top: var(--sp-5);
    transition: transform 0.2s ease;
  }

  .consultation-button:hover {
    transform: scale(0.98);
    color: var(--color-cream);
  }

  /* Craftsman Status Right Side */
  .craftsman-status-wrapper {
    display: flex;
    justify-content: center;
    width: 100%;
  }

  .craftsman-status-card {
    background-color: #312111; /* Deep espresso/brown */
    border-radius: 8px;
    padding: 32px;
    max-width: 440px;
    width: 100%;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
    color: #e3cca6; /* Cream/gold */
  }

  .cs-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 32px;
  }

  .cs-status-dot {
    width: 8px;
    height: 8px;
    background-color: #6ab054;
    border-radius: 50%;
  }

  .cs-header-text {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #e3cca6;
  }

  .cs-profile {
    display: flex;
    align-items: center;
    gap: 20px;
    margin-bottom: 24px;
  }

  .cs-avatar {
    width: 80px;
    height: 80px;
    flex-shrink: 0;
    border-radius: 50%;
    overflow: hidden;
  }

  .cs-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .cs-profile-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cs-name {
    font-family: var(--font-heading, 'Times New Roman', serif);
    font-size: 26px;
    font-weight: 400;
    font-style: italic;
    margin: 0;
    color: #f2e2c4;
  }

  .cs-title {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    margin: 4px 0;
  }

  .cs-subtitle {
    font-family: var(--font-heading, 'Times New Roman', serif);
    font-size: 15px;
    font-style: italic;
    color: rgba(227, 204, 166, 0.7); /* Slightly muted */
    margin: 0;
  }

  .cs-divider {
    border: 0;
    height: 1px;
    background-color: rgba(227, 204, 166, 0.15);
    margin: 24px 0;
  }

  .cs-quote {
    font-family: var(--font-heading, 'Times New Roman', serif);
    font-size: 20px;
    line-height: 1.5;
    font-style: italic;
    color: #f2e2c4;
    text-align: left;
  }

  .cs-stats {
    display: flex;
    justify-content: space-between;
    margin-top: 24px;
  }

  .cs-stat {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .cs-stat-value {
    font-family: var(--font-heading, 'Times New Roman', serif);
    font-size: 22px;
    color: #f2e2c4;
    display: flex;
    align-items: baseline;
    gap: 4px;
  }

  .cs-stat-value-italic {
    font-style: italic;
    font-size: 18px;
  }

  .cs-stat-label {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(227, 204, 166, 0.7);
  }

  @media screen and (min-width: 768px) {
    .consultation-section {
      padding: var(--section-spacing-tablet) var(--layout-padding-tablet);
    }
  }

  @media screen and (min-width: 1024px) {
    .consultation-section {
      padding: var(--section-spacing-desktop) var(--layout-padding-desktop);
    }

    .consultation-inner {
      display: flex;
      flex-direction: row;
      justify-content: center;
      gap: 48px;
      align-items: center;
      max-width: var(--page-width, 1200px);
    }

    .consultation-container {
      max-width: 600px;
      margin: 0;
    }

    .craftsman-status-wrapper {
      justify-content: flex-end;
      width: fit-content;
    }
  }
{% endstylesheet %}

<section class="consultation-section page-width">
  <div class="consultation-inner">
    <div class="consultation-container">
      <div class="consultation-header">
        <h2 class="consultation-heading">{{ section.settings.heading }}</h2>
        <p class="consultation-text">{{ section.settings.text }}</p>
      </div>

      <div class="consultation-features">
        {% for block in section.blocks %}
          <div
            class="consultation-feature {% if block.settings.show_border %}consultation-feature--bordered{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="consultation-feature__icon">
              {% case block.settings.icon %}
                {% when 'image' %}
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline>
                  </svg>
                {% when 'video' %}
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
                  </svg>
                {% when 'bag' %}
                  <svg
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <rect x="4" y="6" width="16" height="16" rx="2"></rect><path d="M8 6V4a4 4 0 0 1 8 0v2"></path><polyline points="9 13 11 15 15 10"></polyline>
                  </svg>
              {% endcase %}
            </div>
            <div class="consultation-feature__content">
              <h3 class="consultation-feature__title">{{ block.settings.title }}</h3>
              <p class="consultation-feature__description">{{ block.settings.description }}</p>
            </div>
          </div>
        {% endfor %}
      </div>

      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: '#' }}" class="consultation-button">
          <span>{{ section.settings.button_label }}</span>
          <span>&rarr;</span>
        </a>
      {% endif %}
    </div>

    <div class="craftsman-status-wrapper">
      <div class="craftsman-status-card">
        <div class="cs-header">
          <span class="cs-status-dot"></span>
          <span class="cs-header-text">{{ section.settings.status_text }}</span>
        </div>

        <div class="cs-profile">
          <div class="cs-avatar">
            {%- if section.settings.avatar != blank -%}
              <img
                src="{{ section.settings.avatar | image_url: width: 160 }}"
                alt="{{ section.settings.name }}"
                loading="lazy"
              >
            {%- else -%}
              <!-- Placeholder avatar if not selected -->
              <img src="{{ 'fouder_wrydeco.webp' | asset_url }}" alt="Craftsman" loading="lazy">
            {%- endif -%}
          </div>
          <div class="cs-profile-info">
            <h3 class="cs-name">{{ section.settings.name }}</h3>
            <p class="cs-title">{{ section.settings.title }}</p>
            <p class="cs-subtitle">— {{ section.settings.subtitle }} —</p>
          </div>
        </div>

        <hr class="cs-divider">

        <div class="cs-quote">"{{ section.settings.quote }}"</div>

        <hr class="cs-divider">

        <div class="cs-stats">
          <div class="cs-stat">
            <div class="cs-stat-value">
              {{ section.settings.stat1_value_pre -}}
              <span class="cs-stat-value-italic">{{ section.settings.stat1_value_italic }}</span>
            </div>
            <div class="cs-stat-label">{{ section.settings.stat1_label }}</div>
          </div>
          <div class="cs-stat">
            <div class="cs-stat-value">{{ section.settings.stat2_value }}</div>
            <div class="cs-stat-label">{{ section.settings.stat2_label }}</div>
          </div>
          <div class="cs-stat">
            <div class="cs-stat-value">{{ section.settings.stat3_value }}</div>
            <div class="cs-stat-label">{{ section.settings.stat3_label }}</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Consultation",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Unsure what will fit your room?"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Before you decide, talk with one of our master craftsmen. A free, no-pressure conversation about size, wood, light, and your space."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "BOOK A FREE CONSULTATION"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Craftsman Status Card"
    },
    {
      "type": "text",
      "id": "status_text",
      "label": "Status Text",
      "default": "3 CRAFTSMEN ON DUTY · AVG REPLY 14 MIN"
    },
    {
      "type": "image_picker",
      "id": "avatar",
      "label": "Craftsman Avatar"
    },
    {
      "type": "text",
      "id": "name",
      "label": "Craftsman Name",
      "default": "Mr Nguyen"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "MASTER CARVER · FOUNDER"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "On duty today until 18:00 GMT+7"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "A cabinet that does not fit your room is a cabinet you will resent for life. Measure twice, build once."
    },
    {
      "type": "text",
      "id": "stat1_value_pre",
      "label": "Stat 1 Value (Normal)",
      "default": "22"
    },
    {
      "type": "text",
      "id": "stat1_value_italic",
      "label": "Stat 1 Value (Italic)",
      "default": "yrs"
    },
    {
      "type": "text",
      "id": "stat1_label",
      "label": "Stat 1 Label",
      "default": "CARVING"
    },
    {
      "type": "text",
      "id": "stat2_value",
      "label": "Stat 2 Value",
      "default": "4.98 ★"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Stat 2 Label",
      "default": "CONSULT RATING"
    },
    {
      "type": "text",
      "id": "stat3_value",
      "label": "Stat 3 Value",
      "default": "0%"
    },
    {
      "type": "text",
      "id": "stat3_label",
      "label": "Stat 3 Label",
      "default": "SALES PRESSURE"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" },
            { "value": "bag", "label": "Bag" }
          ],
          "default": "image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "checkbox",
          "id": "show_border",
          "label": "Show border",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Consultation",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "image",
            "title": "Send photos of your space",
            "description": "We will sketch dimensions that fit and reply within 24 hours. Free of charge.",
            "show_border": false
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "video",
            "title": "Video consultation",
            "description": "Send a video of your space, or schedule a 20-minute call with a master craftsman. No sales pitch.",
            "show_border": true
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "bag",
            "title": "Trade-in",
            "description": "Trade in",
            "show_border": false
          }
        }
      ]
    }
  ]
}
{% endschema %}
