{% comment %}
  Details, Materials & Care section.

  Left column: eyebrow, title, subtitle, divider and a "what makes this piece
  special" feature grid (feature blocks). Right column: tabbed product details
  (accordion blocks rendered as tabs); the first item is active by default.
{% endcomment %}

{% stylesheet %}
  .details-materials {
    box-sizing: border-box;
    width: 100%;
    height: 100svh;
    max-height: 700px;
    max-width: calc(var(--layout-max-width) + var(--sp-12) + var(--sp-8));
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    grid-template-rows: minmax(0, 1fr) auto;
    align-items: stretch;
    gap: var(--sp-5) var(--sp-6);
    padding: var(--sp-4) var(--layout-padding-desktop);
    background: radial-gradient(
        circle at 12% 18%,
        color-mix(in srgb, var(--color-clay) 8%, transparent),
        transparent 30%
      ),
      radial-gradient(circle at 88% 74%, color-mix(in srgb, var(--color-earth-brown) 6%, transparent), transparent 32%),
      var(--surface-default);
    margin-top: var(--sp-0);
  }

  .details-materials__left {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-self: center;
    min-width: 0;
    min-height: 0;
    text-align: center;
    height: 100%;
  }

  .details-materials__eyebrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    margin: 0 0 var(--sp-3);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-earth-brown);
  }
  .details-materials__eyebrow svg {
    width: var(--sp-4);
    height: var(--sp-4);
    flex: 0 0 auto;
  }
  .details-materials__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(var(--font-size-display-sm), 7.5vw, var(--font-size-display-lg));
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-display);
    letter-spacing: var(--letter-spacing-normal);
    color: var(--text-primary);
    text-wrap: balance;
  }
  .details-materials__subtitle {
    margin: var(--sp-4) auto 0;
    max-width: 58ch;
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-generous);
    color: var(--text-primary);
  }
  .details-materials__rule {
    position: relative;
    width: min(calc(var(--sp-10) * 2 + var(--sp-5)), 40%);
    height: var(--border-width);
    margin: var(--sp-4) auto;
    border: none;
    overflow: visible;
    background-color: color-mix(in srgb, var(--color-clay) 48%, transparent);
  }
  .details-materials__rule::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: var(--sp-2);
    height: var(--sp-2);
    border: var(--border-width) solid var(--color-clay);
    background: var(--surface-default);
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .details-materials__features-eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    margin: var(--sp-4) 0 var(--sp-4);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-earth-brown);
  }
  .details-materials__features-eyebrow::before,
  .details-materials__features-eyebrow::after {
    content: '';
    width: var(--sp-9);
    height: var(--border-width);
    background-color: color-mix(in srgb, var(--color-clay) 42%, transparent);
  }

  .details-materials__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sp-4);
  }
  .dm-feature {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--sp-4);
    min-height: var(--sp-9);
    padding: var(--sp-4);
    border: var(--border-width) solid var(--border-light);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--surface-elevated) 72%, transparent);
  }
  .dm-feature__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: var(--sp-7);
    height: var(--sp-7);
    border: var(--border-width) solid color-mix(in srgb, var(--color-clay) 36%, transparent);
    border-radius: var(--radius-full);
    background-color: color-mix(in srgb, var(--color-milk) 76%, transparent);
    color: var(--color-earth-brown);
  }
  .dm-feature__icon svg {
    width: var(--sp-5);
    height: var(--sp-5);
  }
  .dm-feature__body {
    min-width: 0;
  }
  .dm-feature__title {
    margin: 0 0 var(--sp-2);
    font-family: var(--font-display);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    text-align: left;
  }
  .dm-feature__text {
    margin: 0;
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-normal);
    color: var(--text-primary);
    text-align: left;
  }

  .details-materials__right {
    display: flex;
    align-self: stretch;
    min-width: 0;
    min-height: 0;
  }

  .dm-tabs {
    display: flex;
    flex-direction: column;
    width: 100%;
    min-height: 0;
    border: var(--border-width) solid var(--border-light);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: color-mix(in srgb, var(--surface-elevated) 68%, transparent);
    box-shadow: var(--shadow-card);
  }
  .dm-tabs__list {
    flex: 0 0 auto;
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(max-content, 1fr);
    align-items: center;
    gap: var(--sp-1);
    min-height: var(--sp-10);
    padding: var(--sp-3);
    border-bottom: var(--border-width) solid var(--border-light);
    overflow-x: auto;
    scrollbar-width: thin;
  }
  .dm-tabs__tab {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--sp-7);
    padding: 0 var(--sp-3);
    border: var(--border-width) solid transparent;
    border-radius: var(--radius-lg);
    background-color: transparent;
    color: var(--text-primary);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    white-space: nowrap;
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard), border-color var(--timing-short) var(--ease-standard);
  }
  .dm-tabs__tab:hover,
  .dm-tabs__tab:focus-visible {
    border-color: color-mix(in srgb, var(--color-earth-brown) 22%, transparent);
    outline: none;
  }
  .dm-tabs__tab[aria-selected='true'] {
    background-color: var(--color-earth-brown);
    color: var(--color-cream);
    border-color: var(--color-earth-brown);
  }
  .dm-tabs__panel {
    display: none;
    min-height: 0;
  }
  .dm-tabs__panel.is-active {
    display: flex;
    flex: 1 1 auto;
  }
  .dm-tabs__content {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1fr);
    align-items: center;
    gap: var(--sp-6);
    width: 100%;
    min-height: 0;
    padding: var(--sp-5);
  }
  .dm-tabs__media {
    overflow: hidden;
    align-self: center;
    height: 100%;
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-milk) 72%, transparent);
  }
  .dm-tabs__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .dm-tabs__placeholder {
    width: 100%;
    height: 100%;
    color: color-mix(in srgb, var(--color-earth-brown) 24%, transparent);
  }
  .dm-tabs__body {
    min-width: 0;
    height: 100%;
    overflow-y: auto;
    padding-right: var(--sp-2);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
    color: var(--text-primary);
  }
  .dm-tabs__body > :last-child {
    margin-bottom: 0;
  }
  .dm-tabs__body img,
  .dm-tabs__body picture,
  .dm-tabs__body figure {
    display: none;
  }
  .dm-tabs__rte,
  .dm-tabs__rte * {
    color: var(--text-primary) !important;
    font-family: var(--font-body) !important;
  }
  .dm-tabs__rte h1,
  .dm-tabs__rte h2,
  .dm-tabs__rte h3,
  .dm-tabs__rte h4 {
    break-after: avoid;
    margin: 0 0 var(--sp-3);
    font-family: var(--font-display);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-regular);
    color: var(--text-primary);
  }
  .dm-tabs__rte h1,
  .dm-tabs__rte h1 *,
  .dm-tabs__rte h2,
  .dm-tabs__rte h2 *,
  .dm-tabs__rte h3,
  .dm-tabs__rte h3 *,
  .dm-tabs__rte h4,
  .dm-tabs__rte h4 * {
    font-family: var(--font-display) !important;
  }
  .dm-tabs__rte p,
  .dm-tabs__rte ul,
  .dm-tabs__rte ol {
    margin-top: 0;
    break-inside: avoid;
  }
  .dm-tabs__rte p + h1,
  .dm-tabs__rte p + h2,
  .dm-tabs__rte p + h3,
  .dm-tabs__rte p + h4,
  .dm-tabs__rte ul + h1,
  .dm-tabs__rte ul + h2,
  .dm-tabs__rte ul + h3,
  .dm-tabs__rte ul + h4 {
    margin-top: var(--sp-5);
  }
  .dm-tabs__rte a {
    color: inherit;
    text-underline-offset: 0.18em;
  }
  .details-materials__trust {
    grid-column: 1 / -1;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    align-items: center;
    min-height: var(--sp-8);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--surface-elevated) 58%, transparent);
    box-shadow: var(--shadow-card);
  }
  .dm-trust {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-5);
    color: var(--color-earth-brown);
  }
  .dm-trust + .dm-trust {
    border-left: var(--border-width) solid var(--border-light);
  }
  .dm-trust__icon {
    display: inline-flex;
    width: var(--sp-6);
    height: var(--sp-6);
    flex: 0 0 auto;
  }
  .dm-trust__icon svg {
    width: 100%;
    height: 100%;
  }
  .dm-trust__title {
    display: block;
    font-family: var(--font-display);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .dm-trust__text {
    display: block;
    margin-top: var(--sp-1);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-normal);
    color: var(--text-secondary);
  }

  @media screen and (max-width: 1180px) {
    .details-materials {
      height: auto;
      max-height: none;
      column-gap: var(--sp-6);
      padding-inline: var(--layout-padding-tablet);
    }
    .details-materials__title {
      font-size: var(--font-size-display-md);
    }
    .details-materials__features {
      gap: var(--sp-3);
    }
    .dm-feature {
      padding: var(--sp-4);
    }
  }

  @media screen and (max-width: 768px) {
    .details-materials {
      height: auto;
      max-height: none;
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto;
      row-gap: var(--sp-5);
      padding: var(--section-spacing-mobile) var(--layout-padding-mobile) var(--sp-7);
    }
    .details-materials__eyebrow {
      gap: var(--sp-2);
      margin-bottom: var(--sp-4);
      font-size: var(--font-size-caption);
    }
    .details-materials__title {
      font-size: var(--font-size-display-md);
    }
    .details-materials__subtitle {
      font-size: var(--font-size-body-md);
    }
    .details-materials__features-eyebrow {
      gap: var(--sp-3);
      margin-top: var(--sp-5);
      font-size: var(--font-size-caption);
    }
    .details-materials__features-eyebrow::before,
    .details-materials__features-eyebrow::after {
      width: var(--sp-6);
    }
    .details-materials__features {
      grid-template-columns: 1fr;
    }
    .dm-feature {
      flex-direction: column;
      min-height: 0;
      text-align: center;
    }
    .dm-feature__title,
    .dm-feature__text {
      text-align: center;
    }
    .dm-tabs__list {
      display: flex;
      min-height: var(--sp-8);
      padding: var(--sp-2);
      scroll-snap-type: x proximity;
    }
    .dm-tabs__tab {
      flex: 0 0 auto;
      min-height: var(--sp-7);
      padding: 0 var(--sp-4);
      scroll-snap-align: start;
    }
    .dm-tabs__content {
      grid-template-columns: minmax(0, 1fr);
      min-height: 0;
      padding: var(--sp-4);
      gap: var(--sp-4);
    }
    .dm-tabs__media {
      aspect-ratio: 16 / 11;
    }
    .dm-tabs__body {
      max-height: calc(var(--sp-10) * 6 + var(--sp-4));
      padding-right: var(--sp-1);
    }
    .details-materials__trust {
      grid-template-columns: 1fr;
    }
    .dm-trust {
      justify-content: flex-start;
    }
    .dm-trust + .dm-trust {
      border-left: 0;
      border-top: var(--border-width) solid var(--border-light);
    }
  }

  @media screen and (max-width: 480px) {
    .details-materials__title {
      font-size: var(--font-size-display-sm);
    }
    .dm-feature {
      gap: var(--sp-3);
      padding: var(--sp-4);
    }
    .dm-feature__icon {
      width: var(--sp-7);
      height: var(--sp-7);
    }
    .dm-tabs__tab {
      padding: 0 var(--sp-3);
    }
  }
{% endstylesheet %}

<section class="details-materials" id="ProductComparison-{{ section.id }}">
  <div class="details-materials__left">
    {% if section.settings.eyebrow != blank %}
      <p class="details-materials__eyebrow">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" aria-hidden="true">
          <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8c0 5.5-4.78 10-10 10"></path>
            <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
          </g>
        </svg>
        <span>{{ section.settings.eyebrow | escape }}</span>
      </p>
    {% endif %}

    {% if section.settings.title != blank %}
      <h2 class="details-materials__title">{{ section.settings.title | escape }}</h2>
    {% endif %}

    {% if section.settings.subtitle != blank %}
      <p class="details-materials__subtitle">{{ section.settings.subtitle | escape }}</p>
    {% endif %}

    <hr class="details-materials__rule">

    {% if section.settings.features_heading != blank %}
      <p class="details-materials__features-eyebrow">{{ section.settings.features_heading | escape }}</p>
    {% endif %}

    <div class="details-materials__features">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class="dm-feature" {{ block.shopify_attributes }}>
            <span class="dm-feature__icon" aria-hidden="true">
              {% case block.settings.icon %}
                {% when 'grain' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                    <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                      <circle cx="12" cy="12" r="10"></circle>
                      <circle cx="12" cy="12" r="1"></circle>
                    </g>
                  </svg>
                {% when 'joinery' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                    <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                      <path d="m15 12l-9.373 9.373a1 1 0 0 1-3.001-3L12 9m6 6l4-4"></path>
                      <path d="m21.5 11.5l-1.914-1.914A2 2 0 0 1 19 8.172v-.344a2 2 0 0 0-.586-1.414l-1.657-1.657A6 6 0 0 0 12.516 3H9l1.243 1.243A6 6 0 0 1 12 8.485V10l2 2h1.172a2 2 0 0 1 1.414.586L18.5 14.5"></path>
                    </g>
                  </svg>
                {% when 'finish' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                    <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                      <path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2m0 4V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2m0 4.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"></path>
                      <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"></path>
                    </g>
                  </svg>
                {% when 'made_to_order' %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                    <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                      <path d="M12 22V12m4 5l2 2l4-4"></path>
                      <path d="M21 11.127V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.729l7 4a2 2 0 0 0 2 .001l1.32-.753"></path>
                      <path d="M3.29 7L12 12l8.71-5M7.5 4.27l8.997 5.148"></path>
                    </g>
                  </svg>
                {% else %}
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
                    <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
                      <circle cx="12" cy="12" r="10"></circle>
                      <circle cx="12" cy="12" r="1"></circle>
                    </g>
                  </svg>
              {% endcase %}
            </span>
            <div class="dm-feature__body">
              {% if block.settings.title != blank %}
                <h3 class="dm-feature__title">{{ block.settings.title | escape }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="dm-feature__text">{{ block.settings.text | escape }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="details-materials__right">
    <div class="dm-tabs" data-dm-tabs>
      <div class="dm-tabs__list custom-scrollbar" role="tablist" aria-label="{{ section.settings.title | escape }}">
        {% assign tab_index = 0 %}
        {% for block in section.blocks %}
          {% if block.type == 'accordion' %}
            {% assign tab_index = tab_index | plus: 1 %}
            <button
              type="button"
              class="dm-tabs__tab"
              id="DmTab-{{ section.id }}-{{ tab_index }}"
              role="tab"
              aria-selected="{% if tab_index == 1 %}true{% else %}false{% endif %}"
              aria-controls="DmPanel-{{ section.id }}-{{ tab_index }}"
              tabindex="{% if tab_index == 1 %}0{% else %}-1{% endif %}"
              data-dm-tab
            >
              {{ block.settings.heading | escape }}
            </button>
          {% endif %}
        {% endfor %}
      </div>

      {% assign panel_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'accordion' %}
          {% assign panel_index = panel_index | plus: 1 %}
          <div
            class="dm-tabs__panel{% if panel_index == 1 %} is-active{% endif %}"
            id="DmPanel-{{ section.id }}-{{ panel_index }}"
            role="tabpanel"
            aria-labelledby="DmTab-{{ section.id }}-{{ panel_index }}"
            {% unless panel_index == 1 %}
              hidden
            {% endunless %}
            {{ block.shopify_attributes }}
          >
            <div class="dm-tabs__content">
              <div class="dm-tabs__media" aria-hidden="true">
                {% if product.featured_image != blank %}
                  {{
                    product.featured_image
                    | image_url: width: 760
                    | image_tag:
                      class: 'dm-tabs__image',
                      loading: 'lazy',
                      widths: '360, 520, 760',
                      sizes: '(max-width: 768px) 100vw, 360px',
                      alt: ''
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'dm-tabs__placeholder' }}
                {% endif %}
              </div>
              <div class="dm-tabs__body custom-scrollbar">
                <div class="dm-tabs__rte">
                  {% if block.settings.use_product_description %}
                    {{ product.description }}
                  {% else %}
                    {{ block.settings.content }}
                  {% endif %}
                </div>
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="details-materials__trust" aria-label="Purchase assurances">
    <div class="dm-trust">
      <span class="dm-trust__icon" aria-hidden="true">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24">
          <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
            <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path>
            <path d="m9 12l2 2l4-4"></path>
          </g>
        </svg>
      </span>
      <span>
        <span class="dm-trust__title">Heirloom Quality</span>
