<script>
  (function () {
    function activateTab(tabs, tab) {
      var allTabs = Array.prototype.slice.call(tabs.querySelectorAll('[data-dm-tab]'));
      allTabs.forEach(function (item) {
        var selected = item === tab;
        var panel = document.getElementById(item.getAttribute('aria-controls'));
        item.setAttribute('aria-selected', selected ? 'true' : 'false');
        item.setAttribute('tabindex', selected ? '0' : '-1');
        if (panel) {
          panel.hidden = !selected;
          panel.classList.toggle('is-active', selected);
        }
      });
    }

    function setupTabs(root) {
      if (!root || root.dataset.dmTabsInit === 'true') return;
      root.dataset.dmTabsInit = 'true';
      var tabs = Array.prototype.slice.call(root.querySelectorAll('[data-dm-tab]'));
      tabs.forEach(function (tab, index) {
        tab.addEventListener('click', function () {
          activateTab(root, tab);
        });
        tab.addEventListener('keydown', function (event) {
          var nextIndex = index;
          if (event.key === 'ArrowRight') nextIndex = (index + 1) % tabs.length;
          else if (event.key === 'ArrowLeft') nextIndex = (index - 1 + tabs.length) % tabs.length;
          else if (event.key === 'Home') nextIndex = 0;
          else if (event.key === 'End') nextIndex = tabs.length - 1;
          else return;
          event.preventDefault();
          activateTab(root, tabs[nextIndex]);
          tabs[nextIndex].focus();
        });
      });
    }

    function initDetailsMaterialsTabs() {
      document.querySelectorAll('[data-dm-tabs]').forEach(setupTabs);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initDetailsMaterialsTabs);
    } else {
      initDetailsMaterialsTabs();
    }

    document.addEventListener('shopify:section:load', initDetailsMaterialsTabs);
  })();
</script>

