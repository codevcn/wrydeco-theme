{% comment %}
  Details, Materials & Care section.

  Left column: eyebrow, title, subtitle, divider and a "what makes this piece
  special" feature grid (feature blocks). Right column: a numbered accordion
  (accordion blocks); the first item is open by default.
{% endcomment %}

{% stylesheet %}
  /* Desktop-first */
  .details-materials {
    width: 100%;
    max-width: var(--layout-max-width);
    margin-inline: auto;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.05fr);
    align-items: start;
    column-gap: var(--sp-8);
    padding: var(--sp-7) var(--layout-padding-desktop);
  }

  .details-materials__eyebrow {
    margin: 0 0 var(--sp-4);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-bark);
  }
  .details-materials__title {
    margin: 0 0 var(--sp-4);
    font-family: var(--font-display);
    font-size: var(--font-size-display-lg);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-display);
    letter-spacing: var(--letter-spacing-normal);
    color: var(--text-primary);
    text-wrap: balance;
  }
  .details-materials__subtitle {
    margin: 0;
    max-width: 52ch;
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }
  .details-materials__rule {
    width: 100%;
    height: 1px;
    margin: var(--sp-6) 0;
    border: none;
    background-color: var(--border-light);
  }

  .details-materials__features-eyebrow {
    margin: 0 0 var(--sp-5);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-bark);
  }

  .details-materials__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }
  .dm-feature {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
    padding: var(--sp-5);
  }
  .dm-feature:nth-child(odd) {
    padding-left: 0;
    border-right: 1px solid var(--border-light);
  }
  .dm-feature:nth-child(even) {
    padding-right: 0;
  }
  .dm-feature:nth-child(1),
  .dm-feature:nth-child(2) {
    padding-top: 0;
  }
  .dm-feature:nth-child(n + 3) {
    border-top: 1px solid var(--border-light);
    padding-bottom: 0;
  }
  .dm-feature__icon {
    flex: 0 0 auto;
    width: 44px;
    height: 44px;
    color: var(--color-bark);
  }
  .dm-feature__icon svg {
    width: 100%;
    height: 100%;
  }
  .dm-feature__body {
    min-width: 0;
  }
  .dm-feature__title {
    margin: 0 0 var(--sp-2);
    font-family: var(--font-display);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .dm-feature__text {
    margin: 0;
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }

  /* Accordion */
  .dm-accordion {
    border: 1px solid #33333328;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: transparent;
  }
  .dm-acc {
    border-bottom: 1px solid #33333328;
  }
  .dm-acc:last-child {
    border-bottom: none;
  }
  .dm-acc__summary {
    display: grid;
    grid-template-columns: 2.75rem 1fr auto;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-5) var(--sp-5);
    cursor: pointer;
    list-style: none;
  }
  .dm-acc__summary::-webkit-details-marker {
    display: none;
  }
  .dm-acc__summary:hover {
    background-color: var(--bg-secondary);
  }
  .dm-acc__num {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-regular);
    color: var(--color-clay);
  }
  .dm-acc__title {
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .dm-acc__icon {
    position: relative;
    width: 16px;
    height: 16px;
    color: var(--text-secondary);
  }
  .dm-acc__icon::before,
  .dm-acc__icon::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background-color: currentColor;
    transition: transform var(--timing-base) var(--ease-standard);
  }
  .dm-acc__icon::before {
    width: 16px;
    height: 1.5px;
  }
  .dm-acc__icon::after {
    width: 1.5px;
    height: 16px;
  }
  .dm-acc[open] .dm-acc__icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }
  .dm-acc__content {
    padding: 0 var(--sp-5) var(--sp-5) 32px;
    max-height: 220px;
    overflow-y: auto;
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
    color: var(--text-secondary);
  }
  .dm-acc__content > :last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 1024px) {
    .details-materials {
      column-gap: var(--sp-6);
      padding-inline: var(--layout-padding-tablet);
    }
    .details-materials__title {
      font-size: var(--font-size-display-md);
    }
  }

  @media screen and (max-width: 768px) {
    .details-materials {
      grid-template-columns: minmax(0, 1fr);
      row-gap: var(--sp-6);
      padding: var(--section-spacing-mobile) var(--layout-padding-mobile);
    }
    .details-materials__title {
      font-size: var(--font-size-display-md);
    }
    .details-materials__subtitle {
      font-size: var(--font-size-body-md);
    }
    .details-materials__features {
      grid-template-columns: 1fr;
    }
    .dm-feature,
    .dm-feature:nth-child(odd),
    .dm-feature:nth-child(even) {
      padding: var(--sp-5) 0;
      border-right: none;
      border-top: 1px solid var(--border-light);
    }
    .dm-feature:nth-child(1) {
      border-top: none;
      padding-top: 0;
    }
    .dm-acc__content {
      max-height: none;
    }
  }
{% endstylesheet %}

<section class="details-materials" id="ProductComparison-{{ section.id }}">
  <div class="details-materials__left">
    {% if section.settings.eyebrow != blank %}
      <p class="details-materials__eyebrow">{{ section.settings.eyebrow | escape }}</p>
    {% endif %}

    {% if section.settings.title != blank %}
      <h2 class="details-materials__title">{{ section.settings.title | escape }}</h2>
    {% endif %}

    {% if section.settings.subtitle != blank %}
      <p class="details-materials__subtitle">{{ section.settings.subtitle | escape }}</p>
    {% endif %}

    <hr class="details-materials__rule">

    {% if section.settings.features_heading != blank %}
      <p class="details-materials__features-eyebrow">{{ section.settings.features_heading | escape }}</p>
    {% endif %}

    <div class="details-materials__features">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class="dm-feature" {{ block.shopify_attributes }}>
            <span class="dm-feature__icon" aria-hidden="true">
              {% case block.settings.icon %}
                {% when 'grain' %}
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4">
                    <circle cx="24" cy="24" r="19"></circle>
                    <circle cx="24" cy="24" r="13.5"></circle>
                    <circle cx="24" cy="24" r="8"></circle>
                    <circle cx="24" cy="24" r="2.6" fill="currentColor" stroke="none"></circle>
                  </svg>
                {% when 'joinery' %}
                  <svg
                    viewBox="0 0 48 48"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M8 30l9-9 4 4-9 9a2.8 2.8 0 0 1-4-4Z"></path>
                    <path d="M21 25l13-13"></path>
                    <path d="M30 8l10 10-5 5-10-10Z"></path>
                    <path d="M28 34l4 4"></path>
                  </svg>
                {% when 'finish' %}
                  <svg
                    viewBox="0 0 48 48"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M22 24V13a2.5 2.5 0 0 1 5 0M27 23v-13a2.5 2.5 0 0 1 5 0v3"></path>
                    <path d="M17 25.5V18a2.5 2.5 0 0 1 5 0v6"></path>
                    <path d="M32 15a2.5 2.5 0 0 1 5 0v9a11 11 0 0 1-11 11h-1c-3 0-5-1-7-3l-5-5a2.5 2.5 0 0 1 3.6-3.5l3.4 3"></path>
                    <path d="M12 8l1.2 2.8L16 12l-2.8 1.2L12 16l-1.2-2.8L8 12l2.8-1.2Z"></path>
                  </svg>
                {% when 'made_to_order' %}
                  <svg
                    viewBox="0 0 48 48"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="1.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M18 11h12"></path>
                    <path d="M19 11c0 4-4 5-4 11a9 9 0 0 0 18 0c0-6-4-7-4-11"></path>
                    <path d="M16 24h16"></path>
                  </svg>
                {% else %}
                  <svg viewBox="0 0 48 48" fill="none" stroke="currentColor" stroke-width="1.4">
                    <circle cx="24" cy="24" r="18"></circle>
                  </svg>
              {% endcase %}
            </span>
            <div class="dm-feature__body">
              {% if block.settings.title != blank %}
                <h3 class="dm-feature__title">{{ block.settings.title | escape }}</h3>
              {% endif %}
              {% if block.settings.text != blank %}
                <p class="dm-feature__text">{{ block.settings.text | escape }}</p>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <div class="details-materials__right">
    <div class="dm-accordion">
      {% assign acc_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'accordion' %}
          {% assign acc_index = acc_index | plus: 1 %}
          {% assign acc_label = acc_index | prepend: '0' %}
          <details
            class="dm-acc"
            {% if acc_index == 1 %}
              open
            {% endif %}
            {{ block.shopify_attributes }}
          >
            <summary class="dm-acc__summary">
              <span class="dm-acc__num">{{ acc_label }}</span>
              <span class="dm-acc__title">{{ block.settings.heading | escape }}</span>
              <span class="dm-acc__icon" aria-hidden="true"></span>
            </summary>
            <div class="dm-acc__content custom-scrollbar">
              {% if block.settings.use_product_description %}
                {{ product.description }}
              {% else %}
                {{ block.settings.content }}
              {% endif %}
            </div>
          </details>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Details & Materials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Details, Materials & Care"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Thoughtfully made from solid walnut and finished by hand, this fluted floating shelf brings quiet depth and refined texture to your space."
    },
    {
      "type": "text",
      "id": "features_heading",
      "label": "Features heading",
      "default": "What makes this piece special"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "grain",
          "options": [
            { "value": "grain", "label": "Wood grain" },
            { "value": "joinery", "label": "Joinery" },
            { "value": "finish", "label": "Finish" },
            { "value": "made_to_order", "label": "Made to order" }
          ]
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Describe what makes this aspect special."
        }
      ]
    },
    {
      "type": "accordion",
      "name": "Accordion item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Heading"
        },
        {
          "type": "checkbox",
          "id": "use_product_description",
          "label": "Use product description as content",
          "default": false
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Add details here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Details & Materials",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "icon": "grain",
            "title": "Unique natural grain",
            "text": "Each shelf showcases the organic beauty of solid walnut, with distinct grain patterns that make every piece one of a kind."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "joinery",
            "title": "Hand-shaped joinery",
            "text": "Expertly crafted with precision joinery for lasting strength and a seamless, architectural silhouette."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "finish",
            "title": "Hand-rubbed finish",
            "text": "Finished by hand using natural oils and waxes to enhance the wood's depth, texture, and timeless appeal."
          }
        },
        {
          "type": "feature",
          "settings": {
            "icon": "made_to_order",
            "title": "Made-to-order craftsmanship",
            "text": "Each piece is made to order in small batches with care and intention, not mass produced."
          }
        },
        { "type": "accordion", "settings": { "heading": "Description", "use_product_description": true } },
        {
          "type": "accordion",
          "settings": {
            "heading": "Dimensions",
            "content": "<p>24\" L x 8\" D x 2.5\" H. Custom dimensions available on request.</p>"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Delivery & Returns",
            "content": "<p>Made to order in 3–5 weeks. White-glove delivery available. 30-day returns on catalog items.</p>"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Care Guide",
            "content": "<p>Wipe clean with a soft, dry cloth. Keep away from direct sunlight and extreme temperatures to preserve the finish.</p>"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "Customization",
            "content": "<p>Choose your slab and finish, or work with our design concierge to tailor dimensions to your space.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
