<div class="secondary-menu">
  <div class="page-width">
    <nav class="secondary-menu__nav">
      <ul class="secondary-menu__list list-unstyled" role="list">
        {%- if section.settings.menu != blank -%}
          {%- for link in section.settings.menu.links -%}
            <li class="secondary-menu__item">
              <a
                href="{{ link.url }}"
                class="secondary-menu__link{% if link.active %} secondary-menu__link--active{% endif %}"
                {% if link.active %}
                  aria-current="page"
                {% endif %}
              >
                {{ link.title | escape }}
                {%- if link.links != blank -%}
                  <svg
                    aria-hidden="true"
                    focusable="false"
                    role="presentation"
                    class="icon icon-caret"
                    viewBox="0 0 10 6"
                  >
                    <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
                  </svg>
                {%- endif -%}
              </a>
            </li>
          {%- endfor -%}
        {%- else -%}
          <li class="secondary-menu__item">
            <a href="#" class="secondary-menu__link"
              >LIVING ROOM
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
              </svg>
            </a>
          </li>
          <li class="secondary-menu__item">
            <a href="#" class="secondary-menu__link"
              >DINING & KITCHEN
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
              </svg>
            </a>
          </li>
          <li class="secondary-menu__item">
            <a href="#" class="secondary-menu__link secondary-menu__link--active" aria-current="page"
              >BATHROOM
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
              </svg>
            </a>
          </li>
          <li class="secondary-menu__item">
            <a href="#" class="secondary-menu__link"
              >BED ROOM
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
              </svg>
            </a>
          </li>
          <li class="secondary-menu__item">
            <a href="#" class="secondary-menu__link"
              >HOME OFFICE
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
              </svg>
            </a>
          </li>
          <li class="secondary-menu__item">
            <a href="#" class="secondary-menu__link"
              >OUTDOOR & GARDEN
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
              </svg>
            </a>
          </li>
          <li class="secondary-menu__item">
            <a href="#" class="secondary-menu__link"
              >HOME HIGHLIGHTS
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
              </svg>
            </a>
          </li>
          <li class="secondary-menu__item">
            <a href="#" class="secondary-menu__link">HAPPY CUSTOMER</a>
          </li>
        {%- endif -%}
      </ul>
    </nav>
  </div>
</div>

{% stylesheet %}
  .secondary-menu {
    display: none;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    background-color: var(--color-background, #ffffff);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .secondary-menu::-webkit-scrollbar {
    display: none;
  }
  .secondary-menu__nav {
    display: flex;
    justify-content: center;
    width: 100%;
  }
  .secondary-menu__list {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 0;
    list-style: none;
    gap: 32px;
    white-space: nowrap;
  }
  .secondary-menu__item {
    display: inline-flex;
    align-items: center;
  }
  .secondary-menu__link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding-top: 16px;
    padding-bottom: 14px;
    color: var(--text-primary, #333333);
    text-decoration: none;
    font-family: var(--font-body, sans-serif);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    border-bottom: 2px solid transparent;
    transition: color 0.2s ease, border-color 0.2s ease;
  }
  .secondary-menu__link .icon-caret {
    width: 8px;
    height: auto;
    fill: currentColor;
    opacity: 0.6;
    transition: transform 0.2s ease;
  }
  .secondary-menu__link:hover,
  .secondary-menu__link--active {
    color: #e52029;
    border-bottom-color: #e52029;
  }
  .secondary-menu__link:hover .icon-caret,
  .secondary-menu__link--active .icon-caret {
    opacity: 1;
  }

  /* Mobile scrolling if items exceed width */
  @media screen and (min-width: 720px) {
    .secondary-menu {
      display: block;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Secondary menu",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "info": "Leave blank to show default placeholder links."
    }
  ],
  "presets": [
    {
      "name": "Secondary menu"
    }
  ]
}
{% endschema %}
