<div class="custom-section-divider"></div>

<div class="client-reviews page-width">
  <div class="client-reviews__inner">
    <!-- Left Column: Fixed Text -->
    <div class="client-reviews__left">
      <div class="client-reviews__eyebrow-wrapper">
        <div class="client-reviews__eyebrow-line"></div>
        <span class="client-reviews__eyebrow">TESTIMONIALS</span>
      </div>

      <h2 class="client-reviews__heading">
        What Our<br>
        Clients Say
      </h2>
      <p class="client-reviews__subtitle">
        Real stories from homes where craftsmanship becomes part of everyday living.
      </p>

      <div class="client-reviews__quote-mark">“</div>

      <p class="client-reviews__quote-text" id="client-review-text"></p>

      <div class="client-reviews__author-box">
        <p class="client-reviews__author-name" id="client-review-author"></p>
        <p class="client-reviews__author-location">Hanoi, Vietnam</p>
      </div>

      <div class="client-reviews__verified">
        <svg
          width="22"
          height="22"
          viewBox="0 0 40 40"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <circle cx="20" cy="20" r="19" stroke="currentColor" stroke-width="2" stroke-dasharray="2 2"/>
          <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="2"/>
          <circle cx="20" cy="20" r="5" stroke="currentColor" stroke-width="2"/>
        </svg>
        <span>VERIFIED CLIENT</span>
      </div>
    </div>

    <!-- Right Column: Image Slider -->
    <div class="client-reviews__right">
      <div class="client-reviews__slider" id="client-reviews-slider">
        {%- for block in section.blocks -%}
          <div
            class="client-reviews__card"
            data-review="{{ block.settings.review_text | escape }}"
            data-author="{{ block.settings.author_name | escape }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag: class: 'client-reviews__img', loading: 'lazy', draggable: 'false'
              }}
            {%- else -%}
              {%- assign fallback_asset = block.settings.fallback_image -%}
              {%- if forloop.index == 1 -%}
                {%- assign fallback_asset = 'curated-collections-img-2.png' -%}
              {%- elsif forloop.index == 2 -%}
                {%- assign fallback_asset = 'curated-collections-img-3.png' -%}
              {%- endif -%}
              <img
                src="{{ fallback_asset | asset_url }}"
                alt="{{ block.settings.author_name }}"
                class="client-reviews__img"
                loading="lazy"
                draggable="false"
                width="900"
                height="1100"
              >
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <div class="client-reviews__footer">
    <div class="client-reviews__footer-content">
      <svg
        width="20"
        height="20"
        viewBox="0 0 40 40"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        class="client-reviews__footer-icon"
      >
        <circle cx="20" cy="20" r="19" stroke="currentColor" stroke-width="2" stroke-dasharray="2 2"/>
        <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="2"/>
        <circle cx="20" cy="20" r="5" stroke="currentColor" stroke-width="2"/>
      </svg>
      <span class="client-reviews__footer-text">HANDCRAFTED FROM SOLID WOOD</span>
      <span class="client-reviews__footer-sep">•</span>
      <span class="client-reviews__footer-text">INSPIRED BY NATURE</span>
      <span class="client-reviews__footer-sep">•</span>
      <span class="client-reviews__footer-text">MADE TO ENDURE</span>
    </div>
  </div>
</div>

{% stylesheet %}
  .client-reviews {
    padding-top: var(--sp-12, 64px);
    padding-bottom: var(--sp-12, 64px);
    background-color: var(--bg-primary, #f5f1ed);
    color: var(--text-primary, #1a1815);
    margin-top: var(--sp-4, 64px);
    margin-bottom: var(--sp-4, 64px);
  }

  .client-reviews__inner {
    display: flex;
    flex-direction: column;
    gap: var(--sp-14, 48px);
  }

  @media screen and (min-width: 900px) {
    .client-reviews__inner {
      flex-direction: row;
      align-items: flex-start;
      gap: 10vw;
    }
  }

  /* Left Column */
  .client-reviews__left {
    display: flex;
    flex-direction: column;
    transform: translateX(78px); /* Create a new stacking context for sticky positioning */
    max-width: 420px;
  }

  @media screen and (min-width: 900px) {
    .client-reviews__left {
    }
  }

  .client-reviews__eyebrow-wrapper {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: var(--sp-4, 16px);
  }

  .client-reviews__eyebrow-line {
    height: 1px;
    width: 24px;
    background-color: var(--text-primary, #1a1815);
  }

  .client-reviews__eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.15em;
    font-weight: 600;
  }

  .client-reviews__heading {
    font-family: var(--font-display);
    font-size: clamp(40px, 5vw, 64px);
    font-weight: var(--font-weight-regular, 400);
    line-height: 1.1;
    margin: 0 0 var(--sp-4, 16px) 0;
    letter-spacing: -0.02em;
  }

  .client-reviews__subtitle {
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.6;
    color: var(--text-secondary, #6b5d52);
    margin: 0 0 var(--sp-8, 32px) 0;
  }

  .client-reviews__quote-mark {
    font-family: var(--font-display);
    font-size: 80px;
    line-height: 0.6;
    color: rgba(107, 93, 82, 0.4);
    margin-bottom: 6px;
    transform: translateY(18px); /* Adjust vertical alignment */
  }

  .client-reviews__quote-text {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, 24px);
    line-height: 1.4;
    font-weight: var(--font-weight-regular, 400);
    margin: 0 0 0 0;
    min-height: 120px; /* Prevent layout jump */
    transition: opacity 0.3s ease;
  }

  .client-reviews__author-name {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 500;
    margin: 0 0 4px 0;
  }

  .client-reviews__author-location {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-secondary, #6b5d52);
    margin: 0 0 var(--sp-5, 20px) 0;
  }

  .client-reviews__verified {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--color-bark, #6b5d52);
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.18em;
  }

  /* Right Column (Slider) */
  .client-reviews__right {
    flex: 1.4;
    width: 100%;
    min-width: 0; /* Important for flex-child overflow */
  }

  .client-reviews__slider {
    display: flex;
    gap: var(--sp-4, 16px);
    overflow-x: auto;
    padding-bottom: var(--sp-4, 16px);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    cursor: grab;
  }

  .client-reviews__slider::-webkit-scrollbar {
    display: none;
  }

  .client-reviews__slider.is-dragging {
    cursor: grabbing;
  }

  .client-reviews__slider.is-dragging .client-reviews__card {
    pointer-events: none;
  }

  .client-reviews__card {
    flex: 0 0 85%;
    max-width: 450px;
    border-radius: var(--radius-lg, 12px);
    overflow: hidden;
    position: relative;
    aspect-ratio: 3 / 4; /* Tall portrait images like the screenshot */
    opacity: 0.4;
    transition: opacity 0.4s ease;
  }

  .client-reviews__card.slider-focused {
    opacity: 1;
  }

  @media screen and (min-width: 768px) {
    .client-reviews__card {
      flex: 0 0 65%;
    }
  }

  .client-reviews__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-user-drag: none;
    user-select: none;
  }

  /* Footer Section */
  .client-reviews__footer {
    margin: 40px 0 20px;
    display: flex;
    justify-content: center;
  }

  .client-reviews__footer-content {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
    color: var(--text-secondary, #6b5d52);
  }

  .client-reviews__footer-text {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.12em;
    font-weight: 500;
  }

  .client-reviews__footer-sep {
    font-size: 8px;
    opacity: 0.5;
  }

  .client-reviews__footer-icon {
    opacity: 0.8;
  }

  @media screen and (min-width: 1200px) {
    .client-reviews {
      display: grid;
      grid-template-rows: minmax(0, 1fr) auto;
      width: 100%;
      max-width: none;
      min-height: 100svh;
      height: 100svh;
      padding: clamp(44px, 5.8svh, 58px) clamp(70px, 4.7vw, 78px) clamp(28px, 3.4svh, 36px);
      overflow: hidden;
    }

    .client-reviews__inner {
      display: grid;
      grid-template-columns: minmax(360px, 31.8%) minmax(0, 1fr);
      align-items: stretch;
      gap: clamp(54px, 6.2vw, 98px);
      min-height: 0;
    }

    .client-reviews__left {
      max-width: 430px;
      min-height: 0;
      transform: none;
    }

    .client-reviews__eyebrow-wrapper {
      display: block;
      margin-bottom: clamp(28px, 3.6svh, 34px);
    }

    .client-reviews__eyebrow-line {
      width: 48px;
      margin-top: 18px;
      background-color: rgba(74, 44, 24, 0.72);
    }

    .client-reviews__eyebrow {
      display: block;
      margin-bottom: 16px;
      color: var(--color-earth-brown, #4a2c18);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.25em;
    }

    .client-reviews__heading {
      max-width: 380px;
      margin-bottom: clamp(24px, 3.1svh, 32px);
      font-size: clamp(62px, 4.6vw, 78px);
      font-weight: 300;
      line-height: 0.96;
      letter-spacing: -0.055em;
    }

    .client-reviews__subtitle {
      max-width: 330px;
      margin-bottom: clamp(46px, 5.6svh, 58px);
      color: var(--text-secondary, #6b5d52);
      font-size: clamp(16px, 1vw, 18px);
      line-height: 1.48;
    }

    .client-reviews__quote-mark {
      margin-bottom: clamp(18px, 2.6svh, 24px);
      color: rgba(107, 93, 82, 0.38);
      font-size: clamp(66px, 5vw, 82px);
      line-height: 0.35;
      transform: none;
    }

    .client-reviews__quote-text {
      max-width: 375px;
      min-height: 0;
      margin-bottom: clamp(26px, 3.5svh, 34px);
      font-size: clamp(28px, 1.9vw, 34px);
      font-weight: 300;
      line-height: 1.17;
      letter-spacing: -0.035em;
    }

    .client-reviews__author-box {
      margin-bottom: clamp(24px, 3.5svh, 34px);
    }

    .client-reviews__author-box::before {
      display: block;
      width: 38px;
      height: 1px;
      margin-bottom: 18px;
      background: rgba(107, 93, 82, 0.42);
      content: '';
    }

    .client-reviews__author-name {
      margin-bottom: 6px;
      font-family: var(--font-display);
      font-size: 24px;
      font-weight: 300;
      letter-spacing: -0.025em;
      line-height: 1.1;
    }

    .client-reviews__author-location {
      margin: 0;
      font-size: 13px;
      line-height: 1.3;
    }

    .client-reviews__right {
      min-height: 0;
      height: 100%;
    }

    .client-reviews__slider {
      display: grid;
      grid-template-columns: minmax(0, 1.46fr) minmax(280px, 1fr);
      gap: clamp(14px, 1.1vw, 18px);
      height: 100%;
      min-height: 0;
      overflow: hidden;
      padding-bottom: 0;
      cursor: default;
    }

    .client-reviews__card {
      display: none;
      flex: none;
      max-width: none;
      width: 100%;
      height: 100%;
      aspect-ratio: auto;
      border-radius: var(--radius-lg, 12px);
      opacity: 1;
      transition: none;
    }

    .client-reviews__card:nth-child(-n + 2) {
      display: block;
    }

    .client-reviews__card:nth-child(1) .client-reviews__img {
      object-position: center center;
    }

    .client-reviews__card:nth-child(2) .client-reviews__img {
      object-position: center center;
    }

    .client-reviews__img {
      height: 100%;
      filter: saturate(0.9) contrast(0.98);
    }

    .client-reviews__footer {
      position: relative;
      margin-top: 40px;
      justify-content: center;
    }

    .client-reviews__footer::before,
    .client-reviews__footer::after {
      position: absolute;
      top: 50%;
      width: min(22vw, 350px);
      height: 1px;
      background: rgba(107, 93, 82, 0.24);
      content: '';
    }

    .client-reviews__footer::before {
      left: 0;
    }

    .client-reviews__footer::after {
      right: 0;
    }

    .client-reviews__footer-content {
      gap: clamp(18px, 1.7vw, 28px);
      color: var(--color-bark, #6b5d52);
    }

    .client-reviews__footer-icon {
      width: 30px;
      height: 30px;
      opacity: 0.78;
    }

    .client-reviews__footer-text {
      color: var(--color-earth-brown, #4a2c18);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.22em;
    }

    .client-reviews__footer-sep {
      color: rgba(74, 44, 24, 0.72);
      font-size: 9px;
      opacity: 1;
    }
  }

  @media screen and (min-width: 1200px) and (max-height: 820px) {
    .client-reviews {
      padding: 32px clamp(58px, 4.8vw, 70px) 24px;
    }

    .client-reviews__inner {
      grid-template-columns: minmax(330px, 30.6%) minmax(0, 1fr);
      gap: clamp(42px, 5vw, 72px);
    }

    .client-reviews__eyebrow-wrapper {
      margin-bottom: 34px;
    }

    .client-reviews__eyebrow {
      margin-bottom: 12px;
      font-size: 11px;
    }

    .client-reviews__eyebrow-line {
      margin-top: 14px;
    }

    .client-reviews__heading {
      margin-bottom: 22px;
      font-size: clamp(52px, 4.6vw, 64px);
    }

    .client-reviews__subtitle {
      max-width: 330px;
      margin-bottom: 38px;
      font-size: 15px;
      line-height: 1.42;
    }

    .client-reviews__quote-mark {
      margin-bottom: 16px;
      font-size: 58px;
    }

    .client-reviews__quote-text {
      max-width: 330px;
      margin-bottom: 22px;
      font-size: clamp(22px, 1.85vw, 27px);
      line-height: 1.18;
    }

    .client-reviews__author-box {
      margin-bottom: 18px;
    }

    .client-reviews__author-box::before {
      margin-bottom: 14px;
    }

    .client-reviews__author-name {
      font-size: 21px;
    }

    .client-reviews__verified {
      font-size: 10px;
    }

    .client-reviews__slider {
      grid-template-columns: minmax(0, 1.45fr) minmax(260px, 1fr);
      gap: 14px;
    }

    .client-reviews__footer {
      margin-top: 40px;
    }

    .client-reviews__footer-icon {
      width: 24px;
      height: 24px;
    }

    .client-reviews__footer-text {
      font-size: 10px;
      letter-spacing: 0.2em;
    }

    .client-reviews__footer-content {
      gap: 18px;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('client-reviews-slider');
    if (!slider) return;

    const cards = Array.from(slider.querySelectorAll('.client-reviews__card'));
    const textEl = document.getElementById('client-review-text');
    const authorEl = document.getElementById('client-review-author');

    let isUpdating = false;
    let currentFocusedCard = null;

    function updateText(card) {
      if (!card || card === currentFocusedCard || isUpdating) return;
      isUpdating = true;
      currentFocusedCard = card;

      // Update active class on cards
      cards.forEach((c) => c.classList.remove('slider-focused'));
      card.classList.add('slider-focused');

      // Slight fade effect
      textEl.style.opacity = '0';
      authorEl.style.opacity = '0';

      setTimeout(() => {
        textEl.textContent = `“${card.dataset.review}”`;
        authorEl.textContent = card.dataset.author;
        textEl.style.opacity = '1';
        authorEl.style.opacity = '1';
        isUpdating = false;
      }, 150);
    }

    function updateLayout() {
      if (cards.length === 0) return;
      const lastCard = cards[cards.length - 1];
      const sliderWidth = slider.clientWidth;
      const cardWidth = lastCard.offsetWidth;
      const extraSpace = sliderWidth - cardWidth;
      if (extraSpace > 0) {
        lastCard.style.marginRight = `${extraSpace}px`;
      }
    }

    function updateFocusedCard() {
      if (cards.length === 0) return;

      const sliderRect = slider.getBoundingClientRect();
      const sliderLeftEdge = sliderRect.left;

      let closestCard = cards[0];
      let minDistance = Infinity;

      cards.forEach((card) => {
        const cardRect = card.getBoundingClientRect();
        const cardLeftEdge = cardRect.left;
        const distance = Math.abs(sliderLeftEdge - cardLeftEdge);

        if (distance < minDistance) {
          minDistance = distance;
          closestCard = card;
        }
      });

      updateText(closestCard);
    }

    // Initial check
    updateLayout();
    updateFocusedCard();

    // Listen for scroll events on the slider to update the focused card
    let ticking = false;
    slider.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          window.requestAnimationFrame(() => {
            updateFocusedCard();
            ticking = false;
          });
          ticking = true;
        }
      },
      { passive: true }
    );

    // Also update on window resize since layout might change
    window.addEventListener('resize', () => {
      if (!ticking) {
        window.requestAnimationFrame(() => {
          updateLayout();
          updateFocusedCard();
          ticking = false;
        });
        ticking = true;
      }
    });

    // Drag to scroll logic
    let isDown = false;
    let startX;
    let scrollLeft;

    slider.addEventListener('mousedown', (e) => {
      isDown = true;
      slider.classList.add('is-dragging');
      startX = e.pageX - slider.offsetLeft;
      scrollLeft = slider.scrollLeft;
    });
    slider.addEventListener('mouseleave', () => {
      isDown = false;
      slider.classList.remove('is-dragging');
    });
    slider.addEventListener('mouseup', () => {
      isDown = false;
      slider.classList.remove('is-dragging');
    });
    slider.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - slider.offsetLeft;
      const walk = (x - startX) * 2.5; // Scroll speed multiplier
      slider.scrollLeft = scrollLeft - walk;
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "What Our Clients Say",
  "tag": "section",
  "class": "section section-client-reviews",
  "settings": [],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "limit": 12,
      "settings": [
