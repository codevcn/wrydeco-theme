          "type": "text",
          "id": "author_name",
          "label": "Author Name",
          "default": "Nguyen H. Minh"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "What Our Clients Say",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "fallback_image": "review-1.jpg",
            "review_text": "Love the table and the craftsmanship. Two things to be aware of: the piece is substantial and beautifully made.",
