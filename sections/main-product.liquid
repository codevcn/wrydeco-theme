  {%- comment -%}
    Product state for product-info.js. Must live INSIDE the section: the script
    resolves it via `container.querySelector('[data-product-state]')` (container =
    this section), so if it sits outside, variant switching — including the price
    update via the Section Rendering API — silently never runs.
  {%- endcomment -%}
  <script type="application/json" data-product-state>
    {
      "id": {{ product.id | json }},
      "url": {{ product.url | json }},
      "selectedVariantId": {{ current_variant.id | json }},
      "hasOnlyDefaultVariant": {{ product.has_only_default_variant | json }}
    }
  </script>
</section>

{%- liquid
  assign sticky_media = current_variant.featured_media | default: product.featured_media
  assign sticky_title = product.title | split: ',' | first | split: ' - ' | first | strip
-%}
<div
  class="mp-sticky-bar"
  data-mp-sticky
  data-form-id="{{ product_form_id }}"
  aria-hidden="true"
  hidden
>
  <div class="mp-sticky-bar__inner">
    <div class="mp-sticky-bar__product">
      {% if sticky_media != blank %}
        <span class="mp-sticky-bar__thumb">
          {{
            sticky_media.preview_image
            | image_url: width: 160
            | image_tag: loading: 'lazy', widths: '80, 160', sizes: '48px', alt: sticky_title
          }}
        </span>
      {% endif %}
      <span class="mp-sticky-bar__meta">
        <span class="mp-sticky-bar__title">{{ sticky_title | escape }}</span>
        <span class="mp-sticky-bar__price" data-mp-sticky-price>{{ current_variant.price | money }}</span>
      </span>
    </div>

    <div class="mp-sticky-bar__actions">
      <div class="mp-sticky-bar__qty" data-mp-sticky-qty>
        <button
          type="button"
          class="mp-sticky-bar__qty-btn"
          data-action="decrease"
          aria-label="{{ 'products.decrease_quantity' | t | default: 'Decrease quantity' }}"
        >
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="4" y1="12" x2="20" y2="12"></line>
          </svg>
        </button>
        <input
          type="number"
          class="mp-sticky-bar__qty-input"
          value="1"
          min="1"
          inputmode="numeric"
          aria-label="{{ 'products.quantity' | t | default: 'Quantity' }}"
          data-mp-sticky-qty-input
        >
        <button
          type="button"
          class="mp-sticky-bar__qty-btn"
          data-action="increase"
          aria-label="{{ 'products.increase_quantity' | t | default: 'Increase quantity' }}"
        >
          <svg
            width="12"
            height="12"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            aria-hidden="true"
          >
            <line x1="12" y1="4" x2="12" y2="20"></line><line x1="4" y1="12" x2="20" y2="12"></line>
          </svg>
        </button>
      </div>

      <button
        type="button"
        class="mp-sticky-bar__add"
        data-mp-sticky-add
        {% if current_variant.available == false %}
          disabled
        {% endif %}
      >
        <span class="mp-sticky-bar__add-icon" aria-hidden="true">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
            <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0M9 5.5V7h1.5a.5.5 0 0 1 0 1H9v1.5a.5.5 0 0 1-1 0V8H6.5a.5.5 0 0 1 0-1H8V5.5a.5.5 0 0 1 1 0"/>
          </svg>
        </span>
        <span class="mp-sticky-bar__add-text" data-mp-sticky-add-text>
          {%- if current_variant.available -%}
            {{ 'products.add_to_cart' | t | default: 'Add to cart' }}
          {%- else -%}
            {{ 'products.sold_out' | t | default: 'Sold out' }}
          {%- endif -%}
        </span>
      </button>
    </div>
  </div>
</div>

{% render 'product-consultation-popup' %}

<script>
  const mainProductSection = document.getElementById('MainProduct-{{ section.id }}');
  if (mainProductSection) {
    mainProductSection.closest('body').querySelector('.header__icon--search').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header__icon--cart').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header').style.border = '1px solid #cfcbc7b4';
  }
</script>

{%- comment -%}
  Product JSON-LD is rendered once in snippets/meta-tags.liquid (inside <head>).
  Do not duplicate it here — duplicate structured data triggers Search Console warnings.
  See doc/SEO-diagnose.md #2.
{%- endcomment -%}

<script>
  (function () {
    function initStickyAddToCart() {
      var bar = document.querySelector('[data-mp-sticky]');
      if (!bar || bar.dataset.init === 'true') return;

      var formId = bar.getAttribute('data-form-id');
      var form = document.getElementById(formId);
      if (!form) return;

      var mainBtn = form.querySelector('button[name="add"]');
      var mainQty = form.querySelector('.quantity-input__input');
      var mainText = form.querySelector('[data-add-to-cart-text]');
      if (!mainBtn || !mainQty) return;

      bar.dataset.init = 'true';
      bar.hidden = false;

      var stickyQtyInput = bar.querySelector('[data-mp-sticky-qty-input]');
      var stickyQtyBtns = bar.querySelectorAll('[data-mp-sticky-qty] [data-action]');
      var stickyAdd = bar.querySelector('[data-mp-sticky-add]');
      var stickyAddText = bar.querySelector('[data-mp-sticky-add-text]');
      var stickyPrice = bar.querySelector('[data-mp-sticky-price]');
      var mainPrice = document.querySelector('[data-regular-price]');

      function readQty() {
        var v = parseInt(mainQty.value, 10);
        if (isNaN(v) || v < 1) v = 1;
        return v;
      }

      // Quantity is kept in sync with the main form input (single source of truth).
      function setQty(val) {
        if (val < 1) val = 1;
        mainQty.value = val;
        stickyQtyInput.value = val;
        mainQty.dispatchEvent(new Event('change', { bubbles: true }));
      }

      stickyQtyInput.value = readQty();

      stickyQtyBtns.forEach(function (btn) {
        btn.addEventListener('click', function () {
          var val = readQty();
          setQty(btn.dataset.action === 'increase' ? val + 1 : val - 1);
        });
      });
      stickyQtyInput.addEventListener('change', function () {
        setQty(parseInt(stickyQtyInput.value, 10) || 1);
      });

      // Reuse the main form's add-to-cart logic (product-form.js) verbatim by
      // pushing the chosen quantity into the main form and submitting it.
      stickyAdd.addEventListener('click', function () {
        if (stickyAdd.disabled || stickyAdd.classList.contains('is-loading')) return;
        setQty(readQty());
        stickyAdd.classList.add('is-loading');
        if (form.requestSubmit) {
          form.requestSubmit();
        } else {
          form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
        }
        // Clear the loading state once the cart update lands (or as a fallback).
        var clear = function () {
          stickyAdd.classList.remove('is-loading');
        };
        document.addEventListener('cart:updated', clear, { once: true });
        setTimeout(clear, 5000);
      });

      // Mirror the primary button's availability/label and the live price so the
      // bar always reflects the current variant.
      function syncFromMain() {
        stickyAdd.disabled = mainBtn.hasAttribute('disabled');
        if (mainText && stickyAddText && !mainBtn.classList.contains('loading')) {
          stickyAddText.textContent = mainText.textContent.trim();
        }
        if (mainPrice && stickyPrice) {
          stickyPrice.textContent = mainPrice.textContent.trim();
        }
      }
      syncFromMain();
      if (window.MutationObserver) {
        new MutationObserver(syncFromMain).observe(form, {
          subtree: true,
          childList: true,
          characterData: true,
          attributes: true,
          attributeFilter: ['disabled'],
        });
        if (mainPrice) {
          new MutationObserver(syncFromMain).observe(mainPrice, {
            childList: true,
            characterData: true,
            subtree: true,
          });
        }
      }

      // Show the bar only once the user has scrolled DOWN past the add-to-cart
      // button — i.e. the viewport's top edge is below the button (the whole
      // button has scrolled above the top of the screen). It stays hidden while
      // the button is still below the fold (not yet reached).
      if ('IntersectionObserver' in window) {
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              var scrolledPast = entry.boundingClientRect.bottom <= 0;
              bar.classList.toggle('is-visible', scrolledPast);
              bar.setAttribute('aria-hidden', scrolledPast ? 'false' : 'true');
            });
          },
          { root: null, rootMargin: '0px', threshold: 0 }
        );
        io.observe(mainBtn);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStickyAddToCart);
    } else {
      initStickyAddToCart();
    }
  })();
</script>

{% schema %}
{
  "name": "Main Product",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Benefit description goes here.</p>"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (SVG string)",
          "info": "Optional"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "Craft assurance panel"
    },
    {
      "type": "text",
      "id": "trust_subheading",
      "label": "Subheading",
      "default": "Why you choose this masterpiece"
    },
    {
      "type": "text",
      "id": "trust_delivery_title",
      "label": "Delivery title",
      "default": "White-glove delivery available"
    },
    {
      "type": "text",
      "id": "trust_delivery_text",
      "label": "Delivery description",
      "default": "Carefully delivered to your home."
    },
    {
      "type": "text",
      "id": "trust_grain_title",
      "label": "Natural grain title",
      "default": "Natural grain variation in every piece"
    },
    {
      "type": "text",
      "id": "trust_grain_text",
      "label": "Natural grain description",
      "default": "Uniquely yours."
    },
    {
      "type": "text",
      "id": "trust_craft_title",
      "label": "Craftsmanship title",
      "default": "Crafted by master artisans"
    },
    {
      "type": "text",
      "id": "trust_craft_text",
      "label": "Craftsmanship description",
      "default": "Heirloom quality, built to last."
    }
  ]
}
{% endschema %}
