{% comment %}
  Main Product Section
{% endcomment %}

<script src="{{ 'product-info.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-gallery.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
<script src="{{ 'sale-event.js' | asset_url }}" defer="defer"></script>

{% stylesheet %}
  .main-product {
    width: 100%;
    max-width: var(--layout-max-width);
    margin-inline: auto;
  }
  .main-product__media {
    min-width: 0;
  }
  .main-product__info {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }
  .main-product__title {
    margin: 0;
    padding-inline: var(--layout-gutter-mobile);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-bold);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-normal);
    color: var(--text-primary);
    text-wrap: balance;
  }
  .main-product__price-inventory {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--sp-3);
  }
  .main-product__details {
    margin: 0;
    margin-inline: var(--layout-gutter-mobile);
    padding-block: var(--sp-4) var(--sp-3);
    background-color: var(--surface-elevated);
    border-radius: var(--radius-lg);
  }

  @media screen and (min-width: 720px) {
    .main-product {
      display: grid;
      grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
      align-items: start;
      gap: var(--sp-5);
      padding: var(--section-spacing-tablet) var(--layout-padding-tablet);
      max-width: 1200px;
    }
    .main-product__info {
      gap: var(--sp-4);
    }
    .main-product__title {
      padding-inline: 0;
      font-family: var(--font-display);
      font-size: var(--font-size-display-sm);
      letter-spacing: var(--letter-spacing-tight);
    }
    .main-product__price-inventory {
      align-items: flex-end;
    }
    .main-product__details {
      margin-inline: 0;
      padding: var(--sp-5);
      border-radius: var(--radius-sm);
      box-shadow: var(--shadow-elevation-1);
    }
    .main-product__price-inventory .product-price,
    .main-product__price-inventory .product-inventory {
      margin: 0;
      padding-inline: 0px;
    }

    .main-product__price-inventory .product-inventory {
      margin: 0;
      padding-inline: 8px;
    }

    .main-product__details .product-variant-picker,
    .main-product__details .product-buy-buttons,
    .main-product__details .product-rating-summary {
      padding-inline: 0;
    }
  }

  @media screen and (min-width: 1024px) {
    .main-product {
      gap: var(--sp-7);
      padding: var(--section-spacing-desktop) var(--layout-padding-desktop);
    }
    .main-product__title {
      font-size: var(--font-size-display-md);
    }
  }
{% endstylesheet %}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  if current_variant == blank
    assign current_variant = product.first_available_variant
  endif
  if current_variant == blank
    assign current_variant = product.variants.first
  endif
  assign product_form_id = 'ProductForm-' | append: section.id
%}

<section
  id="MainProduct-{{ section.id }}"
  class="main-product"
  data-product-id="{{ product.id }}"
  data-product-url="{{ product.url }}"
  aria-labelledby="MainProductTitle-{{ section.id }}"
>
  <div class="main-product__media">
    {% render 'product-media-gallery', product: product, current_variant: current_variant, section_id: section.id %}
  </div>

  <div class="main-product__info">
    <h1 class="main-product__title" id="MainProductTitle-{{ section.id }}">{{ product.title | escape }}</h1>

    <div class="main-product__price-inventory">
      {% render 'product-price', product: product, current_variant: current_variant %}

      {% render 'product-inventory-status', current_variant: current_variant %}
    </div>

    {% render 'product-annualized-cost', product: product, current_variant: current_variant %}

    <div class="main-product__details">
      {% render 'product-sale-notice', product: product, current_variant: current_variant %}

      {% render 'product-variant-picker', product: product, current_variant: current_variant, section_id: section.id %}

      {% render 'product-buy-buttons',
        product: product,
        current_variant: current_variant,
        product_form_id: product_form_id
      %}

      {% render 'product-consultation', product: product %}

      {% render 'product-rating-summary', product: product %}

      {% for block in section.blocks %}
        {% if block.type == '@app' %}
          <div class="main-product__app-block" {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{% render 'product-consultation-popup' %}

<script type="application/json" data-product-state>
  {
    "id": {{ product.id | json }},
    "url": {{ product.url | json }},
    "selectedVariantId": {{ current_variant.id | json }},
    "hasOnlyDefaultVariant": {{ product.has_only_default_variant | json }}
  }
</script>
<script type="application/ld+json">
  {{ product | structured_data }}
</script>

{% schema %}
{
  "name": "Main Product",
  "tag": "section",
  "class": "section",
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Benefit Title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Benefit description goes here.</p>"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (SVG string)",
          "info": "Optional"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "settings": []
}
{% endschema %}
