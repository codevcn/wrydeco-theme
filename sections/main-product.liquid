{% comment %}
  Main Product Section
{% endcomment %}

{%- comment -%}
  product-info.js (Section Rendering API on variant change) is intentionally not
  loaded: variant switching now updates price/save/availability instantly on the
  client (see product-price.liquid + product-variant-picker.liquid), with no API
  round-trip.
{%- endcomment -%}
<script src="{{ 'product-gallery.js' | file_url }}" defer="defer"></script>
<script src="{{ 'product-form.js' | file_url }}" defer="defer"></script>
<script src="{{ 'sale-event.js' | file_url }}" defer="defer"></script>

{% stylesheet %}
  .judgeme-reviews__divider {
    display: flex;
    align-items: center;
    width: 100%;
    margin-block: var(--sp-3) var(--sp-4);
  }
  .judgeme-reviews__divider.divider-top {
    margin-block-start: 0;
    margin-block-end: 0;
  }

  /* Desktop-first layout */
  .main-product {
    --main-product-padding-top: 100px;
    width: 100%;
    max-width: 100rem;
    margin-inline: auto;
    padding: var(--main-product-padding-top) 64px var(--section-spacing-desktop);
  }

  .main-product__summary {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    align-items: start;
    column-gap: var(--sp-7);
  }
  .main-product__media {
    --product-gallery-viewport-offset: var(--main-product-padding-top);
    position: sticky;
    top: var(--sp-2);
    z-index: 20;
    min-width: 0;
    align-self: start;
  }
  .main-product__info {
    display: flex;
    flex-direction: column;
    gap: 15px;
    min-width: 0;
  }

  .main-product__header {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }
  .main-product__eyebrow {
    margin: 0;
    font-family: var(--font-roboto);
    font-size: 12px;
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-clay);
    padding-left: 12px;
    border-left: 3px solid var(--color-clay);
    width: fit-content;
  }
  .main-product__title {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    letter-spacing: -0.03rem;
    color: var(--text-primary);
  }
  .main-product__subtitle {
    margin: 0;
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
    /* Clamp the description teaser to 2 lines; overflow shows an ellipsis. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .main-product__features {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-evenly;
    gap: var(--sp-4);
  }
  .main-product__feature {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    margin: 0;
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
    font-weight: var(--font-weight-medium);
  }
  .main-product__feature svg {
    width: 18px;
    height: 18px;
    flex: 0 0 auto;
    color: var(--color-bark);
  }
  .main-product__feature + .main-product__feature {
    padding-left: var(--sp-4);
    border-left: 1px solid var(--border-default);
  }

  .main-product__divider {
    width: 100%;
    height: 2px;
    margin: 0;
    border: none;
    background-color: #33333317;
  }

  /* Neutralize the legacy gutter padding on the untouched buy-buttons snippet */
  .main-product__purchase .product-buy-buttons {
    padding-inline: 0;
    margin-bottom: 0;
  }

  /* Craft assurance panel spanning full width below both product columns */
  .main-product__trust {
    width: 100%;
    padding: 48px 0 0;
    background: radial-gradient(circle at top, var(--color-milk) 0%, var(--surface-default) 65%);
  }

  .main-product__trust-subheading {
    display: block;
    font-size: clamp(var(--font-size-display-sm), 7.5vw, var(--font-size-display-lg));
    font-family: var(--font-display-light);
    letter-spacing: -0.05rem;
    text-align: center;
    width: 100%;
    margin-top: var(--sp-7);
  }

  .trust-divider {
    background-color: var(--border-default);
    min-height: 100%;
    width: 0.5px;
  }

  .main-product__trust-list {
    display: flex;
    justify-content: space-between;
    gap: var(--sp-4);
    width: 100%;
    max-width: var(--layout-max-width);
    margin: 0 auto;
    padding: 0 64px;
    list-style: none;
    margin-top: var(--sp-4);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
  }

  .main-product__trust-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: flex-start;
    gap: var(--sp-4);
    min-width: 0;
    margin: 0;
    padding: var(--sp-5) 0;
    text-align: left;
  }

  .main-product__trust-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    color: var(--color-bark);
  }

  .main-product__trust-icon svg {
    width: 48px;
    height: 48px;
  }

  .main-product__trust-text {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .main-product__trust-title {
    margin: 0;
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }

  .main-product__trust-title::after {
    display: none;
  }

  .main-product__trust-sub {
    margin: 0;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: var(--line-height-normal);
    color: var(--text-secondary);
  }

  @media screen and (max-width: 1024px) {
    .main-product__summary {
      column-gap: var(--sp-6);
    }

    .main-product {
      padding-inline: var(--layout-padding-tablet);
    }

    .main-product__trust {
      min-height: calc(var(--sp-8) * 8);
      padding-block: calc(var(--sp-8) * 2);
    }

    .main-product__trust-item {
      min-height: calc(var(--sp-8) * 5);
      padding: var(--sp-5);
    }

    .main-product__trust-icon {
      width: calc(var(--sp-7) * 2);
      height: calc(var(--sp-7) * 2);
    }

    .main-product__trust-icon svg {
      width: var(--sp-6);
      height: var(--sp-6);
    }

    .main-product__trust-title {
      font-size: var(--font-size-body-xl);
    }
  }

  @media screen and (max-width: 768px) {
    .main-product {
      padding: var(--sp-5) var(--layout-padding-mobile) var(--section-spacing-mobile);
    }
    .main-product__summary {
      grid-template-columns: minmax(0, 1fr);
    }
    .main-product__media {
      --product-gallery-viewport-offset: 0px;
      position: static;
      top: auto;
    }
    .main-product__title {
      font-size: var(--font-size-display-sm);
    }
    .main-product__subtitle {
      font-size: var(--font-size-body-md);
    }
    .main-product__trust {
      margin-top: var(--sp-4);
      padding-block: var(--sp-8);
    }

    .main-product__trust-list {
      display: flex;
      flex-direction: column;
      gap: 0;
      padding: 0;
    }

    .main-product__trust-item {
      min-height: 0;
      align-items: flex-start;
      gap: var(--sp-4);
      padding: var(--sp-5) 0;
      border-bottom: 1px solid var(--border-light);
    }

    .main-product__trust-item:last-child {
      border-bottom: 0;
    }

    .main-product__trust-icon,
    .main-product__trust-icon svg {
      width: 40px;
      height: 40px;
    }

    .main-product__media {
      margin-top: var(--sp-8);
    }
  }

  @media screen and (max-width: 480px) {
    .main-product__trust {
      padding-block: var(--sp-0);
      min-height: 0;
    }

    .main-product__trust-icon,
    .main-product__trust-icon svg {
      width: 32px;
      height: 32px;
    }

    .main-product__trust-item {
      min-height: 0;
      padding: var(--sp-3) var(--sp-3);
    }

    .main-product__trust-title {
      font-size: var(--font-size-body-md);
    }

    .main-product__trust-subheading {
      display: block;
      font-size: clamp(var(--font-size-display-sm), 7.5vw, var(--font-size-display-lg));
      font-family: var(--font-display-light);
      letter-spacing: -0.05rem;
      text-align: center;
      width: 100%;
      margin-top: var(--sp-5);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .main-product__trust-item {
      transition: none;
    }

    .main-product__trust-item:hover {
      transform: none;
    }
  }

  /* Sticky quick add-to-cart bar (shown when the primary button leaves view) */
  .mp-sticky-bar {
    display: none;
    position: fixed;
    inset: auto 0 0 0;
    z-index: var(--z-overlay);
    background-color: var(--color-milk);
    border-top: 1px solid var(--border-light);
    box-shadow: var(--cart-drawer-footer-shadow);
    transform: translateY(100%);
    visibility: hidden;
    transition: transform var(--timing-base) var(--ease-out), visibility var(--timing-base) var(--ease-out);
    padding-bottom: env(safe-area-inset-bottom, 0px);
  }
  .mp-sticky-bar.is-visible {
    transform: translateY(0);
    visibility: visible;
  }
  .mp-sticky-bar[hidden] {
    display: none;
  }
  .mp-sticky-bar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
    width: 100%;
    max-width: var(--layout-max-width);
    margin-inline: auto;
    padding: var(--sp-3) 64px;
  }
  .mp-sticky-bar__product {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    min-width: 0;
  }
  .mp-sticky-bar__thumb {
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    overflow: hidden;
    border-radius: var(--radius-md);
    background-color: var(--bg-secondary);
  }
  .mp-sticky-bar__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .mp-sticky-bar__meta {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }
  .mp-sticky-bar__title {
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 42ch;
  }
  .mp-sticky-bar__price {
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }
  .mp-sticky-bar__actions {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    flex: 0 0 auto;
  }
  .mp-sticky-bar__qty {
    display: flex;
    align-items: center;
    height: 48px;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-sm);
  }
  .mp-sticky-bar__qty-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 100%;
    background: none;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard);
  }
  .mp-sticky-bar__qty-btn:hover {
    background-color: var(--bg-secondary);
  }
  .mp-sticky-bar__qty-input {
    width: 40px;
    min-width: 0;
    height: 100%;
    text-align: center;
    border: none;
    background: none;
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    color: var(--text-primary);
    -moz-appearance: textfield;
  }
  .mp-sticky-bar__qty-input::-webkit-outer-spin-button,
  .mp-sticky-bar__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .mp-sticky-bar__add {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    height: 48px;
    min-width: 220px;
    padding: 0 var(--sp-6);
    background-color: var(--color-ebony);
    color: var(--color-milk);
    border: none;
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard);
  }
  .mp-sticky-bar__add:hover {
    background-color: var(--text-primary);
  }
  .mp-sticky-bar__add[disabled] {
    opacity: 0.6;
    cursor: not-allowed;
  }
  .mp-sticky-bar__add.is-loading {
    pointer-events: none;
    opacity: 0.7;
  }
  .mp-sticky-bar__add.is-loading .mp-sticky-bar__add-icon,
  .mp-sticky-bar__add.is-loading .mp-sticky-bar__add-text {
    opacity: 0;
  }
  .mp-sticky-bar__add.is-loading::after {
    content: '';
    position: absolute;
    top: calc(50% - 10px);
    left: calc(50% - 10px);
    width: 20px;
    height: 20px;
    border: 2px solid currentColor;
    border-top-color: transparent;
    border-radius: 50%;
    animation: mp-sticky-spinner 0.6s linear infinite;
  }
  @keyframes mp-sticky-spinner {
    to {
      transform: rotate(360deg);
    }
  }
  .mp-sticky-bar__add-icon {
    display: inline-flex;
  }

  @media screen and (max-width: 1024px) {
    .mp-sticky-bar__inner {
      padding-inline: var(--layout-padding-tablet);
    }
  }

  @media screen and (max-width: 768px) {
    .mp-sticky-bar__add-icon svg {
      height: 24px;
      width: 24px;
    }
    .mp-sticky-bar__inner {
      gap: var(--sp-4);
      padding: var(--sp-3) var(--layout-padding-mobile);
      background-color: var(--color-milk);
      box-shadow: 0 -2px 4px rgb(0 0 0 / 10%);
    }
    /* On phones the product summary is dropped so the controls get the space. */
    .mp-sticky-bar__product {
      display: none;
    }
    .mp-sticky-bar__actions {
      flex: 1 1 auto;
      justify-content: space-between;
    }
    .mp-sticky-bar__add {
      flex: 1 1 auto;
      min-width: 0;
      padding: 0 var(--sp-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mp-sticky-bar {
      transition: none;
    }
  }

  /* Judge.me star rating, placed right under the price */
  .main-product__rating {
    display: flex;
    gap: var(--sp-5);
    align-items: center;
    line-height: 1;
  }
  .main-product__rating:empty {
    display: none;
  }
  .main-product__rating .jdgm-preview-badge {
    display: inline-flex;
    align-items: center;
  }
  .main-product__rating .jdgm-prev-badge {
    display: inline-flex !important;
    gap: 8px;
  }

  .main-product__rating .free-shipping-included {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: var(--font-size-body-sm);
    padding: var(--sp-1) var(--sp-3);
    background-color: #b2e6b2;
    color: #333;
    width: fit-content;
    border-radius: 99px;
  }

  .main-product__rating .free-shipping-included svg {
    width: 20px;
    height: 20px;
  }

  @media screen and (max-width: 400px) {
    .main-product__rating {
      align-items: flex-start;
      flex-direction: column;
      gap: 4px;
    }
  }
{% endstylesheet %}

{% liquid
  assign current_variant = product.selected_or_first_available_variant
  if current_variant == blank
    assign current_variant = product.first_available_variant
  endif
  if current_variant == blank
    assign current_variant = product.variants.first
  endif
  assign product_form_id = 'ProductForm-' | append: section.id
%}

<section
  id="MainProduct-{{ section.id }}"
  class="main-product"
  data-product-id="{{ product.id }}"
  data-product-url="{{ product.url }}"
  aria-labelledby="MainProductTitle-{{ section.id }}"
>
  <div class="main-product__summary">
    <div class="main-product__media">
      {% render 'product-media-gallery', product: product, current_variant: current_variant, section_id: section.id %}
    </div>

    <div class="main-product__info">
      <div class="main-product__header">
        {%- assign current_collection = collection | default: product.collections.first -%}
        {%- if current_collection != blank -%}
          <a href="{{ current_collection.url }}" class="main-product__eyebrow" style="text-decoration: none;">
            {{ current_collection.title }}
          </a>
        {%- endif -%}
        <h1 class="main-product__title" id="MainProductTitle-{{ section.id }}">{{ product.title | escape }}</h1>
        {%- comment -%}
          Real per-product teaser from the product description (plain text, clamped to 2 lines
          with an ellipsis via CSS). Replaces the old hardcoded subtitle that was identical on
          every product. The full description still renders in the product-comparison accordion.
          See doc/SEO-diagnose.md #3.
        {%- endcomment -%}
        {%- assign product_subtitle = product.description | strip_html | strip -%}
        {%- if product_subtitle != blank -%}
          <p class="main-product__subtitle">{{ product_subtitle }}</p>
        {%- endif -%}
      </div>

      {% render 'product-price', product: product, current_variant: current_variant %}

      {%- comment -%}
        Judge.me star rating rendered from the product's judgeme.badge metafield so it appears
        right under the price — independent of Judge.me's automatic JS placement (which otherwise
        injects the badge elsewhere and leaves the preview placeholder empty). The Judge.me script
        re-hydrates this .jdgm-preview-badge with live data on load.
      {%- endcomment -%}
      <div class="main-product__rating">
        <div class="jdgm-widget jdgm-preview-badge" data-id="{{ product.id }}">
          {{ product.metafields.judgeme.badge }}
        </div>
        <div class="free-shipping-included">
          <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
            <path d="M0 0h24v24H0z" fill="none"></path>
            <path fill="currentColor" d="M18 8h-2V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v10h2a3 3 0 1 0 6 0h4a3 3 0 1 0 6 0h2v-5zM7 18.5a1.5 1.5 0 1 1 .001-3.001A1.5 1.5 0 0 1 7 18.5M4 14V7h10v7zm13 4.5a1.5 1.5 0 1 1 .001-3.001A1.5 1.5 0 0 1 17 18.5"></path>
          </svg>
          <span class="free-shipping-included-text">Free shipping included</span>
        </div>
      </div>

      <ul class="main-product__features">
        <li class="main-product__feature">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
            <path d="M2 21c0-3 1.85-5.36 5.08-6"></path>
          </svg>
          Solid walnut
        </li>
        <li class="main-product__feature">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M18 11V6a2 2 0 0 0-2-2 2 2 0 0 0-2 2"></path>
            <path d="M14 10V4a2 2 0 0 0-2-2 2 2 0 0 0-2 2v2"></path>
            <path d="M10 10.5V6a2 2 0 0 0-2-2 2 2 0 0 0-2 2v8"></path>
            <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"></path>
          </svg>
          Hand-finished
        </li>
        <li class="main-product__feature">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="3" y="4" width="18" height="18" rx="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          Made to order in 3–5 weeks
        </li>
      </ul>

      <hr class="main-product__divider">

      {% render 'product-variant-picker', product: product, current_variant: current_variant, section_id: section.id %}

      <div class="main-product__purchase">
        {% render 'product-buy-buttons',
          product: product,
          current_variant: current_variant,
          product_form_id: product_form_id
        %}
      </div>

      {% render 'product-consultation', product: product %}
      {% render 'product-custom-link-popup' %}

      {% for block in section.blocks %}
        {% if block.type == '@app' %}
          <div class="main-product__app-block" {{ block.shopify_attributes }}>
            {% render block %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <aside class="main-product__trust" aria-labelledby="MainProductTrustHeading-{{ section.id }}">
    <div class="judgeme-reviews__divider divider-top" aria-hidden="true">
      <span></span>
    </div>

    {%- comment -%}
      Single logical H2 for this panel, driven by schema (was hardcoded + a second hidden
      H2 that duplicated the heading). See doc/SEO-diagnose.md #5.
    {%- endcomment -%}
