{% comment %}
  Collection listing page.

  Top toolbar (Filter + Material/Room/Price facets, Sort by, item count) and a
  3-column product grid. The Filter button opens an (empty) drawer from the left.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/collection
{% endcomment %}

<section class="collection-page" id="Collection-{{ section.id }}">
  {%- liquid
    assign collection_is_empty = false
    assign per_page = 24
    if collection.all_products_count == 0
      assign collection_is_empty = true
    endif
    assign consultation_url = section.settings.consultation_url | default: pages.customization.url | default: routes.root_url
  -%}

  {%- unless collection_is_empty -%}
    <div class="col-toolbar">
      <div class="col-toolbar__left">
        <div class="col-toolbar__facets">
          {%- capture col_caret -%}
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"></polyline></svg>
        {%- endcapture -%}
          {%- capture col_check -%}
          <span class="col-checkbox"><svg viewBox="0 0 14 14" fill="none" class="col-checkbox__icon"><path d="M3 7.5L6 10.5L11 3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
        {%- endcapture -%}

          {%- liquid
            assign avail_filter = null
            assign price_filter = null
            assign wood_native = null
            for f in collection.filters
              if f.type == 'price_range'
                assign price_filter = f
              elsif f.param_name == 'filter.v.availability'
                assign avail_filter = f
              elsif f.param_name contains 'wood_type'
                assign wood_native = f
              endif
            endfor
          -%}

          {%- comment -%} Availability — native storefront filter (multi-select) {%- endcomment -%}
          {%- if avail_filter != blank -%}
            <div
              class="col-dropdown col-dropdown--left col-toolbar__facet{% if avail_filter.active_values.size > 0 %} has-active{% endif %}"
              data-dropdown
            >
              <button
                type="button"
                class="col-dropdown__trigger"
                data-dropdown-toggle
                aria-expanded="false"
                aria-haspopup="true"
              >
                <span>{{ avail_filter.label | escape }}</span>
                {{ col_caret }}
              </button>
              <div class="col-dropdown__menu">
                {%- for value in avail_filter.values -%}
                  <a
                    href="{% if value.active %}{{ value.url_to_remove }}{% else %}{{ value.url_to_add }}{% endif %}"
                    class="col-dropdown__option{% if value.active %} is-active{% endif %}"
                  >
                    <input
                      type="checkbox"
                      class="visually-hidden"
                      {% if value.active %}
                        checked
                      {% endif %}
                      tabindex="-1"
                      aria-hidden="true"
                    >
                    {{ col_check }}
                    <span class="col-dropdown__option-label">{{ value.label | escape }}</span>
                    <span class="col-dropdown__option-count">({{ value.count }})</span>
                  </a>
                {%- endfor -%}
                {%- if avail_filter.active_values.size > 0 -%}
                  <a href="{{ avail_filter.url_to_remove }}" class="col-dropdown__clear">Clear</a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%} Price — native price_range filter (carries other active filters + sort) {%- endcomment -%}
          {%- if price_filter != blank -%}
            {%- assign price_active = false -%}
            {%- if price_filter.min_value.value != null or price_filter.max_value.value != null -%}
              {%- assign price_active = true -%}
            {%- endif -%}
            <div
              class="col-dropdown col-dropdown--left col-toolbar__facet{% if price_active %} has-active{% endif %}"
              data-dropdown
            >
              <button
                type="button"
                class="col-dropdown__trigger"
                data-dropdown-toggle
                aria-expanded="false"
                aria-haspopup="true"
              >
                <span>{{ price_filter.label | escape }}</span>
                {{ col_caret }}
              </button>
              <div class="col-dropdown__menu">
                <form class="col-price-form">
                  <div class="col-price-form__header">
                    <span>MIN</span>
                    <span>MAX</span>
                  </div>
                  <div class="col-price-form__inputs">
                    <label class="visually-hidden" for="CollectionPriceMin-{{ section.id }}">Minimum price</label>
                    <input
                      id="CollectionPriceMin-{{ section.id }}"
                      name="{{ price_filter.min_value.param_name }}"
                      type="number"
                      placeholder="0"
                      value="{{ price_filter.min_value.value | money_without_currency | replace: ',', '' }}"
                      step="0.01"
                      min="0"
                    >
                    <label class="visually-hidden" for="CollectionPriceMax-{{ section.id }}">Maximum price</label>
                    <input
                      id="CollectionPriceMax-{{ section.id }}"
                      name="{{ price_filter.max_value.param_name }}"
                      type="number"
                      placeholder="{{ price_filter.range_max | money_without_currency | replace: ',', '' }}"
                      value="{{ price_filter.max_value.value | money_without_currency | replace: ',', '' }}"
                      step="0.01"
                      min="0"
                    >
                  </div>
                  <button type="submit" class="col-price-form__apply">Apply</button>

                  {%- for f in collection.filters -%}
                    {%- if f.type != 'price_range' -%}
                      {%- for v in f.active_values -%}
                        <input type="hidden" name="{{ v.param_name }}" value="{{ v.value }}">
                      {%- endfor -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if collection.sort_by != blank -%}
                    <input type="hidden" name="sort_by" value="{{ collection.sort_by }}">
                  {%- endif -%}
                </form>
                {%- if price_active -%}
                  <a href="{{ price_filter.url_to_remove }}" class="col-dropdown__clear">Clear</a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}

          {%- comment -%}
            Wood Type is rendered only when the custom.wood_type metafield filter is
            enabled in Shopify Search & Discovery. A client-side fallback would only
            filter the current pagination page and would produce incomplete results.
          {%- endcomment -%}
          {%- if wood_native != blank -%}
            <div
              class="col-dropdown col-dropdown--left col-toolbar__facet{% if wood_native.active_values.size > 0 %} has-active{% endif %}"
              data-dropdown
            >
              <button
                type="button"
                class="col-dropdown__trigger"
                data-dropdown-toggle
                aria-expanded="false"
                aria-haspopup="true"
              >
                <span>Wood Type</span>
                {{ col_caret }}
              </button>
              <div class="col-dropdown__menu">
                {%- for value in wood_native.values -%}
                  <a
                    href="{% if value.active %}{{ value.url_to_remove }}{% else %}{{ value.url_to_add }}{% endif %}"
                    class="col-dropdown__option{% if value.active %} is-active{% endif %}"
                  >
                    <input
                      type="checkbox"
                      class="visually-hidden"
                      {% if value.active %}
                        checked
                      {% endif %}
                      tabindex="-1"
                      aria-hidden="true"
                    >
                    {{ col_check }}
                    <span class="col-dropdown__option-label">{{ value.label | escape }}</span>
                    <span class="col-dropdown__option-count">({{ value.count }})</span>
                  </a>
                {%- endfor -%}
                {%- if wood_native.active_values.size > 0 -%}
                  <a href="{{ wood_native.url_to_remove }}" class="col-dropdown__clear">Clear</a>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="col-toolbar__right">
        {% liquid
          assign sort_by = collection.sort_by | default: collection.default_sort_by
          assign current_sort_option = collection.sort_options | find: 'value', sort_by
          assign current_sort_label = current_sort_option.name | default: 'Featured'
          if sort_by == 'manual'
            assign current_sort_label = 'Featured'
          endif
        %}
        <div class="col-dropdown col-dropdown--right col-toolbar__sort" data-dropdown>
          <button
            type="button"
            class="col-dropdown__trigger"
            data-dropdown-toggle
            aria-expanded="false"
            aria-haspopup="true"
          >
            <span class="col-toolbar__sort-label">Sort by:</span>
            <span class="col-toolbar__sort-value">{{ current_sort_label }}</span>
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </button>
          <div class="col-dropdown__menu">
            <button
              type="button"
              class="col-dropdown__option{% if sort_by == 'manual' %} is-active{% endif %}"
              data-sort-value="manual"
            >
              <span class="col-dropdown__option-label">Featured</span>
            </button>
            <button
              type="button"
              class="col-dropdown__option{% if sort_by == 'best-selling' %} is-active{% endif %}"
              data-sort-value="best-selling"
            >
              <span class="col-dropdown__option-label">Best Selling</span>
            </button>
            <button
              type="button"
              class="col-dropdown__option{% if sort_by == 'price-ascending' %} is-active{% endif %}"
              data-sort-value="price-ascending"
            >
              <span class="col-dropdown__option-label">Price: Low to High</span>
            </button>
            <button
              type="button"
              class="col-dropdown__option{% if sort_by == 'price-descending' %} is-active{% endif %}"
              data-sort-value="price-descending"
            >
              <span class="col-dropdown__option-label">Price: High to Low</span>
            </button>
            <button
              type="button"
              class="col-dropdown__option{% if sort_by == 'created-descending' %} is-active{% endif %}"
              data-sort-value="created-descending"
            >
              <span class="col-dropdown__option-label">Newest</span>
            </button>
          </div>
        </div>
        <div class="col-toolbar__count">
          {{ collection.products_count }}
          {{ collection.products_count | pluralize: 'item', 'items' }}
        </div>
      </div>
    </div>
  {%- endunless -%}

  {%- if collection_is_empty -%}
    <div class="col-empty-state">
      <div class="col-empty-state__inner">
        <div class="col-empty-state__art" aria-hidden="true">
          <svg viewBox="0 0 240 168" fill="none" xmlns="http://www.w3.org/2000/svg">
            <!-- Arch backdrop -->
            <path d="M40 150V90a80 80 0 0 1 160 0v60Z" fill="var(--color-stone)" opacity="0.55"/>
            <!-- Console table top -->
            <path d="M64 108h112" stroke="var(--color-bark)" stroke-width="1.6" stroke-linecap="round"/>
            <!-- Table legs (arched omega) -->
            <path d="M80 108c0 18-6 24-14 42M160 108c0 18 6 24 14 42" stroke="var(--color-bark)" stroke-width="1.6" stroke-linecap="round"/>
            <path d="M84 150c0-14 4-22 12-22s12 8 12 22M132 150c0-14 4-22 12-22s12 8 12 22" stroke="var(--color-bark)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            <!-- Vase -->
            <path d="M96 108c-5 0-8-4-8-9s3-11 9-11h6c6 0 9 6 9 11s-3 9-8 9Z" stroke="var(--color-bark)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            <!-- Branches -->
            <path d="M100 88V52" stroke="var(--color-clay)" stroke-width="1.4" stroke-linecap="round"/>
            <path d="M100 70c-7-2-12-8-13-17M100 66c7-2 11-7 12-15M100 60c-6-1-11-5-13-11M100 76c6-1 10-4 12-9" stroke="var(--color-clay)" stroke-width="1.4" stroke-linecap="round"/>
            <!-- Bowl -->
            <path d="M132 108a11 11 0 0 0 22 0Z" stroke="var(--color-bark)" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <h2 class="col-empty-state__title">{{ section.settings.empty_heading | escape }}</h2>
        <p class="col-empty-state__text">{{ section.settings.empty_text | escape | newline_to_br }}</p>

        <div class="col-empty-state__actions">
          <a class="col-empty-state__btn col-empty-state__btn--primary" href="{{ routes.collections_url }}">
            {{- section.settings.empty_primary_label | escape -}}
          </a>
          <a class="col-empty-state__btn col-empty-state__btn--secondary" href="{{ consultation_url }}">
            {{- section.settings.empty_secondary_label | escape -}}
          </a>
        </div>
      </div>

      {%- assign other_collections = collections | where: 'products_count' -%}
      {%- assign other_count = 0 -%}
      {%- for other in other_collections -%}
        {%- if other.handle != collection.handle and other.all_products_count > 0 -%}
          {%- assign other_count = other_count | plus: 1 -%}
        {%- endif -%}
      {%- endfor -%}

      {%- if other_count > 0 -%}
        <div class="col-empty-state__divider" role="separator">
          <span class="col-empty-state__divider-line"></span>
          <span class="col-empty-state__divider-label">{{ section.settings.empty_other_label | escape }}</span>
          <span class="col-empty-state__divider-line"></span>
        </div>

        <ul class="col-empty-state__others" role="list">
          {%- assign shown = 0 -%}
          {%- for other in other_collections -%}
            {%- if other.handle == collection.handle or other.all_products_count == 0 -%}
              {%- continue -%}
            {%- endif -%}
            {%- assign shown = shown | plus: 1 -%}
            <li class="col-empty-state__other">
              <a class="col-empty-state__other-link" href="{{ other.url }}">
                <span class="col-empty-state__other-media">
                  {%- if other.featured_image != blank -%}
                    {%- assign other_image_alt = other.featured_image.alt | default: other.title -%}
                    {{
                      other.featured_image
                      | image_url: width: 640
                      | image_tag:
                        class: 'col-empty-state__other-img',
                        loading: 'lazy',
                        widths: '280, 420, 640',
                        sizes: '(min-width: 768px) 25vw, 45vw',
                        alt: other_image_alt
                    }}
                  {%- else -%}
                    {{ 'collection-1' | placeholder_svg_tag: 'col-empty-state__other-img placeholder-svg' }}
                  {%- endif -%}
                </span>
                <span class="col-empty-state__other-title">{{ other.title | escape }}</span>
              </a>
            </li>
            {%- if shown >= 4 -%}{%- break -%}{%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </div>
  {%- else -%}
    <div class="col-grid-wrap">
      {% paginate collection.products by per_page %}
        {% if collection.products.size == 0 %}
          <p class="col-empty">No products match the selected filters.</p>
        {% else %}
          <div class="col-grid">
            {% for product in collection.products %}
              {% liquid
                assign artist = ''
                assign author = product.metafields.custom.author_info.value
                if author != blank and author.author_name.value != blank
                  assign artist = author.author_name.value
                elsif product.vendor != blank
                  assign artist = product.vendor
                endif

                assign material = product.metafields.custom.product_material
                assign ptype = product.type

                # Flag products in the "new-arrivals" collection for the "New" badge.
                assign is_new = false
                for coll in product.collections
                  if coll.handle == 'new-arrivals'
                    assign is_new = true
                    break
                  endif
                endfor
              %}
              {% assign card_variant = product.selected_or_first_available_variant | default: product.variants.first %}
              <article class="pcard">
                <div class="pcard__media-wrap">
                  <a
                    class="pcard__media"
                    href="{{ product.url }}"
                    aria-label="{{ product.title | escape }}"
                    data-hover-gallery
                  >
                    {% if product.media.size > 0 %}
                      {% assign img_count = 0 %}
                      {% for media in product.media %}
                        {% if media.media_type == 'image' %}
                          {% assign img_class = 'pcard__image' %}
                          {% if img_count == 0 %}{% assign img_class = 'pcard__image is-active' %}{% endif %}
                          {%- comment -%}
                            Fallback alt to the product title when the media has no alt. Compute it in a
                            variable: chaining `| default:` after image_tag applies to the <img> string
                            (never blank), so the fallback never fired. See doc/SEO-diagnose.md #8.
                          {%- endcomment -%}
                          {% assign card_alt = media.alt | default: product.title %}
                          {{
                            media.preview_image
                            | image_url: width: 720
                            | image_tag:
                              class: img_class,
                              loading: 'lazy',
                              widths: '280, 420, 560, 720',
                              sizes: '(min-width: 1024px) 24vw, (min-width: 720px) 33vw, 90vw',
                              alt: card_alt
                          }}
                          {% assign img_count = img_count | plus: 1 %}
                          {% if img_count >= 5 %}{% break %}{% endif %}
                        {% endif %}
                      {% endfor %}
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'pcard__image is-active placeholder-svg' }}
                    {% endif %}
                  </a>

                  <button
                    type="button"
                    class="pcard__add"
                    data-add-to-cart
                    data-variant-id="{{ card_variant.id }}"
                    aria-label="Add {{ product.title | escape }} to cart"
                    {% unless product.available %}
                      disabled aria-disabled="true"
                    {% endunless %}
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      fill="currentColor"
                      class="bi bi-cart-plus-fill"
                      viewBox="0 0 16 16"
                      aria-hidden="true"
                    >
                      <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0M9 5.5V7h1.5a.5.5 0 0 1 0 1H9v1.5a.5.5 0 0 1-1 0V8H6.5a.5.5 0 0 1 0-1H8V5.5a.5.5 0 0 1 1 0"/>
                    </svg>
                  </button>

                  {%- if is_new -%}
                    <span class="pcard__new">
                      <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 36 36">
                        <path d="M0 0h36v36H0z" fill="none" />
                        <path fill="currentColor" d="m34.11 24.49l-3.92-6.62l3.88-6.35a1 1 0 0 0-.85-1.52H2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h31.25a1 1 0 0 0 .86-1.51m-23.6-3.31H9.39l-3.26-4.34v4.35H5V15h1.13l3.27 4.35V15h1.12ZM16.84 16h-3.53v1.49h3.2v1h-3.2v1.61h3.53v1h-4.66V15h4.65Zm8.29 5.16H24l-1.55-4.59l-1.55 4.61h-1.12l-2-6.18H19l1.32 4.43L21.84 15h1.22l1.46 4.43L25.85 15h1.23Z" class="clr-i-solid clr-i-solid-path-1" />
                        <path fill="none" d="M0 0h36v36H0z" />
                      </svg>
                      <span class="pcard__new-text">New</span>
                    </span>
                  {%- endif -%}
                </div>

                <div class="pcard__info">
                  {% if ptype != blank %}
                    <span class="pcard__pill">{{ ptype | escape }}</span>
                  {% endif %}

                  <h2 class="pcard__title">
                    <a class="pcard__title-link" href="{{ product.url }}">
                      {{- product.title | split: ',' | first | split: ' - ' | first | strip | escape -}}
                    </a>
                  </h2>

                  <hr class="pcard__divider">

                  {% if artist != blank %}
                    <p class="pcard__artist">Crafted By {{ artist | escape }}</p>
                  {% endif %}

                  {%- comment -%}
                    Judge.me star rating from the product's judgeme.badge metafield (server-rendered).
                    Hidden by CSS for products with no reviews.
                  {%- endcomment -%}
                  {%- if product.metafields.judgeme.badge != blank -%}
                    <div class="pcard__rating">
                      {{ product.metafields.judgeme.badge }}
                    </div>
                  {%- endif -%}

                  <p class="pcard__price">
                    <span style="font-weight: var(--font-weight-light);">From</span> {{ product.price | money }}
                  </p>

                  <span class="pcard__freeshipping">
                    <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 24 24">
                      <path d="M0 0h24v24H0z" fill="none" />
                      <path fill="currentColor" d="M18 8h-2V7a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v10h2a3 3 0 1 0 6 0h4a3 3 0 1 0 6 0h2v-5zM7 18.5a1.5 1.5 0 1 1 .001-3.001A1.5 1.5 0 0 1 7 18.5M4 14V7h10v7zm13 4.5a1.5 1.5 0 1 1 .001-3.001A1.5 1.5 0 0 1 17 18.5" />
                    </svg>
                    <span class="pcard__freeshipping-text">Free Shipping</span>
                  </span>
                </div>
              </article>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="col-pagination" role="navigation" aria-label="Pagination">
              <div class="col-pagination__inner">
                {% if paginate.previous %}
                  <a href="{{ paginate.previous.url }}" class="col-pagination__prev" aria-label="Previous page">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                    <span>Previous</span>
                  </a>
                {% else %}
                  <span class="col-pagination__prev is-disabled">
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="15 18 9 12 15 6"></polyline>
                    </svg>
                    <span>Previous</span>
                  </span>
                {% endif %}

                <div class="col-pagination__sep"></div>

                <div class="col-pagination__numbers">
                  {% for part in paginate.parts %}
                    {% if part.is_link %}
                      <a href="{{ part.url }}" class="col-pagination__num" aria-label="Page {{ part.title }}">
                        {{- part.title -}}
                      </a>
                    {% else %}
                      {% if part.title == paginate.current_page %}
                        <span class="col-pagination__num is-current" aria-current="page">{{ part.title }}</span>
                      {% else %}
                        <span class="col-pagination__num is-deco">{{ part.title }}</span>
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                </div>

                <div class="col-pagination__sep"></div>

                {% if paginate.next %}
                  <a href="{{ paginate.next.url }}" class="col-pagination__next" aria-label="Next page">
                    <span>Next</span>
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                  </a>
                {% else %}
                  <span class="col-pagination__next is-disabled">
                    <span>Next</span>
                    <svg
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <polyline points="9 18 15 12 9 6"></polyline>
                    </svg>
                  </span>
                {% endif %}
              </div>
            </nav>
          {% endif %}
        {% endif %}
      {% endpaginate %}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    white-space: nowrap;
    border: 0;
  }

  .collection-page {
    width: 100%;
    background-color: var(--color-cream);
    font-family: var(--font-body);
  }

  /* Toolbar */
  .col-toolbar {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    border-top: 1px solid var(--border-light);
    border-bottom: 1px solid var(--border-light);
  }
  .col-toolbar__left,
  .col-toolbar__right {
    display: flex;
    align-items: stretch;
  }
  .col-toolbar__facet,
  .col-toolbar__sort,
  .col-toolbar__count {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    height: 52px;
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.05em;
    color: var(--text-primary);
  }
  .col-toolbar__facets {
    display: flex;
    align-items: stretch;
    padding-left: var(--layout-padding-mobile);
  }
  .col-toolbar__facet {
    padding: 0 var(--sp-5);
    border-right: 1px solid var(--border-light);
  }
  .col-toolbar__facet:last-child {
    border-right: none;
  }
  .col-toolbar__sort {
    padding: 0 var(--sp-5);
  }
  .col-toolbar__sort-label {
    color: var(--text-secondary);
  }

  /* Generic Dropdown Component */
  .col-dropdown {
    position: relative;
  }
  .col-dropdown__trigger {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    height: 100%;
    cursor: pointer;
    transition: color var(--timing-fast) var(--ease-standard);
    background: none;
    border: none;
    padding: 0;
    font: inherit;
    color: inherit;
  }
  .col-dropdown__trigger svg {
    width: 14px;
    height: 14px;
    color: var(--text-secondary);
    transition: transform var(--timing-fast) var(--ease-standard);
  }
  .col-dropdown__trigger:hover,
  .col-dropdown__trigger.picked {
    color: var(--color-earth-brown);
  }
  .col-dropdown__trigger.picked svg {
    transform: rotate(180deg);
  }
  /* Indicator when a filter currently has active values */
  .col-dropdown.has-active > .col-dropdown__trigger {
    color: var(--color-earth-brown);
    font-weight: var(--font-weight-bold);
  }
  .col-dropdown__menu {
    position: absolute;
    top: 100%;
    background-color: var(--color-milk);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-elevation-3);
    min-width: 240px;
    max-width: calc(100vw - var(--sp-6));
    padding: var(--sp-2) 0;
    opacity: 0;
    visibility: hidden;
    transform: translateY(10px);
    transition: opacity var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard),
      visibility var(--timing-short) var(--ease-standard);
    z-index: 100;
    display: flex;
    flex-direction: column;
  }
  .col-dropdown--left .col-dropdown__menu {
    left: 0;
  }
  .col-dropdown--right .col-dropdown__menu {
    right: 0;
  }
  .col-dropdown.is-open .col-dropdown__menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }
  .col-dropdown__option {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-5);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    color: var(--text-primary);
    text-decoration: none;
    text-transform: none;
    letter-spacing: 0;
    font-weight: var(--font-weight-medium);
    transition: background-color var(--timing-fast) var(--ease-standard);
    text-align: left;
    background: none;
    border: none;
    cursor: pointer;
  }
  .col-dropdown__option:hover {
    background-color: var(--surface-default);
  }
  .col-dropdown__option.is-active {
    background-color: var(--bg-secondary);
    font-weight: var(--font-weight-semibold);
  }
  .col-dropdown__option-label {
    flex: 1 1 auto;
  }
  .col-dropdown__option-count {
    color: var(--text-secondary);
  }

  /* Custom Checkbox */
  .col-checkbox {
    width: 20px;
    height: 20px;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-milk);
    color: transparent;
    transition: all var(--timing-fast) var(--ease-standard);
    flex: 0 0 auto;
    pointer-events: none;
    border-color: var(--color-ebony);
  }
  .col-checkbox__icon {
    width: 12px;
    height: 12px;
  }
  input[type='checkbox']:checked + .col-checkbox {
    background-color: var(--color-ebony);
    color: var(--color-milk);
  }

  /* Custom Radio */
  .col-radio {
    width: 20px;
    height: 20px;
    border: 1px solid #1a1815;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-milk);
    transition: all var(--timing-fast) var(--ease-standard);
    flex: 0 0 auto;
    pointer-events: none;
  }
  .col-radio__inner {
    width: 10px;
    height: 10px;
    border-radius: var(--radius-full);
    background-color: transparent;
    transition: all var(--timing-fast) var(--ease-standard);
  }
  input[type='radio']:checked + .col-radio {
    border-color: var(--color-ebony);
  }
  input[type='radio']:checked + .col-radio .col-radio__inner {
    background-color: var(--color-ebony);
  }

  /* Price Form */
  .col-price-form {
    padding: var(--sp-3) var(--sp-4);
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }
  .col-price-form__header {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-roboto);
    font-size: var(--font-size-caption);
    color: var(--text-secondary);
    font-weight: var(--font-weight-medium);
    padding: 0 var(--sp-2);
  }
  .col-price-form__inputs {
    display: flex;
    gap: var(--sp-3);
  }
  .col-price-form__inputs input {
    width: 100%;
    padding: var(--sp-2) var(--sp-3);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    color: var(--text-primary);
    outline: none;
    transition: border-color var(--timing-fast) var(--ease-standard);
    -moz-appearance: textfield;
  }
  .col-price-form__inputs input::-webkit-outer-spin-button,
  .col-price-form__inputs input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }
  .col-price-form__inputs input:focus {
    border-color: var(--border-default);
  }
  .col-price-form__apply {
    padding: var(--sp-2);
    background-color: var(--color-ebony);
    color: var(--color-milk);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: background-color var(--timing-fast) var(--ease-standard);
    margin-top: var(--sp-2);
  }
  .col-price-form__apply:hover {
    background-color: var(--text-primary);
  }

  .col-dropdown__clear {
    display: inline-block;
    margin: var(--sp-3) var(--sp-5) var(--sp-2);
    color: var(--color-error);
    font-size: var(--font-size-body-sm);
    text-decoration: underline;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-align: left;
  }
  .col-dropdown__clear:hover {
    text-decoration: none;
  }
  .col-toolbar__count {
    padding: 0 var(--sp-5);
    padding-right: var(--layout-padding-desktop);
    border-left: 1px solid var(--border-light);
    color: var(--text-secondary);
    background-color: var(--surface-default);
  }

  /* Grid */
  .col-grid-wrap {
    padding: var(--sp-6) 64px var(--section-spacing-desktop);
  }
  .col-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: var(--sp-5);
    row-gap: var(--sp-7);
  }
  .col-empty {
    padding: var(--sp-8) 0;
    text-align: center;
    color: var(--text-secondary);
  }

  /* Empty collection state */
  .col-empty-state {
    width: min(calc(100% - (var(--layout-padding-desktop) * 2)), var(--layout-max-width));
    margin-inline: auto;
    padding-block: var(--sp-7) var(--section-spacing-desktop);
  }
  .col-empty-state__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }
  .col-empty-state__art {
    width: clamp(200px, 22vw, 260px);
    margin-bottom: var(--sp-3);
  }
  .col-empty-state__art svg {
    width: 100%;
    height: auto;
    display: block;
  }
  .col-empty-state__title {
    margin: 0;
    font-family: var(--font-display-light);
    font-size: clamp(var(--font-size-display-md), 3.4vw, var(--font-size-display-lg));
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    text-wrap: balance;
  }
  .col-empty-state__text {
    max-width: 60ch;
    margin: var(--sp-5) 0 0;
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-generous);
    color: var(--text-secondary);
  }
  .col-empty-state__actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--sp-4);
    margin-top: var(--sp-7);
  }
  .col-empty-state__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 56px;
    padding: 0 var(--sp-7);
    border-radius: var(--radius-md);
    font-family: var(--font-display);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-regular);
    letter-spacing: 0.01em;
    text-decoration: none;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard);
  }
  .col-empty-state__btn--primary {
    background-color: var(--color-earth-brown);
    color: var(--text-inverse);
    border: 1px solid var(--color-earth-brown);
  }
  .col-empty-state__btn--primary:hover {
    background-color: var(--color-charcoal);
    border-color: var(--color-charcoal);
  }
  .col-empty-state__btn--secondary {
    background-color: transparent;
    color: var(--color-earth-brown);
    border: 1px solid var(--color-earth-brown);
  }
  .col-empty-state__btn--secondary:hover {
    background-color: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .col-empty-state__divider {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    margin-top: var(--sp-11);
  }
  .col-empty-state__divider-line {
    flex: 1 1 auto;
    height: 1px;
    background-color: var(--border-default);
  }
  .col-empty-state__divider-label {
    font-family: var(--font-roboto);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-earth-brown);
    white-space: nowrap;
  }

  .col-empty-state__others {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--sp-5);
    margin: var(--sp-7) 0 0;
    padding: 0;
    list-style: none;
  }
  .col-empty-state__other {
    min-width: 0;
  }
  .col-empty-state__other-link {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
    text-decoration: none;
    color: var(--text-primary);
  }
  .col-empty-state__other-media {
    display: block;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    border-radius: var(--radius-md);
    background-color: var(--bg-secondary);
  }
  .col-empty-state__other-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--timing-long) var(--ease-standard);
  }
  .col-empty-state__other-link:hover .col-empty-state__other-img {
    transform: scale(1.04);
  }
  .col-empty-state__other-title {
    font-family: var(--font-display);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }

  .pcard {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding: var(--sp-3);
    background-color: var(--color-milk);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-elevation-1);
  }
  .pcard__media-wrap {
    position: relative;
  }
  .pcard__media {
    display: block;
    aspect-ratio: 6 / 5;
    overflow: hidden;
    border-radius: var(--radius-md);
    background-color: var(--bg-secondary);
    position: relative;
  }
  .pcard__image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0;
    z-index: 0;
    transition: transform var(--timing-long) var(--ease-standard), opacity var(--timing-base) var(--ease-standard);
  }
  .pcard__image.is-prev {
    opacity: 1;
    z-index: 1;
  }
  .pcard__image.is-active {
    opacity: 1;
    z-index: 2;
  }
  .pcard__media:hover .pcard__image {
    transform: scale(1.03);
  }
  .pcard__add {
    position: absolute;
    right: var(--sp-3);
    bottom: var(--sp-3);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: none;
    border-radius: var(--radius-full);
    background-color: var(--surface-elevated);
    color: var(--color-earth-brown);
    box-shadow: var(--shadow-elevation-2);
    cursor: pointer;
    transition: transform var(--timing-short) var(--ease-standard),
      background-color var(--timing-short) var(--ease-standard);
  }
  .pcard__add svg {
    width: 18px;
    height: 18px;
  }
  .pcard__add:hover {
    transform: translateY(-2px);
    background-color: var(--color-cream);
  }
  .pcard__add:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .pcard__add.is-loading {
    pointer-events: none;
    opacity: 0.6;
  }

  .pcard__new {
    position: absolute;
    top: var(--sp-3);
    left: var(--sp-3);
    z-index: 3;
    display: flex;
    align-items: center;
    padding: 0 8px;
    border-radius: 99px;
    background: var(--color-milk, #fffdf9);
    color: var(--color-earth-brown, #4a2c18);
    font-family: var(--font-body);
    font-weight: var(--font-weight-bold);
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0.02em;
  }
  .pcard__new svg {
    display: flex;
    width: 24px;
    height: 24px;
    margin-right: 4px;
    fill: currentColor;
  }

  .pcard__rating {
    margin: var(--sp-2) 0 0;
    line-height: 1;
    /* Colour the Judge.me stars with the theme's star-rating token. */
    --jm-review-widget-star-and-histogram-color: var(--color-star-rating, #cba077);
  }
  /* The judgeme.badge metafield ships display:none (meant for Judge.me's own JS, which
     doesn't hydrate this static copy) — reveal it so the SSR stars show. */
  .pcard__rating .jdgm-prev-badge {
    display: inline-flex !important;
    align-items: center;
    gap: 5px;
    font-size: 13px;
  }
  .pcard__rating .jdgm-star {
    color: var(--color-star-rating, #cba077) !important;
  }
  /* Replace Judge.me's verbose "N reviews" label with a compact count, e.g. (11). */
  .pcard__rating .jdgm-prev-badge__text {
    display: none;
  }
  .pcard__rating .jdgm-prev-badge::after {
    content: '(' attr(data-number-of-reviews) ')';
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1;
    color: var(--color-muted, #6a625c);
  }
  /* Hide the row entirely for products with no reviews. */
  .pcard__rating:has(.jdgm-prev-badge[data-number-of-reviews='0']) {
    display: none;
  }

  .pcard__info {
    display: flex;
    flex-direction: column;
    padding: var(--sp-5) var(--sp-2) var(--sp-2);
    position: relative;
  }
  .pcard__pill {
    align-self: flex-start;
    border-radius: var(--radius-full);
    font-family: var(--font-roboto);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-clay);
  }
  .pcard__title {
    margin: var(--sp-2) 0 0;
    min-width: 0;
    font-family: var(--font-body);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .pcard__title-link {
    color: inherit;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    letter-spacing: 0.01em;
  }
  .pcard__artist {
    margin: var(--sp-2) 0 0;
    font-size: var(--font-size-body-sm);
    font-family: var(--font-body);
    color: var(--color-clay);
  }
  .pcard__meta-item {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }
  .pcard__meta-item svg {
    width: 16px;
    height: 16px;
    flex: 0 0 auto;
  }
  .pcard__meta-sep {
    width: 1px;
    height: 14px;
    margin: 0 var(--sp-4);
    background-color: var(--border-default);
  }
  .pcard__divider {
    width: 20px;
    height: 2px;
    margin: var(--sp-4) 0 0;
    border: none;
    background-color: var(--color-orange);
  }
  .pcard__price {
    margin: var(--sp-1) 0 0;
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .pcard__freeshipping {
    position: absolute;
    bottom: var(--sp-2);
    right: var(--sp-1);
    z-index: 3;
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 2px var(--sp-3);
    border-radius: var(--radius-full);
    background-color: #f8e9cb;
  }
  .pcard__freeshipping-text {
    font-size: var(--font-size-body-sm);
  }

  .col-pagination {
    margin-top: var(--sp-8);
    display: flex;
    justify-content: center;
  }
  .col-pagination__inner {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    height: 52px;
    background-color: transparent;
  }
  .col-pagination__prev,
  .col-pagination__next {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 0 var(--sp-5);
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-secondary);
    text-decoration: none;
    transition: var(--transition-fast);
  }
  .col-pagination__prev:not(.is-disabled):hover,
  .col-pagination__next:not(.is-disabled):hover {
    color: var(--color-earth-brown);
  }
  .col-pagination__prev svg,
  .col-pagination__next svg {
    width: 14px;
    height: 14px;
  }
  .col-pagination__prev.is-disabled,
  .col-pagination__next.is-disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .col-pagination__sep {
    width: 1px;
    height: 24px;
    background-color: var(--border-default);
  }
  .col-pagination__numbers {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    padding: 0 var(--sp-4);
  }
  .col-pagination__num {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 36px;
    height: 36px;
    padding: 0 var(--sp-2);
    border-radius: var(--radius-lg);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
    text-decoration: none;
    border: 1px solid var(--border-default);
    background-color: transparent;
    transition: var(--transition-fast);
  }
  .col-pagination__num:not(.is-current):not(.is-deco):hover {
    background-color: var(--bg-secondary);
  }
  .col-pagination__num.is-current {
    background-color: var(--color-earth-brown);
    color: var(--color-milk);
    border-color: var(--color-earth-brown);
  }
  .col-pagination__num.is-deco {
    border-color: transparent;
  }

  @media screen and (max-width: 1440px) {
    .col-toolbar__facet,
    .col-toolbar__sort,
    .col-toolbar__count {
      font-size: var(--font-size-body-sm);
    }
  }

  @media screen and (max-width: 1024px) {
    .col-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .col-empty-state__others {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 768px) {
    .col-empty-state {
      width: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--layout-max-width));
      padding-block: var(--sp-9) var(--section-spacing-mobile);
    }
    .col-empty-state__text {
      font-size: var(--font-size-body-md);
    }
    .col-empty-state__actions {
      flex-direction: column;
      align-self: stretch;
      width: 100%;
      max-width: 360px;
      margin-inline: auto;
    }
    .col-empty-state__btn {
      width: 100%;
    }
    .col-empty-state__divider {
      margin-top: var(--sp-9);
      gap: var(--sp-3);
    }
    .col-toolbar__facet,
    .col-toolbar__sort,
    .col-toolbar__count {
      font-size: var(--font-size-caption);
    }
    /* Stack the toolbar so filters stay usable (tap to open) on mobile */
    .col-toolbar {
      flex-direction: column;
      align-items: stretch;
    }
    .col-toolbar__facets {
      flex-wrap: wrap;
      padding-left: var(--layout-padding-mobile);
    }
    .col-toolbar__facet {
      padding: 0 var(--sp-4);
      height: 48px;
    }
    .col-toolbar__right {
      justify-content: space-between;
      border-top: 1px solid var(--border-light);
    }
    .col-toolbar__count {
      padding-right: var(--layout-padding-mobile);
    }
    .col-toolbar__sort-label {
      display: none;
    }
    .col-grid-wrap {
      padding: var(--sp-5) 8px var(--section-spacing-mobile);
    }
    .col-grid {
      column-gap: var(--sp-4);
      row-gap: var(--sp-6);
    }

    body:has(.collection-page) .header__icon--search,
    body:has(.collection-page) .header__icon--cart,
    body:has(.collection-page) .header__icon--menu,
    body:has(.collection-page) .header__icon--account,
    body:has(.collection-page) .header__localization .loc-picker__code,
    body:has(.collection-page) .header__localization .loc-picker__chevron {
      color: var(--color-earth-brown) !important;
    }
    body:has(.collection-page) .loc-picker__option .loc-picker__code {
      color: var(--color-earth-brown) !important;
    }
  }

  @media screen and (max-width: 480px) {
    .col-grid {
      grid-template-columns: repeat(1, minmax(0, 1fr));
    }
    .col-empty-state__others {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--sp-4);
    }
    .col-empty-state__other-title {
      font-size: var(--font-size-body-md);
    }
    .col-dropdown--left {
      padding-left: 3px;
    }
    .col-dropdown--right {
      padding-left: 18px;
    }
    .col-pagination {
      margin-top: var(--sp-5);
    }
    .pcard__pill {
      display: block;
      max-width: 100%;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .pcard__info {
      padding-top: var(--sp-3);
    }
    .pcard__title {
      margin: var(--sp-2) 0 0;
    }
    .pcard__price {
      margin: var(--sp-2) 0 0;
      font-size: var(--font-size-body-md);
    }
    .col-grid {
      column-gap: var(--sp-3);
      row-gap: var(--sp-5);
    }
    .pcard__title {
      font-size: var(--font-size-body-md);
    }
    .pcard__artist {
      font-size: var(--font-size-body-sm);
    }
    .pcard__add {
      width: 40px;
      height: 40px;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    function initCollection() {
      // Add to cart (AJAX) from product cards
      function updateCartBubble() {
        fetch(window.Shopify.routes.root + 'cart.js')
          .then(function (res) {
            return res.json();
          })
          .then(function (cart) {
            var cartIcon = document.querySelector('.header__icon--cart');
            if (!cartIcon) return;
            var bubble = cartIcon.querySelector('.cart-count-bubble');
            if (cart.item_count > 0) {
              if (!bubble) {
                bubble = document.createElement('div');
                bubble.className = 'cart-count-bubble';
                bubble.innerHTML = '<span></span>';
                cartIcon.appendChild(bubble);
              }
              bubble.querySelector('span').textContent = cart.item_count;
            } else if (bubble) {
              bubble.remove();
            }
          });
      }

      document.querySelectorAll('[data-add-to-cart]').forEach(function (btn) {
        if (btn.dataset.init === 'true') return;
        btn.dataset.init = 'true';
        btn.addEventListener('click', function () {
          if (btn.disabled || btn.classList.contains('is-loading')) return;
          var variantId = btn.dataset.variantId;
          if (!variantId) return;

          btn.classList.add('is-loading');
          fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/javascript' },
            body: JSON.stringify({ id: variantId, quantity: 1 }),
          })
            .then(function (res) {
              return res.json();
            })
            .then(function (data) {
              if (data.status) {
                throw new Error(data.description || 'Could not add to cart');
              }
              if (window.showToast) {
                window.showToast({ message: 'Item added to your cart.', type: 'success', position: 'bottom-left' });
              }
              updateCartBubble();
              document.dispatchEvent(new CustomEvent('cart:updated', { detail: { open: true } }));
            })
            .catch(function (err) {
              if (window.showToast) {
                window.showToast({ message: err.message, type: 'error', position: 'bottom-left' });
              }
            })
            .finally(function () {
              btn.classList.remove('is-loading');
            });
        });
      });
      // Hover gallery
      document.querySelectorAll('[data-hover-gallery]').forEach(function (gallery) {
        if (gallery.dataset.initHover === 'true') return;
        gallery.dataset.initHover = 'true';

        var images = gallery.querySelectorAll('.pcard__image');
        if (images.length <= 1) return;

        var intervalId = null;
        var currentIndex = 0;

        function showImage(index) {
          images.forEach(function (img) {
            img.classList.remove('is-prev');
            if (img.classList.contains('is-active')) {
              img.classList.remove('is-active');
              img.classList.add('is-prev');
            }
          });
          images[index].classList.add('is-active');
        }

        gallery.addEventListener('mouseenter', function () {
          if (images.length <= 1) return;
          currentIndex = 1;
          showImage(currentIndex);

          intervalId = setInterval(function () {
            currentIndex = (currentIndex + 1) % images.length;
            showImage(currentIndex);
          }, 2000);
        });

        gallery.addEventListener('mouseleave', function () {
          clearInterval(intervalId);
          currentIndex = 0;
          showImage(0);
        });
      });

      // Filter/sort dropdowns: open on click/tap (mobile friendly) and mark the
      // pressed trigger with a "picked" class as an open indicator.
      var dropdowns = Array.prototype.slice.call(document.querySelectorAll('[data-dropdown]'));
      function closeDropdowns(except) {
        dropdowns.forEach(function (d) {
          if (d === except) return;
          d.classList.remove('is-open');
          var t = d.querySelector('[data-dropdown-toggle]');
          if (t) {
            t.classList.remove('picked');
            t.setAttribute('aria-expanded', 'false');
          }
        });
      }
      // Keep an opened menu fully inside the viewport. Works for both left- and
      // right-anchored menus (facets open rightward, "Sort by" opens leftward) by
      // overriding to an explicit `left`, so neither edge spills off screen.
      function clampMenu(d) {
        var menu = d.querySelector('.col-dropdown__menu');
        if (!menu) return;
        // Reset any previous override and measure the natural position.
        menu.style.left = '';
        menu.style.right = '';
        var gutter = 8;
        var vw = document.documentElement.clientWidth;
        var rect = menu.getBoundingClientRect();
        var dx = 0;
        if (rect.right > vw - gutter) {
          dx = vw - gutter - rect.right;
        }
        if (rect.left + dx < gutter) {
          dx = gutter - rect.left;
        }
        if (dx) {
          var baseLeft = menu.offsetLeft;
          menu.style.right = 'auto';
          menu.style.left = baseLeft + dx + 'px';
        }
      }
      dropdowns.forEach(function (d) {
        if (d.dataset.initDropdown === 'true') return;
        d.dataset.initDropdown = 'true';
        var toggle = d.querySelector('[data-dropdown-toggle]');
        if (!toggle) return;
        toggle.addEventListener('click', function (e) {
          e.preventDefault();
          e.stopPropagation();
          var willOpen = !d.classList.contains('is-open');
          closeDropdowns(willOpen ? d : null);
          d.classList.toggle('is-open', willOpen);
          toggle.classList.toggle('picked', willOpen);
          toggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          if (willOpen) clampMenu(d);
        });
      });
      if (document.body.dataset.colDropdownGlobal !== 'true') {
        document.body.dataset.colDropdownGlobal = 'true';
        document.addEventListener('click', function (e) {
          if (!e.target.closest('[data-dropdown]')) closeDropdowns(null);
        });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape') closeDropdowns(null);
        });
      }

      // Sort: preserve active filters (and wood-type params) when changing sort.
      document.querySelectorAll('[data-sort-value]').forEach(function (el) {
        if (el.dataset.init === 'true') return;
        el.dataset.init = 'true';
        el.addEventListener('click', function (e) {
          e.preventDefault();
          var params = new URLSearchParams(window.location.search);
          params.set('sort_by', el.dataset.sortValue);
          params.delete('page');
          window.location.search = params.toString();
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initCollection);
    } else {
      initCollection();
    }
  })();
</script>

