{%- liquid
  assign showroom_entries = shop.metaobjects.showroom.values
  if showroom_entries == blank
    assign showroom_entries = metaobjects.showroom.values
  endif
  assign room_count = 0
-%}

<section class="showroom-intro" aria-labelledby="ShowroomTitle-{{ section.id }}">
  <img
    class="showroom-intro__image"
    src="{{ 'showroom-bg.png' | file_url }}"
    width="1672"
    height="941"
    alt="Handcrafted natural wood furniture displayed in the WRYDECO showroom"
    loading="eager"
    fetchpriority="high"
  >
  <div class="showroom-intro__shade" aria-hidden="true"></div>

  <div class="showroom-intro__content">
    <p class="showroom-intro__eyebrow">Curated by Room</p>
    <h1 class="showroom-intro__title" id="ShowroomTitle-{{ section.id }}">
      {{ page.title | default: 'Showroom' | escape }}
    </h1>
    <span class="showroom-intro__rule" aria-hidden="true">
      <span class="showroom-intro__rule-dot"></span>
    </span>
    <p class="showroom-intro__copy">
      Step inside our collection of craftsmanship and calm. Explore thoughtfully curated spaces designed to inspire and
      made to last for generations.
    </p>
  </div>
</section>

<section class="showroom-page" id="ShowroomPage-{{ section.id }}" aria-label="Showroom rooms">
  {%- for entry in showroom_entries -%}
    {%- liquid
      assign collection_handle = entry.collection_handle.value | default: entry.collection_handle | strip
      assign room_collection = collections[collection_handle]

      if collection_handle == blank or room_collection == blank
        continue
      endif

      assign room_count = room_count | plus: 1
      assign room_image = room_collection.image
      if room_image == blank
        assign room_image = room_collection.featured_image
      endif
      if room_image == blank
        assign room_image = room_collection.products.first.featured_image
      endif

      assign room_title = room_collection.title | remove_first: 'Showroom ' | strip
      assign room_description = room_collection.description | strip_html | strip
      assign room_alt = room_image.alt | default: room_title | escape
      assign image_loading = 'lazy'
      assign image_priority = 'auto'
      if room_count == 1
        assign image_loading = 'eager'
        assign image_priority = 'high'
      endif
    -%}

    <article
      class="showroom-room"
      id="ShowroomRoom-{{ section.id }}-{{ room_count }}"
      aria-labelledby="ShowroomRoomTitle-{{ section.id }}-{{ room_count }}"
    >
      {%- if room_image != blank -%}
        <div class="showroom-room__media">
          {{
            room_image
            | image_url: width: 2400
            | image_tag:
              class: 'showroom-room__image',
              loading: image_loading,
              fetchpriority: image_priority,
              sizes: '100vw',
              widths: '1200, 1400, 1800, 2200, 2400',
              alt: room_alt
          }}
        </div>
      {%- endif -%}

      <div class="showroom-room__shade" aria-hidden="true"></div>

      <div class="showroom-room__content">
        <h2 class="showroom-room__title" id="ShowroomRoomTitle-{{ section.id }}-{{ room_count }}">
          {{- room_title | escape -}}
        </h2>

        {%- if room_description != blank -%}
          <p class="showroom-room__description">
            {{- room_description -}}
          </p>
        {%- endif -%}

        <a class="showroom-room__button" href="{{ room_collection.url }}">
          {{- 'Shop ' | append: room_title | escape -}}
        </a>
      </div>
    </article>
  {%- endfor -%}

  {%- if room_count == 0 -%}
    <article class="showroom-room showroom-room--empty" aria-labelledby="ShowroomEmptyTitle-{{ section.id }}">
      <div class="showroom-room__content">
        <h2 class="showroom-room__title" id="ShowroomEmptyTitle-{{ section.id }}">Showroom</h2>
        <p class="showroom-room__description">
          Add showroom metaobject entries with collection handles to publish room sections here.
        </p>
      </div>
    </article>
  {%- endif -%}
</section>

<section class="showroom-closing" aria-labelledby="ShowroomClosingTitle-{{ section.id }}">
  <div class="showroom-closing__inner">
    <p class="showroom-closing__eyebrow">A Room Made Personal</p>
    <h2 class="showroom-closing__title" id="ShowroomClosingTitle-{{ section.id }}">Let the next space be yours.</h2>
    <p class="showroom-closing__copy">
      Share your vision with our design team and discover furniture shaped around the way you live.
    </p>
    <div class="showroom-closing__actions">
      <a class="showroom-closing__button showroom-closing__button--primary" href="/pages/customization">
        Book Consultation
      </a>
      <a
        class="showroom-closing__button showroom-closing__button--secondary"
        href="{{ routes.all_products_collection_url }}"
      >
        Explore All Pieces
      </a>
    </div>
  </div>
</section>

{% stylesheet %}
  #MainContent {
    background-color: var(--color-cream);
  }

  body:has(.showroom-intro) .header__heading-logo {
    filter: brightness(0) invert(1);
  }

  body:has(.showroom-intro) .header__heading-link,
  body:has(.showroom-intro) .header__nav-item,
  body:has(.showroom-intro) .header__icon,
  body:has(.showroom-intro) .header__icon--search,
  body:has(.showroom-intro) .header__icon--cart,
  body:has(.showroom-intro) .header__icon--account,
  body:has(.showroom-intro) .header__icon--menu,
  body:has(.showroom-intro) .loc-picker__chevron,
  body:has(.showroom-intro) .loc-picker .loc-picker__code {
    color: var(--color-milk);
  }

  body:has(.showroom-intro) .header__icon svg,
  body:has(.showroom-intro) .header__icon--search svg,
  body:has(.showroom-intro) .header__icon--cart svg,
  body:has(.showroom-intro) .header__icon--account svg,
  body:has(.showroom-intro) .header__icon--menu svg {
    color: var(--color-milk);
  }

  body:has(.showroom-intro) .Vtl-WishlistHeader__HeartIconWrapper {
    fill: var(--color-milk) !important;
  }

  body:has(.showroom-intro) .header {
    border-bottom-color: color-mix(in srgb, var(--color-milk) 24%, transparent);
  }

  body:has(.showroom-intro) .header__nav-item:hover,
  body:has(.showroom-intro) .header__icon:hover {
    color: var(--color-stone);
  }

  body:has(.showroom-intro) .header__consultation-link {
    background-color: transparent;
    border-color: color-mix(in srgb, var(--color-milk) 64%, transparent);
    color: var(--color-milk);
  }

  body:has(.showroom-intro) .header__consultation-link:hover {
    background-color: var(--color-milk);
    color: var(--color-earth-brown);
  }

  .showroom-intro {
    align-items: center;
    display: flex;
    isolation: isolate;
    justify-content: center;
    min-block-size: min(100svh, var(--layout-hero-wide-height));
    overflow: hidden;
    padding: var(--sp-10) var(--layout-padding-desktop);
    position: relative;
    text-align: center;
  }

  .showroom-intro__image,
  .showroom-intro__shade {
    inset: var(--sp-0);
    position: absolute;
  }

  .showroom-intro__image {
    block-size: 100%;
    inline-size: 100%;
    object-fit: cover;
    object-position: center center;
    z-index: -2;
  }

  .showroom-intro__shade {
    background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-ebony) 79%, transparent),
        color-mix(in srgb, var(--color-ebony) 12%, transparent) 24%,
        transparent 52%
      ),
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-ebony) 14%, transparent),
        color-mix(in srgb, var(--color-ebony) 8%, transparent) 48%,
        color-mix(in srgb, var(--color-ebony) 18%, transparent)
      ),
      linear-gradient(90deg, color-mix(in srgb, var(--color-ebony) 12%, transparent), transparent 72%);
    z-index: -1;
  }

  .showroom-intro__content {
    align-items: center;
    display: flex;
    flex-direction: column;
    inline-size: min(100%, calc(var(--sp-12) * 9));
  }

  .showroom-intro__eyebrow {
    color: var(--color-milk);
    font-family: var(--font-body);
    font-size: clamp(var(--font-size-body-md), 1.25vw, var(--font-size-body-2xl));
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--letter-spacing-normal);
    line-height: var(--line-height-tight);
    margin: var(--sp-0) var(--sp-0) var(--sp-3);
    text-transform: uppercase;
    text-shadow: 0 var(--border-width) var(--sp-3) var(--color-ebony);
  }

  .showroom-intro__title {
    color: var(--color-milk);
    font-family: var(--font-display-light);
    font-size: clamp(var(--font-size-display-xl), 7vw, calc(var(--font-size-display-2xl) * 1.55));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-normal);
    line-height: var(--line-height-tight);
    margin: var(--sp-0);
    text-shadow: 0 var(--sp-1) var(--sp-5) color-mix(in srgb, var(--color-ebony) 68%, transparent);
  }

  .showroom-intro__rule {
    align-items: center;
    display: flex;
    gap: var(--sp-2);
    inline-size: min(24vw, calc(var(--sp-12) * 2));
    margin-block: var(--sp-5) var(--sp-5);
  }

  .showroom-intro__rule::before,
  .showroom-intro__rule::after {
    background: color-mix(in srgb, var(--color-milk) 78%, transparent);
    block-size: var(--border-width);
    content: '';
    flex: 1;
  }

  .showroom-intro__rule-dot {
    background: var(--color-milk);
    block-size: var(--sp-2);
    border-radius: var(--radius-full);
    display: block;
    flex: 0 0 var(--sp-2);
  }

  .showroom-intro__copy {
    color: var(--color-milk);
    font-family: var(--font-body);
    font-size: clamp(var(--font-size-body-md), 1.2vw, var(--font-size-body-xl));
    line-height: var(--line-height-relaxed);
    margin: var(--sp-0);
    max-inline-size: calc(var(--sp-12) * 6);
    text-shadow: 0 var(--border-width) var(--sp-3) var(--color-ebony);
  }

  .showroom-page {
    color: var(--color-milk);
    overflow: hidden;
    background-color: var(--color-ebony);
  }

  .showroom-room {
    align-items: center;
    block-size: 100svh;
    display: grid;
    isolation: isolate;
    min-block-size: 100svh;
    overflow: hidden;
    position: relative;
  }
  .showroom-room:first-of-type {
    border-top: 1px solid var(--color-earth-brown);
  }

  .showroom-room__media,
  .showroom-room__shade {
    inset: var(--sp-0);
    position: absolute;
  }

  .showroom-room__media {
    z-index: -2;
  }

  .showroom-room__image {
    block-size: 100%;
    display: block;
    inline-size: 100%;
    object-fit: cover;
    object-position: center center;
  }

  .showroom-room__shade {
    z-index: -1;
  }

  .showroom-room__media,
  .showroom-room__title,
  .showroom-room__description,
  .showroom-room__button {
    transition: opacity calc(var(--timing-short) * 4) var(--ease-standard),
      transform calc(var(--timing-short) * 4) var(--ease-standard);
  }

  .showroom-page--reveal-ready .showroom-room:not(.showroom-room--is-visible) .showroom-room__media {
    opacity: 0.4;
    transform: scale(1.04);
  }

  .showroom-page--reveal-ready .showroom-room:not(.showroom-room--is-visible) .showroom-room__title,
  .showroom-page--reveal-ready .showroom-room:not(.showroom-room--is-visible) .showroom-room__description,
  .showroom-page--reveal-ready .showroom-room:not(.showroom-room--is-visible) .showroom-room__button {
    opacity: 0;
    transform: translateY(var(--sp-5));
  }

  .showroom-page--reveal-ready .showroom-room--is-visible .showroom-room__description {
    transition-delay: var(--timing-short);
  }

  .showroom-page--reveal-ready .showroom-room--is-visible .showroom-room__button {
    transition-delay: calc(var(--timing-short) * 2);
  }

  .showroom-room__content {
    align-items: center;
    display: flex;
    flex-direction: column;
    padding: var(--sp-12) var(--layout-padding);
    position: relative;
    text-align: center;
    z-index: 1;
    width: 100vw;
    max-width: 100vw;
    transform: translateY(30%);
  }

  .showroom-room__title {
    color: var(--color-milk);
    font-family: var(--font-body);
    font-size: clamp(var(--font-size-display-xl), 5vw, calc(var(--font-size-display-2xl) * 1.25));
    font-weight: var(--font-weight-bold);
    letter-spacing: var(--letter-spacing-normal);
    line-height: var(--line-height-tight);
    margin: var(--sp-0);
    text-shadow: 0 var(--sp-1) var(--sp-8) color-mix(in srgb, var(--color-ebony) 54%, transparent);
    width: max-content;
  }

  .showroom-room__description {
    color: var(--color-milk);
    display: -webkit-box;
    font-family: var(--font-body);
    font-size: clamp(var(--font-size-body-lg), 1.35vw, var(--font-size-body-xl));
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    line-height: var(--line-height-relaxed);
    margin: var(--sp-5) auto var(--sp-0);
    overflow: hidden;
    text-shadow: 0 var(--border-width) var(--sp-5) color-mix(in srgb, var(--color-ebony) 58%, transparent);
    inline-size: min(
      70%,
      calc(var(--sp-12) + var(--sp-12) + var(--sp-12) + var(--sp-12) + var(--sp-12) + var(--sp-12))
    );
    max-inline-size: 100%;
  }

  .showroom-room__button {
    align-items: center;
    border: var(--border-width) solid color-mix(in srgb, var(--color-milk) 86%, transparent);
    border-radius: var(--radius-sm);
    color: var(--color-milk);
    display: inline-flex;
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-bold);
    justify-content: center;
    letter-spacing: var(--letter-spacing-relaxed);
    line-height: var(--line-height-snug);
    margin-block-start: var(--sp-6);
    min-block-size: var(--sp-8);
    min-inline-size: calc(var(--sp-12) * 3);
    padding-inline: var(--sp-8);
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color var(--timing-short) var(--ease-standard),
      border-color var(--timing-short) var(--ease-standard), color var(--timing-short) var(--ease-standard);
  }

  .showroom-room__button:hover,
  .showroom-room__button:focus-visible {
    background-color: var(--color-milk);
    border-color: var(--color-milk);
    color: var(--color-earth-brown);
  }

  .showroom-room__button:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-milk);
    outline-offset: var(--sp-1);
  }

  .showroom-room--empty {
    background: linear-gradient(135deg, var(--color-earth-brown), var(--color-ebony));
  }

  .showroom-closing {
    align-items: center;
    background: linear-gradient(180deg, var(--color-earth-brown), var(--color-clay));
    color: var(--color-milk);
    display: flex;
    justify-content: center;
    min-block-size: calc(var(--sp-12) * 3);
    padding: var(--sp-10) var(--layout-padding-desktop);
    text-align: center;
  }

  .showroom-closing__inner {
    align-items: center;
    display: flex;
    flex-direction: column;
    max-inline-size: calc(var(--sp-12) * 7);
  }

  .showroom-closing__eyebrow {
    color: var(--color-linen);
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-normal);
    line-height: var(--line-height-normal);
    margin: var(--sp-0) var(--sp-0) var(--sp-4);
    text-transform: uppercase;
  }

  .showroom-closing__title {
    color: var(--color-milk);
    font-family: var(--font-display-light);
    font-size: clamp(var(--font-size-display-lg), 4.5vw, var(--font-size-display-2xl));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-normal);
    line-height: var(--line-height-display);
    margin: var(--sp-0);
  }

  .showroom-closing__copy {
    color: var(--color-stone);
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-relaxed);
    margin: var(--sp-5) var(--sp-0) var(--sp-0);
    max-inline-size: calc(var(--sp-12) * 5);
  }

  .showroom-closing__actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    justify-content: center;
    margin-block-start: var(--sp-6);
  }

  .showroom-closing__button {
    align-items: center;
    border: var(--border-width) solid var(--color-milk);
    border-radius: var(--radius-sm);
    display: inline-flex;
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    justify-content: center;
    letter-spacing: var(--letter-spacing-normal);
    min-block-size: var(--sp-7);
    min-inline-size: calc(var(--sp-12) * 1.5);
    padding-inline: var(--sp-5);
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard);
  }

  .showroom-closing__button--primary,
  .showroom-closing__button--secondary:hover,
  .showroom-closing__button--secondary:focus-visible {
    background-color: var(--color-milk);
    color: var(--color-earth-brown);
  }

  .showroom-closing__button--secondary,
  .showroom-closing__button--primary:hover,
  .showroom-closing__button--primary:focus-visible {
    background-color: transparent;
    color: var(--color-milk);
  }

  .showroom-closing__button:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-milk);
    outline-offset: var(--sp-1);
  }

  @media screen and (max-width: 989px) {
    .showroom-room__content {
      inline-size: min(100%, calc(var(--sp-12) * 7));
      transform: translateY(10svh);
    }

    .showroom-room__title {
      font-size: clamp(var(--font-size-display-lg), 8vw, var(--font-size-display-xl));
    }
  }

  @media screen and (max-width: 749px) {
    .showroom-intro {
      min-block-size: min(76svh, calc(var(--sp-12) * 5));
      padding: var(--sp-8) var(--layout-padding-mobile) var(--sp-7);
    }

    .showroom-intro__image {
      object-position: 54% center;
    }

    .showroom-intro__shade {
      background: linear-gradient(
        180deg,
        color-mix(in srgb, var(--color-ebony) 42%, transparent),
        color-mix(in srgb, var(--color-ebony) 28%, transparent) 48%,
        color-mix(in srgb, var(--color-ebony) 58%, transparent)
      );
    }

    .showroom-intro__eyebrow {
      font-size: var(--font-size-caption);
      margin-block-end: var(--sp-3);
    }

    .showroom-intro__title {
      font-size: clamp(var(--font-size-display-lg), 14vw, var(--font-size-display-xl));
    }

    .showroom-intro__rule {
      inline-size: min(58vw, calc(var(--sp-12) * 2));
      margin-block: var(--sp-4) var(--sp-4);
    }

    .showroom-intro__copy {
      font-size: var(--font-size-body-md);
      line-height: var(--line-height-relaxed);
      max-inline-size: calc(var(--sp-12) * 3);
    }

    .showroom-room {
      block-size: min(
        50svh,
        calc(var(--sp-12) + var(--sp-12) + var(--sp-12) + var(--sp-12) + var(--sp-12) + var(--sp-7))
      );
      min-block-size: min(
        50svh,
        calc(var(--sp-12) + var(--sp-12) + var(--sp-12) + var(--sp-12) + var(--sp-12) + var(--sp-7))
      );
    }

    .showroom-room__shade {
      background: linear-gradient(
          180deg,
          color-mix(in srgb, var(--color-ebony) 8%, transparent) 0 36%,
          color-mix(in srgb, var(--color-ebony) 46%, transparent) 72%,
          color-mix(in srgb, var(--color-ebony) 64%, transparent) 100%
        ),
        linear-gradient(
          90deg,
          color-mix(in srgb, var(--color-ebony) 18%, transparent),
          transparent 52%,
          color-mix(in srgb, var(--color-ebony) 12%, transparent)
        );
    }

    .showroom-room__content {
      inline-size: 100%;
      padding: var(--sp-12) var(--layout-padding-mobile) var(--sp-10);
      transform: none;
    }

    .showroom-room__title {
      font-size: clamp(var(--font-size-display-md), 11vw, var(--font-size-display-xl));
    }

    .showroom-room__description {
      font-size: clamp(var(--font-size-body-lg), 5.6vw, var(--font-size-display-sm));
      inline-size: min(100%, calc(var(--sp-12) + var(--sp-12) + var(--sp-8)));
      line-height: var(--line-height-relaxed);
      margin-block-start: var(--sp-4);
      max-inline-size: none;
    }

    .showroom-room__button {
      font-size: var(--font-size-body-lg);
      margin-block-start: var(--sp-5);
      min-block-size: var(--sp-6-bigger);
      min-inline-size: 0;
      padding-inline: var(--sp-6);
      width: fit-content;
    }

    .showroom-closing {
      min-block-size: calc(var(--sp-12) * 3);
      padding: var(--sp-9) var(--layout-padding-mobile);
    }

    .showroom-closing__title {
      font-size: var(--font-size-display-md);
    }

    .showroom-closing__copy {
      font-size: var(--font-size-body-md);
      max-inline-size: calc(var(--sp-12) * 3);
    }

    .showroom-closing__actions {
      flex-direction: column;
      inline-size: min(100%, calc(var(--sp-12) * 2.5));
    }

    .showroom-closing__button {
      inline-size: 100%;
      min-block-size: calc(var(--sp-7) + var(--sp-1));
    }
  }

  @media screen and (max-width: 390px) {
    .showroom-room__title {
      font-size: clamp(var(--font-size-display-sm), 6vw, var(--font-size-display-lg));
    }

    .showroom-room__description {
      font-size: var(--font-size-body-sm);
      line-height: var(--line-height-tight);
    }

    .showroom-room__button {
      font-size: var(--font-size-caption);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .showroom-room__media,
    .showroom-room__title,
    .showroom-room__description,
    .showroom-room__button {
      transition: none;
    }

    .showroom-page--reveal-ready .showroom-room:not(.showroom-room--is-visible) .showroom-room__media,
    .showroom-page--reveal-ready .showroom-room:not(.showroom-room--is-visible) .showroom-room__title,
    .showroom-page--reveal-ready .showroom-room:not(.showroom-room--is-visible) .showroom-room__description,
    .showroom-page--reveal-ready .showroom-room:not(.showroom-room--is-visible) .showroom-room__button {
      opacity: 1;
      transform: none;
    }
  }
{% endstylesheet %}

