<div class="shop-collections">
  <div class="shop-collections__inner page-width">
    <div class="shop-collections__head">
      <div class="shop-collections__head-text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="shop-collections__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="shop-collections__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="shop-collections__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank -%}
        <a class="shop-collections__view-all" href="{{ section.settings.view_all_link | default: routes.collections_url }}">
          <span>{{ section.settings.view_all_label }}</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <div class="shop-collections__grid">
      {%- for block in section.blocks limit: 5 -%}
        {%- liquid
          assign col = block.settings.collection
          assign card_title = block.settings.title
          if card_title == blank and col != blank
            assign card_title = col.title
          endif
          assign card_url = block.settings.link
          if card_url == blank and col != blank
            assign card_url = col.url
          endif
          if card_url == blank and card_title != blank
            assign generated_handle = card_title | handleize
            assign card_url = routes.collections_url | append: '/' | append: generated_handle
          endif
          assign card_url = card_url | default: routes.collections_url
        -%}
        <a class="shop-collections__card" href="{{ card_url }}" {{ block.shopify_attributes }}>
          <div class="shop-collections__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag: class: 'shop-collections__img', loading: 'lazy', sizes: '(min-width: 1200px) 18vw, (min-width: 768px) 32vw, 86vw', widths: '360, 540, 720, 900' }}
            {%- elsif col != blank and col.featured_image != blank -%}
              {{ col.featured_image | image_url: width: 900 | image_tag: class: 'shop-collections__img', loading: 'lazy', sizes: '(min-width: 1200px) 18vw, (min-width: 768px) 32vw, 86vw', widths: '360, 540, 720, 900' }}
            {%- else -%}
              {%- case forloop.index -%}
                {%- when 1 -%}
                  {%- assign fallback_image = 'collection-top-banner.png' -%}
                {%- when 2 -%}
                  {%- assign fallback_image = 'curated-collections-img-4.png' -%}
                {%- when 3 -%}
                  {%- assign fallback_image = 'curated-collections-img-1.png' -%}
                {%- when 4 -%}
                  {%- assign fallback_image = 'curated-collections-img-3.png' -%}
                {%- else -%}
                  {%- assign fallback_image = 'curated-collections-img-2.png' -%}
              {%- endcase -%}
              <img
                src="{{ fallback_image | asset_url }}"
                alt="{{ card_title | default: 'Handcrafted wood furniture collection' | escape }}"
                class="shop-collections__img"
                loading="lazy"
                width="900"
                height="1125"
              >
            {%- endif -%}
          </div>
          <div class="shop-collections__card-body">
            <h3 class="shop-collections__card-title">{{ card_title | default: 'Collection' }}</h3>
            {%- if block.settings.subtitle != blank -%}
              <p class="shop-collections__card-subtitle">{{ block.settings.subtitle }}</p>
            {%- endif -%}
            <span class="shop-collections__card-link">
              <span>{{ section.settings.explore_label | default: 'Explore Collection' | escape }}</span>
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M5 12h14M13 6l6 6-6 6"/>
              </svg>
            </span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .shop-collections {
    display: block;
    background:
      radial-gradient(circle at 12% 8%, rgba(255, 255, 255, 0.78), transparent 38%),
      linear-gradient(180deg, #fbf8f3 0%, #f5efe7 100%);
    color: var(--color-text, #1a1815);
  }

  .shop-collections__inner {
    max-width: var(--page-max-width, 1440px);
    margin: 0 auto;
    padding: var(--section-padding-y, 80px) var(--container-padding-x, 48px);
    box-sizing: border-box;
  }

  .shop-collections__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: clamp(32px, 6vw, 96px);
    margin-bottom: clamp(32px, 3.5vw, 48px);
  }

  .shop-collections__head-text {
    max-width: 760px;
  }

  .shop-collections__eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-body);
    font-size: var(--eyebrow-size, 12px);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--eyebrow-tracking, 0.3em);
    text-transform: uppercase;
    color: var(--color-brown);
  }

  .shop-collections__heading {
    font-family: var(--font-heading);
    font-size: var(--section-heading-size, 48px);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--section-heading-tracking, -0.02em);
    line-height: var(--section-heading-line, 1.02);
    color: var(--color-text, #2b1a11);
    margin: 0;
    text-wrap: balance;
  }

  .shop-collections__subtitle {
    font-family: var(--font-body);
    font-size: var(--section-subtitle-size, 16px);
    line-height: 1.6;
    color: var(--color-muted, #4f4944);
    max-width: 620px;
    margin: 16px 0 0;
  }

  .shop-collections__view-all {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: clamp(13px, 1.45svh, 16px);
    font-weight: var(--font-weight-medium, 500);
    color: #2d211a;
    text-decoration: none;
    padding-bottom: clamp(4px, 0.8svh, 8px);
    border-bottom: 1px solid rgba(74, 44, 24, 0.46);
    transition:
      gap var(--timing-short, 0.2s) var(--ease-standard, ease),
      color var(--timing-short, 0.2s) var(--ease-standard, ease);
  }

  .shop-collections__view-all:hover {
    gap: 16px;
    color: var(--color-earth-brown, #4a2c18);
  }

  .shop-collections__grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: clamp(14px, 1.25vw, 24px);
    min-height: 0;
  }

  .shop-collections__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    min-width: 0;
    min-height: 0;
    padding-left: clamp(12px, 1.1vw, 20px);
    border-left: 1px solid rgba(74, 44, 24, 0.16);
  }

  .shop-collections__media {
    position: relative;
    width: 100%;
    aspect-ratio: 0.78 / 1;
    overflow: hidden;
    border-radius: var(--card-radius, 6px);
    background-color: var(--surface-tertiary, #e8e4df);
  }

  .shop-collections__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-standard, ease);
  }

  .shop-collections__card:hover .shop-collections__img {
    transform: scale(1.04);
  }

  .shop-collections__card-body {
    display: flex;
    flex: 1;
    flex-direction: column;
    align-items: flex-start;
    min-height: 0;
    padding: clamp(12px, 1.9svh, 24px) 0 0;
  }

  .shop-collections__card-title {
    font-family: var(--font-heading);
    font-size: clamp(19px, 1.5vw, 24px);
    font-weight: var(--font-weight-regular, 400);
    line-height: 1.12;
    color: var(--color-text, #2b1a11);
    margin: 0;
    text-wrap: balance;
  }

  .shop-collections__card-subtitle {
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.45;
    color: var(--color-muted, #6c625b);
    max-width: 22ch;
    margin: 8px 0 0;
  }

  .shop-collections__card-link {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: auto;
    padding-top: 18px;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(74, 44, 24, 0.48);
    color: var(--color-brown);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: var(--font-weight-medium);
    line-height: 1;
    transition:
      gap var(--timing-short) var(--ease-standard),
      border-color var(--timing-short) var(--ease-standard);
  }

  .shop-collections__card:hover .shop-collections__card-link {
    gap: 18px;
    border-color: var(--color-earth-brown);
  }

  .shop-collections :is(a, button):focus-visible {
    outline: 3px solid rgba(122, 137, 104, 0.38);
    outline-offset: 4px;
  }

  /* --- Responsive (desktop-first overrides) --- */
  @media screen and (max-width: 1280px) {
    .shop-collections__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 34px 24px;
    }
  }

  @media screen and (max-width: 768px) {
    .shop-collections__inner {
      padding: 56px 18px 64px;
    }

    .shop-collections__head {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 30px;
    }

    .shop-collections__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 30px 14px;
    }

    .shop-collections__card {
      padding-left: 0;
      border-left: 0;
    }

    /* Avoid an orphan card in the 2-column grid: let a trailing odd card
       span both columns as a wide banner. */
    .shop-collections__card:last-child:nth-child(odd) {
      grid-column: 1 / -1;
    }

    .shop-collections__card:last-child:nth-child(odd) .shop-collections__media {
      aspect-ratio: 1.6 / 1;
    }

    .shop-collections__card-title {
      font-size: 17px;
    }

    .shop-collections__card-subtitle {
      font-size: 12px;
      max-width: none;
    }

    .shop-collections__card-link {
      padding-top: 12px;
      font-size: 12px;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Shop Collections",
  "tag": "section",
  "class": "section section-shop-collections",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Collections" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Shop Collections & Furniture" },
    { "type": "text", "id": "subtitle", "label": "Subtitle" },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All Collections" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    { "type": "text", "id": "explore_label", "label": "Card link label", "default": "Explore Collection" }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection card",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Collection" },
        { "type": "image_picker", "id": "image", "label": "Image (overrides collection image)" },
        { "type": "text", "id": "title", "label": "Title (overrides collection title)" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" },
        { "type": "url", "id": "link", "label": "Link (overrides collection URL)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shop Collections",
      "blocks": [
        { "type": "collection_card", "settings": { "title": "Bookshelves & Tree Bookcases", "subtitle": "Sculptural storage" } },
        { "type": "collection_card", "settings": { "title": "Floating & Wall Shelves", "subtitle": "Statement pieces" } },
        { "type": "collection_card", "settings": { "title": "Coffee & Console Tables", "subtitle": "Live-edge & organic" } },
        { "type": "collection_card", "settings": { "title": "Beds & Bedroom", "subtitle": "Branch headboards" } },
        { "type": "collection_card", "settings": { "title": "Storage & Cabinets", "subtitle": "Organized with elegance" } },
        { "type": "collection_card", "settings": { "title": "Wood Décor & Accents", "subtitle": "Small details, big impact" } }
      ]
    }
  ]
}
{% endschema %}
