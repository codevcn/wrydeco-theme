<footer class="footer-custom">
  <div class="footer-custom__logo-wrapper page-width">
    <img src="{{ 'app-logo.png' | asset_url }}" alt="{{ shop.name }}" loading="lazy" class="footer-premium-logo-img">
  </div>

  <div class="footer-custom__top page-width">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'text' %}
          <div class="footer-custom__column footer-custom__column--text">
            <h4 class="footer-custom__heading">{{ block.settings.heading }}</h4>
            <div class="footer-custom__text">
              {{ block.settings.text }}
            </div>
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link | default: '#' }}" class="footer-custom__btn">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  style="margin-right: 8px;"
                >
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>

        {% when 'link_list' %}
          <div class="footer-custom__column footer-custom__column--links">
            <h4 class="footer-custom__heading">{{ block.settings.heading }}</h4>
            {% if block.settings.menu != blank %}
              <ul class="footer-custom__menu list-unstyled">
                {% for link in linklists[block.settings.menu].links %}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% else %}
              <ul class="footer-custom__menu list-unstyled">
                {% if block.settings.heading == 'Company' %}
                  <li><a href="#">About Us</a></li>
                  <li><a href="#">Blogs</a></li>
                  <li><a href="#">Contact Us</a></li>
                  <li><a href="#">Terms of Service</a></li>
                  <li><a href="#">Privacy Policy</a></li>
                {% elsif block.settings.heading == 'Help Center' %}
                  <li><a href="#">Track Order</a></li>
                  <li><a href="#">FAQ</a></li>
                  <li><a href="#">Shipping & Delivery</a></li>
                  <li><a href="#">Return & Refunds</a></li>
                  <li><a href="#">Intellectual Property Claim</a></li>
                {% else %}
                  <li><a href="#">Link 1</a></li>
                  <li><a href="#">Link 2</a></li>
                  <li><a href="#">Link 3</a></li>
                {% endif %}
              </ul>
            {% endif %}
          </div>

        {% when 'newsletter' %}
          <div class="footer-custom__column footer-custom__column--newsletter">
            <h4 class="footer-custom__heading footer-custom__heading--large">{{ block.settings.heading }}</h4>
            <div class="footer-custom__text">
              {{ block.settings.text }}
            </div>
            {% form 'customer', class: 'footer-custom__form' %}
              <div class="footer-custom__input-group">
                <input
                  type="email"
                  name="contact[email]"
                  class="footer-custom__input"
                  placeholder="E-mail address"
                  required
                >
                <button type="submit" class="footer-custom__submit">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </button>
              </div>
            {% endform %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>

  <div class="footer-custom__bottom page-width">
    <div class="footer-custom__bottom-socials">
      {% if section.settings.show_social %}
        <div class="footer-custom__social">
          <a href="#">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
          <a href="#">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
          <a href="#">
            <svg width="18" height="18" viewBox="0 24 24" fill="currentColor">
              <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.951-7.252 4.163 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.367 18.625 0 12.017 0z"/>
            </svg>
          </a>
          <a href="#">
            <svg
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
            </svg>
          </a>
        </div>
      {% endif %}
      <div class="footer-custom__copyright">&copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}. Powered by Shopify</div>
    </div>
  </div>
</footer>

{% stylesheet %}
  .footer-custom {
    background-color: var(--color-background, #f5f1ed);
    color: var(--text-primary, #1a1815);
    padding-block-start: clamp(3rem, 8vw, 4rem);
    padding-block-end: clamp(2rem, 5vw, 3rem);
    padding-inline: var(--space-12);
    font-family: var(--font-body);
    font-size: 15px;
    border-top: 1px solid var(--border-light, #e8e4df);
    text-align: left;
  }

  @media (min-width: 768px) {
    .footer-custom {
      padding-inline: var(--space-14);
    }
  }

  .footer-custom__logo-wrapper {
    margin-bottom: clamp(2rem, 5vw, 4rem);
    display: flex;
    justify-content: flex-start;
  }

  .footer-premium-logo-shell {
    display: inline-flex;
    padding: 6px;
    background-color: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 2rem;
    text-decoration: none;
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .footer-premium-logo-shell:hover {
    transform: scale(0.98);
  }

  .footer-premium-logo-core {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px 24px;
    background-color: #ffffff;
    border-radius: calc(2rem - 6px);
    box-shadow: inset 0 1px 1px rgba(255, 255, 255, 0.8), 0 2px 4px rgba(0, 0, 0, 0.03);
  }

  .footer-premium-logo-img {
    height: auto;
    width: 280px;
    object-fit: contain;
  }

  .footer-custom__top {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 48px 16px; /* 48px vertical, 16px horizontal */
    margin-bottom: 1rem;
  }

  .footer-custom__column--text {
    grid-column: span 2;
  }

  .footer-custom__column--links {
    grid-column: span 1;
  }

  .footer-custom__column--newsletter {
    grid-column: span 2;
  }

  @media (min-width: 1024px) {
    .footer-custom__top {
      grid-template-columns: 2.5fr 1fr 1fr 2fr;
      gap: 3rem;
    }
    .footer-custom__column--text,
    .footer-custom__column--links,
    .footer-custom__column--newsletter {
      grid-column: span 1;
    }
  }

  .footer-custom__heading {
    font-family: var(--font-body);
    font-size: 16px;
    font-weight: 700;
    margin-bottom: 1.5rem;
    color: var(--text-primary, #1a1815);
  }

  .footer-custom__heading--large {
    font-family: var(--font-display);
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 400;
    margin-bottom: 1.25rem;
    letter-spacing: var(--letter-spacing-tight, -0.01em);
  }

  .footer-custom__text {
    line-height: 1.6;
    margin-bottom: 1.5rem;
    color: var(--text-secondary, #6b5d52);
  }
  .footer-custom__text p {
    margin: 0 0 16px 0;
  }
  .footer-custom__text strong {
    color: var(--text-primary, #1a1815);
    font-weight: 600;
  }

  .footer-custom__btn {
    display: inline-flex;
    align-items: center;
    background-color: var(--color-ebony, #1a1815);
    color: var(--color-cream, #f5f1ed);
    padding: 12px 24px;
    border-radius: 999px;
    font-weight: 500;
    font-size: 15px;
    text-decoration: none;
    transition: opacity 0.2s;
    margin-top: 8px;
  }
  .footer-custom__btn:hover {
    transform: scale(1.02);
    color: var(--color-cream, #f5f1ed);
  }

  .footer-custom__menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer-custom__menu li {
    margin-bottom: 0;
    font-family: var(--font-roboto);
  }
  .footer-custom__menu a {
    text-decoration: none;
    color: var(--text-secondary, #6b5d52);
    transition: color 0.2s;
    display: block;
    padding-block: 8px; /* ensures >=44px touch target (16px spacing logic) */
    margin-block: -4px;
  }
  .footer-custom__menu a:hover {
    color: var(--text-primary, #1a1815);
  }

  .footer-custom__input-group {
    position: relative;
    display: flex;
    align-items: center;
  }
  .footer-custom__input {
    width: 100%;
    padding: 16px 56px 16px 24px;
    border: 1px solid #b0b0b0;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 15px;
    background: transparent;
    outline: none;
    color: #1a1815;
    transition: border-color 0.2s;
  }
  .footer-custom__input:focus {
    border-color: var(--color-ebony, #1a1815);
  }
  .footer-custom__input::placeholder {
    color: var(--text-tertiary, #b8b4af);
  }

  .footer-custom__submit {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    background: var(--color-ebony, #1a1815);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-cream, #f5f1ed);
    transition: opacity 0.2s;
  }
  .footer-custom__submit:hover {
    opacity: 0.85;
  }

  .footer-custom__bottom {
    display: flex;
    justify-content: space-between;
    flex-direction: column;
    gap: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--border-light, #e8e4df);
  }
  @media (min-width: 768px) {
    .footer-custom__bottom {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }

  .footer-custom__social {
    display: flex;
    gap: 0.25rem;
    margin-left: -12px;
  }
  .footer-custom__social a {
    color: var(--text-primary, #1a1815);
    transition: opacity 0.2s;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 12px;
    border-radius: 50%;
  }
  .footer-custom__social a:hover {
    opacity: 0.7;
  }

  .footer-custom__copyright {
    color: #5e5e5e;
    font-size: 13px;
  }

  .footer-custom__localization {
    display: flex;
    align-items: center;
    font-size: 14px;
    font-weight: 500;
    color: var(--text-primary, #1a1815);
    cursor: pointer;
  }

  .footer-custom__payment {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .footer-custom__payment svg {
    width: 38px;
    height: 24px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Show currency selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text Info",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Get In Touch"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>E-mail: support@yourstore.com</p><p>Address: 123 Street</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Follow on shop"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Company"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Newsletter"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Sign up for exclusive offers, original stories, events and more.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}
