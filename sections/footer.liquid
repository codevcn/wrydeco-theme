<footer class="footer-custom">
  <div class="footer-custom__logo-wrapper page-width">
    <img src="{{ 'app-logo.png' | asset_url }}" alt="{{ shop.name }}" loading="lazy" class="footer-premium-logo-img">
  </div>

  <div class="footer-custom__top footer-custom__inner">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'text' %}
          <div class="footer-custom__column footer-custom__column--text">
            <h4 class="footer-custom__heading">{{ block.settings.heading }}</h4>
            <div class="footer-custom__text">
              {{ block.settings.text }}
            </div>
            {% if block.settings.button_label != blank %}
              <a href="{{ block.settings.button_link | default: '#' }}" class="footer-custom__btn">
                <svg
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="footer-custom__btn-icon"
                >
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
                {{ block.settings.button_label }}
              </a>
            {% endif %}
          </div>

        {% when 'link_list' %}
          <div class="footer-custom__column footer-custom__column--links">
            <h4 class="footer-custom__heading">{{ block.settings.heading }}</h4>
            {% if block.settings.menu != blank %}
              <ul class="footer-custom__menu list-unstyled">
                {% for link in linklists[block.settings.menu].links %}
                  <li>
                    <a href="{{ link.url }}">{{ link.title }}</a>
                  </li>
                {% endfor %}
              </ul>
            {% else %}
              <ul class="footer-custom__menu list-unstyled">
                {% if block.settings.heading == 'Company' %}
                  <li><a href="{{ pages['about-us'].url }}?view=about-us">About Us</a></li>
                  <li><a href="#">Blogs</a></li>
                  <li><a href="#">Contact Us</a></li>
                  <li><a href="#">Terms of Service</a></li>
                  <li><a href="#">Privacy Policy</a></li>
                {% elsif block.settings.heading == 'Help Center' %}
                  <li><a href="#">Track Order</a></li>
                  <li><a href="{{ pages['faq'].url }}?view=faq">FAQ</a></li>
                  <li><a href="#">Shipping & Delivery</a></li>
                  <li><a href="#">Return & Refunds</a></li>
                  <li><a href="#">Intellectual Property Claim</a></li>
                {% else %}
                  <li><a href="#">Link 1</a></li>
                  <li><a href="#">Link 2</a></li>
                  <li><a href="#">Link 3</a></li>
                {% endif %}
              </ul>
            {% endif %}
          </div>

        {% when 'newsletter' %}
          <div class="footer-custom__column footer-custom__column--newsletter">
            <svg
              class="footer-custom__newsletter-icon"
              viewBox="0 0 64 64"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M17 30c0-8 6-14 15-14s15 6 15 14v13H17V30Z"/>
              <path d="M13 31c-4 0-7 3-7 7v12h52V38c0-4-3-7-7-7"/>
              <path d="M12 50v8M52 50v8M20 43v-9c0-4 3-7 7-7h10c4 0 7 3 7 7v9M24 16l2-7 6 5 6-5 2 7"/>
            </svg>
            <h4 class="footer-custom__heading footer-custom__heading--large">{{ block.settings.heading }}</h4>
            <div class="footer-custom__newsletter-ornament" aria-hidden="true"><span></span><i></i><span></span></div>
            <div class="footer-custom__text">
              {{ block.settings.text }}
            </div>
            {% form 'customer', class: 'footer-custom__form' %}
              <div class="footer-custom__input-group">
                <input
                  type="email"
                  name="contact[email]"
                  class="footer-custom__input"
                  placeholder="Enter your e-mail address"
                  aria-label="E-mail address"
                  required
                >
                <button type="submit" class="footer-custom__submit">
                  <svg
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </button>
              </div>
            {% endform %}
          </div>
      {% endcase %}
    {% endfor %}
  </div>

  <div class="footer-custom__utility">
    <div class="footer-custom__utility-inner footer-custom__inner">
      <div class="footer-custom__bottom-socials">
        <span class="footer-custom__follow-label">Follow us</span>
        {% if section.settings.show_social %}
          <div class="footer-custom__social">
            <a href="#">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
              </svg>
            </a>
            <a href="#">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
              </svg>
            </a>
            <a href="#">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.401.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.951-7.252 4.163 0 7.392 2.967 7.392 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.367 18.625 0 12.017 0z"/>
              </svg>
            </a>
            <a href="#">
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33 2.78 2.78 0 0 0 1.94 2c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.33 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon>
              </svg>
            </a>
          </div>
        {% endif %}
      </div>
      <div class="footer-custom__utility-mark" aria-hidden="true">
        <span></span>
        <svg viewBox="0 0 64 64" fill="none" stroke="currentColor" stroke-width="1.5">
          <circle cx="32" cy="32" r="25"/><circle cx="32" cy="32" r="18"/><circle cx="32" cy="32" r="11"/><circle cx="32" cy="32" r="5"/>
        </svg>
        <span></span>
      </div>
      <nav class="footer-custom__legal" aria-label="Footer legal">
        <a href="{{ shop.privacy_policy.url | default: '/policies/privacy-policy' }}">Privacy Policy</a>
        <a href="{{ shop.terms_of_service.url | default: '/policies/terms-of-service' }}">Terms of Service</a>
        <a href="{{ routes.root_url }}pages/accessibility">Accessibility</a>
      </nav>
    </div>
  </div>

  <div class="footer-custom__copyright">
    &copy; {{ 'now' | date: '%Y' }}, {{ shop.name }}. All rights reserved. Powered by Shopify.
  </div>
</footer>

{% stylesheet %}
  .footer-custom {
    border-top: 1px solid var(--border-default);
    background: radial-gradient(circle at top, var(--color-milk) 0%, var(--surface-default) 70%);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .footer-custom__inner {
    width: 100%;
    max-width: none;
    margin-inline: auto;
    padding-inline: calc(var(--sp-8) + var(--sp-2));
  }

  .footer-custom__logo-wrapper {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: calc(var(--sp-5) + var(--sp-6));
    padding-bottom: var(--sp-7);
  }
  .footer-custom__logo-wrapper img {
    height: 64px;
  }

  .footer-custom__brand {
    display: inline-flex;
    align-items: center;
    color: var(--color-earth-brown);
    text-decoration: none;
  }

  .footer-custom__wordmark {
    font-family: var(--font-display);
    font-size: calc(var(--font-size-display-lg) + var(--font-size-body-md));
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-wide);
  }

  .footer-custom__brand-mark {
    width: var(--sp-8);
    height: var(--sp-8);
    flex: 0 0 auto;
  }

  .footer-custom__tagline {
    margin: var(--sp-2) 0 0 var(--sp-5);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: calc(var(--letter-spacing-wide) * 6);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .footer-custom__brand-ornament {
    width: var(--sp-8);
    height: 1px;
    margin: var(--sp-5) 0 0 calc(var(--sp-8) * 2);
    background-color: var(--color-clay);
  }

  .footer-custom__top {
    display: grid;
    grid-template-columns: minmax(0, 2.1fr) minmax(0, 1fr) minmax(0, 1.25fr) minmax(0, 2.2fr);
    gap: var(--sp-7);
    padding-top: var(--sp-3);
    padding-bottom: 0;
  }

  .footer-custom__column {
    min-width: 0;
  }

  .footer-custom__column--links,
  .footer-custom__column--newsletter {
    padding-left: var(--sp-7);
    border-left: 1px solid var(--border-light);
  }

  .footer-custom__heading {
    margin: 0 0 var(--sp-5);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-earth-brown);
  }

  .footer-custom__column--links .footer-custom__heading::after {
    content: '';
    display: block;
    width: var(--sp-7);
    height: 1px;
    margin-top: var(--sp-4);
    background-color: var(--color-clay);
  }

  .footer-custom__text {
    margin-bottom: var(--sp-5);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
    color: var(--text-secondary);
  }

  .footer-custom__text p {
    margin: 0;
  }

  .footer-custom__column--text .footer-custom__text p {
    position: relative;
    min-height: var(--sp-7);
    padding-left: var(--sp-7);
    padding-top: var(--sp-1);
  }

  .footer-custom__column--text .footer-custom__text p::before {
    content: '•';
    position: absolute;
    left: 0;
    top: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-6);
    height: var(--sp-6);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    background-color: var(--color-milk);
    color: var(--color-bark);
  }

  .footer-custom__column--text .footer-custom__text p:nth-child(1)::before {
    content: '✉';
  }
  .footer-custom__column--text .footer-custom__text p:nth-child(2)::before,
  .footer-custom__column--text .footer-custom__text p:nth-child(3)::before {
    content: '⌖';
  }
  .footer-custom__column--text .footer-custom__text p:nth-child(4)::before {
    content: '◷';
  }

  .footer-custom__text strong {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .footer-custom__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    width: min(100%, calc(var(--sp-8) * 5));
    min-height: var(--sp-8);
    margin-top: var(--sp-2);
    padding-inline: var(--sp-5);
    border: 1px solid var(--color-earth-brown);
    border-radius: var(--radius-sm);
    background: linear-gradient(90deg, var(--color-earth-brown), var(--color-bark), var(--color-earth-brown));
    box-shadow: var(--shadow-card);
    font-family: var(--font-display);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-cream);
    transition: transform var(--timing-short) var(--ease-standard);
  }

  .footer-custom__btn:hover {
    transform: translateY(calc(var(--sp-1) * -1));
    color: var(--color-cream);
  }

  .footer-custom__btn-icon {
    width: var(--font-size-body-lg);
    height: var(--font-size-body-lg);
  }

  .footer-custom__menu {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-custom__menu li {
    margin: 0;
    border-bottom: 1px solid var(--border-light);
  }

  .footer-custom__menu a {
    display: flex;
    align-items: center;
    min-height: var(--sp-7);
    padding-block: var(--sp-2);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-md);
    text-decoration: none;
    color: var(--text-primary);
    transition: color var(--timing-short) var(--ease-standard), padding-left var(--timing-short) var(--ease-standard);
  }

  .footer-custom__menu a:hover {
    padding-left: var(--sp-2);
    color: var(--color-clay);
  }

  .footer-custom__column--newsletter {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .footer-custom__newsletter-icon {
    width: var(--sp-8);
    height: var(--sp-8);
    margin-bottom: var(--sp-3);
    color: var(--color-bark);
  }

  .footer-custom__heading--large {
    margin-bottom: var(--sp-4);
    font-family: var(--font-display);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-normal);
    text-transform: none;
    color: var(--text-primary);
  }

  .footer-custom__newsletter-ornament {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
    color: var(--color-clay);
  }

  .footer-custom__newsletter-ornament span {
    width: var(--sp-7);
    height: 1px;
    background-color: currentColor;
  }

  .footer-custom__newsletter-ornament i {
    width: var(--sp-2);
    height: var(--sp-2);
    border: 1px solid currentColor;
    transform: rotate(45deg);
  }

  .footer-custom__column--newsletter .footer-custom__text {
    max-width: 40ch;
    margin-bottom: var(--sp-5);
  }

  .footer-custom__form {
    width: 100%;
  }

  .footer-custom__input-group {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .footer-custom__input {
    width: 100%;
    min-height: calc(var(--sp-6) + var(--sp-4));
    padding: 0 calc(var(--sp-9) + var(--sp-5)) 0 var(--sp-5);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-lg);
    background-color: var(--surface-elevated);
    outline: none;
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    color: var(--text-primary);
  }

  .footer-custom__input:focus {
    border-color: var(--color-bark);
    box-shadow: var(--shadow-focus);
  }

  .footer-custom__input::placeholder {
    color: var(--text-tertiary);
  }

  .footer-custom__submit {
    position: absolute;
    top: var(--sp-1);
    right: var(--sp-1);
    display: flex;
    align-items: center;
    justify-content: center;
    width: calc(var(--sp-8) + var(--sp-2));
    height: calc(var(--sp-6) + var(--sp-2));
    border: 0;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, var(--color-earth-brown), var(--color-bark));
    color: var(--color-cream);
    cursor: pointer;
    transition: opacity var(--timing-short) var(--ease-standard);
  }

  .footer-custom__submit:hover {
    opacity: 0.86;
  }

  .footer-custom__utility {
    border-bottom: 1px solid var(--border-light);
  }

  .footer-custom__utility-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: var(--sp-6);
    min-height: 100px;
  }

  .footer-custom__bottom-socials,
  .footer-custom__social,
  .footer-custom__legal,
  .footer-custom__utility-mark {
    display: flex;
    align-items: center;
  }

  .footer-custom__bottom-socials {
    gap: var(--sp-5);
  }

  .footer-custom__follow-label {
    padding-right: var(--sp-5);
    border-right: 1px solid var(--border-default);
    font-family: var(--font-display);
    font-size: var(--font-size-body-md);
  }

  .footer-custom__social {
    gap: var(--sp-3);
  }

  .footer-custom__social a,
  .footer-custom__social-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-7);
    height: var(--sp-7);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    color: var(--color-earth-brown);
    text-decoration: none;
  }

  .footer-custom__social a:hover {
    border-color: var(--color-clay);
    color: var(--color-clay);
  }

  .footer-custom__utility-mark {
    gap: var(--sp-5);
    color: var(--color-bark);
  }

  .footer-custom__utility-mark span {
    width: calc(var(--sp-8) * 3);
    height: 1px;
    background-color: var(--border-light);
  }

  .footer-custom__utility-mark svg {
    width: var(--sp-7);
    height: var(--sp-7);
  }

  .footer-custom__legal {
    justify-content: flex-end;
    gap: var(--sp-5);
  }

  .footer-custom__legal a {
    min-height: var(--sp-7);
    display: inline-flex;
    align-items: center;
    color: var(--color-earth-brown);
    text-decoration: none;
    font-family: var(--font-roboto);
  }

  .footer-custom__legal a + a {
    padding-left: var(--sp-5);
    border-left: 1px solid var(--border-default);
  }

  .footer-custom__copyright {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: var(--layout-padding-mobile);
    padding-block: var(--sp-5);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
    text-align: center;
  }

  @media (max-width: 1200px) {
    .footer-custom__top {
      grid-template-columns: minmax(0, 1.8fr) minmax(0, 1fr) minmax(0, 1.15fr) minmax(0, 1.7fr);
      gap: var(--sp-5);
    }

    .footer-custom__column--links,
    .footer-custom__column--newsletter {
      padding-left: var(--sp-5);
    }

    .footer-custom__utility-mark span {
      width: var(--sp-8);
    }
  }

  @media (max-width: 1024px) {
    .footer-custom__inner {
      padding-inline: var(--layout-padding-tablet);
    }

    .footer-custom__top {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer-custom__column {
      padding: var(--sp-5) 0 0;
      border-top: 1px solid var(--border-light);
      border-left: 0;
    }

    .footer-custom__utility-inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }

    .footer-custom__utility-mark {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .footer-custom__inner {
      padding-inline: var(--layout-padding-mobile);
    }

    .footer-custom__logo-wrapper {
      align-items: center;
      padding-top: var(--sp-8);
      text-align: center;
    }

    .footer-custom__tagline,
    .footer-custom__brand-ornament {
      margin-left: 0;
    }

    .footer-custom__top {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-6);
      padding-bottom: var(--sp-8);
    }

    .footer-custom__column--newsletter {
      align-items: flex-start;
      text-align: left;
    }

    .footer-custom__newsletter-ornament {
      justify-content: flex-start;
    }

    .footer-custom__utility-inner {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-4);
      padding-block: var(--sp-5);
    }

    .footer-custom__bottom-socials,
    .footer-custom__legal {
      justify-content: center;
      flex-wrap: wrap;
    }

    .footer-custom__legal a {
      min-height: var(--sp-7);
    }
  }

  @media (max-width: 480px) {
    .footer-custom__wordmark {
      font-size: var(--font-size-display-lg);
    }

    .footer-custom__brand-mark {
      width: var(--sp-7);
      height: var(--sp-7);
    }

    .footer-custom__tagline {
      font-size: var(--font-size-caption);
      letter-spacing: calc(var(--letter-spacing-wide) * 3);
    }

    .footer-custom__bottom-socials {
      gap: var(--sp-3);
    }

    .footer-custom__follow-label {
      width: 100%;
      padding: 0;
      border-right: 0;
      text-align: center;
    }

    .footer-custom__legal {
      gap: var(--sp-3);
    }

    .footer-custom__legal a + a {
      padding-left: var(--sp-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-custom__btn {
      transition: none;
    }

    .footer-custom__btn:hover {
      transform: none;
    }
  }
{% endstylesheet %}

