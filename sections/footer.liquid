<footer class="footer-custom">
  <div class="footer-custom__inner footer-custom__main">
    <section class="footer-custom__brand-panel" aria-label="WRYDECO contact details">
      {%- assign footer_logo_alt = section.settings.logo.alt | default: shop.name -%}
      <h2 class="footer-custom__wordmark">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 360
            | image_tag:
              class: 'footer__heading-logo',
              widths: '160, 240, 320, 360',
              height: section.settings.logo.height,
              width: section.settings.logo.width,
              alt: footer_logo_alt
          }}
        {%- elsif section.settings.logo_asset != blank -%}
          <img
            src="{{ section.settings.logo_asset | file_url }}"
            class="footer__heading-logo"
            alt="{{ shop.name | escape }}"
            width="200"
            height="64"
            loading="lazy"
          >
        {%- else -%}
          <span class="footer-custom__wordmark-text">{{ shop.name }}</span>
        {%- endif -%}
      </h2>
      <p class="footer-custom__tagline">
        Bespoke wooden furniture, handcrafted for timeless spaces and meaningful living.
      </p>

      <ul class="footer-custom__contact" aria-label="Contact information">
        <li>
          <span aria-hidden="true">☎</span>
          <a href="tel:+14159026735">+1 (415) 902-6735</a>
        </li>
        <li>
          <span aria-hidden="true">✉</span>
          <a href="mailto:support@wrydeco.com">support@wrydeco.com</a>
        </li>
        <li>
          <span aria-hidden="true">⌖</span>
          <span>San Francisco, California</span>
        </li>
      </ul>

      {% if section.settings.show_social %}
        <nav class="footer-custom__social" aria-label="Social links">
          <a href="https://www.tiktok.com/@wrydeco" aria-label="TikTok" target="_blank" rel="noopener noreferrer">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              fill="currentColor"
              class="bi bi-tiktok"
              viewBox="0 0 16 16"
            >
              <path d="M9 0h1.98c.144.715.54 1.617 1.235 2.512C12.895 3.389 13.797 4 15 4v2c-1.753 0-3.07-.814-4-1.829V11a5 5 0 1 1-5-5v2a3 3 0 1 0 3 3z"/>
            </svg>
          </a>
          <a href="https://www.youtube.com/@Wrydeco" aria-label="YouTube" target="_blank" rel="noopener noreferrer">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              fill="currentColor"
              class="bi bi-youtube"
              viewBox="0 0 16 16"
            >
              <path d="M8.051 1.999h.089c.822.003 4.987.033 6.11.335a2.01 2.01 0 0 1 1.415 1.42c.101.38.172.883.22 1.402l.01.104.022.26.008.104c.065.914.073 1.77.074 1.957v.075c-.001.194-.01 1.108-.082 2.06l-.008.105-.009.104c-.05.572-.124 1.14-.235 1.558a2.01 2.01 0 0 1-1.415 1.42c-1.16.312-5.569.334-6.18.335h-.142c-.309 0-1.587-.006-2.927-.052l-.17-.006-.087-.004-.171-.007-.171-.007c-1.11-.049-2.167-.128-2.654-.26a2.01 2.01 0 0 1-1.415-1.419c-.111-.417-.185-.986-.235-1.558L.09 9.82l-.008-.104A31 31 0 0 1 0 7.68v-.123c.002-.215.01-.958.064-1.778l.007-.103.003-.052.008-.104.022-.26.01-.104c.048-.519.119-1.023.22-1.402a2.01 2.01 0 0 1 1.415-1.42c.487-.13 1.544-.21 2.654-.26l.17-.007.172-.006.086-.003.171-.007A100 100 0 0 1 7.858 2zM6.4 5.209v4.818l4.157-2.408z"/>
            </svg>
          </a>
          <a
            href="https://www.pinterest.com/wrydecovip"
            aria-label="Pinterest"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              fill="currentColor"
              class="bi bi-pinterest"
              viewBox="0 0 16 16"
            >
              <path d="M8 0a8 8 0 0 0-2.915 15.452c-.07-.633-.134-1.606.027-2.297.146-.625.938-3.977.938-3.977s-.239-.479-.239-1.187c0-1.113.645-1.943 1.448-1.943.682 0 1.012.512 1.012 1.127 0 .686-.437 1.712-.663 2.663-.188.796.4 1.446 1.185 1.446 1.422 0 2.515-1.5 2.515-3.664 0-1.915-1.377-3.254-3.342-3.254-2.276 0-3.612 1.707-3.612 3.471 0 .688.265 1.425.595 1.826a.24.24 0 0 1 .056.23c-.061.252-.196.796-.222.907-.035.146-.116.177-.268.107-1-.465-1.624-1.926-1.624-3.1 0-2.523 1.834-4.84 5.286-4.84 2.775 0 4.932 1.977 4.932 4.62 0 2.757-1.739 4.976-4.151 4.976-.811 0-1.573-.421-1.834-.919l-.498 1.902c-.181.695-.669 1.566-.995 2.097A8 8 0 1 0 8 0"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/profile.php?id=61591715281987"
            aria-label="Facebook"
            target="_blank"
            rel="noopener noreferrer"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              fill="currentColor"
              class="bi bi-facebook"
              viewBox="0 0 16 16"
            >
              <path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/>
            </svg>
          </a>
          <a href="https://www.instagram.com/" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              fill="currentColor"
              class="bi bi-instagram"
              viewBox="0 0 16 16"
            >
              <path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.035 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/>
            </svg>
          </a>
        </nav>
      {% endif %}
    </section>

    <nav class="footer-custom__nav" aria-label="Footer navigation">
      <div class="footer-custom__column footer-custom__column--links">
        <h3 class="footer-custom__heading">Shop</h3>
        <ul class="footer-custom__menu">
          <li><a href="{{ routes.collections_url }}">All Collections</a></li>
          <li><a href="{{ routes.collections_url | append: '/wooden-plant-stand' }}">Wooden Plant Stand</a></li>
          <li><a href="{{ routes.collections_url | append: '/coffee-table' }}">Coffee Tables</a></li>
          <li><a href="{{ routes.collections_url | append: '/storage-cabinets' }}">Storage & Cabinets</a></li>
          <li><a href="{{ routes.collections_url | append: '/sculptural-shelving' }}">Sculptural Shelving</a></li>
          <li><a href="{{ routes.collections_url | append: '/bedroom-furniture' }}">Bedroom Furniture</a></li>
          <li><a href="{{ routes.collections_url | append: '/signature-pieces' }}">Signature Pieces</a></li>
        </ul>
      </div>

      <div class="footer-custom__column footer-custom__column--links">
        <h3 class="footer-custom__heading">Company</h3>
        <ul class="footer-custom__menu">
          <li><a href="{{ pages['about-us'].url | default: '/pages/about-us' }}">Our Story</a></li>
          <li><a href="/pages/customization">Consultation</a></li>
          <li><a href="/pages/care-guide">Care Guide</a></li>
          <li><a href="/apps/track-order">Track Order</a></li>
          <li><a href="/blogs/news">Blogs</a></li>
        </ul>
      </div>

      <div class="footer-custom__column footer-custom__column--links">
        <h3 class="footer-custom__heading">Support</h3>
        <ul class="footer-custom__menu">
          <li><a href="{{ pages['faq'].url | default: '/pages/faq' }}">FAQs</a></li>
          <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          <li><a href="/policies/refund-policy">Refund Policy</a></li>
          <li><a href="/policies/terms-of-service">Terms of Service</a></li>
          <li><a href="/policies/shipping-policy">Shipping Policy</a></li>
          <li><a href="/policies/legal-notice">Legal Notice</a></li>
        </ul>
      </div>
    </nav>

    <section class="footer-custom__newsletter" aria-labelledby="footer-newsletter-title">
      <h3 id="footer-newsletter-title" class="footer-custom__heading footer-custom__heading--large">Stay Inspired</h3>
      <p>Join our newsletter for new collections, design stories, and exclusive offers.</p>
      {% form 'customer', class: 'footer-custom__form' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="footer-custom__input-group">
          <input
            type="email"
            name="contact[email]"
            class="footer-custom__input"
            placeholder="Your email address"
            aria-label="Your email address"
            autocomplete="email"
            required
          >
          <button type="submit" class="footer-custom__submit">Subscribe</button>
        </div>
      {% endform %}
      <p class="footer-custom__privacy">
        <span aria-hidden="true">▧</span> We respect your privacy. Unsubscribe anytime.
      </p>

      {%- if section.settings.show_currency -%}
        <div class="footer-custom__localization">
          {% render 'localization-selector', variant: 'footer', id: 'footer' %}
        </div>
      {%- endif -%}
    </section>
  </div>

  <div class="footer-custom__bottom footer-custom__inner">
    <p>&copy; {{ 'now' | date: '%Y' }} WRYDECO. All rights reserved.</p>

    <nav class="footer-custom__legal" aria-label="Footer legal">
      {% if shop.privacy_policy.body != blank %}
        <a href="{{ shop.privacy_policy.url }}">Privacy Policy</a>
      {% endif %}
      {% if shop.refund_policy.body != blank %}
        <a href="{{ shop.refund_policy.url }}">Refund Policy</a>
      {% endif %}
      {% if shop.terms_of_service.body != blank %}
        <a href="{{ shop.terms_of_service.url }}">Terms of Service</a>
      {% endif %}
      {% if shop.shipping_policy.body != blank %}
        <a href="{{ shop.shipping_policy.url }}">Shipping Policy</a>
      {% endif %}
      {% if shop.legal_notice.body != blank %}
        <a href="{{ shop.legal_notice.url }}">Legal Notice</a>
      {% endif %}
    </nav>
  </div>
</footer>

{% stylesheet %}
  .footer-custom {
    border-top: 1px solid var(--border-default);
    background: radial-gradient(circle at top, var(--color-milk) 0%, var(--surface-default) 70%);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .footer-custom__inner {
    width: 100%;
    max-width: none;
    margin-inline: auto;
    padding-inline: calc(var(--sp-8) + var(--sp-2));
  }

  .footer-custom__logo-wrapper {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    padding-top: calc(var(--sp-5) + var(--sp-6));
    padding-bottom: var(--sp-7);
  }
  .footer-custom__logo-wrapper img {
    height: 64px;
  }

  .footer-custom__brand {
    display: inline-flex;
    align-items: center;
    color: var(--color-earth-brown);
    text-decoration: none;
  }

  .footer-custom__wordmark {
    font-family: var(--font-display);
    font-size: calc(var(--font-size-display-lg) + var(--font-size-body-md));
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-wide);
  }
  .footer__heading-logo {
    display: block;
    height: 74px;
    width: fit-content;
  }

  .footer-custom__brand-mark {
    width: var(--sp-8);
    height: var(--sp-8);
    flex: 0 0 auto;
  }

  .footer-custom__tagline {
    margin: var(--sp-2) 0 0 var(--sp-5);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    letter-spacing: calc(var(--letter-spacing-wide) * 6);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .footer-custom__brand-ornament {
    width: var(--sp-8);
    height: 1px;
    margin: var(--sp-5) 0 0 calc(var(--sp-8) * 2);
    background-color: var(--color-clay);
  }

  .footer-custom__top {
    display: grid;
    grid-template-columns: minmax(0, 2.1fr) minmax(0, 1fr) minmax(0, 1.25fr) minmax(0, 2.2fr);
    gap: var(--sp-7);
    padding-top: var(--sp-3);
    padding-bottom: 0;
  }

  .footer-custom__column {
    min-width: 0;
  }

  .footer-custom__column--links,
  .footer-custom__column--newsletter {
    padding-left: var(--sp-7);
    border-left: 1px solid var(--border-light);
  }

  .footer-custom__heading {
    margin: 0 0 var(--sp-5);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-earth-brown);
  }

  .footer-custom__column--links .footer-custom__heading::after {
    content: '';
    display: block;
    width: var(--sp-7);
    height: 1px;
    margin-top: var(--sp-4);
    background-color: var(--color-clay);
  }

  .footer-custom__text {
    margin-bottom: var(--sp-5);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
    color: var(--text-secondary);
  }

  .footer-custom__text p {
    margin: 0;
  }

  .footer-custom__column--text .footer-custom__text p {
    position: relative;
    min-height: var(--sp-7);
    padding-left: var(--sp-7);
    padding-top: var(--sp-1);
  }

  .footer-custom__column--text .footer-custom__text p::before {
    content: '•';
    position: absolute;
    left: 0;
    top: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-6);
    height: var(--sp-6);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    background-color: var(--color-milk);
    color: var(--color-bark);
  }

  .footer-custom__column--text .footer-custom__text p:nth-child(1)::before {
    content: '✉';
  }
  .footer-custom__column--text .footer-custom__text p:nth-child(2)::before,
  .footer-custom__column--text .footer-custom__text p:nth-child(3)::before {
    content: '⌖';
  }
  .footer-custom__column--text .footer-custom__text p:nth-child(4)::before {
    content: '◷';
  }

  .footer-custom__text strong {
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }

  .footer-custom__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    width: min(100%, calc(var(--sp-8) * 5));
    min-height: var(--sp-8);
    margin-top: var(--sp-2);
    padding-inline: var(--sp-5);
    border: 1px solid var(--color-earth-brown);
    border-radius: var(--radius-full);
    background: linear-gradient(90deg, var(--color-earth-brown), var(--color-bark), var(--color-earth-brown));
    box-shadow: var(--shadow-card);
    font-family: var(--font-display);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-cream);
    transition: transform var(--timing-short) var(--ease-standard);
  }

  .footer-custom__btn:hover {
    transform: translateY(calc(var(--sp-1) * -1));
    color: var(--color-cream);
  }

  .footer-custom__btn-icon {
    width: var(--font-size-body-lg);
    height: var(--font-size-body-lg);
  }

  .footer-custom__menu {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-custom__menu li {
    margin: 0;
    border-bottom: 1px solid var(--border-light);
  }

  .footer-custom__menu a {
    display: flex;
    align-items: center;
    min-height: var(--sp-7);
    padding-block: var(--sp-2);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-md);
    text-decoration: none;
    color: var(--text-primary);
    transition: color var(--timing-short) var(--ease-standard), padding-left var(--timing-short) var(--ease-standard);
  }

  .footer-custom__menu a:hover {
    padding-left: var(--sp-2);
    color: var(--color-clay);
  }

  .footer-custom__column--newsletter {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .footer-custom__newsletter-icon {
    width: var(--sp-8);
    height: var(--sp-8);
    margin-bottom: var(--sp-3);
    color: var(--color-bark);
  }

  .footer-custom__heading--large {
    margin-bottom: var(--sp-4);
    font-family: var(--font-display);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-normal);
    text-transform: none;
    color: var(--text-primary);
  }

  .footer-custom__newsletter-ornament {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
    color: var(--color-clay);
  }

  .footer-custom__newsletter-ornament span {
    width: var(--sp-7);
    height: 1px;
    background-color: currentColor;
  }

  .footer-custom__newsletter-ornament i {
    width: var(--sp-2);
    height: var(--sp-2);
    border: 1px solid currentColor;
    transform: rotate(45deg);
  }

  .footer-custom__column--newsletter .footer-custom__text {
    max-width: 40ch;
    margin-bottom: var(--sp-5);
  }

  .footer-custom__form {
    width: 100%;
  }

  .footer-custom__input-group {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
  }

  .footer-custom__input {
    width: 100%;
    min-height: calc(var(--sp-6) + var(--sp-4));
    padding: 0 calc(var(--sp-9) + var(--sp-5)) 0 var(--sp-5);
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    background-color: var(--surface-elevated);
    outline: none;
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    color: var(--text-primary);
  }

  .footer-custom__input:focus {
    border-color: var(--color-bark);
    box-shadow: var(--shadow-focus);
  }

  .footer-custom__input::placeholder {
    color: var(--text-tertiary);
  }

  .footer-custom__submit {
    position: absolute;
    top: var(--sp-1);
    right: var(--sp-1);
    display: flex;
    align-items: center;
    justify-content: center;
    width: calc(var(--sp-8) + var(--sp-2));
    height: calc(var(--sp-6) + var(--sp-2));
    border: 0;
    border-radius: var(--radius-full);
    background: linear-gradient(135deg, var(--color-earth-brown), var(--color-bark));
    color: var(--color-cream);
    cursor: pointer;
    transition: opacity var(--timing-short) var(--ease-standard);
  }

  .footer-custom__submit:hover {
    opacity: 0.86;
  }

  .footer-custom__utility {
    border-bottom: 1px solid var(--border-light);
  }

  .footer-custom__utility-inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: var(--sp-6);
    min-height: 100px;
  }

  .footer-custom__bottom-socials,
  .footer-custom__social,
  .footer-custom__legal,
  .footer-custom__utility-mark {
    display: flex;
    align-items: center;
  }

  .footer-custom__bottom-socials {
    gap: var(--sp-5);
  }

  .footer-custom__follow-label {
    padding-right: var(--sp-5);
    border-right: 1px solid var(--border-default);
    font-family: var(--font-display);
    font-size: var(--font-size-body-md);
  }

  .footer-custom__social {
    gap: var(--sp-3);
  }

  .footer-custom__social a,
  .footer-custom__social-placeholder {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-7);
    height: var(--sp-7);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    color: var(--color-earth-brown);
    text-decoration: none;
  }

  .footer-custom__social a:hover {
    border-color: var(--color-clay);
    color: var(--color-clay);
  }

  .footer-custom__utility-mark {
    gap: var(--sp-5);
    color: var(--color-bark);
  }

  .footer-custom__utility-mark span {
    width: calc(var(--sp-8) * 3);
    height: 1px;
    background-color: var(--border-light);
  }

  .footer-custom__utility-mark svg {
    width: var(--sp-7);
    height: var(--sp-7);
  }

  .footer-custom__legal {
    justify-content: flex-end;
    gap: var(--sp-5);
  }

  .footer-custom__legal a {
    min-height: var(--sp-7);
    display: inline-flex;
    align-items: center;
    color: var(--color-earth-brown);
    text-decoration: none;
    font-family: var(--font-roboto);
  }

  .footer-custom__legal a + a {
    padding-left: var(--sp-5);
    border-left: 1px solid var(--border-default);
  }

  .footer-custom__copyright {
    display: flex;
    align-items: center;
    justify-content: center;
    padding-inline: var(--layout-padding-mobile);
    padding-block: var(--sp-5);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
    text-align: center;
  }

  @media (max-width: 1200px) {
    .footer-custom__top {
      grid-template-columns: minmax(0, 1.8fr) minmax(0, 1fr) minmax(0, 1.15fr) minmax(0, 1.7fr);
      gap: var(--sp-5);
    }

    .footer-custom__column--links,
    .footer-custom__column--newsletter {
      padding-left: var(--sp-5);
    }

    .footer-custom__utility-mark span {
      width: var(--sp-8);
    }
  }

  @media (max-width: 1024px) {
    .footer-custom__inner {
      padding-inline: var(--layout-padding-tablet);
    }

    .footer-custom__top {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .footer-custom__column {
      padding: var(--sp-5) 0 0;
      border-top: 1px solid var(--border-light);
      border-left: 0;
    }

    .footer-custom__utility-inner {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    }

    .footer-custom__utility-mark {
      display: none;
    }
  }

  @media (max-width: 768px) {
    .footer-custom__inner {
      padding-inline: var(--layout-padding-mobile);
    }

    .footer-custom__logo-wrapper {
      align-items: center;
      padding-top: var(--sp-8);
      text-align: center;
    }

    .footer-custom__tagline,
    .footer-custom__brand-ornament {
      margin-left: 0;
    }

    .footer-custom__top {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-6);
      padding-bottom: var(--sp-8);
    }

    .footer-custom__column--newsletter {
      align-items: flex-start;
      text-align: left;
    }

    .footer-custom__newsletter-ornament {
      justify-content: flex-start;
    }

    .footer-custom__utility-inner {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-4);
      padding-block: var(--sp-5);
    }

    .footer-custom__bottom-socials,
    .footer-custom__legal {
      justify-content: center;
      flex-wrap: wrap;
    }

    .footer-custom__legal a {
      min-height: var(--sp-7);
    }
  }

  @media (max-width: 480px) {
    .footer-custom__wordmark {
      font-size: var(--font-size-display-lg);
    }

    .footer-custom__brand-mark {
      width: var(--sp-7);
      height: var(--sp-7);
    }

    .footer-custom__tagline {
      font-size: var(--font-size-caption);
      letter-spacing: calc(var(--letter-spacing-wide) * 3);
    }

    .footer-custom__bottom-socials {
      gap: var(--sp-3);
    }

    .footer-custom__follow-label {
      width: 100%;
      padding: 0;
      border-right: 0;
      text-align: center;
    }

    .footer-custom__legal {
      gap: var(--sp-3);
    }

    .footer-custom__legal a + a {
      padding-left: var(--sp-3);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-custom__btn {
      transition: none;
    }

    .footer-custom__btn:hover {
      transform: none;
    }
  }

  .footer-custom {
    --footer-bg: #4a2c18;
    --footer-bg-deep: #331c0f;
    --footer-ink: #f8f0e7;
    --footer-muted: rgba(248, 240, 231, 0.72);
    --footer-line: rgba(248, 240, 231, 0.18);
    border-top: 0;
    background: radial-gradient(circle at 78% 8%, rgba(166, 120, 79, 0.38), transparent 34%),
      radial-gradient(circle at 16% 100%, rgba(30, 15, 8, 0.54), transparent 42%),
      linear-gradient(135deg, var(--footer-bg) 0%, var(--footer-bg-deep) 100%);
    color: var(--footer-ink);
    font-family: var(--font-body);
  }

  .footer-custom__inner {
    width: min(100%, 1500px);
    margin: 0 auto;
    padding-inline: clamp(20px, 6vw, 112px);
  }

  .footer-custom__main {
    display: grid;
    grid-template-columns: minmax(220px, 1.28fr) minmax(430px, 2.05fr) minmax(280px, 1.32fr);
    gap: clamp(24px, 4vw, 78px);
    padding-top: clamp(46px, 5vw, 72px);
    padding-bottom: clamp(10px, 3vw, 58px);
  }

  .footer-custom__brand-panel,
  .footer-custom__newsletter {
    min-width: 0;
  }

  @media (max-width: 760px) {
    .footer-custom__brand-panel {
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .footer-custom__main {
      grid-template-columns: 1fr;
    }

    .footer-custom__tagline {
      text-align: center;
    }

    .footer-custom__nav {
      place-items: center;
    }

    .footer-custom__menu {
      place-items: center;
    }
    .footer-custom__menu li {
      width: fit-content;
    }

    .footer-custom__heading {
      text-align: center;
    }

    .footer-custom__wordmark {
      justify-content: center;
      width: 100%;
    }

    .footer__heading-logo {
      width: min(100%, calc(var(--sp-12) + var(--sp-7)));
      max-height: var(--sp-7);
    }

    .footer-custom__column--links:last-child {
      grid-column: 1 / span 2;
    }
  }

  .footer-custom__wordmark {
    display: flex;
    align-items: center;
    margin: 0 0 var(--sp-5);
    color: var(--footer-ink);
    font-family: var(--font-display-light, var(--font-display));
    font-size: clamp(42px, 3.1vw, 56px);
    font-weight: 300;
    line-height: 0.95;
    letter-spacing: var(--letter-spacing-normal);
  }

  .footer-custom__wordmark-text {
    display: inline-block;
    max-width: 100%;
    overflow-wrap: anywhere;
  }

  .footer-custom__tagline {
    max-width: 32ch;
    margin: 0 0 28px;
    color: var(--footer-muted);
    font-size: 15px;
    line-height: 1.55;
    letter-spacing: 0;
    text-transform: none;
  }

  .footer-custom__contact,
  .footer-custom__menu {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .footer-custom__contact {
    display: grid;
    gap: 11px;
    margin-bottom: 28px;
  }

  .footer-custom__contact li {
    display: flex;
    align-items: center;
    gap: 13px;
    margin: 0;
    color: var(--footer-muted);
    font-size: 14px;
  }

  .footer-custom__contact span:first-child {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    color: var(--footer-ink);
    font-size: 17px;
  }

  .footer-custom a {
    color: inherit;
    text-decoration: none;
  }

  .footer-custom a:hover {
    color: #fff;
  }

  .footer-custom__social {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .footer-custom__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: auto;
    height: 30px;
    min-width: 22px;
    border: 0;
    border-radius: 0;
    color: var(--footer-ink);
    font-family: var(--font-display);
    font-size: 23px;
    line-height: 1;
  }

  .footer-custom__social a:nth-child(3) {
    font-family: var(--font-body);
    font-size: 18px;
    font-weight: 600;
  }

  .footer-custom__social a:nth-child(4) {
    width: 25px;
    height: 25px;
    border: 1px solid currentColor;
    border-radius: 999px;
    font-size: 14px;
  }

  .footer-custom__nav {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(34px, 4vw, 58px);
  }

  .footer-custom__column,
  .footer-custom__column--links,
  .footer-custom__column--newsletter {
    padding: 0;
    border: 0;
  }

  .footer-custom__heading {
    margin: 0 0 22px;
    color: var(--footer-ink);
    font-family: var(--font-roboto);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.16em;
    line-height: 1.2;
    text-transform: uppercase;
  }

  .footer-custom__column--links .footer-custom__heading::after {
    display: none;
  }

  .footer-custom__menu {
    display: grid;
    gap: 13px;
  }

  .footer-custom__menu li {
    margin: 0;
    border: 0;
  }

  .footer-custom__menu a {
    display: inline-flex;
    min-height: 0;
    padding: 0;
    color: var(--footer-muted);
    font-family: var(--font-roboto);
    font-size: 14px;
    line-height: 1.25;
    transition: color var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
  }

  .footer-custom__menu a:hover {
    padding-left: 0;
    color: var(--footer-ink);
    transform: translateX(2px);
  }

  .footer-custom__newsletter {
    padding-left: clamp(34px, 4vw, 58px);
    border-left: 1px solid var(--footer-line);
  }

  .footer-custom__heading--large {
    margin-bottom: 18px;
    color: var(--footer-ink);
    font-family: var(--font-display-light, var(--font-display));
    font-size: clamp(29px, 2.3vw, 42px);
    font-weight: 300;
    letter-spacing: -0.05em;
    line-height: 1;
    text-transform: none;
  }

  .footer-custom__newsletter p {
    margin: 0 0 26px;
    color: var(--footer-muted);
    font-size: 14px;
    line-height: 1.55;
  }

  .footer-custom__form {
    width: 100%;
    margin-bottom: 24px;
  }

  .footer-custom__input-group {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: stretch;
    overflow: hidden;
    width: min(100%, 340px);
    min-height: 54px;
    border: 1px solid rgba(248, 240, 231, 0.42);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.03);
  }

  .footer-custom__input {
    width: 100%;
    min-height: 54px;
    padding: 0 20px;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--footer-ink);
    font-size: 14px;
  }

  .footer-custom__input:focus {
    border-color: transparent;
    box-shadow: none;
  }

  .footer-custom__input::placeholder {
    color: rgba(248, 240, 231, 0.74);
  }

  .footer-custom__submit {
    position: static;
    width: auto;
    height: auto;
    min-width: 104px;
    min-height: 54px;
    padding: 0 22px;
    border: 0;
    border-radius: 8px;
    background: #f4e9de;
    color: var(--footer-bg-deep);
    font-size: 14px;
    font-weight: 500;
    transition: background-color var(--timing-short) var(--ease-standard),
      transform var(--timing-short) var(--ease-standard);
  }

  .footer-custom__submit:hover {
    background: #fff6ed;
    opacity: 1;
    transform: translateY(-1px);
  }

  .footer-custom__privacy {
    display: flex;
    align-items: center;
    gap: 10px;
    margin: 0;
    color: rgba(248, 240, 231, 0.64);
    font-size: 12px;
    width: max-content;
  }

  .footer-custom__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 26px;
    padding-bottom: 30px;
    border-top: 1px solid var(--footer-line);
  }

  .footer-custom__bottom p {
    margin: 0;
    color: rgba(248, 240, 231, 0.58);
    font-size: 12px;
  }

  .footer-custom__localization {
    display: flex;
    align-items: center;
    margin-top: var(--sp-5);
  }

  .footer-custom__legal {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: clamp(30px, 5vw, 82px);
  }

  .footer-custom__legal a {
    min-height: 0;
    color: rgba(248, 240, 231, 0.68);
    font-family: var(--font-body);
    font-size: 12px;
  }

  .footer-custom__legal a + a {
    padding-left: 0;
    border-left: 0;
  }

  @media (max-width: 1120px) {
    .footer-custom__main {
      grid-template-columns: 1fr;
    }

    .footer-custom__newsletter {
      padding-left: 0;
      padding-top: 34px;
      border-left: 0;
      border-top: 1px solid var(--footer-line);
    }
  }

  @media (max-width: 760px) {
    .footer-custom__nav {
      grid-template-columns: 1fr 1fr;
      gap: 30px;
    }

    .footer-custom__bottom {
      flex-direction: column;
      align-items: flex-start;
    }

    .footer-custom__legal {
      justify-content: flex-start;
      flex-wrap: wrap;
      gap: 18px 26px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Custom Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_asset",
      "label": "Shopify Files logo",
      "default": "store-logo-trans.png",
      "info": "Filename uploaded in Shopify Content > Files, for example store-logo-trans.png"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_currency",
      "label": "Show currency selector",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_payment",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text Info",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Get In Touch"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>E-mail: support@yourstore.com</p><p>Address: 123 Street</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Follow on shop"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    },
    {
      "type": "link_list",
      "name": "Menu",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Company"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Stay Inspired"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Sign up for exclusive offers, original stories, events and more.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Footer"
    }
  ]
}
{% endschema %}
