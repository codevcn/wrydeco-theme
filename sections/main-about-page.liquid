{%- liquid
  assign collections_url = section.settings.collections_url | default: routes.collections_url
-%}

<main class="about-new" id="about-new-{{ section.id }}">
  <section class="about-new-hero" aria-labelledby="about-new-title-{{ section.id }}">
    <div class="about-new-hero__media" aria-hidden="true">
      <img
        src="{{ 'about-us-natural-wood.png' | file_url }}"
        width="1792"
        height="1024"
        alt="{{ section.settings.hero_image_alt | escape }}"
        loading="eager"
        fetchpriority="high"
      >
    </div>

    <div class="about-new-hero__inner">
      <div class="about-new-hero__copy">
        <p class="about-new__eyebrow">{{ section.settings.hero_eyebrow | escape }}</p>
        <h1 id="about-new-title-{{ section.id }}">
          <span>{{ section.settings.hero_heading_first_line | escape }}</span>
          <span>{{ section.settings.hero_heading_second_line | escape }}</span>
          <span>{{ section.settings.hero_heading_third_line | escape }}</span>
        </h1>
        <div class="about-new-hero__text rte">{{ section.settings.hero_text }}</div>
        <a class="about-new__button" href="{{ collections_url }}">
          {{ section.settings.hero_button_label | escape }}
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <section class="about-new-story" aria-labelledby="about-new-story-title-{{ section.id }}">
    <div class="about-new-story__inner">
      <div class="about-new-story__media">
        <img
          src="{{ 'about-us-made-to-endure.png' | file_url }}"
          width="1024"
          height="1024"
          alt="{{ section.settings.story_image_alt | escape }}"
          loading="lazy"
        >
      </div>

      <div class="about-new-story__content">
        <p class="about-new__eyebrow">{{ section.settings.story_eyebrow | escape }}</p>
        <h2 id="about-new-story-title-{{ section.id }}">
          <span>{{ section.settings.story_heading_first_line | escape }}</span>
          <span>{{ section.settings.story_heading_second_line | escape }}</span>
        </h2>
        <div class="about-new-story__text rte">{{ section.settings.story_text }}</div>

        <div class="about-new-story__proofs" aria-label="{{ section.settings.proofs_label | escape }}">
          <article class="about-new-proof">
            <span class="about-new-proof__icon" aria-hidden="true">{% render 'about-craft-icon', icon: 'wood' %}</span>
            <div>
              <h3>{{ section.settings.proof_one_heading | escape }}</h3>
              <p>{{ section.settings.proof_one_text | escape }}</p>
            </div>
          </article>
          <article class="about-new-proof">
            <span class="about-new-proof__icon" aria-hidden="true">{% render 'about-craft-icon', icon: 'handmade' %}</span>
            <div>
              <h3>{{ section.settings.proof_two_heading | escape }}</h3>
              <p>{{ section.settings.proof_two_text | escape }}</p>
            </div>
          </article>
          <article class="about-new-proof">
            <span class="about-new-proof__icon" aria-hidden="true">{% render 'about-craft-icon', icon: 'shield' %}</span>
            <div>
              <h3>{{ section.settings.proof_three_heading | escape }}</h3>
              <p>{{ section.settings.proof_three_text | escape }}</p>
            </div>
          </article>
        </div>
      </div>
    </div>
  </section>

  <section class="about-new-team" aria-labelledby="about-new-team-title-{{ section.id }}">
    <div class="about-new-team__inner">
      <header class="about-new-team__header">
        <p class="about-new__eyebrow">{{ section.settings.team_eyebrow | escape }}</p>
        <h2 id="about-new-team-title-{{ section.id }}">{{ section.settings.team_heading | escape }}</h2>
        <p>{{ section.settings.team_intro | escape }}</p>
      </header>

      {%- comment -%}
        Team cards are populated from the first entries of the "Product Author"
        metaobject (image, name, bio). Each block is paired with the metaobject
        entry at the same index; role and tags stay on the block because the
        metaobject does not expose them. Block values act as fallbacks.
      {%- endcomment -%}
      <div class="about-new-team__grid">
        {%- for author in metaobjects.product_author.values limit: 3 -%}
          {%- assign block = section.blocks[forloop.index0] -%}
          {%- assign member_name = author.author_name.value | default: block.settings.name -%}
          {%- assign member_image = author.author_image_url.value -%}
          {%- assign member_bio = author.author_bio.value -%}
          {%- if member_bio == blank -%}
            {%- assign member_bio = block.settings.bio -%}
          {%- endif -%}
            <article class="about-new-member" {{ block.shopify_attributes }}>
              <div class="about-new-member__media">
                {%- if member_image != blank -%}
                  <img
                    src="{{ member_image }}"
                    width="1024"
                    height="1024"
                    alt="{{ member_name | escape }}"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
              </div>
              <div class="about-new-member__content">
                <p class="about-new-member__role">{{ block.settings.role | escape }}</p>
                <h3>{{ member_name | escape }}</h3>
                <div class="about-new-member__bio rte">{{ member_bio }}</div>
                {%- assign member_tags = block.settings.tags | split: ',' -%}
                <ul class="about-new-member__tags" aria-label="Specialties">
                  {%- for tag in member_tags -%}
                    {%- assign clean_tag = tag | strip -%}
                    {%- if clean_tag != blank -%}
                      <li>{{ clean_tag | escape }}</li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>
            </article>
        {%- endfor -%}
      </div>
    </div>
  </section>
</main>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AboutPage",
    "name": {{ section.settings.hero_heading_first_line | append: ' ' | append: section.settings.hero_heading_second_line | append: ' ' | append: section.settings.hero_heading_third_line | json }},
    "description": {{ section.settings.hero_text | strip_html | strip | json }},
    "url": {{ canonical_url | json }}
  }
</script>

<script>
  const mainProductSection = document.getElementById('about-new-{{ section.id }}');
  if (mainProductSection && window.innerWidth < 768) {
    mainProductSection.closest('body').querySelector('.header__icon--search').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header__icon--cart').style.color = 'var(--color-earth-brown)';
  }
</script>
{% stylesheet %}
  .about-new {
    --about-new-max-width: var(--layout-showcase-max-width);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .about-new__eyebrow {
    margin: var(--sp-0) var(--sp-0) var(--sp-3);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 4);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .about-new-hero {
    position: relative;
    display: grid;
    min-block-size: calc(var(--sp-8) * 9);
    overflow: hidden;
    height: 100vh;
  }

  .about-new-hero__media {
    position: absolute;
    inset: var(--sp-0);
  }

  .about-new-hero__media::after {
    position: absolute;
    inset: var(--sp-0);
    background: linear-gradient(90deg, var(--bg-primary) 0%, color-mix(in srgb, var(--bg-primary) 92%, transparent) 24%, transparent 62%);
    content: '';
  }

  .about-new-hero__media img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center;
  }

  .about-new-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    inline-size: min(calc(100% - (var(--sp-8) * 2)), var(--about-new-max-width));
    margin-inline: auto;
    padding-block: var(--sp-11) var(--sp-8);
  }

  .about-new-hero__copy {
    inline-size: min(42%, var(--layout-hero-copy-width));
  }

  .about-new-hero h1,
  .about-new-story h2,
  .about-new-team__header h2,
  .about-new-member h3 {
    color: var(--color-ebony);
    font-family: var(--font-display-light);
    font-weight: var(--font-weight-light);
  }

  .about-new-hero h1 {
    margin: var(--sp-0);
    font-size: var(--font-size-display-2xl);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
  }

  .about-new-hero h1 span,
  .about-new-story h2 span {
    display: block;
  }

  .about-new-hero__text {
    max-inline-size: 46ch;
    margin-block-start: var(--sp-5);
    color: var(--color-charcoal);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
  }

  .about-new-hero__text p,
  .about-new-story__text p,
  .about-new-member__bio p {
    margin: var(--sp-0);
  }

  .about-new__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
    min-block-size: var(--sp-8);
    margin-block-start: var(--sp-5);
    padding: var(--sp-3) var(--sp-5);
    border-radius: var(--radius-md);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
  }

  .about-new__button:hover {
    background: var(--color-charcoal);
  }

  .about-new__button:active {
    transform: translateY(var(--border-width));
  }

  .about-new__button:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  .about-new-story {
    padding: var(--sp-7) var(--sp-8);
    border-block-end: var(--border-width) solid var(--border-light);
  }

  .about-new-story__inner {
    display: grid;
    grid-template-columns: minmax(0, 40%) minmax(0, 60%);
    align-items: center;
    gap: var(--sp-7);
    inline-size: min(100%, var(--about-new-max-width));
    margin-inline: auto;
  }

  .about-new-story__media {
    overflow: hidden;
    aspect-ratio: 1;
    border-radius: var(--radius-lg);
  }

  .about-new-story__media img,
  .about-new-member__media img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .about-new-story__content {
    padding-inline-end: var(--sp-5);
  }

  .about-new-story h2 {
    margin: var(--sp-0);
    font-size: var(--font-size-display-xl);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
  }

  .about-new-story__text {
    display: grid;
    gap: var(--sp-4);
    max-inline-size: 68ch;
    margin-block-start: var(--sp-4);
    color: var(--color-charcoal);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .about-new-story__proofs {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-block-start: var(--sp-6);
    padding-block-start: var(--sp-5);
    border-block-start: var(--border-width) solid var(--border-light);
  }

  .about-new-proof {
    display: grid;
    grid-template-columns: var(--sp-7) minmax(0, 1fr);
    align-items: start;
    gap: var(--sp-3);
    min-inline-size: 0;
    padding-inline: var(--sp-4);
  }

  .about-new-proof:first-child {
    padding-inline-start: var(--sp-0);
  }

  .about-new-proof + .about-new-proof {
    border-inline-start: var(--border-width) solid var(--border-light);
  }

  .about-new-proof__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: var(--sp-7);
    block-size: var(--sp-7);
    padding: var(--sp-3);
    border: var(--border-width) solid var(--color-linen);
    border-radius: var(--radius-full);
    color: var(--color-bark);
  }

  .about-new-proof__icon svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .about-new-proof h3 {
    margin: var(--sp-0) var(--sp-0) var(--sp-1);
    color: var(--color-charcoal);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .about-new-proof p {
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-relaxed);
  }

  .about-new-team {
    background: color-mix(in srgb, var(--bg-secondary) 48%, var(--bg-primary));
  }

  .about-new-team__inner {
    inline-size: min(calc(100% - (var(--sp-8) * 2)), var(--about-new-max-width));
    margin-inline: auto;
    padding-block: var(--sp-7) var(--sp-9);
  }

  .about-new-team__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-block-end: var(--sp-6);
    text-align: center;
  }

  .about-new-team__header .about-new__eyebrow {
    margin-block-end: var(--sp-2);
  }

  .about-new-team__header h2 {
    margin: var(--sp-0);
    font-size: var(--font-size-display-lg);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
  }

  .about-new-team__header > p:last-child {
    margin: var(--sp-2) var(--sp-0) var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
  }

  .about-new-team__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--sp-5);
  }

  .about-new-member {
    overflow: hidden;
    border: var(--border-width) solid var(--border-light);
    border-radius: var(--radius-lg);
    background-color: var(--color-milk);
  }

  .about-new-member__media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .about-new-member__media img,
  .about-new-member__media svg {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    filter: sepia(0.1);
  }

  .about-new-member__content {
    padding: var(--sp-5);
  }

  .about-new-member__role {
    margin: var(--sp-0) var(--sp-0) var(--sp-1);
    color: var(--color-bark);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .about-new-member h3 {
    margin: var(--sp-0);
    font-size: var(--font-size-display-sm);
    line-height: var(--line-height-tight);
  }

  .about-new-member__bio {
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 4;
    line-clamp: 4;
    min-block-size: calc(var(--sp-8) + var(--sp-3));
    margin-block-start: var(--sp-2);
    overflow: hidden;
    color: var(--color-charcoal);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-generous);
  }

  .about-new-member__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin: var(--sp-4) var(--sp-0) var(--sp-0);
    padding: var(--sp-0);
    list-style: none;
  }

  .about-new-member__tags li {
    padding: var(--sp-1) var(--sp-3);
    border: var(--border-width) solid var(--border-light);
    border-radius: var(--radius-sm);
    color: var(--color-bark);
    font-size: var(--font-size-caption);
    letter-spacing: var(--letter-spacing-wide);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  @media screen and (max-width: 75rem) {
    .about-new-hero__inner,
    .about-new-team__inner {
      inline-size: min(calc(100% - (var(--layout-padding-desktop) * 2)), var(--about-new-max-width));
    }

    .about-new-hero h1 {
      font-size: var(--font-size-display-xl);
    }

    .about-new-story__proofs {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-3);
    }

    .about-new-proof,
    .about-new-proof:first-child {
      padding-inline: var(--sp-0);
    }

    .about-new-proof + .about-new-proof {
      padding-block-start: var(--sp-3);
      border-block-start: var(--border-width) solid var(--border-light);
      border-inline-start: var(--sp-0);
    }
  }

  @media screen and (max-width: 64rem) {
    .about-new-hero__copy {
      inline-size: 54%;
    }

    .about-new-story {
      padding-inline: var(--layout-padding-tablet);
    }

    .about-new-story__inner {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-6);
    }

    .about-new-story__media {
      aspect-ratio: 16 / 10;
    }

    .about-new-story__content {
      padding-inline-end: var(--sp-0);
    }

    .about-new-team__grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .about-new-member__bio {
      min-block-size: auto;
    }
  }

  @media screen and (max-width: 48rem) {
    .about-new-hero {
      min-block-size: 80svh;
    }

    .about-new-hero__media::after {
      background: linear-gradient(90deg, color-mix(in srgb, var(--bg-primary) 94%, transparent) 0%, color-mix(in srgb, var(--bg-primary) 78%, transparent) 72%, transparent 100%);
    }

    .about-new-hero__media img {
      object-position: 60% center;
    }

    .about-new-hero__inner,
    .about-new-team__inner {
      inline-size: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--about-new-max-width));
    }

    .about-new-hero__inner {
      padding-block: var(--sp-10) var(--sp-7);
    }

    .about-new-hero__copy {
      inline-size: 100%;
    }

    .about-new-hero h1,
    .about-new-story h2,
    .about-new-team__header h2 {
      font-size: var(--font-size-display-md);
    }

    .about-new-hero__text {
      max-inline-size: 34ch;
      font-size: var(--font-size-body-sm);
    }

    .about-new-story {
      padding: var(--sp-7) var(--layout-padding-mobile);
    }

    .about-new-story__media {
      aspect-ratio: 1;
    }

    .about-new-team__inner {
      padding-block: var(--sp-7);
    }

    .about-new-member__media {
      aspect-ratio: 4 / 3;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Main About page",
  "tag": "section",
  "class": "section-main-about-page",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Our story" },
    { "type": "text", "id": "hero_heading_first_line", "label": "Heading first line", "default": "A Gallery of Craft," },
    { "type": "text", "id": "hero_heading_second_line", "label": "Heading second line", "default": "Character, and" },
    { "type": "text", "id": "hero_heading_third_line", "label": "Heading third line", "default": "Natural Wood" },
    { "type": "richtext", "id": "hero_text", "label": "Text", "default": "<p>WRYDECO celebrates handcrafted furniture made from solid natural wood. Each piece is a collectible expression of form, function, and the quiet beauty of nature.</p>" },
    { "type": "text", "id": "hero_button_label", "label": "Button label", "default": "Explore our collections" },
    { "type": "url", "id": "collections_url", "label": "Collections page" },
    { "type": "text", "id": "hero_image_alt", "label": "Image alt text", "default": "A gallery of sculptural natural wood furniture in a calm interior" },
    { "type": "header", "content": "Brand story" },
    { "type": "text", "id": "story_eyebrow", "label": "Eyebrow", "default": "Brand story" },
    { "type": "text", "id": "story_heading_first_line", "label": "Heading first line", "default": "Rooted in Nature." },
    { "type": "text", "id": "story_heading_second_line", "label": "Heading second line", "default": "Made to Endure." },
    { "type": "richtext", "id": "story_text", "label": "Text", "default": "<p>Born from a deep respect for nature and tradition, WRYDECO creates sculptural furniture that brings warmth, soul, and calm into everyday life.</p><p>We work with solid hardwoods, selected for their strength and character, and shape each piece by hand with intention and care. Our designs are timeless—made not for trends, but to be lived with and passed on.</p><p>Transparency, honest materials, and meaningful relationships guide everything we do. This is our commitment to a more thoughtful way of living.</p>" },
    { "type": "text", "id": "story_image_alt", "label": "Image alt text", "default": "Solid natural wood dining furniture shaped to endure for generations" },
    { "type": "text", "id": "proofs_label", "label": "Proof points label", "default": "WRYDECO craftsmanship principles" },
    { "type": "text", "id": "proof_one_heading", "label": "Proof one heading", "default": "Solid wood only" },
    { "type": "textarea", "id": "proof_one_text", "label": "Proof one text", "default": "No veneers. No shortcuts. Just honest materials." },
    { "type": "text", "id": "proof_two_heading", "label": "Proof two heading", "default": "Handcrafted" },
    { "type": "textarea", "id": "proof_two_text", "label": "Proof two text", "default": "Shaped by skilled hands. Finished with care." },
    { "type": "text", "id": "proof_three_heading", "label": "Proof three heading", "default": "Built to endure" },
    { "type": "textarea", "id": "proof_three_text", "label": "Proof three text", "default": "Furniture that ages beautifully and lasts for generations." },
    { "type": "header", "content": "Team" },
    { "type": "text", "id": "team_eyebrow", "label": "Eyebrow", "default": "Our team" },
    { "type": "text", "id": "team_heading", "label": "Heading", "default": "Meet the People Behind WRYDECO" },
    { "type": "text", "id": "team_intro", "label": "Introduction", "default": "A small team with big respect—for wood, for craft, and for you." }
  ],
  "blocks": [
    {
