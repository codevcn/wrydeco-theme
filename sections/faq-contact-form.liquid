{% comment %}
  Renders a "still have a question?" prompt below the FAQ content with a
  call-to-action button that links to the dedicated Contact page.
{% endcomment %}

<section class="faq-contact" id="FaqContact-{{ section.id }}" aria-labelledby="FaqContactTitle-{{ section.id }}">
  <div class="faq-contact__inner">
    <div class="faq-contact__intro">
      <p class="faq-contact__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 id="FaqContactTitle-{{ section.id }}">{{ section.settings.heading | escape }}</h2>
      <p class="faq-contact__description">{{ section.settings.description | escape }}</p>

      <div class="faq-contact__details">
        <div class="faq-contact__detail">
          <span>{{ section.settings.email_label | escape }}</span>
          <a href="mailto:{{ section.settings.email_address | escape }}">
            {{- section.settings.email_address | escape -}}
          </a>
        </div>
        <div class="faq-contact__detail">
          <span>{{ section.settings.response_label | escape }}</span>
          <p>{{ section.settings.response_text | escape }}</p>
        </div>
      </div>
    </div>

    <div class="faq-contact__panel">
      <div class="faq-contact__cta">
        {% if section.settings.cta_heading != blank %}
          <h3 class="faq-contact__cta-heading">{{ section.settings.cta_heading | escape }}</h3>
        {% endif %}
        {% if section.settings.cta_text != blank %}
          <p class="faq-contact__cta-text">{{ section.settings.cta_text | escape }}</p>
        {% endif %}
        <a
          class="faq-contact__cta-button"
          href="{{ section.settings.button_url | default: '/pages/contact' }}"
        >
          <span>{{ section.settings.button_label | escape }}</span>
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .faq-contact {
    border-block-start: var(--border-width) solid var(--border-default);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .faq-contact__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    align-items: stretch;
    gap: var(--sp-10);
    inline-size: min(calc(100% - (var(--layout-padding-desktop) * 2)), var(--layout-showcase-max-width));
    margin-inline: auto;
    padding-block: var(--sp-8) var(--sp-8);
  }

  .faq-contact__intro {
    align-self: start;
    max-inline-size: 44ch;
    padding-block-start: var(--sp-5);
  }

  .faq-contact__eyebrow {
    margin: var(--sp-0) var(--sp-0) var(--sp-3);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 5);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .faq-contact__intro h2 {
    margin: var(--sp-0);
    color: var(--color-ebony);
    font-family: var(--font-display-light);
    font-size: var(--font-size-display-lg);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
    text-wrap: balance;
  }

  .faq-contact__description {
    max-inline-size: 38ch;
    margin: var(--sp-5) var(--sp-0) var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
  }

  .faq-contact__details {
    display: grid;
    gap: var(--sp-5);
    margin-block-start: var(--sp-8);
    padding-block-start: var(--sp-5);
    border-block-start: var(--border-width) solid var(--border-default);
  }

  .faq-contact__detail {
    display: grid;
    gap: var(--sp-2);
  }

  .faq-contact__detail > span {
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    text-transform: uppercase;
  }

  .faq-contact__detail a,
  .faq-contact__detail p {
    margin: var(--sp-0);
    color: var(--text-primary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .faq-contact__detail a {
    inline-size: fit-content;
    border-block-end: var(--border-width) solid var(--color-clay);
  }

  .faq-contact__panel {
    display: flex;
    padding: var(--sp-8) var(--sp-7);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--bg-tertiary) 54%, transparent);
  }

  .faq-contact__cta {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: var(--sp-4);
    margin-block: auto;
  }

  .faq-contact__cta-heading {
    margin: var(--sp-0);
    color: var(--color-ebony);
    font-family: var(--font-display-light);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-light);
    line-height: var(--line-height-display);
    text-wrap: balance;
  }

  .faq-contact__cta-text {
    max-inline-size: 42ch;
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
  }

  .faq-contact__cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    min-block-size: calc(var(--sp-8) + var(--sp-2));
    min-inline-size: calc(var(--sp-12) * 2);
    margin-block-start: var(--sp-3);
    padding-inline: var(--sp-5);
    border-radius: var(--radius-md);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    text-decoration: none;
    transition: background-color var(--timing-short) var(--ease-standard),
      transform var(--timing-short) var(--ease-standard);
  }

  .faq-contact__cta-button:hover {
    background: var(--color-charcoal);
  }

  .faq-contact__cta-button:active {
    transform: translateY(var(--border-width));
  }

  .faq-contact__cta-button:focus-visible,
  .faq-contact__detail a:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  @media screen and (max-width: 64rem) {
    .faq-contact__inner {
      grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
      gap: var(--sp-7);
      inline-size: min(calc(100% - (var(--layout-padding-tablet) * 2)), var(--layout-showcase-max-width));
      padding-block: var(--sp-8) var(--sp-9);
    }

    .faq-contact__panel {
      padding: var(--sp-6);
    }

    .faq-contact__cta-button {
      inline-size: 100%;
    }
  }

  @media screen and (max-width: 48rem) {
    .faq-contact__inner {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-7);
      inline-size: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--layout-showcase-max-width));
      padding-block: var(--sp-5) var(--sp-4);
    }

    .faq-contact__intro {
      max-inline-size: none;
      padding-block-start: var(--sp-0);
    }

    .faq-contact__intro h2 {
      max-inline-size: 12ch;
      font-size: var(--font-size-display-md);
    }

    .faq-contact__description {
      font-size: var(--font-size-body-sm);
    }

    .faq-contact__details {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-block-start: var(--sp-6);
    }

    .faq-contact__panel {
      padding: var(--sp-5);
    }
  }

  @media screen and (max-width: 30rem) {
    .faq-contact__details {
      grid-template-columns: minmax(0, 1fr);
    }

    .faq-contact__cta-button {
      min-inline-size: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "FAQ contact CTA",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Personal guidance" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Still have a question?" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Tell us what you are considering. Our team will reply with thoughtful guidance for your space, timeline, and piece." },
    { "type": "text", "id": "email_label", "label": "Email detail label", "default": "Write to us" },
    { "type": "text", "id": "email_address", "label": "Contact email", "default": "support@wrydeco.com" },
    { "type": "text", "id": "response_label", "label": "Response label", "default": "Response time" },
    { "type": "text", "id": "response_text", "label": "Response text", "default": "We usually reply within two business days." },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "cta_heading", "label": "CTA heading", "default": "Talk to our team" },
    { "type": "textarea", "id": "cta_text", "label": "CTA text", "default": "Reach out through our contact page and we'll help with product, custom sizing, care, or delivery." },
    { "type": "url", "id": "button_url", "label": "Button link", "info": "Defaults to the Contact page (/pages/contact) when left empty." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Contact us" }
  ],
  "presets": [{ "name": "FAQ contact CTA" }]
}
{% endschema %}
