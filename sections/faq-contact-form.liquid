{% comment %}
  Renders the contact form below the FAQ content.
  The form is server-rendered through Shopify's contact form endpoint.
{% endcomment %}

{% liquid
  assign form_id = 'FaqContactForm-' | append: section.id
  assign success_message = section.settings.success_message
  assign error_message = section.settings.error_message
%}

<section class="faq-contact" id="FaqContact-{{ section.id }}" aria-labelledby="FaqContactTitle-{{ section.id }}">
  <div class="faq-contact__inner">
    <div class="faq-contact__intro">
      <p class="faq-contact__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      <h2 id="FaqContactTitle-{{ section.id }}">{{ section.settings.heading | escape }}</h2>
      <p class="faq-contact__description">{{ section.settings.description | escape }}</p>

      <div class="faq-contact__details">
        <div class="faq-contact__detail">
          <span>{{ section.settings.email_label | escape }}</span>
          <a href="mailto:{{ section.settings.email_address | escape }}">
            {{- section.settings.email_address | escape -}}
          </a>
        </div>
        <div class="faq-contact__detail">
          <span>{{ section.settings.response_label | escape }}</span>
          <p>{{ section.settings.response_text | escape }}</p>
        </div>
      </div>
    </div>

    <div class="faq-contact__panel">
      {% form 'contact', id: form_id, class: 'faq-contact__form' %}
        <input type="hidden" name="contact[tags]" value="faq-contact">

        {% if form.posted_successfully? %}
          <p
            class="faq-contact__visually-hidden"
            role="status"
            data-faq-contact-toast
            data-toast-type="success"
            data-toast-message="{{ success_message | escape }}"
          >
            {{ success_message | escape }}
          </p>
          <noscript>
            <p class="faq-contact__noscript-status">{{ success_message | escape }}</p>
          </noscript>
        {% endif %}

        {% if form.errors %}
          <div
            class="faq-contact__errors"
            role="alert"
            data-faq-contact-toast
            data-toast-type="error"
            data-toast-message="{{ error_message | escape }}"
          >
            <p>{{ error_message | escape }}</p>
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="faq-contact__fields">
          <div class="faq-contact__field">
            <label for="{{ form_id }}-first-name">{{ section.settings.first_name_label | escape }}</label>
            <input
              id="{{ form_id }}-first-name"
              type="text"
              name="contact[first_name]"
              value="{{ form.first_name | default: customer.first_name | escape }}"
              autocomplete="given-name"
              placeholder="{{ section.settings.first_name_placeholder | escape }}"
            >
          </div>

          <div class="faq-contact__field">
            <label for="{{ form_id }}-last-name">{{ section.settings.last_name_label | escape }}</label>
            <input
              id="{{ form_id }}-last-name"
              type="text"
              name="contact[last_name]"
              value="{{ form.last_name | default: customer.last_name | escape }}"
              autocomplete="family-name"
              placeholder="{{ section.settings.last_name_placeholder | escape }}"
            >
          </div>

          <div class="faq-contact__field">
            <label for="{{ form_id }}-email">{{ section.settings.email_field_label | escape }}</label>
            <input
              id="{{ form_id }}-email"
              type="email"
              name="contact[email]"
              value="{{ form.email | default: customer.email | escape }}"
              autocomplete="email"
              autocorrect="off"
              autocapitalize="off"
              placeholder="{{ section.settings.email_placeholder | escape }}"
              required
              {% if form.errors contains 'email' %}
                aria-invalid="true"
                aria-describedby="{{ form_id }}-email-error"
              {% endif %}
            >
            {% if form.errors contains 'email' %}
              <small id="{{ form_id }}-email-error" class="faq-contact__field-error">
                {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
              </small>
            {% endif %}
          </div>

          <div class="faq-contact__field">
            <label for="{{ form_id }}-phone">{{ section.settings.phone_label | escape }}</label>
            <input
              id="{{ form_id }}-phone"
              type="tel"
              name="contact[phone]"
              value="{{ form.phone | default: customer.phone | escape }}"
              autocomplete="tel"
              placeholder="{{ section.settings.phone_placeholder | escape }}"
            >
          </div>

          <div class="faq-contact__field faq-contact__field--full">
            <label for="{{ form_id }}-subject">{{ section.settings.subject_label | escape }}</label>
            <input
              id="{{ form_id }}-subject"
              type="text"
              name="contact[subject]"
              value="{{ form.subject | escape }}"
              placeholder="{{ section.settings.subject_placeholder | escape }}"
            >
          </div>

          <div class="faq-contact__field faq-contact__field--full">
            <label for="{{ form_id }}-message">{{ section.settings.message_label | escape }}</label>
            <textarea
              id="{{ form_id }}-message"
              name="contact[body]"
              placeholder="{{ section.settings.message_placeholder | escape }}"
              required
            >{{ form.body }}</textarea>
          </div>
        </div>

        <div class="faq-contact__actions">
          <p>{{ section.settings.privacy_note | escape }}</p>
          <button type="submit">
            <span>{{ section.settings.button_label | escape }}</span>
            <span aria-hidden="true">&rarr;</span>
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% stylesheet %}
  .faq-contact {
    border-block-start: var(--border-width) solid var(--border-default);
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .faq-contact__inner {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    align-items: start;
    gap: var(--sp-10);
    inline-size: min(calc(100% - (var(--layout-padding-desktop) * 2)), var(--layout-showcase-max-width));
    margin-inline: auto;
    padding-block: var(--sp-8) var(--sp-8);
  }

  .faq-contact__intro {
    align-self: start;
    max-inline-size: 44ch;
    padding-block-start: var(--sp-5);
  }

  .faq-contact__eyebrow {
    margin: var(--sp-0) var(--sp-0) var(--sp-3);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 5);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .faq-contact__intro h2 {
    margin: var(--sp-0);
    color: var(--color-ebony);
    font-family: var(--font-display-light);
    font-size: var(--font-size-display-lg);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
    text-wrap: balance;
  }

  .faq-contact__description {
    max-inline-size: 38ch;
    margin: var(--sp-5) var(--sp-0) var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
  }

  .faq-contact__details {
    display: grid;
    gap: var(--sp-5);
    margin-block-start: var(--sp-8);
    padding-block-start: var(--sp-5);
    border-block-start: var(--border-width) solid var(--border-default);
  }

  .faq-contact__detail {
    display: grid;
    gap: var(--sp-2);
  }

  .faq-contact__detail > span,
  .faq-contact__field label {
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    text-transform: uppercase;
  }

  .faq-contact__detail a,
  .faq-contact__detail p {
    margin: var(--sp-0);
    color: var(--text-primary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .faq-contact__detail a {
    inline-size: fit-content;
    border-block-end: var(--border-width) solid var(--color-clay);
  }

  .faq-contact__panel {
    padding: var(--sp-7);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--bg-tertiary) 54%, transparent);
  }

  .faq-contact__fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--sp-5) var(--sp-4);
  }

  .faq-contact__field {
    display: grid;
    gap: var(--sp-2);
    min-inline-size: 0;
  }

  .faq-contact__field--full {
    grid-column: 1 / -1;
  }

  .faq-contact__field input,
  .faq-contact__field textarea {
    inline-size: 100%;
    min-block-size: calc(var(--sp-7) + var(--sp-2));
    padding: var(--sp-3) var(--sp-4);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-normal);
    transition: border-color var(--timing-short) var(--ease-standard),
      box-shadow var(--timing-short) var(--ease-standard);
  }

  .faq-contact__field textarea {
    min-block-size: calc(var(--sp-12) + var(--sp-8));
    resize: vertical;
  }

  .faq-contact__field input::placeholder,
  .faq-contact__field textarea::placeholder {
    color: gray;
  }

  .faq-contact__field input:focus,
  .faq-contact__field textarea:focus {
    border-color: var(--color-earth-brown);
    outline: none;
    box-shadow: var(--shadow-focus);
  }

  .faq-contact__field input[aria-invalid='true'] {
    border-color: var(--color-error);
  }

  .faq-contact__field-error {
    color: var(--color-error);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-normal);
  }

  .faq-contact__errors,
  .faq-contact__noscript-status {
    margin-block-end: var(--sp-5);
    padding: var(--sp-4);
    border: var(--border-width) solid var(--color-error);
    border-radius: var(--radius-md);
    color: var(--text-primary);
    font-size: var(--font-size-body-sm);
  }

  .faq-contact__errors p,
  .faq-contact__noscript-status {
    margin: var(--sp-0);
  }

  .faq-contact__errors ul {
    margin: var(--sp-2) var(--sp-0) var(--sp-0);
    padding-inline-start: var(--sp-5);
  }

  .faq-contact__actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-5);
    margin-block-start: var(--sp-6);
  }

  .faq-contact__actions p {
    max-inline-size: 42ch;
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .faq-contact__actions button {
    display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-6);
    min-block-size: calc(var(--sp-7) + var(--sp-2));
    min-inline-size: calc(var(--sp-12) * 2);
    padding-inline: var(--sp-5);
    border: 0;
    border-radius: var(--radius-md);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    transition: background-color var(--timing-short) var(--ease-standard),
      transform var(--timing-short) var(--ease-standard);
  }

  .faq-contact__actions button:hover {
    background: var(--color-charcoal);
  }

  .faq-contact__actions button:active {
    transform: translateY(var(--border-width));
  }

  .faq-contact__actions button:focus-visible,
  .faq-contact__detail a:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  .faq-contact__visually-hidden {
    position: absolute;
    inline-size: var(--border-width);
    block-size: var(--border-width);
    padding: var(--sp-0);
    margin: calc(var(--border-width) * -1);
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media screen and (max-width: 64rem) {
    .faq-contact__inner {
      grid-template-columns: minmax(0, 0.72fr) minmax(0, 1.28fr);
      gap: var(--sp-7);
      inline-size: min(calc(100% - (var(--layout-padding-tablet) * 2)), var(--layout-showcase-max-width));
      padding-block: var(--sp-8) var(--sp-9);
    }

    .faq-contact__panel {
      padding: var(--sp-5);
    }

    .faq-contact__fields {
      grid-template-columns: minmax(0, 1fr);
    }

    .faq-contact__field--full {
      grid-column: auto;
    }

    .faq-contact__actions {
      align-items: stretch;
      flex-direction: column;
    }

    .faq-contact__actions button {
      inline-size: 100%;
    }
  }

  @media screen and (max-width: 48rem) {
    .faq-contact__inner {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-7);
      inline-size: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--layout-showcase-max-width));
      padding-block: var(--sp-5) var(--sp-4);
    }

    .faq-contact__intro {
      max-inline-size: none;
      padding-block-start: var(--sp-0);
    }

    .faq-contact__intro h2 {
      max-inline-size: 12ch;
      font-size: var(--font-size-display-md);
    }

    .faq-contact__description {
      font-size: var(--font-size-body-sm);
    }

    .faq-contact__details {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-block-start: var(--sp-6);
    }

    .faq-contact__panel {
      padding: var(--sp-4);
    }
  }

  @media screen and (max-width: 30rem) {
    .faq-contact__details {
      grid-template-columns: minmax(0, 1fr);
    }

    .faq-contact__actions button {
      min-inline-size: 0;
    }
  }
{% endstylesheet %}

{% javascript %}
  const showFaqContactToasts = () => {
    document.querySelectorAll('[data-faq-contact-toast]:not([data-toast-shown])').forEach((feedback) => {
      if (!window.showToast) return;

      feedback.dataset.toastShown = 'true';
      window.showToast({
        message: feedback.dataset.toastMessage,
        type: feedback.dataset.toastType,
        position: 'bottom-right',
        duration: 4000,
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', showFaqContactToasts, { once: true });
  } else {
    showFaqContactToasts();
  }

  document.addEventListener('shopify:section:load', showFaqContactToasts);
{% endjavascript %}

{% schema %}
{
  "name": "FAQ contact form",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Personal guidance" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Still have a question?" },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Tell us what you are considering. Our team will reply with thoughtful guidance for your space, timeline, and piece." },
    { "type": "text", "id": "email_label", "label": "Email detail label", "default": "Write to us" },
    { "type": "text", "id": "email_address", "label": "Contact email", "default": "support@wrydeco.com" },
    { "type": "text", "id": "response_label", "label": "Response label", "default": "Response time" },
    { "type": "text", "id": "response_text", "label": "Response text", "default": "We usually reply within two business days." },
    { "type": "header", "content": "Form labels" },
    { "type": "text", "id": "first_name_label", "label": "First name label", "default": "First name" },
    { "type": "text", "id": "first_name_placeholder", "label": "First name placeholder", "default": "Your first name" },
    { "type": "text", "id": "last_name_label", "label": "Last name label", "default": "Last name" },
    { "type": "text", "id": "last_name_placeholder", "label": "Last name placeholder", "default": "Your last name" },
    { "type": "text", "id": "email_field_label", "label": "Email label", "default": "Email address" },
    { "type": "text", "id": "email_placeholder", "label": "Email placeholder", "default": "you@example.com" },
    { "type": "text", "id": "phone_label", "label": "Phone label", "default": "Phone number" },
    { "type": "text", "id": "phone_placeholder", "label": "Phone placeholder", "default": "Optional" },
    { "type": "text", "id": "subject_label", "label": "Subject label", "default": "What can we help with?" },
    { "type": "text", "id": "subject_placeholder", "label": "Subject placeholder", "default": "Product, custom sizing, care, or delivery" },
    { "type": "text", "id": "message_label", "label": "Message label", "default": "Your message" },
    { "type": "textarea", "id": "message_placeholder", "label": "Message placeholder", "default": "Share the piece, room, dimensions, or timeline you have in mind." },
    { "type": "textarea", "id": "privacy_note", "label": "Privacy note", "default": "Your details are used only to respond to this inquiry." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Send inquiry" },
    { "type": "text", "id": "success_message", "label": "Success message", "default": "Thank you. Your inquiry has been sent." },
    { "type": "text", "id": "error_message", "label": "Error message", "default": "Please review the highlighted fields and try again." }
  ],
  "presets": [{ "name": "FAQ contact form" }]
}
{% endschema %}
