<div class="projects">
  <div class="projects__inner page-width">
    <div class="projects__head">
      <div class="projects__head-text">
        {%- if section.settings.eyebrow != blank -%}
          <p class="projects__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="projects__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subtitle != blank -%}
          <p class="projects__subtitle">{{ section.settings.subtitle }}</p>
        {%- endif -%}
      </div>
      {%- if section.settings.view_all_label != blank -%}
        <a class="projects__view-all" href="{{ section.settings.view_all_link | default: routes.root_url }}">
          <span>{{ section.settings.view_all_label }}</span>
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M13 6l6 6-6 6"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    {%- assign cards_menu = section.settings.cards_menu -%}
    <div class="projects__grid">
      {%- for block in section.blocks -%}
        {%- liquid
          # Card link. Default to the block's own link (or home).
          assign card_url = block.settings.link | default: routes.root_url

          # Extensible menu mapping: link the card to the blog of the menu item whose
          # label matches this card's title. To add cards later, add a project block
          # and a matching menu item (same label) — no code change needed.
          if cards_menu != blank and block.settings.title != blank
            for menu_link in cards_menu.links
              if menu_link.title == block.settings.title
                assign card_url = menu_link.url
                break
              endif
            endfor
          endif

          # Cycle the bundled fallback images for cards without their own image.
          assign image_cycle = forloop.index0 | modulo: 4
          case image_cycle
            when 0
              assign fallback_image = 'curated-collections-img-1.png'
            when 1
              assign fallback_image = 'curated-collections-img-3.png'
            when 2
              assign fallback_image = 'curated-collections-img-4.png'
            else
              assign fallback_image = 'curated-collections-img-2.png'
          endcase
        -%}
        <a class="projects__card" href="{{ card_url }}" {{ block.shopify_attributes }}>
          <div class="projects__media">
            {%- assign project_image_alt = block.settings.image.alt | default: block.settings.title | default: 'Custom wood furniture installed in a refined home' -%}
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 900 | image_tag: class: 'projects__img', loading: 'lazy', sizes: '(min-width: 1280px) 22vw, (min-width: 768px) 44vw, 92vw', widths: '360, 540, 720, 900', alt: project_image_alt }}
            {%- else -%}
              <img
                src="{{ fallback_image | file_url }}"
                alt="{{ project_image_alt | escape }}"
                class="projects__img"
                loading="lazy"
                width="900"
                height="720"
              >
            {%- endif -%}
          </div>
          <div class="projects__card-body">
            <h3 class="projects__card-title">{{ block.settings.title }}</h3>
            {%- if block.settings.location != blank -%}
              <p class="projects__card-location">{{ block.settings.location }}</p>
            {%- endif -%}
            {%- if block.settings.detail != blank -%}
              <p class="projects__card-detail">{{ block.settings.detail }}</p>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% stylesheet %}
  .projects {
    display: block;
    background:
      radial-gradient(circle at 48% 18%, rgba(255, 255, 255, 0.82), transparent 42%),
      linear-gradient(180deg, #fbf7f1 0%, #f5efe8 100%);
    color: var(--color-text, #1a1815);
  }
  .projects__inner {
    max-width: var(--page-max-width, 1440px);
    margin: 0 auto;
    padding: var(--section-padding-y, 80px) var(--container-padding-x, 48px);
    box-sizing: border-box;
  }
  .projects__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: clamp(32px, 6vw, 96px);
    margin-bottom: clamp(32px, 3.5vw, 48px);
  }
  .projects__head-text {
    max-width: 620px;
  }
  .projects__eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-body);
    font-size: var(--eyebrow-size, 12px);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--eyebrow-tracking, 0.3em);
    text-transform: uppercase;
    color: var(--color-brown);
  }
  .projects__heading {
    font-family: var(--font-heading);
    font-size: var(--section-heading-size, 48px);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--section-heading-tracking, -0.02em);
    line-height: var(--section-heading-line, 1.02);
    color: var(--color-text, #201813);
    margin: 0;
    text-wrap: balance;
  }
  .projects__subtitle {
    font-family: var(--font-body);
    font-size: var(--section-subtitle-size, 16px);
    line-height: 1.6;
    color: var(--color-muted, rgba(31, 26, 22, 0.68));
    max-width: 560px;
    margin: 16px 0 0;
  }
  .projects__view-all {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    flex-shrink: 0;
    font-family: var(--font-body);
    font-size: 15px;
    font-weight: var(--font-weight-medium, 500);
    line-height: 1;
    color: var(--color-brown, #4a2c18);
    text-decoration: none;
    transition:
      gap var(--timing-short, 0.2s) var(--ease-standard, ease),
      color var(--timing-short, 0.2s) var(--ease-standard, ease);
  }
  .projects__view-all:hover {
    gap: 16px;
    color: var(--color-earth-brown, #4a2c18);
  }

  .projects__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(22px, 2vw, 34px);
    min-height: 0;
  }
  .projects__card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    min-width: 0;
    min-height: 0;
    border: 1px solid rgba(74, 44, 24, 0.09);
    border-radius: var(--card-radius, 6px);
    overflow: hidden;
    background: rgba(255, 252, 247, 0.18);
    box-shadow: 0 1px 0 rgba(74, 44, 24, 0.03);
  }
  .projects__media {
    position: relative;
    width: 100%;
    aspect-ratio: 0.82 / 1;
    overflow: hidden;
    background-color: var(--surface-tertiary, #e8e4df);
  }
  .projects__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-standard, ease);
  }
  .projects__card:hover .projects__img {
    transform: scale(1.04);
  }
  .projects__card-body {
    display: flex;
    flex: 1;
    min-height: 0;
    flex-direction: column;
    padding: var(--card-padding, 24px) 20px;
  }
  .projects__card-title {
    font-family: var(--font-heading);
    font-size: clamp(21px, 1.6vw, 26px);
    font-weight: var(--font-weight-regular, 400);
    line-height: 1.1;
    color: var(--color-text, #211812);
    margin: 0;
    letter-spacing: 0;
    text-wrap: balance;
  }
  .projects__card-location {
    font-family: var(--font-body);
    font-size: 13px;
    color: rgba(74, 44, 24, 0.68);
    margin: 8px 0 0;
  }

  .projects__card-detail {
    position: relative;
    margin: 24px 0 0;
    padding-top: 18px;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.55;
    color: rgba(31, 26, 22, 0.76);
  }

  .projects__card-detail::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 36px;
    height: 1px;
    background: rgba(168, 132, 92, 0.5);
  }

  .projects :is(a, button):focus-visible {
    outline: 3px solid rgba(122, 137, 104, 0.38);
    outline-offset: 4px;
  }

  /* --- Responsive --- */
  @media screen and (max-width: 1280px) {
    .projects__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 28px;
    }
  }
  @media screen and (max-width: 768px) {
    .projects__inner {
      padding: 56px 18px 64px;
    }
    .projects__head {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 30px;
    }
    .projects__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 24px 14px;
    }
    .projects__card-body {
      padding: 16px 14px 18px;
    }
    .projects__card-title {
      font-size: 17px;
    }
    .projects__card-location {
      font-size: 12px;
      margin-top: 6px;
    }
    .projects__card-detail {
      margin-top: 14px;
      padding-top: 12px;
      font-size: 12px;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Project Showcase",
  "tag": "section",
  "class": "section section-projects",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our clients" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Real Homes, Real Stories" },
    { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "Explore how our pieces transform spaces around the world." },
    { "type": "text", "id": "view_all_label", "label": "View all label", "default": "View All Projects" },
    { "type": "url", "id": "view_all_link", "label": "View all link" },
    { "type": "header", "content": "Card links" },
    { "type": "link_list", "id": "cards_menu", "label": "Cards → blog menu", "info": "Pick the \"blog-posts\" menu. Each card links to the blog of the menu item whose label matches the card title. Add a card block + a menu item with the same label to extend. Falls back to the card's own Link when there's no match." }
  ],
  "blocks": [
    {
      "type": "project",
      "name": "Project",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Project name" },
        { "type": "text", "id": "location", "label": "Location", "default": "City, Country" },
        { "type": "text", "id": "detail", "label": "Custom detail", "default": "Custom walnut bookshelf · hand-finished details" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Project Showcase",
      "blocks": [
        { "type": "project", "settings": { "title": "Modern Cabin Retreat", "location": "British Columbia, Canada", "detail": "Custom oak shelving wall · hand-finished details" } },
        { "type": "project", "settings": { "title": "Brooklyn Brownstone", "location": "New York, USA", "detail": "Walnut tree bookcase · measured for a parlor wall" } },
        { "type": "project", "settings": { "title": "Scandinavian Apartment", "location": "Copenhagen, Denmark", "detail": "Light oak floating shelves · matte finish" } },
        { "type": "project", "settings": { "title": "Coastal Villa", "location": "Malibu, California", "detail": "Live-edge console · sealed for bright interiors" } },
        { "type": "project", "settings": { "title": "Mountain Home", "location": "Aspen, Colorado", "detail": "Smoked walnut storage · white-glove delivery" } }
      ]
    }
  ]
}
{% endschema %}
