{% comment %}
  Trust bar section
{% endcomment %}

<section class="trust-bar" style="background-color: {{ section.settings.bg_color }}; color: {{ section.settings.text_color }};">
  <div class="trust-bar__inner">
    {% for block in section.blocks %}
      <div class="trust-bar__item">
        <span class="trust-bar__icon">
          {% case block.settings.icon %}
            {% when 'wood' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10" stroke-dasharray="4 2"/>
                <circle cx="12" cy="12" r="7" />
                <circle cx="12" cy="12" r="4" stroke-dasharray="3 1"/>
                <circle cx="12" cy="12" r="1" />
              </svg>
            {% when 'hand' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 11V6a2 2 0 0 0-4 0M14 10V4a2 2 0 0 0-4 0v2M10 10.5V6a2 2 0 0 0-4 0v8" />
                <path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15" />
              </svg>
            {% when 'chair' %}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 10V6c0-1.1.9-2 2-2h8c1.1 0 2 .9 2 2v4" />
                <path d="M4 10h16v5a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-5z" />
                <path d="M6 17v3" />
                <path d="M18 17v3" />
                <path d="M4 12h16" />
              </svg>
          {% endcase %}
        </span>
        <span class="trust-bar__text">{{ block.settings.text }}</span>
      </div>
      {% unless forloop.last %}
        <div class="trust-bar__divider" style="background-color: {{ section.settings.text_color }};"></div>
      {% endunless %}
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .trust-bar {
    width: 100%;
    padding: var(--sp-4) 0;
    margin-top: -5px; /* Offset any negative spaces if needed */
  }
  .trust-bar__inner {
    max-width: var(--layout-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--layout-padding-desktop);
  }
  .trust-bar__item {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: 0 var(--sp-8);
  }
  .trust-bar__icon svg {
    width: 24px;
    height: 24px;
  }
  .trust-bar__text {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: var(--font-weight-medium);
    letter-spacing: 0.15em;
    text-transform: uppercase;
  }
  .trust-bar__divider {
    width: 1px;
    height: 18px;
    opacity: 0.2;
  }

  @media screen and (max-width: 768px) {
    .trust-bar__inner {
      flex-direction: column;
      gap: var(--sp-4);
      padding: var(--sp-5) var(--layout-padding-mobile);
    }
    .trust-bar__item {
      padding: 0;
    }
    .trust-bar__divider {
      display: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust Bar",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#4b443b"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#d6cec2"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "wood", "label": "Wood Rings" },
            { "value": "hand", "label": "Hand" },
            { "value": "chair", "label": "Chair" }
          ],
          "default": "wood"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Feature Text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Bar",
      "blocks": [
        { "type": "feature", "settings": { "icon": "wood", "text": "Solid Wood Only" } },
        { "type": "feature", "settings": { "icon": "hand", "text": "Master Craftsmanship" } },
        { "type": "feature", "settings": { "icon": "chair", "text": "Bespoke & Custom" } }
      ]
    }
  ]
}
{% endschema %}
