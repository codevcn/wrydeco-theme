{%- liquid
  assign process_url = section.settings.process_url | default: pages['about-us'].url | default: routes.root_url
  assign consultation_url = section.settings.consultation_url | default: pages['customization'].url | default: routes.root_url
  assign contact_url = section.settings.contact_url | default: pages['contact'].url | default: routes.root_url
-%}

<section class="about-heritage" aria-labelledby="about-heritage-heading-{{ section.id }}">
  <div class="about-heritage__inner">
    <div class="about-heritage__sourcing">
      <header class="about-heritage__header">
        <p class="about-heritage__eyebrow">{{ section.settings.sourcing_eyebrow | escape }}</p>
        <h2 id="about-heritage-heading-{{ section.id }}">{{ section.settings.sourcing_heading | escape }}</h2>
        <p>{{ section.settings.sourcing_intro | escape }}</p>
      </header>

      <div class="about-heritage__values">
        {%- for block in section.blocks -%}
          {%- if block.type == 'sourcing_value' -%}
            <article class="about-heritage-value" {{ block.shopify_attributes }}>
              <span class="about-heritage-value__icon" aria-hidden="true">
                {% render 'about-craft-icon', icon: block.settings.icon %}
              </span>
              <div>
                <h3>{{ block.settings.heading | escape }}</h3>
                <p>{{ block.settings.text | escape }}</p>
              </div>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="about-heritage__story">
      <div class="about-heritage__media">
        <img
          src="{{ 'about-us-heritage.png' | file_url }}"
          width="1792"
          height="1024"
          alt="{{ section.settings.heritage_image_alt | escape }}"
          loading="lazy"
        >
      </div>

      <div class="about-heritage__copy">
        <p class="about-heritage__eyebrow">{{ section.settings.heritage_eyebrow | escape }}</p>
        <h2>
          <span>{{ section.settings.heritage_heading_first_line | escape }}</span>
          <span>{{ section.settings.heritage_heading_second_line | escape }}</span>
        </h2>
        <div class="about-heritage__text rte">{{ section.settings.heritage_text }}</div>
        <a class="about-heritage__text-link" href="{{ process_url }}">
          {{ section.settings.process_link_label | escape }}
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>

  <div class="about-heritage__cta">
    <div class="about-heritage__cta-media" aria-hidden="true">
      <img src="{{ 'faq--faq-img.png' | file_url }}" width="1792" height="1024" alt="" loading="lazy">
    </div>
    <div class="about-heritage__cta-content">
      <h2>{{ section.settings.cta_heading | escape }}</h2>
      <p>{{ section.settings.cta_text | escape }}</p>
      <div class="about-heritage__actions">
        <a class="about-heritage__button about-heritage__button--primary" href="{{ consultation_url }}#custom-inquiry__story-telling">
          {{ section.settings.consultation_button_label | escape }}
          <span aria-hidden="true">&rarr;</span>
        </a>
        <a class="about-heritage__button about-heritage__button--secondary" href="{{ contact_url }}">
          {{ section.settings.contact_button_label | escape }}
        </a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .about-heritage {
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .about-heritage__inner {
    inline-size: min(calc(100% - (var(--sp-8) * 2)), var(--layout-showcase-max-width));
    margin-inline: auto;
    padding-block: var(--sp-7) var(--sp-5);
  }

  .about-heritage__header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .about-heritage__eyebrow {
    margin: var(--sp-0) var(--sp-0) var(--sp-2);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 4);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .about-heritage__header h2,
  .about-heritage__copy h2,
  .about-heritage__cta h2 {
    margin: var(--sp-0);
    color: var(--color-ebony);
    font-family: var(--font-display-light);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
  }

  .about-heritage__header h2 {
    font-size: var(--font-size-display-lg);
  }

  .about-heritage__header > p:last-child {
    max-inline-size: 58ch;
    margin: var(--sp-2) var(--sp-0) var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-relaxed);
  }

  .about-heritage__values {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-block-start: var(--sp-6);
  }

  .about-heritage-value {
    display: grid;
    grid-template-columns: var(--sp-8) minmax(0, 1fr);
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-6);
  }

  .about-heritage-value + .about-heritage-value {
    border-inline-start: var(--border-width) solid var(--border-light);
  }

  .about-heritage-value__icon {
    display: inline-flex;
    inline-size: var(--sp-8);
    block-size: var(--sp-8);
    padding: var(--sp-3);
    color: var(--color-earth-brown);
  }

  .about-heritage-value__icon svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .about-heritage-value h3 {
    margin: var(--sp-0) var(--sp-0) var(--sp-1);
    color: var(--color-charcoal);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    line-height: var(--line-height-normal);
  }

  .about-heritage-value p {
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-relaxed);
  }

  .about-heritage__story {
    display: grid;
    grid-template-columns: minmax(0, 48%) minmax(0, 52%);
    align-items: center;
    gap: var(--sp-8);
    margin-block-start: var(--sp-6);
  }

  .about-heritage__media {
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border-radius: var(--radius-lg);
  }

  .about-heritage__media img,
  .about-heritage__cta-media img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .about-heritage__copy {
    padding-inline-end: var(--sp-7);
  }

  .about-heritage__copy h2 {
    font-size: var(--font-size-display-xl);
  }

  .about-heritage__copy h2 span {
    display: block;
  }

  .about-heritage__text {
    display: grid;
    gap: var(--sp-3);
    max-inline-size: 66ch;
    margin-block-start: var(--sp-4);
    color: var(--color-charcoal);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .about-heritage__text p {
    margin: var(--sp-0);
  }

  .about-heritage__text-link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-5);
    min-block-size: var(--sp-7);
    margin-block-start: var(--sp-3);
    border-block-end: var(--border-width) solid var(--color-bark);
    color: var(--color-charcoal);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-decoration: none;
    text-transform: uppercase;
  }

  .about-heritage__cta {
    position: relative;
    display: grid;
    place-items: center;
    overflow: hidden;
    min-block-size: calc(var(--sp-8) * 3);
    margin-block-start: var(--sp-5);
    border-block: var(--border-width) solid var(--border-light);
  }

  .about-heritage__cta-media {
    position: absolute;
    inset: var(--sp-0);
  }

  .about-heritage__cta-media::after {
    position: absolute;
    inset: var(--sp-0);
    background: linear-gradient(90deg, color-mix(in srgb, var(--bg-primary) 35%, transparent) 0%, color-mix(in srgb, var(--bg-primary) 90%, transparent) 42%, color-mix(in srgb, var(--bg-primary) 96%, transparent) 100%);
    content: '';
  }

  .about-heritage__cta-media img {
    object-position: left 68%;
  }

  .about-heritage__cta-content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--sp-5);
    text-align: center;
  }

  .about-heritage__cta h2 {
    font-size: var(--font-size-display-lg);
  }

  .about-heritage__cta-content > p {
    margin: var(--sp-1) var(--sp-0) var(--sp-4);
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
  }

  .about-heritage__actions {
    display: grid;
    grid-template-columns: repeat(2, minmax(calc(var(--sp-8) * 3), 1fr));
    gap: var(--sp-3);
  }

  .about-heritage__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-5);
    min-block-size: var(--sp-8);
    padding: var(--sp-3) var(--sp-6);
    border: var(--border-width) solid var(--color-earth-brown);
    border-radius: var(--radius-sm);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color var(--timing-short) var(--ease-standard), color var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
  }

  .about-heritage__button--primary {
    background: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .about-heritage__button--secondary {
    background: color-mix(in srgb, var(--bg-primary) 72%, transparent);
    color: var(--color-earth-brown);
  }

  .about-heritage__button:hover {
    background: var(--color-charcoal);
    color: var(--text-inverse);
  }

  .about-heritage__button:active {
    transform: translateY(var(--border-width));
  }

  .about-heritage__button:focus-visible,
  .about-heritage__text-link:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  @media screen and (max-width: 75rem) {
    .about-heritage__inner {
      inline-size: min(calc(100% - (var(--layout-padding-desktop) * 2)), var(--layout-showcase-max-width));
    }

    .about-heritage-value {
      padding-inline: var(--sp-4);
    }
  }

  @media screen and (max-width: 64rem) {
    .about-heritage__values {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .about-heritage-value:nth-child(odd) {
      border-inline-start: var(--sp-0);
    }

    .about-heritage-value:nth-child(n + 3) {
      border-block-start: var(--border-width) solid var(--border-light);
    }

    .about-heritage__story {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-6);
    }

    .about-heritage__copy {
      padding-inline-end: var(--sp-0);
    }
  }

  @media screen and (max-width: 48rem) {
    .about-heritage__inner {
      inline-size: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--layout-showcase-max-width));
      padding-block: var(--sp-7) var(--sp-4);
    }

    .about-heritage__header h2,
    .about-heritage__copy h2,
    .about-heritage__cta h2 {
      font-size: var(--font-size-display-md);
    }

    .about-heritage__values {
      grid-template-columns: minmax(0, 1fr);
      margin-block-start: var(--sp-5);
    }

    .about-heritage-value + .about-heritage-value {
      border-block-start: var(--border-width) solid var(--border-light);
      border-inline-start: var(--sp-0);
    }

    .about-heritage__story {
      margin-block-start: var(--sp-5);
    }

    .about-heritage__media {
      aspect-ratio: 4 / 3;
    }

    .about-heritage__cta {
      min-block-size: calc(var(--sp-8) * 5);
    }

    .about-heritage__cta-media::after {
      background: color-mix(in srgb, var(--bg-primary) 82%, transparent);
    }

    .about-heritage__actions {
      grid-template-columns: minmax(0, 1fr);
      inline-size: 100%;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About heritage",
  "tag": "section",
  "class": "section-about-heritage",
  "settings": [
    { "type": "header", "content": "Sustainable sourcing" },
    { "type": "text", "id": "sourcing_eyebrow", "label": "Eyebrow", "default": "Sustainable sourcing" },
    { "type": "text", "id": "sourcing_heading", "label": "Heading", "default": "Thoughtful by Nature" },
    { "type": "textarea", "id": "sourcing_intro", "label": "Introduction", "default": "We source with care and act with responsibility—because great design begins with respect for the earth." },
    { "type": "header", "content": "Vietnam craftsmanship" },
    { "type": "text", "id": "heritage_eyebrow", "label": "Eyebrow", "default": "Vietnam craftsmanship" },
    { "type": "text", "id": "heritage_heading_first_line", "label": "Heading first line", "default": "Shaped by Heritage." },
    { "type": "text", "id": "heritage_heading_second_line", "label": "Heading second line", "default": "Handed Down with Pride." },
    { "type": "richtext", "id": "heritage_text", "label": "Text", "default": "<p>Our furniture is handcrafted in Vietnam by a network of master artisans and family-run workshops. With generations of woodworking knowledge, they shape each piece using time-honored techniques and deep respect for the material.</p><p>Every curve is carved, every edge is refined, and every finish is applied by hand. This is craftsmanship that carries culture, patience, and pride.</p>" },
    { "type": "text", "id": "heritage_image_alt", "label": "Image alt text", "default": "Vietnamese artisan hand-finishing a sculptural solid wood table" },
    { "type": "text", "id": "process_link_label", "label": "Process link label", "default": "Discover our process" },
    { "type": "url", "id": "process_url", "label": "Process page" },
    { "type": "header", "content": "Call to action" },
    { "type": "text", "id": "cta_heading", "label": "Heading", "default": "Let’s Create Something Timeless" },
    { "type": "text", "id": "cta_text", "label": "Text", "default": "Have a question or a project in mind? We’d love to hear from you." },
    { "type": "text", "id": "consultation_button_label", "label": "Consultation button", "default": "Book a private consultation" },
    { "type": "url", "id": "consultation_url", "label": "Consultation page" },
    { "type": "text", "id": "contact_button_label", "label": "Contact button", "default": "Get in touch" },
    { "type": "url", "id": "contact_url", "label": "Contact page" }
  ],
  "blocks": [
    {
      "type": "sourcing_value",
      "name": "Sourcing value",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "leaf", "label": "Leaf" }, { "value": "responsible", "label": "Natural wood" }, { "value": "handmade", "label": "Ethical production" }, { "value": "shield", "label": "Made to endure" }], "default": "leaf" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Solid, Natural Wood" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "No veneers. Hardwoods only, chosen for beauty and strength." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{ "name": "About heritage" }]
}
{% endschema %}
