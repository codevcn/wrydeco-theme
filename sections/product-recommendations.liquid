{% if recommendations.performed and recommendations.products_count > 0 %}
  <div class="product-recommendations page-width">
    <div class="product-recommendations__header">
      {% if section.settings.eyebrow != blank %}
        <p class="product-recommendations__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="product-recommendations__title">{{ section.settings.title | escape }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="product-recommendations__subtitle">{{ section.settings.subtitle | escape }}</p>
      {% endif %}
    </div>

    <div class="product-recommendations__grid">
      {% for product in recommendations.products limit: 6 %}
        {% liquid
          assign material = product.metafields.custom.material
          if material == blank
            assign material = section.settings.material_label
          endif
        %}
        <article class="pairs-card">
          <a class="pairs-card__media" href="{{ product.url }}">
            {%- if product.featured_media != blank -%}
              {% assign recommendation_image_alt = product.featured_media.alt | default: product.title %}
              {{
                product.featured_media.preview_image
                | image_url: width: 640
                | image_tag:
                  class: 'pairs-card__image',
                  loading: 'lazy',
                  widths: '240, 360, 480, 640',
                  sizes: '(min-width: 1024px) 32vw, (min-width: 720px) 33vw, 90vw',
                  alt: recommendation_image_alt
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'pairs-card__image placeholder-svg' }}
            {%- endif -%}
          </a>

          <div class="pairs-card__info">
            <h3 class="pairs-card__title">
              <a class="pairs-card__title-link" href="{{ product.url }}">
                {{- product.title | split: ',' | first | split: ' - ' | first | strip | escape -}}
              </a>
            </h3>
            {% if material != blank %}
              <p class="pairs-card__material">{{ material | escape }}</p>
            {% endif %}
            <a class="pairs-card__link" href="{{ product.url }}">
              <span>{{ section.settings.cta_label | default: 'View piece' }}</span>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="9 18 15 12 9 6"></polyline>
              </svg>
            </a>
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
{% else %}
  <div
    class="product-recommendations"
    id="recommendations-container-{{ section.id }}"
    data-product-id="{{ product.id }}"
  ></div>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const container = document.getElementById('recommendations-container-{{ section.id }}');
      const productId = container.dataset.productId;
      const productName = {{ product.title | split: ',' | first | strip | json }};
      const limit = {{ section.settings.products_to_show | default: 6 }};

      if (productId) {
        fetch(`/recommendations/products?section_id={{ section.id }}&product_id=${productId}&limit=${limit}`)
          .then(r => r.text())
          .then(html => {
            const inner = new DOMParser()
              .parseFromString(html, 'text/html')
              .querySelector('.product-recommendations')?.innerHTML || '';
            container.innerHTML = inner;

            const subtitle = container.querySelector('.product-recommendations__subtitle');
            if (subtitle && subtitle.textContent.indexOf('{product}') !== -1) {
              subtitle.textContent = subtitle.textContent.replace('{product}', productName).replace(/\s+/g, ' ').trim();
            }
          });
      }
    });
  </script>
{% endif %}

{% stylesheet %}
  /* Desktop-first */
  .product-recommendations {
    width: 100%;
    margin-inline: auto;
    padding: var(--section-spacing-desktop) 140px;
  }

  .product-recommendations__header {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto var(--sp-5);
  }
  .product-recommendations__eyebrow {
    margin: 0 0 var(--sp-3);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-clay);
  }
  .product-recommendations__title {
    margin: 0 0 var(--sp-4);
    font-family: var(--font-display);
    font-size: var(--font-size-display-lg);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-display);
    letter-spacing: var(--letter-spacing-normal);
    color: var(--text-primary);
    text-wrap: balance;
  }
  .product-recommendations__subtitle {
    margin: 0;
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
    text-wrap: balance;
  }

  .product-recommendations__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    column-gap: var(--sp-4);
    row-gap: var(--sp-7);
  }

  .pairs-card {
    min-width: 0;
    display: flex;
    flex-direction: column;
  }
  .pairs-card__media {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background-color: var(--bg-secondary);
    box-shadow: var(--shadow-elevation-2);
  }
  .pairs-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--timing-long) var(--ease-standard);
  }
  .pairs-card__media:hover .pairs-card__image {
    transform: scale(1.03);
  }

  .pairs-card__info {
    padding-top: var(--sp-4);
  }
  .pairs-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .pairs-card__title-link {
    color: inherit;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pairs-card__material {
    margin: var(--sp-2) 0 0;
    font-size: var(--font-size-body-sm);
    color: var(--color-clay);
  }
  .pairs-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    margin-top: var(--sp-4);
    padding-bottom: var(--sp-4);
    border-bottom: 1px solid var(--border-default);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color var(--timing-short) var(--ease-standard),
      gap var(--timing-short) var(--ease-standard);
  }
  .pairs-card__link svg {
    width: 14px;
    height: 14px;
  }
  .pairs-card__link:hover {
    border-color: var(--color-clay);
    gap: var(--sp-3);
    color: var(--text-primary);
  }

  @media screen and (max-width: 1024px) {
    .product-recommendations {
      padding-inline: var(--layout-padding-tablet);
    }
    .product-recommendations__title {
      font-size: var(--font-size-display-md);
    }
    .product-recommendations__grid {
      column-gap: var(--sp-5);
      row-gap: var(--sp-6);
    }
  }

  @media screen and (max-width: 768px) {
    .product-recommendations {
      padding: var(--section-spacing-mobile) var(--layout-padding-mobile);
    }
    .product-recommendations__title {
      font-size: var(--font-size-display-md);
    }
    .product-recommendations__subtitle {
      font-size: var(--font-size-body-md);
    }
    .product-recommendations__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: var(--sp-4);
      row-gap: var(--sp-5);
    }
  }

  @media screen and (max-width: 480px) {
    .product-recommendations__grid {
      column-gap: var(--sp-3);
    }
    .pairs-card__title {
      font-size: var(--font-size-body-lg);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Recommendations",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Curated for harmony"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Pairs Beautifully With"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Use {product} to insert the current product name.",
      "default": "Thoughtfully selected pieces that complement the {product} in form, material, and mood."
    },
    {
      "type": "text",
      "id": "material_label",
      "label": "Material label (fallback)",
      "info": "Used when a product has no custom.material metafield.",
      "default": "Solid walnut"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Card link label",
      "default": "View Piece"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Maximum products to show"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}
