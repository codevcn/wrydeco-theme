{% liquid
  assign rec_limit = section.settings.products_to_show | default: 6
%}
{% if recommendations.performed and recommendations.products_count > 0 %}
  <div class="product-recommendations page-width">
    <div class="product-recommendations__header">
      {% if section.settings.eyebrow != blank %}
        <p class="product-recommendations__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}
      {% if section.settings.title != blank %}
        <h2 class="product-recommendations__title">{{ section.settings.title | escape }}</h2>
      {% endif %}
      {% if section.settings.subtitle != blank %}
        <p class="product-recommendations__subtitle">{{ section.settings.subtitle | escape }}</p>
      {% endif %}
    </div>

    <div class="product-recommendations__carousel" data-pairs-carousel>
      <button
        class="product-recommendations__nav product-recommendations__nav--prev"
        type="button"
        aria-label="{{ 'general.previous' | t | default: 'Previous' }}"
        data-pairs-prev
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M15 5L8 12L15 19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="product-recommendations__slider" data-pairs-slider>
        {% for product in recommendations.products limit: rec_limit %}
          {% liquid
            assign material = product.metafields.custom.material
            if material == blank
              assign material = section.settings.material_label
            endif
          %}
          <article class="pairs-card">
            <a class="pairs-card__media" href="{{ product.url }}" draggable="false">
              {%- if product.featured_media != blank -%}
                {% assign recommendation_image_alt = product.featured_media.alt | default: product.title %}
                {{
                  product.featured_media.preview_image
                  | image_url: width: 640
                  | image_tag:
                    class: 'pairs-card__image',
                    loading: 'lazy',
                    draggable: 'false',
                    widths: '240, 360, 480, 640',
                    sizes: '(min-width: 1024px) 24vw, (min-width: 720px) 33vw, 78vw',
                    alt: recommendation_image_alt
                }}
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'pairs-card__image placeholder-svg' }}
              {%- endif -%}
            </a>

            <div class="pairs-card__info">
              <h3 class="pairs-card__title">
                <a class="pairs-card__title-link" href="{{ product.url }}" draggable="false">
                  {{- product.title | split: ',' | first | split: ' - ' | first | strip | escape -}}
                </a>
              </h3>
              {% if material != blank %}
                <p class="pairs-card__material">{{ material | escape }}</p>
              {% endif %}
              <a class="pairs-card__link" href="{{ product.url }}" draggable="false">
                <span>{{ section.settings.cta_label | default: 'View piece' }}</span>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <polyline points="9 18 15 12 9 6"></polyline>
                </svg>
              </a>
            </div>
          </article>
        {% endfor %}
      </div>

      <button
        class="product-recommendations__nav product-recommendations__nav--next"
        type="button"
        aria-label="{{ 'general.next' | t | default: 'Next' }}"
        data-pairs-next
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
{% else %}
  <div
    class="product-recommendations"
    id="recommendations-container-{{ section.id }}"
    data-product-id="{{ product.id }}"
  ></div>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const container = document.getElementById('recommendations-container-{{ section.id }}');
      const productId = container.dataset.productId;
      const productName = {{ product.title | split: ',' | first | strip | json }};
      const limit = {{ rec_limit }};

      if (productId) {
        fetch(`/recommendations/products?section_id={{ section.id }}&product_id=${productId}&limit=${limit}`)
          .then(r => r.text())
          .then(html => {
            const inner = new DOMParser()
              .parseFromString(html, 'text/html')
              .querySelector('.product-recommendations')?.innerHTML || '';
            container.innerHTML = inner;

            const subtitle = container.querySelector('.product-recommendations__subtitle');
            if (subtitle && subtitle.textContent.indexOf('{product}') !== -1) {
              subtitle.textContent = subtitle.textContent.replace('{product}', productName).replace(/\s+/g, ' ').trim();
            }

            // Content was injected via innerHTML (its <script> won't run), so wire
            // up the carousel that just landed in the DOM.
            if (window.initPairsCarousels) window.initPairsCarousels();
          });
      }
    });
  </script>
{% endif %}

{% stylesheet %}
  /* Desktop-first */
  .product-recommendations {
    width: 100%;
    margin-inline: auto;
    padding: var(--section-spacing-desktop) 140px;
  }

  .product-recommendations__header {
    text-align: center;
    max-width: 60ch;
    margin: 0 auto var(--sp-6);
  }
  .product-recommendations__eyebrow {
    margin: 0 0 var(--sp-3);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-clay);
  }
  .product-recommendations__title {
    margin: 0 0 var(--sp-4);
    font-family: var(--font-display);
    font-size: var(--font-size-display-lg);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-display);
    letter-spacing: var(--letter-spacing-normal);
    color: var(--text-primary);
    text-wrap: balance;
  }
  .product-recommendations__subtitle {
    margin: 0;
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
    text-wrap: balance;
  }

  /* Carousel */
  .product-recommendations__carousel {
    position: relative;
  }
  .product-recommendations__slider {
    display: flex;
    gap: var(--sp-5);
    overflow-x: auto;
    padding-bottom: var(--sp-3);
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    cursor: grab;
    scrollbar-width: none; /* Firefox */
    -webkit-overflow-scrolling: touch;
  }
  .product-recommendations__slider::-webkit-scrollbar {
    display: none; /* Chrome, Safari */
  }
  .product-recommendations__slider.is-dragging {
    cursor: grabbing;
    scroll-behavior: auto;
    scroll-snap-type: none;
  }
  /* While dragging, block text selection and hover/click on cards. */
  .product-recommendations__slider.is-dragging .pairs-card {
    user-select: none;
    pointer-events: none;
  }

  .pairs-card {
    display: flex;
    flex-direction: column;
    flex: 0 0 calc((100% - (var(--sp-5) * 3)) / 4);
    min-width: 0;
    scroll-snap-align: start;
  }
  .pairs-card__media {
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: var(--radius-xl);
    background-color: var(--bg-secondary);
    box-shadow: var(--shadow-elevation-2);
  }
  .pairs-card__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    -webkit-user-drag: none;
    user-select: none;
    transition: transform var(--timing-long) var(--ease-standard);
  }
  .pairs-card__media:hover .pairs-card__image {
    transform: scale(1.03);
  }

  .pairs-card__info {
    padding-top: var(--sp-4);
  }
  .pairs-card__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .pairs-card__title-link {
    color: inherit;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pairs-card__material {
    margin: var(--sp-2) 0 0;
    font-size: var(--font-size-body-sm);
    color: var(--color-clay);
  }
  .pairs-card__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    margin-top: var(--sp-4);
    padding-bottom: var(--sp-2);
    border-bottom: 1px solid var(--border-default);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--text-primary);
    text-decoration: none;
    transition: border-color var(--timing-short) var(--ease-standard),
      gap var(--timing-short) var(--ease-standard);
  }
  .pairs-card__link svg {
    width: 14px;
    height: 14px;
  }
  .pairs-card__link:hover {
    border-color: var(--color-clay);
    gap: var(--sp-3);
    color: var(--text-primary);
  }

  /* Prev / Next navigation */
  .product-recommendations__nav {
    position: absolute;
    z-index: 3;
    top: calc((100% - 96px) / 2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--surface-elevated) 88%, transparent);
    color: var(--color-earth-brown);
    cursor: pointer;
    transform: translateY(-50%);
    box-shadow: var(--shadow-elevation-2);
    transition: background-color var(--timing-short) var(--ease-standard),
      border-color var(--timing-short) var(--ease-standard),
      opacity var(--timing-short) var(--ease-standard),
      transform var(--timing-short) var(--ease-standard);
  }
  .product-recommendations__nav:hover {
    background: var(--color-milk);
    border-color: var(--color-clay);
    transform: translateY(-50%) scale(1.05);
  }
  .product-recommendations__nav:focus-visible {
    outline: 2px solid var(--color-sage);
    outline-offset: var(--sp-1);
  }
  .product-recommendations__nav[disabled] {
    opacity: 0.32;
    cursor: default;
    pointer-events: none;
  }
  .product-recommendations__nav--prev {
    left: calc(var(--sp-5) * -1);
  }
  .product-recommendations__nav--next {
    right: calc(var(--sp-5) * -1);
  }
  /* No arrows when everything already fits. */
  .product-recommendations__carousel:not(.has-overflow) .product-recommendations__nav {
    display: none;
  }

  @media screen and (max-width: 1280px) {
    .product-recommendations {
      padding-inline: 64px;
    }
    .pairs-card {
      flex-basis: calc((100% - (var(--sp-5) * 2)) / 3);
    }
    .product-recommendations__nav--prev {
      left: var(--sp-2);
    }
    .product-recommendations__nav--next {
      right: var(--sp-2);
    }
  }

  @media screen and (max-width: 1024px) {
    .product-recommendations {
      padding-inline: var(--layout-padding-tablet);
    }
    .product-recommendations__title {
      font-size: var(--font-size-display-md);
    }
  }

  @media screen and (max-width: 768px) {
    .product-recommendations {
      padding: var(--section-spacing-mobile) var(--layout-padding-mobile);
    }
    .product-recommendations__title {
      font-size: var(--font-size-display-md);
    }
    .product-recommendations__subtitle {
      font-size: var(--font-size-body-md);
    }
    .product-recommendations__slider {
      gap: var(--sp-4);
    }
    .pairs-card {
      flex-basis: calc((100% - var(--sp-4)) / 2);
    }
    /* Touch devices scroll/drag directly; hide the arrows on small screens. */
    .product-recommendations__nav {
      display: none !important;
    }
  }

  @media screen and (max-width: 480px) {
    .pairs-card {
      flex-basis: 78%;
    }
    .pairs-card__title {
      font-size: var(--font-size-body-lg);
    }
  }
{% endstylesheet %}

{% javascript %}
  window.initPairsCarousels = function () {
    document.querySelectorAll('[data-pairs-carousel]').forEach(function (carousel) {
      if (carousel.dataset.pairsInit === 'true') return;
      carousel.dataset.pairsInit = 'true';

      var slider = carousel.querySelector('[data-pairs-slider]');
      if (!slider) return;
      var prev = carousel.querySelector('[data-pairs-prev]');
      var next = carousel.querySelector('[data-pairs-next]');

      function pageWidth() {
        var card = slider.querySelector('.pairs-card');
        var styles = getComputedStyle(slider);
        var gap = parseFloat(styles.columnGap || styles.gap) || 16;
        if (!card) return slider.clientWidth;
        var cardWidth = card.getBoundingClientRect().width + gap;
        var perView = Math.max(1, Math.round(slider.clientWidth / cardWidth));
        return cardWidth * perView;
      }

      function updateNav() {
        var maxScroll = slider.scrollWidth - slider.clientWidth;
        carousel.classList.toggle('has-overflow', maxScroll > 1);
        if (prev) prev.disabled = slider.scrollLeft <= 1;
        if (next) next.disabled = slider.scrollLeft >= maxScroll - 1;
      }

      if (prev) prev.addEventListener('click', function () {
        slider.scrollBy({ left: -pageWidth(), behavior: 'smooth' });
      });
      if (next) next.addEventListener('click', function () {
        slider.scrollBy({ left: pageWidth(), behavior: 'smooth' });
      });

      slider.addEventListener('scroll', updateNav, { passive: true });
      window.addEventListener('resize', updateNav);
      updateNav();

      // Press-and-drag to scroll (mouse). Uses a small threshold so a plain
      // click still activates the card link.
      var isDown = false;
      var startX = 0;
      var scrollLeft = 0;
      var isDragging = false;
      var THRESHOLD = 5;

      slider.addEventListener('mousedown', function (e) {
        isDown = true;
        isDragging = false;
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
      });

      function endDrag() {
        isDown = false;
        slider.classList.remove('is-dragging');
      }
      slider.addEventListener('mouseleave', endDrag);
      slider.addEventListener('mouseup', endDrag);

      slider.addEventListener('mousemove', function (e) {
        if (!isDown) return;
        var x = e.pageX - slider.offsetLeft;
        if (!isDragging && Math.abs(x - startX) > THRESHOLD) {
          isDragging = true;
          slider.classList.add('is-dragging');
        }
        if (!isDragging) return;
        e.preventDefault();
        slider.scrollLeft = scrollLeft - (x - startX) * 1.4;
      });

      // Suppress the click that follows a real drag so links don't navigate.
      slider.addEventListener(
        'click',
        function (e) {
          if (isDragging) {
            e.preventDefault();
            e.stopPropagation();
          }
        },
        true
      );

      // Never start a native image/link drag-and-drop.
      slider.addEventListener('dragstart', function (e) {
        e.preventDefault();
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', window.initPairsCarousels);
  } else {
    window.initPairsCarousels();
  }
{% endjavascript %}

{% schema %}
{
  "name": "Product Recommendations",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Curated for harmony"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Pairs Beautifully With"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "info": "Use {product} to insert the current product name.",
      "default": "Thoughtfully selected pieces that complement the {product} in form, material, and mood."
    },
    {
      "type": "text",
      "id": "material_label",
      "label": "Material label (fallback)",
      "info": "Used when a product has no custom.material metafield.",
      "default": "Solid walnut"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Card link label",
      "default": "View Piece"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6,
      "label": "Maximum products to show"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}
