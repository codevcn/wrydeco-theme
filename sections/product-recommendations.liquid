{% if recommendations.performed and recommendations.products_count > 0 %}
  <div class="product-recommendations page-width">
    <h2 class="product-recommendations__heading">
      {{ section.settings.heading | default: 'You might also <em>like</em>' }}
    </h2>
    <div class="product-recommendations__rows">
      <div class="product-recommendations__grid">
        {% for product in recommendations.products %}
          {%- capture image_ratio -%}square{%- endcapture -%}
          <div class="pin-card pin-card--{{ image_ratio }}">
            <div class="pin-card__image-wrapper">
              <a class="pin-card__image-link" href="{{ product.url }}">
                {%- if product.featured_media != blank -%}
                  {% assign recommendation_image_alt = product.featured_media.alt | default: product.title %}
                  {{
                    product.featured_media.preview_image
                    | image_url: width: 640
                    | image_tag:
                      class: 'pin-card__image',
                      loading: 'lazy',
                      widths: '240, 360, 480, 640',
                      sizes: '(min-width: 1024px) 25vw, (min-width: 720px) 33vw, 75vw',
                      alt: recommendation_image_alt
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'pin-card__image placeholder-svg' }}
                {%- endif -%}
              </a>
              {%- if product.available -%}
                {% form 'product', product %}
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  <button type="submit" name="add" class="pin-card__add-to-cart btn-pill btn-pill--earth-brown">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="24"
                      height="24"
                      fill="currentColor"
                      class="bi bi-cart-plus"
                      viewBox="0 0 16 16"
                    >
                      <path d="M9 5.5a.5.5 0 0 0-1 0V7H6.5a.5.5 0 0 0 0 1H8v1.5a.5.5 0 0 0 1 0V8h1.5a.5.5 0 0 0 0-1H9z"/>
                      <path d="M.5 1a.5.5 0 0 0 0 1h1.11l.401 1.607 1.498 7.985A.5.5 0 0 0 4 12h1a2 2 0 1 0 0 4 2 2 0 0 0 0-4h7a2 2 0 1 0 0 4 2 2 0 0 0 0-4h1a.5.5 0 0 0 .491-.408l1.5-8A.5.5 0 0 0 14.5 3H2.89l-.405-1.621A.5.5 0 0 0 2 1zm3.915 10L3.102 4h10.796l-1.313 7zM6 14a1 1 0 1 1-2 0 1 1 0 0 1 2 0m7 0a1 1 0 1 1-2 0 1 1 0 0 1 2 0"/>
                    </svg>
                  </button>
                {% endform %}
              {%- else -%}
                <button class="pin-card__add-to-cart btn-pill btn-pill--earth-brown" disabled>Sold out</button>
              {%- endif -%}
            </div>

            <div class="pin-card__info">
              <h3 class="pin-card__title">
                <a class="pin-card__title-link" href="{{ product.url }}">
                  {{ product.title | escape }}
                </a>
              </h3>
              <div class="pin-card__meta">
                <div class="pin-card__price">
                  {{ product.price | money }}
                </div>
                <div class="pin-card__author">
                  {% liquid
                    assign author = product.metafields.custom.author_info.value | first
                    assign author_name = blank
                    assign author_image_url = blank

                    if author != blank
                      assign author_name = author.author_name.value
                      assign author_image_url = author.author_image_url.value
                    endif
                  %}
                  <span class="for-you-masonry__pin-card__crafted-by"> Crafted by </span>
                  <div class="pin-card__avatar">
                    {% if author_image_url != blank %}
                      <img
                        src="{{ author_image_url | escape }}"
                        alt="{{ author_name | escape }}"
                        loading="lazy"
                        style="width: 100%; height: 100%; object-fit: cover;"
                      >
                    {% else %}
                      <svg viewBox="0 0 24 24" fill="#333" width="100%" height="100%">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                      </svg>
                    {% endif %}
                  </div>
                </div>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
{% else %}
  <div
    class="product-recommendations"
    id="recommendations-container-{{ section.id }}"
    data-product-id="{{ product.id }}"
  ></div>
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const container = document.getElementById('recommendations-container-{{ section.id }}');
      const productId = container.dataset.productId;
      const limit = {{ section.settings.products_to_show | default: 4 }};

      if (productId) {
        fetch(`/recommendations/products?section_id={{ section.id }}&product_id=${productId}&limit=${limit}`)
          .then(r => r.text())
          .then(html => {
            container.innerHTML = new DOMParser()
              .parseFromString(html, 'text/html')
              .querySelector('.product-recommendations')?.innerHTML || '';
          });
      }
    });
  </script>
{% endif %}

{% stylesheet %}
  .product-recommendations {
    padding: 20px 0 40px;
  }
  .product-recommendations__heading {
    font-size: 32px;
    margin-bottom: 12px;
    font-weight: 500;
    font-family: var(--font-display);
    padding-left: 14px;
  }
  .product-recommendations__heading em {
    color: #e60023; /* Or var(--color-2) if available */
    font-style: italic;
  }
  .product-recommendations__rows {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .product-recommendations__grid {
    display: grid;
    grid-template-columns: repeat(4, calc(75% - var(--sp-4)));
    grid-template-rows: repeat(2, auto);
    overflow-x: auto;
    gap: var(--sp-4);
    padding: 0 var(--layout-gutter-mobile) var(--sp-3);
    scrollbar-width: thin;
    scroll-snap-type: x mandatory;
  }
  .product-recommendations__grid::-webkit-scrollbar {
    height: 8px;
  }
  .product-recommendations__grid::-webkit-scrollbar-track {
    background: #f1f1f1;
    border-radius: 4px;
  }
  .product-recommendations__grid::-webkit-scrollbar-thumb {
    background: #ccc;
    border-radius: 4px;
  }
  .product-recommendations__grid > .pin-card {
    margin-bottom: 0; /* Override default margin from pin-card */
    scroll-snap-align: start;
  }
  @media screen and (min-width: 720px) {
    .product-recommendations {
      max-width: var(--layout-max-width);
      margin-inline: auto;
      padding: var(--section-spacing-tablet) 0;
    }
    .product-recommendations__heading {
      margin: 0 0 var(--sp-5);
      padding: 0;
      font-size: var(--font-size-display-md);
      color: var(--text-primary);
      text-wrap: balance;
    }
    .product-recommendations__rows {
      gap: var(--sp-5);
    }
    .product-recommendations__grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: var(--sp-4);
      overflow: visible;
      padding: 0;
      scroll-snap-type: none;
    }
    .product-recommendations__grid > .pin-card {
      min-width: 0;
      margin: 0;
      scroll-snap-align: none;
    }
  }
  @media screen and (min-width: 1024px) {
    .product-recommendations {
      padding: var(--section-spacing-desktop) 0;
    }
    .product-recommendations__grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: var(--sp-5);
    }
  }

  /* Reuse pin-card styling from for-you-masonry if missing, but we assume it's global or we'll ensure it works */
  .product-recommendations .pin-card {
    display: block;
    margin-bottom: 18px;
    border-radius: 12px;
    overflow: hidden;
    background-color: #fff;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    position: relative;
  }
  .pin-card--square .pin-card__image-wrapper {
    aspect-ratio: 1 / 1;
  }
  .pin-card__image-wrapper {
    position: relative;
    overflow: hidden;
    width: 100%;
  }
  .pin-card__image-link {
    display: block;
    width: 100%;
    height: 100%;
  }
  .pin-card__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }
  .pin-card__add-to-cart {
    position: absolute;
    bottom: 6px;
    right: 6px;
    z-index: 5;
    font-size: 15px;
    padding: 3px 5px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    font-weight: 700;
    color: #fff;
    outline: 2px solid var(--color-human-skin, #e0d0c0);
    cursor: pointer;
    background-color: var(--color-earth-brown, #5c4033);
    border: none;
    border-radius: 50px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pin-card__add-to-cart:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    background-color: #888;
    padding: 6px 12px;
  }
  .pin-card__add-to-cart svg {
    pointer-events: none;
  }
  .pin-card__info {
    padding: 8px;
  }
  .pin-card__title {
    display: block;
    border-bottom: 1px solid var(--color-human-skin, #e0d0c0);
    padding-bottom: 6px;
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 8px 0;
    line-height: 1.4;
  }
  .pin-card__title-link {
    color: inherit;
    text-decoration: none;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .pin-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    gap: 8px;
  }
  .pin-card__author {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .pin-card__avatar {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background: #f1f1f1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .pin-card__avatar-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .recommendation__pin-card__author-name {
    display: inline-block;
    font-weight: 500;
    font-size: 18px;
    color: #442c1a;
    white-space: nowrap;
    min-width: 0;
  }
  .product-recommendations .pin-card__price {
    font-weight: 600;
  }

  @media screen and (min-width: 720px) {
    .recommendation__pin-card__author-name {
      font-size: 16px;
    }
    .product-recommendations .pin-card__price {
      font-size: 16px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Recommendations",
  "limit": 1,
  "settings": [
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "You might also <em>like</em>"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 8,
      "label": "Maximum products to show"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}
