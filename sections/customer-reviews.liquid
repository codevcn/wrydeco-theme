<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer="defer"></script>

<section
  class="customer-carousel"
  aria-label="{{ section.settings.accessible_label | escape }}"
  data-customer-carousel
  data-review-count="{{ section.blocks.size }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-autoplay-delay="{{ section.settings.autoplay_delay | times: 1000 }}"
>
  {%- if section.settings.heading != blank -%}
    <div class="customer-carousel__header page-width">
      <h2 class="customer-carousel__title">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.subtext != blank -%}
        <div class="customer-carousel__subtext">
          {{ section.settings.subtext }}
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}
  
  <div class="customer-carousel__inner">
    {%- if section.blocks.size > 0 -%}
      <div class="customer-carousel__media-viewport">
        <div class="swiper customer-carousel__media" data-customer-media>
          <div class="swiper-wrapper">
            {%- for block in section.blocks -%}
              {%- liquid
                assign fallback_image = block.settings.fallback_image | default: 'eff-1.jpg'
                assign image_alt = block.settings.image_alt
                if image_alt == blank and block.settings.image != blank
                  assign image_alt = block.settings.image.alt
                endif
                if image_alt == blank
                  assign image_alt = 'Handcrafted WRYDECO furniture in a customer home'
                endif
              -%}
              <article
                class="swiper-slide customer-carousel__media-slide"
                data-review-index="{{ forloop.index0 }}"
                data-block-id="{{ block.id }}"
                {{ block.shopify_attributes }}
              >
                <div class="customer-carousel__material">
                  <div class="customer-carousel__image-frame">
                    {%- if block.settings.image != blank -%}
                      {{
                        block.settings.image
                        | image_url: width: 1200
                        | image_tag:
                          widths: '320, 480, 640, 800, 1000, 1200',
                          sizes: '(min-width: 48rem) 27rem, 62vw',
                          class: 'customer-carousel__image',
                          loading: 'lazy',
                          alt: image_alt,
                          draggable: false
                      }}
                    {%- else -%}
                      <img
                        class="customer-carousel__image"
                        src="{{ fallback_image | asset_url }}"
                        alt="{{ image_alt | escape }}"
                        width="1024"
                        height="1024"
                        loading="lazy"
                        draggable="false"
                      >
                    {%- endif -%}
                  </div>
                </div>
              </article>
            {%- endfor -%}
          </div>
        </div>
      </div>

      <div class="swiper customer-carousel__reviews" data-customer-reviews aria-live="polite">
        <div class="swiper-wrapper">
          {%- for block in section.blocks -%}
            <article class="swiper-slide customer-carousel__review-slide">
              <div class="customer-carousel__review-card">
                <div class="customer-carousel__rating" aria-label="{{ block.settings.rating }} out of 5 stars">
                  {%- for rating_position in (1..5) -%}
                    <span
                      class="customer-carousel__star{% if rating_position > block.settings.rating %} is-empty{% endif %}"
                      aria-hidden="true"
                      >&#9733;</span
                    >
                  {%- endfor -%}
                </div>

                <blockquote class="customer-carousel__quote">
                  <p>{{ block.settings.review_text | escape }}</p>
                </blockquote>

                <p class="customer-carousel__author">
                  {%- if block.settings.verified -%}
                    <svg
                      class="customer-carousel__verified"
                      viewBox="0 0 20 20"
                      role="img"
                      aria-label="Verified customer"
                    >
                      <circle cx="10" cy="10" r="9"></circle>
                      <path d="M6.2 10.2 8.7 12.7 13.9 7.5"></path>
                    </svg>
                  {%- endif -%}
                  <span>{{ block.settings.author_name | escape }}</span>
                </p>

                <span class="customer-carousel__quote-mark" aria-hidden="true">&ldquo;</span>
              </div>
            </article>
          {%- endfor -%}
        </div>
      </div>

      <div class="customer-carousel__pagination" data-customer-pagination aria-hidden="true"></div>
    {%- else -%}
      <p class="customer-carousel__empty">Add review blocks to display the customer carousel.</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .customer-carousel {
    container-name: customer-carousel;
    container-type: inline-size;
    overflow: hidden;
    padding-block: var(--sp-8) var(--sp-7);
    color: var(--text-primary);
    background-color: var(--color-cream);
  }

  .customer-carousel *,
  .customer-carousel *::before,
  .customer-carousel *::after {
    box-sizing: border-box;
  }

  .customer-carousel__inner {
    padding: 0 0;
    margin-inline: auto;
  }

  .customer-carousel__header {
    text-align: center;
    margin-bottom: var(--sp-6);
  }

  .customer-carousel__subtext {
    margin-top: 0.5rem;
    color: var(--text-secondary);
    font-size: var(--text-base, 16px);
  }

  .customer-carousel__media-viewport {
    overflow: hidden;
    aspect-ratio: 312 / 337;
  }

  .customer-carousel__media,
  .customer-carousel__media .swiper-wrapper,
  .customer-carousel__media-slide {
    block-size: 100%;
  }

  .customer-carousel__media {
    overflow: visible;
    cursor: grab;
    touch-action: pan-y;
    user-select: none;
  }

  .customer-carousel__media:active {
    cursor: grabbing;
  }

  .customer-carousel__media-slide {
    overflow: visible;
    will-change: transform;
  }

  .customer-carousel__material {
    block-size: 100%;
    overflow: hidden;
    border-radius: calc(var(--radius-xl) + var(--radius-xl) + var(--radius-sm) + var(--radius-md));
    transform: translate3d(0, 0, 0) scaleX(1);
    transform-origin: center;
    transition: transform var(--timing-extra-long) var(--ease-out);
    will-change: transform;
  }

  .customer-carousel__image-frame {
    block-size: 100%;
    overflow: hidden;
  }

  .customer-carousel__image {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center;
    transform: translate3d(0, 0, 0) scale(1);
    transition: transform var(--timing-extra-long) var(--ease-out);
    user-select: none;
    will-change: transform;
  }

  .customer-carousel__reviews {
    overflow: visible;
    margin-block-start: var(--sp-2);
  }

  .customer-carousel__review-slide {
    block-size: auto;
    opacity: 0;
    transition: opacity var(--timing-base) var(--ease-out);
  }

  .customer-carousel__review-slide.swiper-slide-active {
    opacity: 1;
  }

  .customer-carousel__review-card {
    position: relative;
    display: flex;
    min-block-size: 12.75rem;
    flex-direction: column;
    align-items: center;
    padding: var(--sp-5) var(--sp-4) var(--sp-8);
    background-color: var(--color-cream);
    text-align: center;
    transition: opacity var(--timing-short) var(--ease-out), transform var(--timing-short) var(--ease-out);
  }

  .customer-carousel.is-dragging .customer-carousel__review-card {
    opacity: 0.58;
    transform: translateY(var(--sp-1));
  }

  .customer-carousel__rating {
    display: flex;
    justify-content: center;
    gap: var(--sp-1);
    min-block-size: var(--sp-5);
    margin-block-end: var(--sp-3);
    color: var(--color-warning);
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    line-height: 1;
  }

  .customer-carousel__star.is-empty {
    color: var(--color-stone);
  }

  .customer-carousel__quote {
    max-inline-size: 24ch;
    margin: 0;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    font-style: normal;
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-generous);
    text-wrap: pretty;
  }

  .customer-carousel__quote p {
    display: -webkit-box;
    margin: 0;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  .customer-carousel__author {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-1);
    margin: auto 0 0;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-normal);
  }

  .customer-carousel__verified {
    inline-size: var(--sp-4);
    block-size: var(--sp-4);
    flex: 0 0 auto;
    color: var(--text-secondary);
  }

  .customer-carousel__verified circle {
    fill: currentColor;
  }

  .customer-carousel__verified path {
    fill: none;
    stroke: var(--surface-elevated);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
  }

  .customer-carousel__quote-mark {
    position: absolute;
    inset-block-end: calc(-1 * var(--sp-5));
    inset-inline-start: 50%;
    display: grid;
    inline-size: var(--sp-7);
    block-size: var(--sp-7);
    place-items: center;
    color: var(--color-clay);
    font-family: var(--font-display);
    font-size: var(--font-size-display-lg);
    font-weight: var(--font-weight-semibold);
    line-height: 1;
    transform: translateX(-50%);
    bottom: -5px;
  }

  .customer-carousel__pagination {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    block-size: var(--sp-4);
    margin-block-start: var(--sp-5);
  }

  .customer-carousel__pagination .swiper-pagination-bullet {
    inline-size: calc(var(--sp-2) - var(--radius-sm));
    block-size: calc(var(--sp-2) - var(--radius-sm));
    margin-inline: var(--sp-1) !important;
    border-radius: var(--radius-full);
    background-color: var(--color-bark);
    opacity: 1;
    transition: inline-size var(--timing-long) var(--ease-out), background-color var(--timing-short) var(--ease-out);
  }

  .customer-carousel__pagination .swiper-pagination-bullet-active {
    inline-size: var(--sp-5);
    backgroundc-color: var(--color-bark);
  }

  .customer-carousel__empty {
    margin: 0;
    padding: var(--sp-6);
    background: var(--color-cream);
    color: var(--text-secondary);
    font: var(--type-body-regular);
    text-align: center;
  }

  @container customer-carousel (min-width: 48rem) {
    .customer-carousel__inner {
      inline-size: min(calc(100% - (var(--layout-padding-desktop) * 2)), 48rem);
    }

    .customer-carousel__media-viewport {
      aspect-ratio: 16 / 7;
    }

    .customer-carousel__reviews {
      max-inline-size: 34rem;
      margin-inline: auto;
    }

    .customer-carousel__review-card {
      min-block-size: 12rem;
      padding-inline: var(--sp-6);
    }

    .customer-carousel__quote {
      max-inline-size: 38ch;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .customer-carousel__material,
    .customer-carousel__image,
    .customer-carousel__review-slide,
    .customer-carousel__review-card,
    .customer-carousel__pagination .swiper-pagination-bullet {
      transition: none;
    }
  }
{% endstylesheet %}

{% javascript %}
  (() => {
    const sectionSelector = '[data-customer-carousel]';
    const instances = new WeakMap();

    const setMaterialProgress = (swiper, reduceMotion) => {
      swiper.slides.forEach((slide) => {
        const material = slide.querySelector('.customer-carousel__material');
        const image = slide.querySelector('.customer-carousel__image');
        if (!material || !image) return;

        const rawProgress = Number.isFinite(slide.progress) ? slide.progress : 0;
        const progress = Math.max(-1.5, Math.min(1.5, rawProgress));
        const distance = Math.min(Math.abs(progress), 1);
        const morph = Math.sin(Math.PI * distance);
        const scaleX = reduceMotion ? 1 : 1 - morph * 0.16;
        const materialShift = reduceMotion ? 0 : progress * morph * 3.5;
        const imageShift = reduceMotion ? 0 : progress * morph * -4;
        const imageScale = reduceMotion ? 1 : 1 + morph * 0.045;

        material.style.transformOrigin = progress < 0 ? '100% 50%' : progress > 0 ? '0% 50%' : '50% 50%';
        material.style.transform = `translate3d(${materialShift}%, 0, 0) scaleX(${scaleX})`;
        image.style.transform = `translate3d(${imageShift}%, 0, 0) scale(${imageScale})`;
        slide.style.zIndex = String(Math.round(10 - distance * 4));
      });
    };

    const setMaterialTransition = (swiper, duration) => {
      swiper.slides.forEach((slide) => {
        const material = slide.querySelector('.customer-carousel__material');
        const image = slide.querySelector('.customer-carousel__image');
        if (material) material.style.transitionDuration = `${duration}ms`;
        if (image) image.style.transitionDuration = `${duration}ms`;
      });
    };

    const initSection = (section) => {
      if (!section || instances.has(section)) return;

      if (typeof window.Swiper === 'undefined') {
        const attempts = Number(section.dataset.swiperAttempts || 0);
        if (attempts < 50) {
          section.dataset.swiperAttempts = String(attempts + 1);
          window.setTimeout(() => initSection(section), 100);
        }
        return;
      }

      const mediaElement = section.querySelector('[data-customer-media]');
      const reviewsElement = section.querySelector('[data-customer-reviews]');
      const paginationElement = section.querySelector('[data-customer-pagination]');
      const reviewCount = Number(section.dataset.reviewCount || 0);
      if (!mediaElement || !reviewsElement || !paginationElement || reviewCount === 0) return;

      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const shouldLoop = reviewCount > 2;
      const autoplayEnabled = section.dataset.autoplay === 'true' && !reduceMotion;
      const autoplayDelay = Number(section.dataset.autoplayDelay || 5000);

      const reviewsSwiper = new window.Swiper(reviewsElement, {
        allowTouchMove: false,
        autoHeight: true,
        effect: 'fade',
        fadeEffect: { crossFade: true },
        speed: reduceMotion ? 0 : 300,
      });

      const mediaSwiper = new window.Swiper(mediaElement, {
        a11y: {
          enabled: true,
          nextSlideMessage: 'Next customer review',
          prevSlideMessage: 'Previous customer review',
        },
        autoplay: autoplayEnabled
          ? { delay: autoplayDelay, disableOnInteraction: false, pauseOnMouseEnter: true }
          : false,
        centeredSlides: true,
        followFinger: true,
        grabCursor: true,
        longSwipes: true,
        longSwipesMs: 300,
        longSwipesRatio: 0.24,
        loop: shouldLoop,
        pagination: { el: paginationElement, clickable: false },
        resistance: true,
        resistanceRatio: 0.82,
        shortSwipes: true,
        slideToClickedSlide: true,
        slidesPerView: 1.55,
        spaceBetween: 8,
        speed: reduceMotion ? 0 : 500,
        threshold: 5,
        touchAngle: 45,
        watchSlidesProgress: true,
        breakpoints: {
          768: { slidesPerView: 1.72, spaceBetween: 16 },
        },
        on: {
          init(swiper) {
            setMaterialProgress(swiper, reduceMotion);
          },
          progress(swiper) {
            setMaterialProgress(swiper, reduceMotion);
          },
          setTransition(swiper, duration) {
            setMaterialTransition(swiper, duration);
          },
          realIndexChange(swiper) {
            reviewsSwiper.slideTo(swiper.realIndex, reduceMotion ? 0 : 300);
          },
          sliderFirstMove() {
            section.classList.add('is-dragging');
          },
          touchEnd() {
            section.classList.remove('is-dragging');
          },
          transitionEnd(swiper) {
            section.classList.remove('is-dragging');
            setMaterialProgress(swiper, reduceMotion);
          },
        },
      });

      instances.set(section, { mediaSwiper, reviewsSwiper });
    };

    const initAll = (root = document) => {
      root.querySelectorAll(sectionSelector).forEach(initSection);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => initAll());
    } else {
      initAll();
    }

    document.addEventListener('shopify:section:load', (event) => initAll(event.target));

    document.addEventListener('shopify:section:unload', (event) => {
      const section = event.target.matches(sectionSelector)
        ? event.target
        : event.target.querySelector(sectionSelector);
      const instance = section ? instances.get(section) : null;
      if (!instance) return;
      instance.mediaSwiper.destroy(true, true);
      instance.reviewsSwiper.destroy(true, true);
      instances.delete(section);
    });

    document.addEventListener('shopify:block:select', (event) => {
      const section = event.target.closest(sectionSelector);
      const instance = section ? instances.get(section) : null;
      const slide = section ? section.querySelector(`[data-block-id="${event.detail.blockId}"]`) : null;
      if (!instance || !slide) return;
      instance.mediaSwiper.slideToLoop(Number(slide.dataset.reviewIndex), 300);
    });
  })();
{% endjavascript %}

{% schema %}
{
  "name": "Customer carousel",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What our customers are saying"
    },
    {
      "type": "richtext",
      "id": "subtext",
      "label": "Subtext",
      "default": "<p>Stories from people who live with our pieces every day.</p>"
    },
    {
      "type": "text",
      "id": "accessible_label",
      "label": "Accessible label",
      "default": "Customer reviews"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Auto-rotate reviews",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "label": "Auto-rotate delay",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Customer image" },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Handcrafted WRYDECO furniture in a customer home"
        },
        {
          "type": "select",
          "id": "fallback_image",
          "label": "Theme fallback image",
          "options": [
            { "value": "eff-1.jpg", "label": "Vanity scene" },
            { "value": "eff-2.jpg", "label": "Mirror console scene" },
            { "value": "eff-3.jpg", "label": "Branch lamp scene" },
            { "value": "eff-4.jpg", "label": "Tree shelf scene" },
            { "value": "eff-5.jpg", "label": "Library shelf scene" },
            { "value": "eff-6.jpg", "label": "Reading room scene" },
            { "value": "eff-7.jpg", "label": "Furniture scene 7" },
            { "value": "eff-8.jpg", "label": "Furniture scene 8" },
            { "value": "eff-9.jpg", "label": "Furniture scene 9" },
            { "value": "eff-10.jpg", "label": "Furniture scene 10" },
            { "value": "eff-11.jpg", "label": "Furniture scene 11" },
            { "value": "eff-12.jpg", "label": "Furniture scene 12" }
          ],
          "default": "eff-1.jpg"
        },
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "textarea",
          "id": "review_text",
          "label": "Review",
          "default": "Love the table and the craftsmanship. It feels made for our home and even better than the photos."
        },
        { "type": "text", "id": "author_name", "label": "Customer name", "default": "David N." },
        { "type": "checkbox", "id": "verified", "label": "Show verified badge", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customer carousel",
      "blocks": [
        {
          "type": "review",
          "settings": {
            "fallback_image": "eff-1.jpg",
            "review_text": "Love the table and the craftsmanship. Two things to be aware of: the piece is substantial and beautifully made.",
            "author_name": "David N."
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "eff-2.jpg",
            "review_text": "The grain and hand-shaped edges are even more beautiful in person. It changed the whole room.",
            "author_name": "Melissa O."
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "eff-3.jpg",
            "review_text": "Every guest asks who made it. The craftsmanship feels personal, thoughtful, and built to last.",
            "author_name": "Ryan C."
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "eff-4.jpg",
            "review_text": "Our shelf looks like it grew into the room. Installation was clear and the finish is flawless.",
            "author_name": "Nicole P."
          }
        },
        {
          "type": "review",
          "settings": {
            "fallback_image": "eff-5.jpg",
            "review_text": "A functional piece of art. The scale, warmth, and natural form are exactly what the space needed.",
            "author_name": "Jasmine W."
          }
        }
      ]
    }
  ]
}
{% endschema %}
