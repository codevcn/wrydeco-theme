<section class="mc" aria-labelledby="MaterialsCraftHeading-{{ section.id }}">
  <div class="mc__inner">
    <div class="mc__content">
      <header class="mc__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mc__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="mc__title" id="MaterialsCraftHeading-{{ section.id }}">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.intro != blank -%}
          <p class="mc__intro">{{ section.settings.intro | escape }}</p>
        {%- endif -%}
      </header>

      <div class="mc__body">
        <div class="mc__features" aria-label="Customization areas">
          <h3 class="mc__option-heading mc__features-heading">What you can customize</h3>
          <article class="mc__feature">
            <span class="mc__feature-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none">
                <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="1.1"/>
                <path d="M9 20h14M10 18v4M22 18v4M12 13h8M12 16h5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </span>
            <div>
              <h3>Size</h3>
              <p>Custom dimensions to perfectly fit your space</p>
            </div>
          </article>
          <article class="mc__feature">
            <span class="mc__feature-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none">
                <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="1.1"/>
                <circle cx="16" cy="16" r="7.4" stroke="currentColor" stroke-width="1.1"/>
                <circle cx="16" cy="16" r="3" stroke="currentColor" stroke-width="1.1"/>
                <path d="M16 3v5M16 24v5M3 16h5M24 16h5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"/>
              </svg>
            </span>
            <div>
              <h3>Wood</h3>
              <p>Curated hardwoods, responsibly sourced and built to last</p>
            </div>
          </article>
          <article class="mc__feature">
            <span class="mc__feature-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none">
                <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="1.1"/>
                <path d="m11 22 10-10 2 2-10 10H9v-4l10-10 2 2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <h3>Finish</h3>
              <p>Hand-finished for beauty, protection, and longevity</p>
            </div>
          </article>
          <article class="mc__feature">
            <span class="mc__feature-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none">
                <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="1.1"/>
                <path d="M17 6c-2 3-1.8 6 .7 8.8 2.6 2.9 2.2 6.2-1.1 10.2M11 24h10M12 8h8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
              </svg>
            </span>
            <div>
              <h3>Shape & Details</h3>
              <p>Edges, joinery, legs, and bespoke details of your choice</p>
            </div>
          </article>
          <article class="mc__feature">
            <span class="mc__feature-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none">
                <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="1.1"/>
                <path d="M10 10h5v5h-5v-5ZM18 10h4v4M10 18h4v4M17 17h5v5h-5v-5Z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <h3>Space Planning</h3>
              <p>Expert guidance to optimize flow, scale, and function</p>
            </div>
          </article>
          <article class="mc__feature">
            <span class="mc__feature-icon" aria-hidden="true">
              <svg viewBox="0 0 32 32" fill="none">
                <circle cx="16" cy="16" r="13" stroke="currentColor" stroke-width="1.1"/>
                <path d="m10.5 16.3 4 4 7.5-8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
            <div>
              <h3>Design Approval</h3>
              <p>Collaborate and approve every detail before we build</p>
            </div>
          </article>
        </div>

        <div class="mc__options">
          <div class="mc__option-group">
            <h3 class="mc__option-heading">{{ section.settings.materials_heading | escape }}</h3>
            <ul class="mc__wood-list" aria-label="{{ section.settings.materials_heading | escape }}">
              {%- for block in section.blocks -%}
                {%- if block.type == 'wood' -%}
                  <li class="mc__wood" {{ block.shopify_attributes }}>
                    <span class="mc__wood-swatch mc__wood-swatch--{{ block.settings.name | handleize }}"></span>
                    <span>{{ block.settings.name | escape }}</span>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          </div>

          <div class="mc__option-group">
            <h3 class="mc__option-heading">{{ section.settings.finish_heading | escape }}</h3>
            <ul class="mc__finish-list" aria-label="{{ section.settings.finish_heading | escape }}">
              <li><span class="mc__finish mc__finish--natural"></span><span>Natural Oil</span></li>
              <li><span class="mc__finish mc__finish--smoked"></span><span>Smoked</span></li>
              <li><span class="mc__finish mc__finish--dark"></span><span>Dark Brown</span></li>
              <li><span class="mc__finish mc__finish--black"></span><span>Matte Black</span></li>
            </ul>
          </div>

          <div class="mc__option-group mc__option-group--details">
            <h3 class="mc__option-heading">{{ section.settings.details_heading | escape }}</h3>
            <ul class="mc__detail-list" aria-label="{{ section.settings.details_heading | escape }}">
              <li>
                <img src="{{ 'sli-1.webp' | asset_url }}" alt="" loading="lazy" width="180" height="120">
                <span>Live Edge</span>
              </li>
              <li>
                <img src="{{ 'sli-2.webp' | asset_url }}" alt="" loading="lazy" width="180" height="120">
                <span>Curved Edge</span>
              </li>
              <li>
                <img src="{{ 'sli-3.webp' | asset_url }}" alt="" loading="lazy" width="180" height="120">
                <span>Carved Detail</span>
              </li>
              <li>
                <img src="{{ 'sli-4.webp' | asset_url }}" alt="" loading="lazy" width="180" height="120">
                <span>Brass Inlay</span>
              </li>
            </ul>
          </div>

          {%- if section.settings.footer_text != blank -%}
            <p class="mc__footer-text">{{ section.settings.footer_text | newline_to_br }}</p>
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.button_label != blank -%}
        <a class="mc__button" href="{{ section.settings.button_link | default: routes.root_url }}">
          <span>{{ section.settings.button_label | escape }}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <figure class="mc__visual">
      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 1100
          | image_tag:
            class: 'mc__visual-img',
            loading: 'lazy',
            widths: '520, 760, 940, 1100',
            sizes: '(min-width: 64rem) 42vw, 100vw'
        }}
      {%- else -%}
        <img
          class="mc__visual-img"
          src="{{ 'curated-collections-img-3.png' | asset_url }}"
          alt="Warm handcrafted wood furniture with natural light"
          loading="lazy"
          width="1100"
          height="1320"
        >
      {%- endif -%}
    </figure>
  </div>
</section>

{% stylesheet %}
  .mc {
    width: 100%;
    background:
      radial-gradient(circle at 14% 16%, rgba(255, 255, 255, 0.72), transparent 34%),
      linear-gradient(90deg, #fbf7f1 0%, #f3ede5 100%);
    color: var(--color-brown);
  }

  .mc__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.42fr) minmax(420px, 0.9fr);
    gap: 0;
    width: 100%;
    margin-inline: auto;
    align-items: stretch;
  }

  .mc__content {
    min-width: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
    padding: var(--section-padding-y, 80px) clamp(44px, 5.2vw, 96px);
  }

  .mc__header {
    max-width: 760px;
    margin-bottom: clamp(18px, 2vw, 28px);
  }

  .mc__eyebrow,
  .mc__option-heading {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--eyebrow-size, 12px);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--eyebrow-tracking, 0.3em);
    text-transform: uppercase;
    color: var(--color-brown);
  }

  .mc__title {
    margin: 14px 0 18px;
    font-family: var(--font-heading);
    font-size: var(--section-heading-size, 48px);
    font-weight: var(--font-weight-light);
    line-height: var(--section-heading-line, 1.02);
    letter-spacing: var(--section-heading-tracking, -0.02em);
    color: var(--color-text, #2b1a11);
    text-wrap: balance;
  }

  .mc__intro {
    max-width: 510px;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--section-subtitle-size, 15px);
    line-height: 1.6;
    color: var(--color-muted, #4b443f);
  }

  .mc__body {
    display: grid;
    grid-template-columns: minmax(240px, 0.74fr) minmax(0, 1.26fr);
    gap: clamp(20px, 2.8vw, 40px);
    align-items: stretch;
  }

  .mc__features {
    display: flex;
    flex-direction: column;
    height: 100%;
    border-right: 1px solid rgba(74, 44, 24, 0.13);
    padding-right: clamp(18px, 2vw, 32px);
  }

  .mc__features-heading {
    margin-bottom: 12px;
  }

  .mc__feature {
    display: grid;
    grid-template-columns: 46px minmax(0, 1fr);
    gap: 14px;
    align-items: center;
    flex: 1 1 auto;
    padding: 11px 0;
    border-bottom: 1px solid rgba(74, 44, 24, 0.12);
  }

  .mc__feature:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .mc__feature-icon {
    display: grid;
    place-items: center;
    width: 42px;
    height: 42px;
    border-radius: 999px;
    border: 1px solid rgba(74, 44, 24, 0.18);
    color: #5f4939;
  }

  .mc__feature-icon svg {
    width: 28px;
    height: 28px;
  }

  .mc__feature h3 {
    margin: 0 0 4px;
    font-family: var(--font-display);
    font-size: clamp(16px, 1.16vw, 19px);
    font-weight: var(--font-weight-regular);
    line-height: 1.1;
    color: var(--color-text, #2f2118);
  }

  .mc__feature p {
    margin: 0;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.4;
    color: var(--color-muted, #5f5852);
  }

  .mc__options {
    min-width: 0;
  }

  .mc__option-group {
    padding-bottom: 16px;
    margin-bottom: 16px;
    border-bottom: 1px solid var(--color-border, rgba(74, 44, 24, 0.14));
  }

  .mc__option-group--details {
    margin-bottom: 0;
    border-bottom: 0;
  }

  .mc__option-heading {
    margin-bottom: 12px;
    font-size: 11px;
  }

  .mc__wood-list,
  .mc__finish-list,
  .mc__detail-list {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .mc__wood-list {
    grid-template-columns: repeat(5, minmax(48px, 1fr));
    justify-content: space-between;
  }

  .mc__finish-list {
    grid-template-columns: repeat(4, minmax(54px, 1fr));
    justify-content: space-between;
  }

  .mc__detail-list {
    grid-template-columns: repeat(4, minmax(52px, 1fr));
    justify-content: space-between;
  }

  .mc__wood,
  .mc__finish-list li,
  .mc__detail-list li {
    min-width: 0;
    margin: 0;
    text-align: center;
    font-family: var(--font-body);
    font-size: 12px;
    line-height: 1.25;
    color: #2f2a26;
  }

  .mc__wood-swatch,
  .mc__finish,
  .mc__detail-list img {
    display: block;
    width: 100%;
    border: 1px solid rgba(74, 44, 24, 0.1);
    border-radius: var(--card-radius, 6px);
    margin-bottom: 8px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .mc__wood-swatch {
    aspect-ratio: 0.88 / 1.12;
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.08), transparent 22%, rgba(0, 0, 0, 0.08) 62%, transparent),
      repeating-linear-gradient(96deg, rgba(255, 255, 255, 0.08) 0 2px, transparent 2px 9px),
      linear-gradient(105deg, #4d2d17, #1f1209 40%, #7b4d2b 72%, #2a170d);
  }

  .mc__wood-swatch--light-oak,
  .mc__wood-swatch--oak {
    background: linear-gradient(105deg, #c79250, #e0b676 38%, #a46831 68%, #d3a05a);
  }

  .mc__wood-swatch--ash {
    background: linear-gradient(105deg, #ead9bd, #f7ead3 38%, #d6c1a3 66%, #f4e2c6);
  }

  .mc__wood-swatch--cherry {
    background: linear-gradient(105deg, #8c3f1d, #b25d2f 42%, #703015 78%, #c06a35);
  }

  .mc__wood-swatch--maple {
    background: linear-gradient(105deg, #f2ddbc, #fff1d6 42%, #dbc49f 70%, #f8e6c8);
  }

  .mc__finish {
    aspect-ratio: 1.28 / 1;
  }

  .mc__finish--natural {
    background: linear-gradient(105deg, #c8985f, #e2b77b 46%, #b1783e);
  }

  .mc__finish--smoked {
    background: linear-gradient(105deg, #705f50, #9b8878 45%, #59483c);
  }

  .mc__finish--dark {
    background: linear-gradient(105deg, #3a1e10, #62351c 48%, #241108);
  }

  .mc__finish--black {
    background: linear-gradient(105deg, #181817, #2d2d2b 45%, #090909);
  }

  .mc__detail-list img {
    aspect-ratio: 1.18 / 1;
    object-fit: cover;
  }

  .mc__footer-text {
    margin: 20px 0 0;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-muted, #463d37);
  }

  .mc__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    width: min(100%, 352px);
    min-height: var(--btn-height, 52px);
    margin-top: clamp(20px, 2.4vw, 32px);
    padding: 0 var(--btn-padding-x, 32px);
    border-radius: var(--btn-radius, 4px);
    background: var(--color-brown, #4a2c18);
    color: #fff8f0;
    font-family: var(--font-body);
    font-size: var(--btn-font-size, 14px);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    box-shadow: 0 14px 30px rgba(59, 31, 15, 0.12);
    transition:
      transform var(--timing-short) var(--ease-standard),
      background-color var(--timing-short) var(--ease-standard),
      box-shadow var(--timing-short) var(--ease-standard);
  }

  .mc__button svg {
    width: 15px;
    height: 15px;
    transition: transform var(--timing-short) var(--ease-standard);
  }

  .mc__visual {
    align-self: stretch;
    min-width: 0;
    min-height: 0;
    height: 100%;
    margin: 0;
    overflow: hidden;
    background: #ded2c3;
  }

  .mc__visual-img {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    object-position: center;
  }

  @media (hover: hover) {
    .mc__button:hover {
      color: #fff8f0;
      background: var(--color-brown-dark, #2f1a0d);
      transform: translateY(-2px);
      box-shadow: 0 18px 34px rgba(59, 31, 15, 0.18);
    }

    .mc__button:hover svg {
      transform: translateX(4px);
    }
  }

  .mc :is(a, button):focus-visible {
    outline: 3px solid rgba(122, 137, 104, 0.38);
    outline-offset: 4px;
  }

  @media screen and (max-width: 82rem) {
    .mc__inner {
      grid-template-columns: minmax(0, 1fr);
    }

    .mc__content {
      padding: 56px 32px;
    }

    .mc__visual {
      height: 340px;
    }
  }

  @media screen and (max-width: 48rem) {
    .mc__content {
      padding: 48px 18px 52px;
    }

    .mc__body {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .mc__features {
      border-right: 0;
      padding-right: 0;
    }

    .mc__wood-list {
      grid-template-columns: repeat(3, minmax(0, 76px));
      justify-content: start;
    }

    .mc__finish-list,
    .mc__detail-list {
      grid-template-columns: repeat(2, minmax(0, 108px));
      justify-content: start;
    }

    .mc__button {
      width: 100%;
      min-width: 0;
    }
  }

{% endstylesheet %}

{% schema %}
{
  "name": "Materials & Craftsmanship",
  "tag": "section",
  "class": "section section-materials-craft",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Materials & personalization" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Tailored to Your Space, Your Style, Your Story" },
    { "type": "textarea", "id": "intro", "label": "Intro", "default": "Every WRYDECO piece is made to order--crafted from exceptional materials and tailored to your space, your lifestyle, and your vision." },
    { "type": "text", "id": "materials_heading", "label": "Wood heading", "default": "Choose your wood" },
    { "type": "text", "id": "finish_heading", "label": "Finish heading", "default": "Select your finish" },
    { "type": "text", "id": "details_heading", "label": "Details heading", "default": "Custom details & accents" },
    { "type": "textarea", "id": "footer_text", "label": "Footer text", "default": "Personalized service. Exceptional craftsmanship.\nDesigned around you." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Start Your Custom Request" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "hero_image", "label": "Right side image" }
  ],
  "blocks": [
    {
      "type": "wood",
      "name": "Wood swatch",
      "settings": [
        { "type": "text", "id": "name", "label": "Name", "default": "Walnut" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Materials & Craftsmanship",
      "blocks": [
        { "type": "wood", "settings": { "name": "Walnut" } },
        { "type": "wood", "settings": { "name": "Oak" } },
        { "type": "wood", "settings": { "name": "Ash" } },
        { "type": "wood", "settings": { "name": "Cherry" } },
        { "type": "wood", "settings": { "name": "Maple" } }
      ]
    }
  ]
}
{% endschema %}
