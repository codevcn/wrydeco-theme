<section class="mc" aria-labelledby="MaterialsCraftHeading-{{ section.id }}">
  <div class="mc__inner">
    <div class="mc__content">
      <header class="mc__header">
        {%- if section.settings.eyebrow != blank -%}
          <p class="mc__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        <h2 class="mc__title" id="MaterialsCraftHeading-{{ section.id }}">
          {{ section.settings.heading | escape }}
        </h2>
        {%- if section.settings.intro != blank -%}
          <p class="mc__intro">{{ section.settings.intro | escape }}</p>
        {%- endif -%}
      </header>

      <div class="mc__body">
        <div class="mc__options">
          <div class="mc__option-group">
            <h3 class="mc__option-heading">{{ section.settings.materials_heading | escape }}</h3>
            <ul class="mc__wood-list" aria-label="{{ section.settings.materials_heading | escape }}">
              {%- for block in section.blocks -%}
                <li class="mc__wood">
                  {%- assign image_index = forloop.index -%}
                  <img
                    class="mc__wood-swatch mc__wood-swatch--{{ block.settings.name | handleize }}"
                    alt=""
                    loading="lazy"
                    width="48"
                    height="48"
                    src="{{ 'ic-wood-type-' | append: image_index | append: '.png' | file_url }}"
                  >
                  <span>{{ block.settings.name | escape }}</span>
                </li>
              {%- endfor -%}
            </ul>
          </div>

          <div class="mc__option-group">
            <h3 class="mc__option-heading">{{ section.settings.finish_heading | escape }}</h3>
            <ul class="mc__finish-list" aria-label="{{ section.settings.finish_heading | escape }}">
              <li>
                <img
                  class="mc__wood-swatch mc__wood-swatch--{{ block.settings.name | handleize }}"
                  alt=""
                  loading="lazy"
                  width="48"
                  height="48"
                  src="{{ 'ic-footer-your-finish-1.png' | file_url }}"

                ><span>Natural Oil</span>
              </li>
              <li>
                <img
                  class="mc__wood-swatch mc__wood-swatch--{{ block.settings.name | handleize }}"
                  alt=""
                  loading="lazy"
                  width="48"
                  height="48"
                  src="{{ 'ic-footer-your-finish-2.png' | file_url }}"

                ><span>Smoked</span>
              </li>
              <li>
                <img
                  class="mc__wood-swatch mc__wood-swatch--{{ block.settings.name | handleize }}"
                  alt=""
                  loading="lazy"
                  width="48"
                  height="48"
                  src="{{ 'ic-footer-your-finish-3.png' | file_url }}"

                ><span>Dark Brown</span>
              </li>
              <li>
                <img
                  class="mc__wood-swatch mc__wood-swatch--{{ block.settings.name | handleize }}"
                  alt=""
                  loading="lazy"
                  width="48"
                  height="48"
                  src="{{ 'ic-footer-your-finish-4.png' | file_url }}"

                ><span>Matte Black</span>
              </li>
            </ul>
          </div>

          <div class="mc__option-group mc__option-group--details">
            <h3 class="mc__option-heading">{{ section.settings.details_heading | escape }}</h3>
            <ul class="mc__detail-list" aria-label="{{ section.settings.details_heading | escape }}">
              <li>
                <img src="{{ 'ic-your-style-room-1.png' | file_url }}" alt="" loading="lazy" width="180" height="120">
                <span>Live Edge</span>
              </li>
              <li>
                <img src="{{ 'ic-your-style-room-2.png' | file_url }}" alt="" loading="lazy" width="180" height="120">
                <span>Curved Edge</span>
              </li>
              <li>
                <img src="{{ 'ic-your-style-room-3.png' | file_url }}" alt="" loading="lazy" width="180" height="120">
                <span>Carved Detail</span>
              </li>
              <li>
                <img src="{{ 'ic-your-style-room-4.png' | file_url }}" alt="" loading="lazy" width="180" height="120">
                <span>Brass Inlay</span>
              </li>
            </ul>
          </div>
        </div>
      </div>

      {%- if section.settings.button_label != blank -%}
        <a class="mc__button" href="{{ section.settings.button_link | default: routes.root_url }}">
          <span>{{ section.settings.button_label | escape }}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <figure class="mc__visual">
      {%- assign hero_image_alt = section.settings.hero_image.alt | default: section.settings.heading | default: 'Warm handcrafted wood furniture with natural light' -%}
      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 1100
          | image_tag:
            class: 'mc__visual-img',
            loading: 'lazy',
            widths: '520, 760, 940, 1100',
            sizes: '(min-width: 64rem) 42vw, 100vw',
            alt: hero_image_alt
        }}
      {%- else -%}
        <img
          class="mc__visual-img"
          src="{{ 'curated-collections-img-3.png' | file_url }}"
          alt="{{ hero_image_alt | escape }}"
          loading="lazy"
          width="1100"
          height="1320"
        >
      {%- endif -%}
    </figure>
  </div>
</section>

{% stylesheet %}
  .mc {
    width: 100%;
    background: radial-gradient(circle at 14% 16%, rgba(255, 255, 255, 0.72), transparent 34%),
      linear-gradient(90deg, #fbf7f1 0%, #f3ede5 100%);
    color: var(--color-brown);
  }

  .mc__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(520px, 0.9fr);
    gap: 0;
    width: 100%;
    margin-inline: auto;
    align-items: stretch;
  }

  .mc__content {
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    box-sizing: border-box;
    padding-block: clamp(var(--sp-5), 2.2vw, var(--sp-7));
    padding-inline: clamp(var(--sp-6), 4.2vw, var(--sp-10));
  }

  .mc__header {
    max-width: calc(var(--layout-max-width) - (var(--sp-12) * 3));
    margin-bottom: clamp(var(--sp-3), 1.2vw, var(--sp-5));
  }

  .mc__eyebrow,
  .mc__option-heading {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--eyebrow-size, 12px);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.05rem;
    text-transform: uppercase;
    color: var(--color-brown);
  }

  .mc__title {
    margin: var(--sp-2) var(--sp-0) var(--sp-3);
    font-family: var(--font-heading);
    font-size: clamp(var(--font-size-display-md), 2.7vw, var(--font-size-display-xl));
    font-weight: var(--font-weight-light);
    line-height: var(--section-heading-line, 1.02);
    letter-spacing: var(--section-heading-tracking, -0.02em);
    color: var(--color-text, #2b1a11);
    text-wrap: balance;
  }

  .mc__intro {
    max-width: calc(var(--layout-max-width) - (var(--sp-12) * 5));
    margin: var(--sp-0);
    font-family: var(--font-body);
    font-size: clamp(var(--font-size-body-sm), 0.9vw, var(--font-size-body-md));
    line-height: var(--line-height-relaxed);
    color: var(--color-muted, #4b443f);
  }

  .mc__body {
    display: flex;
    flex-direction: column;
    width: 100%;
    gap: clamp(var(--sp-5), 2vw, var(--sp-6));
    align-items: stretch;
  }

  .mc__feature {
    display: grid;
    grid-template-columns: var(--sp-7) minmax(0, 1fr);
    gap: var(--sp-3);
    align-items: center;
    flex: 1 1 auto;
    padding: clamp(var(--sp-1), 0.45vw, var(--sp-2)) var(--sp-0);
    border-bottom: 1px solid rgba(74, 44, 24, 0.12);
  }

  .mc__feature:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .mc__feature-icon {
    display: grid;
    place-items: center;
    width: clamp(var(--sp-6), 2.3vw, calc(var(--sp-6) + var(--sp-2)));
    height: clamp(var(--sp-6), 2.3vw, calc(var(--sp-6) + var(--sp-2)));
    border-radius: 999px;
    border: 1px solid rgba(74, 44, 24, 0.18);
    color: #5f4939;
  }

  .mc__feature-icon svg {
    width: var(--sp-5);
    height: var(--sp-5);
  }

  .mc__feature h3 {
    margin: var(--sp-0) var(--sp-0) var(--sp-1);
    font-family: var(--font-display);
    font-size: clamp(var(--font-size-body-sm), 1vw, var(--font-size-body-lg));
    font-weight: var(--font-weight-regular);
    line-height: 1.1;
    color: var(--color-text, #2f2118);
  }

  .mc__feature p {
    margin: var(--sp-0);
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-normal);
    color: var(--color-muted, #5f5852);
  }

  .mc__options {
    min-width: 0;
  }

  .mc__option-group {
    padding-bottom: var(--sp-3);
    margin-bottom: var(--sp-3);
    border-bottom: 1px solid var(--color-border, rgba(74, 44, 24, 0.14));
  }

  .mc__option-group--details {
    margin-bottom: 0;
    border-bottom: 0;
  }

  .mc__option-heading {
    margin-bottom: var(--sp-2);
    font-size: var(--font-size-caption);
  }

  .mc__wood-list,
  .mc__finish-list,
  .mc__detail-list {
    display: grid;
    gap: var(--sp-2);
    margin: var(--sp-0);
    padding: var(--sp-0);
    list-style: none;
  }

  .mc__wood-list {
    grid-template-columns: repeat(5, minmax(48px, 1fr));
    justify-content: space-between;
  }

  .mc__finish-list {
    grid-template-columns: repeat(4, minmax(54px, 1fr));
    justify-content: space-between;
  }

  .mc__detail-list {
    grid-template-columns: repeat(4, minmax(52px, 1fr));
    justify-content: space-between;
  }

  .mc__wood,
  .mc__finish-list li,
  .mc__detail-list li {
    min-width: 0;
    margin: var(--sp-0);
    text-align: center;
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    line-height: 1.25;
    color: #2f2a26;
  }

  .mc__wood-swatch,
  .mc__finish,
  .mc__detail-list img {
    display: block;
    width: 100%;
    border: 1px solid rgba(74, 44, 24, 0.1);
    border-radius: var(--card-radius, 6px);
    margin-bottom: var(--sp-2);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.22);
  }

  .mc__wood-swatch {
    height: clamp(var(--sp-8), 4.4vw, var(--sp-10));
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.08), transparent 22%, rgba(0, 0, 0, 0.08) 62%, transparent),
      repeating-linear-gradient(96deg, rgba(255, 255, 255, 0.08) 0 2px, transparent 2px 9px),
      linear-gradient(105deg, #4d2d17, #1f1209 40%, #7b4d2b 72%, #2a170d);
  }

  .mc__wood-swatch--light-oak,
  .mc__wood-swatch--oak {
    background: linear-gradient(105deg, #c79250, #e0b676 38%, #a46831 68%, #d3a05a);
  }

  .mc__wood-swatch--ash {
    background: linear-gradient(105deg, #ead9bd, #f7ead3 38%, #d6c1a3 66%, #f4e2c6);
  }

  .mc__wood-swatch--cherry {
    background: linear-gradient(105deg, #8c3f1d, #b25d2f 42%, #703015 78%, #c06a35);
  }

  .mc__wood-swatch--maple {
    background: linear-gradient(105deg, #f2ddbc, #fff1d6 42%, #dbc49f 70%, #f8e6c8);
  }

  .mc__finish {
    height: clamp(var(--sp-7), 3.8vw, var(--sp-9));
  }

  .mc__finish--natural {
    background: linear-gradient(105deg, #c8985f, #e2b77b 46%, #b1783e);
  }

  .mc__finish--smoked {
    background: linear-gradient(105deg, #705f50, #9b8878 45%, #59483c);
  }

  .mc__finish--dark {
    background: linear-gradient(105deg, #3a1e10, #62351c 48%, #241108);
  }

  .mc__finish--black {
    background: linear-gradient(105deg, #181817, #2d2d2b 45%, #090909);
  }

  .mc__detail-list img {
    height: clamp(var(--sp-7), 3.8vw, var(--sp-9));
    object-fit: cover;
  }

  .mc__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    width: min(100%, calc(var(--sp-12) * 2 + var(--sp-11)));
    min-height: var(--sp-7);
    margin-top: clamp(var(--sp-3), 1.2vw, var(--sp-4));
    padding-inline: var(--sp-6);
    border-radius: var(--btn-radius, 4px);
    background: var(--color-brown, #4a2c18);
    color: #fff8f0;
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    box-shadow: 0 14px 30px rgba(59, 31, 15, 0.12);
    transition: transform var(--timing-short) var(--ease-standard),
      background-color var(--timing-short) var(--ease-standard), box-shadow var(--timing-short) var(--ease-standard);
  }

  .mc__button svg {
    width: 15px;
    height: 15px;
    transition: transform var(--timing-short) var(--ease-standard);
  }

  .mc__visual {
    position: relative;
    align-self: stretch;
    min-width: 0;
    min-height: 0;
    height: auto;
    margin: 0;
    overflow: hidden;
    background: #ded2c3;
  }

  .mc__visual-img {
    position: absolute;
    inset: var(--sp-0);
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    object-position: center;
  }

  @media (hover: hover) {
    .mc__button:hover {
      color: #fff8f0;
      background: var(--color-brown-dark, #2f1a0d);
      transform: translateY(-2px);
      box-shadow: 0 18px 34px rgba(59, 31, 15, 0.18);
    }

    .mc__button:hover svg {
      transform: translateX(4px);
    }
  }

  .mc :is(a, button):focus-visible {
    outline: 3px solid rgba(122, 137, 104, 0.38);
    outline-offset: 4px;
  }

  @media screen and (max-width: 82rem) {
    .mc__inner {
      grid-template-columns: minmax(0, 1fr);
    }

    .mc__content {
      padding: 56px 32px;
    }

    .mc__visual {
      height: 340px;
    }
  }

  @media screen and (max-width: 48rem) {
    .mc__content {
      padding: 48px 18px 52px;
    }

    .mc__body {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .mc__wood-list {
      grid-template-columns: repeat(3, minmax(0, 76px));
      justify-content: start;
    }

    .mc__finish-list,
    .mc__detail-list {
      grid-template-columns: repeat(2, minmax(0, 108px));
      justify-content: start;
    }

    .mc__button {
      width: 100%;
      min-width: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Materials & Craftsmanship",
  "tag": "section",
  "class": "section section-materials-craft",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Materials & personalization" },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Tailored to Your Space, Your Style, Your Story"
    },
    { "type": "text", "id": "materials_heading", "label": "Wood heading", "default": "Choose your wood" },
    { "type": "text", "id": "finish_heading", "label": "Finish heading", "default": "Select your finish" },
    { "type": "text", "id": "details_heading", "label": "Details heading", "default": "Custom details & accents" },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer text",
      "default": "Personalized service. Exceptional craftsmanship.\nDesigned around you."
    },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Start Your Custom Request" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "image_picker", "id": "hero_image", "label": "Right side image" }
  ],
  "blocks": [
    {
      "type": "wood",
      "name": "Wood swatch",
      "settings": [{ "type": "text", "id": "name", "label": "Name", "default": "Walnut" }]
    }
  ],
  "presets": [
    {
      "name": "Materials & Craftsmanship",
      "blocks": [
        { "type": "wood", "settings": { "name": "Walnut" } },
        { "type": "wood", "settings": { "name": "Oak" } },
        { "type": "wood", "settings": { "name": "Ash" } },
        { "type": "wood", "settings": { "name": "Cherry" } },
        { "type": "wood", "settings": { "name": "Maple" } }
      ]
    }
  ]
}
{% endschema %}
