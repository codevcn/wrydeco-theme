{% comment %}
  Để chỉnh số lượng sản phẩm hiển thị trong mục "For you, today":
  - Cách 1 (Local Code): Mở file `templates/index.json`, tìm đến section `for_you_masonry` và sửa/thêm thông số `"products_to_show": 20`.
  - Cách 2 (Shopify Admin): Vào Theme Editor -> Chọn section "For You Masonry" -> Kéo thanh trượt "Maximum products to show".
{% endcomment %}

{% style %}
  /* .section-container--{{ section.id }} {
    background-color: #f3f3f3;
  } */
{% endstyle %}
<div class="for-you-masonry page-width section-container--{{ section.id }}">
  <div class="for-you-masonry__header">
    <h2 class="for-you-masonry__heading">{{ section.settings.heading }}</h2>
    <div class="for-you-masonry__filters">
      <button class="filter-btn active">All</button>
      <button class="filter-btn">Newest</button>
      <button class="filter-btn">Under $2000</button>
    </div>
  </div>

  <div class="for-you-masonry__grid">
    {%- assign collection = section.settings.collection -%}
    {%- if collection == blank -%}
      {%- assign collection = collections['for-you-today'] -%}
    {%- endif -%}
    {%- assign products_to_show = section.settings.products_to_show | default: 20 -%}
    {%- for product in collection.products limit: products_to_show -%}
      {%- capture image_ratio -%}{% cycle 'portrait', 'tall', 'square', 'portrait', 'landscape', 'tall', 'portrait', 'square' %}{%- endcapture -%}
      <div
        class="pin-card pin-card--{{ image_ratio }}"
      >
        <div class="pin-card__image-wrapper">
          <a href="{{ product.url }}" style="display: block; width: 100%; height: 100%;">
            {%- if product.featured_media != blank -%}
              {{
                product.featured_media.preview_image
                | image_url: width: 600
                | image_tag: class: 'pin-card__image', loading: 'lazy'
              }}
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'pin-card__image placeholder-svg' }}
            {%- endif -%}
          </a>

          {%- if product.available -%}
            {% form 'product', product %}
              <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
              <button type="submit" name="add" class="pin-card__save-btn btn-pill btn-pill--red">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  fill="currentColor"
                  class="bi bi-cart"
                  viewBox="0 0 16 16"
                  stroke-width="3"
                >
                  <path d="M0 1.5A.5.5 0 0 1 .5 1H2a.5.5 0 0 1 .485.379L2.89 3H14.5a.5.5 0 0 1 .491.592l-1.5 8A.5.5 0 0 1 13 12H4a.5.5 0 0 1-.491-.408L2.01 3.607 1.61 2H.5a.5.5 0 0 1-.5-.5M3.102 4l1.313 7h8.17l1.313-7zM5 12a2 2 0 1 0 0 4 2 2 0 0 0 0-4m7 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4m-7 1a1 1 0 1 1 0 2 1 1 0 0 1 0-2m7 0a1 1 0 1 1 0 2 1 1 0 0 1 0-2"/>
                </svg>
              </button>
            {% endform %}
          {%- else -%}
            <button class="pin-card__save-btn btn-pill btn-pill--red" disabled>Sold out</button>
          {%- endif -%}

          <div class="pin-card__hover">
            <div class="pin-card__hover-top">
              <button class="btn-pill btn-pill--white">
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  style="margin-right: 4px;"
                >
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect><circle cx="8.5" cy="8.5" r="1.5"></circle><polyline points="21 15 16 10 5 21"></polyline>
                </svg>
                {{ collection.title | default: 'tree bookshelf' }}
              </button>
            </div>
            <div class="pin-card__hover-bottom">
              <div class="pin-card__hover-actions">
                <button class="btn-icon">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"></line><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"></line>
                  </svg>
                </button>
                <button class="btn-icon">
                  <svg
                    width="16"
                    height="16"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <circle cx="12" cy="12" r="1"></circle><circle cx="19" cy="12" r="1"></circle><circle cx="5" cy="12" r="1"></circle>
                  </svg>
                </button>
              </div>
              <a href="{{ product.url }}" class="btn-pill btn-pill--red btn-pill--shop">
                Shop now
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  style="margin-left: 4px;"
                >
                  <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>
        </div>

        <div class="pin-card__info">
          <h3 class="pin-card__title">
            <a href="{{ product.url }}" style="text-decoration: none; color: inherit;">
              {{ product.title | escape }}
            </a>
          </h3>
          <div class="pin-card__meta">
            <div class="pin-card__author">
              <div class="pin-card__avatar">
                <svg viewBox="0 0 24 24" fill="#333" width="100%" height="100%">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                </svg>
              </div>
              <span class="pin-card__author-name">{{ product.vendor | default: 'Ngoc Vo' | escape }}</span>
            </div>
            <div class="pin-card__price">
              {{ product.price | money }}
            </div>
          </div>
        </div>
      </div>
    {%- else -%}
      {%- for i in (1..5) -%}
        {%- capture image_ratio -%}{% cycle 'portrait', 'tall', 'square', 'portrait', 'landscape' %}{%- endcapture -%}
        <div class="pin-card pin-card--{{ image_ratio }}">
          <div class="pin-card__image-wrapper">
            {{ 'product-' | append: i | placeholder_svg_tag: 'pin-card__image placeholder-svg' }}
          </div>
          <div class="pin-card__info">
            <h3 class="pin-card__title">Example Product Title</h3>
            <div class="pin-card__meta">
              <div class="pin-card__price">$1,087.00</div>
            </div>
          </div>
        </div>
      {%- endfor -%}
    {%- endfor -%}
  </div>

  {%- if collection.all_products_count > products_to_show -%}
    <div class="for-you-masonry__footer">
      <a href="{{ collection.url }}" class="btn-pill btn-pill--black btn-pill--large">
        View all products
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          style="margin-left: 8px;"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .for-you-masonry {
    padding: 40px 8px 40px;
  }

  .for-you-masonry__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 24px;
  }

  .for-you-masonry__heading {
    font-weight: 500;
    margin: 0;
  }
  .for-you-masonry__heading em {
    color: var(--color-2, #e60023);
    font-style: italic;
  }

  .for-you-masonry__filters {
    display: flex;
    gap: 12px;
  }

  .filter-btn {
    border: 1px solid #c8c8c8;
    background: transparent;
    border-radius: 99px;
    padding: 6px 20px;
    font-size: 15px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s;
  }
  .filter-btn.active {
    background: #111;
    color: #fff;
    border-color: #111;
  }

  /* Masonry Grid */
  .for-you-masonry__grid {
    column-count: 2;
    column-gap: 10px;
  }
  @media screen and (min-width: 768px) {
    .for-you-masonry__grid {
      column-count: 3;
    }
  }
  @media screen and (min-width: 1024px) {
    .for-you-masonry__grid {
      column-count: 5;
    }
  }

  .pin-card {
    display: block;
    break-inside: avoid;
    page-break-inside: avoid;
    margin-bottom: 18px;
    border-radius: 12px;
    overflow: hidden;
    background-color: #fff;
  }

  .pin-card--tall .pin-card__image-wrapper {
    aspect-ratio: 3 / 5;
  }
  .pin-card--portrait .pin-card__image-wrapper {
    aspect-ratio: 4 / 5;
  }
  .pin-card--square .pin-card__image-wrapper {
    aspect-ratio: 1 / 1;
  }
  .pin-card--landscape .pin-card__image-wrapper {
    aspect-ratio: 4 / 3;
  }
  .pin-card--wide .pin-card__image-wrapper {
    aspect-ratio: 16 / 9;
  }

  .pin-card__image-wrapper {
    position: relative;
    overflow: hidden;
    margin-bottom: 12px;
    width: 100%;
  }

  .pin-card__image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    position: absolute;
    top: 0;
    left: 0;
  }

  .pin-card__save-btn {
    position: absolute;
    top: 6px;
    left: 6px;
    z-index: 5;
    font-size: 15px;
    padding: 6px 6px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    font-weight: 700;
    color: #fff;
  }

  /* Hover overlay */
  .pin-card__hover {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.35);
    flex-direction: column;
    justify-content: space-between;
    padding: 12px;
    opacity: 0;
    transition: opacity 0.2s ease;
    pointer-events: none;
  }
  .pin-card__image-wrapper:hover .pin-card__hover {
    opacity: 1;
    pointer-events: auto;
  }

  @media screen and (min-width: 768px) {
    .pin-card__hover {
      display: flex;
    }
  }

  .pin-card__hover-top {
    display: flex;
    justify-content: flex-end;
    align-items: flex-start;
  }

  .pin-card__hover-bottom {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }

  .pin-card__hover-actions {
    display: flex;
    gap: 8px;
  }

  .btn-pill {
    display: inline-flex;
    align-items: center;
    padding: 8px 16px;
    border-radius: 99px;
    font-weight: 700;
    font-size: 14px;
    border: none;
    cursor: pointer;
    text-decoration: none;
  }
  .btn-pill--white {
    background: rgba(255, 255, 255, 0.95);
    color: #111;
  }
  .btn-pill--white:hover {
    background: #fff;
  }
  .btn-pill--red {
    background: #e6002362;
    color: #fff;
  }
  .btn-pill--red:hover {
    background: #c5001d;
  }
  .btn-pill--black {
    background: #111;
    color: #fff;
  }
  .btn-pill--black:hover {
    background: #000;
  }
  .btn-pill--shop {
    padding: 10px 14px 10px 18px;
  }
  .btn-pill--large {
    padding: 16px 32px;
    font-size: 16px;
  }

  .btn-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.95);
    border: none;
    cursor: pointer;
    color: #111;
  }
  .btn-icon:hover {
    background: #fff;
  }

  .pin-card__info {
    padding: 0 8px 8px 8px;
  }

  /* Info part */
  .pin-card__title {
    font-size: 14px;
    font-weight: 500;
    margin: 0 0 8px 0;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pin-card__meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
  }

  .pin-card__author {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .pin-card__avatar {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: #f1f1f1;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .pin-card__author-name {
    font-weight: 500;
    color: #333;
  }
  .pin-card__price {
    font-weight: 600;
  }

  .for-you-masonry__footer {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "For You Masonry",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "html",
      "id": "heading",
      "label": "Heading",
      "default": "For <em>you</em>, today"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 4,
      "max": 24,
      "step": 1,
      "default": 20,
      "label": "Maximum products to show"
    }
  ],
  "presets": [
    {
      "name": "For You Masonry"
    }
  ]
}
{% endschema %}
