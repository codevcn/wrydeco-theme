{%- liquid
  assign question_limit = section.settings.max_questions | default: 7
  assign rendered_questions = 0
  assign consultation_url = section.settings.consultation_url | default: pages.customization.url | default: routes.root_url
-%}

<div class="faq-page" id="faq-page-{{ section.id }}">
  <section class="faq-page__hero" aria-labelledby="faq-title-{{ section.id }}">
    <div class="faq-page__hero-media" aria-hidden="true">
      {%- if section.settings.hero_image != blank -%}
        {{
          section.settings.hero_image
          | image_url: width: 2400
          | image_tag:
            widths: '960, 1440, 1920, 2400',
            sizes: '100vw',
            loading: 'eager',
            fetchpriority: 'high',
            alt: section.settings.hero_image_alt
        }}
      {%- else -%}
        <img
          src="{{ 'collection-top-banner.png' | file_url }}"
          width="2048"
          height="512"
          alt="{{ section.settings.hero_image_alt | escape }}"
          loading="eager"
          fetchpriority="high"
        >
      {%- endif -%}
    </div>

    <div class="faq-page__hero-inner">
      <nav class="faq-page__breadcrumb" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">{{ section.settings.home_label | escape }}</a>
        <span aria-hidden="true">/</span>
        <span aria-current="page">{{ section.settings.breadcrumb_label | escape }}</span>
      </nav>

      <h1 class="faq-page__title" id="faq-title-{{ section.id }}">
        {%- if section.settings.heading_first_line != blank and section.settings.heading_second_line != blank -%}
          <span class="faq-page__title-line">{{ section.settings.heading_first_line | escape }}</span>
          <span class="faq-page__title-line">{{ section.settings.heading_second_line | escape }}</span>
        {%- else -%}
          {{ section.settings.heading | escape }}
        {%- endif -%}
      </h1>
      <div class="faq-page__intro rte">{{ section.settings.intro }}</div>
    </div>
  </section>

  <section class="faq-page__content" aria-label="{{ section.settings.questions_label | escape }}">
    <div class="faq-page__content-inner">
      <header class="faq-page__content-header">
        <p class="faq-page__content-eyebrow">{{ section.settings.content_eyebrow | escape }}</p>
        <h2 class="faq-page__content-title">{{ section.settings.content_heading | escape }}</h2>
        <div class="faq-page__content-ornament" aria-hidden="true">
          <span></span>
          <b>{{ section.settings.content_mark | escape }}</b>
          <span></span>
        </div>
      </header>

      <div class="faq-page__categories" role="tablist" aria-label="{{ section.settings.categories_label | escape }}">
        <button
          class="faq-page__category is-active"
          type="button"
          role="tab"
          aria-selected="true"
          data-faq-filter="all"
        >
          {{ section.settings.all_label | escape }}
        </button>
        <button class="faq-page__category" type="button" role="tab" aria-selected="false" data-faq-filter="shipping">
          <span class="faq-page__category-icon">{% render 'faq-category-icon', icon: 'shipping' %}</span>
          {{ section.settings.shipping_label | escape }}
        </button>
        <button
          class="faq-page__category"
          type="button"
          role="tab"
          aria-selected="false"
          data-faq-filter="custom-orders"
        >
          <span class="faq-page__category-icon">{% render 'faq-category-icon', icon: 'custom-orders' %}</span>
          {{ section.settings.custom_orders_label | escape }}
        </button>
        <button
          class="faq-page__category"
          type="button"
          role="tab"
          aria-selected="false"
          data-faq-filter="materials-care"
        >
          <span class="faq-page__category-icon">{% render 'faq-category-icon', icon: 'materials-care' %}</span>
          {{ section.settings.materials_care_label | escape }}
        </button>
        <button class="faq-page__category" type="button" role="tab" aria-selected="false" data-faq-filter="returns">
          <span class="faq-page__category-icon">{% render 'faq-category-icon', icon: 'returns' %}</span>
          {{ section.settings.returns_label | escape }}
        </button>
        <button class="faq-page__category" type="button" role="tab" aria-selected="false" data-faq-filter="payments">
          <span class="faq-page__category-icon">{% render 'faq-category-icon', icon: 'payments' %}</span>
          {{ section.settings.payments_label | escape }}
        </button>
        <button
          class="faq-page__category"
          type="button"
          role="tab"
          aria-selected="false"
          data-faq-filter="production-timeline"
        >
          <span class="faq-page__category-icon">{% render 'faq-category-icon', icon: 'production-timeline' %}</span>
          {{ section.settings.production_timeline_label | escape }}
        </button>
        <button
          class="faq-page__category"
          type="button"
          role="tab"
          aria-selected="false"
          data-faq-filter="consultation"
        >
          <span class="faq-page__category-icon">{% render 'faq-category-icon', icon: 'consultation' %}</span>
          {{ section.settings.consultation_label | escape }}
        </button>
      </div>

      <div class="faq-page__questions" id="faq-questions-{{ section.id }}" aria-live="polite">
        {%- for block in section.blocks -%}
          {%- if block.type == 'question' -%}
            {%- if rendered_questions < question_limit -%}
              {%- if block.settings.question != blank and block.settings.answer != blank -%}
                {%- assign rendered_questions = rendered_questions | plus: 1 -%}
                {%- assign question_secondary_category = block.settings.secondary_category -%}
                {%- if question_secondary_category == blank or question_secondary_category == 'none' -%}
                  {%- if rendered_questions == 1 -%}
                    {%- assign question_secondary_category = 'payments' -%}
                  {%- elsif rendered_questions == 2 -%}
                    {%- assign question_secondary_category = 'consultation' -%}
                  {%- endif -%}
                {%- endif -%}
                {% render 'faq-page-row',
                  question: block.settings.question,
                  answer: block.settings.answer,
                  number: rendered_questions,
                  category: block.settings.category,
                  secondary_category: question_secondary_category,
                  block_attributes: block.shopify_attributes
                %}
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if rendered_questions == 0 -%}
          <div class="faq-page__empty">
            <h2>{{ section.settings.empty_heading | escape }}</h2>
            <p>{{ section.settings.empty_text | escape }}</p>
          </div>
        {%- endif -%}

        <aside class="faq-page__consultation" data-faq-consultation>
          <span class="faq-page__consultation-branch" aria-hidden="true">
            <svg viewBox="0 0 180 100" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
              <path d="M6 94c39-13 67-35 91-78"/><path d="M47 74c-4-14-4-25 0-36M60 65c12-11 25-18 39-20M77 50c-2-13 0-24 6-34M91 30c10-8 21-12 34-13M35 81c-9-4-18-5-27-3M103 19c3-7 8-12 14-17"/><path d="M45 40c-5 1-8 4-9 9 5-1 8-4 9-9ZM99 43c6-1 10-4 12-9-6 0-10 3-12 9ZM81 18c-4 2-6 6-5 11 4-2 6-6 5-11ZM124 15c6 0 10-3 13-8-6-1-11 2-13 8ZM8 76c5-3 10-3 15 0-5 3-10 3-15 0Z"/>
            </svg>
          </span>
          <span class="faq-page__consultation-icon" aria-hidden="true">
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M4 5h16v11H9l-5 4z"/>
            </svg>
          </span>
          <div class="faq-page__consultation-copy">
            <h3>{{ section.settings.consultation_card_heading | escape }}</h3>
            <p>{{ section.settings.consultation_card_text | escape }}</p>
            <a href="{{ consultation_url }}">
              {{ section.settings.consultation_card_link_label | escape }}
              <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        </aside>
      </div>
    </div>
  </section>
</div>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- assign schema_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'question' -%}
          {%- if schema_count < question_limit -%}
            {%- if block.settings.question != blank and block.settings.answer != blank -%}
              {%- if schema_count > 0 -%},{%- endif -%}
              {
                "@type": "Question",
                "name": {{ block.settings.question | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.answer | strip_html | strip | json }}
                }
              }
              {%- assign schema_count = schema_count | plus: 1 -%}
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  }
</script>

{% stylesheet %}
  body:has(.not-found-page) .header__icon--search,
  body:has(.not-found-page) .header__icon--cart,
  body:has(.not-found-page) .header__icon--menu,
  body:has(.not-found-page) .header__icon--account,
  body:has(.not-found-page) .header__localization .loc-picker__code,
  body:has(.not-found-page) .header__localization .loc-picker__chevron {
    color: var(--color-earth-brown);
  }
  .loc-picker__option .loc-picker__code {
    color: var(--color-earth-brown) !important;
  }

  .faq-page {
    --faq-content-width: var(--layout-showcase-max-width);
    --faq-rule: var(--border-light);
    background: var(--bg-tertiary);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .faq-page__hero {
    position: relative;
    display: grid;
    min-block-size: 80vh;
    overflow: hidden;
    background: var(--bg-primary);
    padding: 0 42px;
  }

  .faq-page__hero-media {
    position: absolute;
    inset: var(--sp-0);
  }

  .faq-page__hero-media img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center;
  }

  .faq-page__hero-inner {
    position: relative;
    z-index: 1;
    align-self: center;
    inline-size: min(calc(100% - (var(--sp-8) * 2)), var(--faq-content-width));
    margin-inline: auto;
    padding-block: var(--sp-8);
  }

  .faq-page__breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-block-end: var(--sp-6);
    color: var(--color-bark);
    font-size: 20px;
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
  }

  .faq-page__breadcrumb a {
    color: inherit;
    text-decoration: none;
    transition: color var(--timing-short) var(--ease-standard);
  }

  .faq-page__breadcrumb a:hover {
    color: var(--color-ebony);
  }

  .faq-page__title {
    max-inline-size: none;
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-display-light);
    font-size: calc(var(--font-size-display-2xl) + var(--font-size-body-xl));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
    text-wrap: balance;
  }

  .faq-page__title-line {
    display: block;
    white-space: nowrap;
  }

  .faq-page__intro {
    max-inline-size: 56ch;
    margin-block-start: var(--sp-6);
    color: var(--color-bark);
    font-size: 24px;
    line-height: var(--line-height-generous);
  }

  .faq-page__intro p,
  .faq-page-row__answer p {
    margin: var(--sp-0);
  }

  .faq-page__content {
    position: relative;
    overflow: hidden;
    background: var(--bg-primary);
  }

  .faq-page__content::before,
  .faq-page__content::after {
    position: absolute;
    inset-block-start: calc(var(--sp-8) * -1);
    z-index: 0;
    inline-size: calc(var(--sp-12) * 4);
    block-size: calc(var(--sp-8) * 2);
    border-radius: 50%;
    background: color-mix(in srgb, var(--bg-secondary) 76%, var(--bg-primary));
    content: '';
    pointer-events: none;
  }

  .faq-page__content::before {
    inset-inline-start: calc(var(--sp-12) * -1);
  }

  .faq-page__content::after {
    inset-inline-end: calc(var(--sp-12) * -1);
  }

  .faq-page__content-inner {
    position: relative;
    z-index: 1;
    inline-size: min(calc(100% - (var(--sp-8) * 2)), var(--faq-content-width));
    margin-inline: auto;
    padding-block: var(--sp-8) var(--sp-9);
  }

  .faq-page__content-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .faq-page__content-eyebrow {
    margin: var(--sp-0) var(--sp-0) var(--sp-2);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 5);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .faq-page__content-title {
    margin: var(--sp-0);
    color: var(--color-ebony);
    font-family: var(--font-display-light);
    font-size: var(--font-size-display-lg);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
    text-wrap: balance;
  }

  .faq-page__content-ornament {
    display: grid;
    grid-template-columns: var(--sp-8) auto var(--sp-8);
    align-items: center;
    gap: var(--sp-3);
    margin-block-start: var(--sp-3);
    color: var(--color-clay);
  }

  .faq-page__content-ornament span {
    block-size: var(--border-width);
    background: currentcolor;
  }

  .faq-page__content-ornament b {
    font-family: var(--font-display-light);
    font-size: var(--font-size-body-2xl);
    font-weight: var(--font-weight-light);
    line-height: var(--line-height-normal);
  }

  .faq-page__categories {
    display: flex;
    gap: var(--sp-3);
    overflow-x: auto;
    margin-block-start: var(--sp-4);
    padding-block: var(--sp-1);
    scrollbar-width: none;
  }

  .faq-page__categories::-webkit-scrollbar {
    display: none;
  }

  .faq-page__category {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    width: max-content;
    padding: var(--sp-3) var(--sp-4);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-earth-brown);
    cursor: pointer;
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-normal);
    white-space: nowrap;
    transition: background-color var(--timing-short) var(--ease-standard),
      border-color var(--timing-short) var(--ease-standard), color var(--timing-short) var(--ease-standard),
      transform var(--timing-short) var(--ease-standard);
  }
  .faq-page__category:first-child {
    padding-inline: var(--sp-6);
  }

  .faq-page__category:hover {
    border-color: var(--color-bark);
    background: color-mix(in srgb, var(--bg-secondary) 60%, transparent);
  }

  .faq-page__category.is-active {
    border-color: var(--color-earth-brown);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .faq-page__category:active {
    transform: translateY(var(--border-width));
  }

  .faq-page__category-icon {
    display: inline-flex;
    flex: 0 0 var(--sp-5);
    inline-size: var(--sp-5);
    block-size: var(--sp-5);
  }

  .faq-page__category-icon svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .faq-page__breadcrumb a:focus-visible,
  .faq-page__category:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  .faq-page__questions {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    overflow: hidden;
    margin-block-start: var(--sp-6);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--bg-tertiary) 48%, transparent);
  }

  .faq-page-row {
    display: grid;
    grid-template-columns: calc(var(--sp-8) + var(--sp-6)) minmax(0, 1fr);
    min-block-size: calc((var(--sp-8) * 2) + var(--sp-7));
    border-block-end: var(--border-width) solid var(--border-default);
    background: color-mix(in srgb, var(--bg-primary) 82%, transparent);
  }

  .faq-page-row:nth-child(odd) {
    border-inline-end: var(--border-width) solid var(--border-default);
  }

  .faq-page-row:nth-child(7) {
    border-block-end: var(--sp-0);
  }

  .faq-page-row[hidden] {
    display: none;
  }

  .faq-page-row__number {
    position: relative;
    padding: var(--sp-6) var(--sp-5);
    background: color-mix(in srgb, var(--bg-primary) 60%, var(--bg-tertiary));
    color: var(--color-clay);
    font-family: var(--font-display-light);
    font-size: var(--font-size-display-md);
    font-variant-numeric: tabular-nums;
    line-height: var(--line-height-normal);
  }

  .faq-page-row__number::after {
    position: absolute;
    inset-block-start: calc(var(--sp-6) + var(--font-size-display-md) + var(--sp-3));
    inset-inline-start: var(--sp-5);
    inline-size: var(--sp-6);
    block-size: var(--border-width);
    background: var(--color-clay);
    content: '';
  }

  .faq-page-row__content {
    align-self: center;
    min-inline-size: 0;
    padding: var(--sp-6) var(--sp-7) var(--sp-6) var(--sp-5);
  }

  .faq-page-row__question {
    margin: var(--sp-0) var(--sp-0) var(--sp-3);
    color: var(--color-ebony);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-2xl);
    font-weight: var(--font-weight-regular);
    letter-spacing: var(--letter-spacing-normal);
    line-height: var(--line-height-tight);
    text-wrap: pretty;
  }

  .faq-page-row__answer {
    max-inline-size: 58ch;
    color: var(--text-primary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .faq-page__consultation {
    display: grid;
    grid-template-columns: minmax(var(--sp-12), 1fr) var(--sp-8) minmax(calc(var(--sp-12) + var(--sp-5)), 1fr);
    align-items: center;
    gap: var(--sp-5);
    min-block-size: calc((var(--sp-8) * 2) + var(--sp-7));
    padding: var(--sp-5) var(--sp-6);
    background: color-mix(in srgb, var(--bg-primary) 72%, var(--bg-tertiary));
  }

  .faq-page__consultation[hidden] {
    display: none;
  }

  .faq-page__consultation-branch {
    align-self: end;
    color: var(--color-clay);
  }

  .faq-page__consultation-branch svg {
    display: block;
    inline-size: 100%;
    block-size: auto;
  }

  .faq-page__consultation-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: var(--sp-8);
    block-size: var(--sp-8);
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--bg-secondary) 70%, transparent);
    color: var(--color-clay);
  }

  .faq-page__consultation-icon svg {
    inline-size: var(--sp-6);
    block-size: var(--sp-6);
  }

  .faq-page__consultation-copy h3 {
    margin: var(--sp-0) var(--sp-0) var(--sp-1);
    color: var(--color-ebony);
    font-family: var(--font-display);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-normal);
  }

  .faq-page__consultation-copy p {
    margin: var(--sp-0) var(--sp-0) var(--sp-3);
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-generous);
  }

  .faq-page__consultation-copy a {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    min-block-size: var(--sp-7);
    border-block-end: var(--border-width) solid currentcolor;
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-body-sm);
    text-decoration: none;
  }

  .faq-page__consultation-copy a:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  .faq-page__empty {
    padding-block: var(--sp-8);
    text-align: center;
  }

  .faq-page__empty h2 {
    margin: var(--sp-0) var(--sp-0) var(--sp-3);
    font: var(--type-display-small);
  }

  .faq-page__empty p {
    color: var(--text-secondary);
    font: var(--type-body-small);
  }

  @media screen and (max-width: 100rem) {
    .faq-page__breadcrumb {
      margin-block-end: var(--sp-5);
      font-size: var(--font-size-caption);
    }

    .faq-page__title {
      font-size: var(--font-size-display-2xl);
    }

    .faq-page__intro {
      margin-block-start: var(--sp-5);
      font-size: var(--font-size-body-md);
    }
  }

  @media screen and (max-width: 64rem) {
    .faq-page__hero {
      min-block-size: 80svh;
    }

    .faq-page__hero-media img {
      object-position: 58% center;
    }

    .faq-page__hero-inner,
    .faq-page__content-inner {
      inline-size: min(calc(100% - (var(--layout-padding-tablet) * 2)), var(--faq-content-width));
    }

    .faq-page__title {
      font-size: var(--font-size-display-xl);
    }

    .faq-page__categories {
      grid-template-columns: repeat(8, minmax(calc(var(--sp-8) + var(--sp-6)), 1fr));
      gap: var(--sp-3);
    }

    .faq-page__questions {
      grid-template-columns: minmax(0, 1fr);
      margin-top: var(--sp-3);
    }

    .faq-page-row:nth-child(odd) {
      border-inline-end: var(--sp-0);
    }

    .faq-page-row:nth-child(7) {
      border-block-end: var(--border-width) solid var(--border-default);
    }

    .faq-page__consultation {
      grid-template-columns: minmax(var(--sp-12), 1fr) var(--sp-8) minmax(calc(var(--sp-12) * 2), 1fr);
    }
  }

  @media screen and (max-width: 48rem) {
    .faq-page__hero {
      min-block-size: 80svh;
    }

    .faq-page__hero-media::after {
      position: absolute;
      inset: var(--sp-0);
      background: color-mix(in srgb, var(--bg-primary) 70%, transparent);
      content: '';
    }

    .faq-page__hero-media img {
      object-position: 70% center;
    }

    .faq-page__hero-inner,
    .faq-page__content-inner {
      inline-size: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--faq-content-width));
    }

    .faq-page__hero-inner {
      padding-block: var(--sp-7);
    }

    .faq-page__title {
      max-inline-size: 8ch;
      font-size: var(--font-size-display-lg);
    }

    .faq-page__title-line {
      white-space: normal;
    }

    .faq-page__intro {
      max-inline-size: 34ch;
      font-size: var(--font-size-body-sm);
    }

    .faq-page__categories {
      margin-block-start: var(--sp-4);
    }

    .faq-page__category {
    }

    .faq-page__content-inner {
      padding-block: var(--sp-5) var(--sp-5);
    }

    .faq-page__content-title {
      font-size: var(--font-size-display-md);
    }

    .faq-page__content::before,
    .faq-page__content::after {
      opacity: 0.55;
    }

    .faq-page-row {
      grid-template-columns: var(--sp-10) minmax(0, 1fr);
      min-block-size: auto;
    }

    .faq-page-row__number {
      padding: var(--sp-5) var(--sp-4);
      font-size: var(--font-size-body-xl);
    }

    .faq-page-row__number::after {
      inset-block-start: calc(var(--sp-5) + var(--font-size-body-xl) + var(--sp-3));
      inset-inline-start: var(--sp-4);
      inline-size: var(--sp-5);
    }

    .faq-page-row__content {
      padding: var(--sp-5);
    }

    .faq-page-row__question {
      font-size: var(--font-size-body-xl);
    }

    .faq-page__consultation {
      grid-template-columns: var(--sp-8) minmax(0, 1fr);
      min-block-size: auto;
      padding: var(--sp-5);
    }

    .faq-page__consultation-branch {
      display: none;
    }
  }

  @media screen and (max-width: 30rem) {
    .faq-page-row {
      display: block;
    }

    .faq-page-row__number {
      padding: var(--sp-5) var(--sp-5) var(--sp-0);
      background: transparent;
    }

    .faq-page-row__content {
      padding: var(--sp-3) var(--sp-5) var(--sp-5);
    }

    .faq-page-row__number::after {
      inset-block-start: auto;
      inset-block-end: var(--sp-0);
      inset-inline-start: var(--sp-5);
    }

    .faq-page__consultation {
      grid-template-columns: minmax(0, 1fr);
    }

    .faq-page__consultation-icon {
      inline-size: var(--sp-7);
      block-size: var(--sp-7);
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('click', (event) => {
    const filterButton = event.target.closest('[data-faq-filter]');
    if (!filterButton) return;

    const faqPage = filterButton.closest('.faq-page');
    if (!faqPage) return;

    const selectedCategory = filterButton.dataset.faqFilter;
    const categoryButtons = faqPage.querySelectorAll('[data-faq-filter]');
    const questionRows = faqPage.querySelectorAll('[data-faq-category]');
    const consultationCard = faqPage.querySelector('[data-faq-consultation]');

    categoryButtons.forEach((button) => {
      const isSelected = button === filterButton;
      button.classList.toggle('is-active', isSelected);
      button.setAttribute('aria-selected', String(isSelected));
    });

    questionRows.forEach((row) => {
      const matchesPrimary = row.dataset.faqCategory === selectedCategory;
      const matchesSecondary = row.dataset.faqSecondaryCategory === selectedCategory;
      row.hidden = selectedCategory !== 'all' && !matchesPrimary && !matchesSecondary;
    });

    if (consultationCard) {
      consultationCard.hidden = selectedCategory !== 'all' && selectedCategory !== 'consultation';
    }
  });
{% endjavascript %}

