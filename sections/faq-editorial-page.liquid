{%- liquid
  assign consultation_url = section.settings.consultation_url | default: '/pages/care-guide'
  assign question_limit = section.settings.max_questions | default: 8
  assign accordion_name = 'faq-editorial-' | append: section.id
  assign displayed_questions = 0
-%}

<main class="faq-editorial" id="faq-editorial-{{ section.id }}">
  <div class="faq-editorial__main">
    <div class="faq-editorial__layout">
      <section class="faq-editorial__intro-panel" aria-labelledby="faq-editorial-title-{{ section.id }}">
        <div class="faq-editorial__intro-copy">
          <p class="faq-editorial__eyebrow">Client care</p>
          <h1 class="faq-editorial__title" id="faq-editorial-title-{{ section.id }}">
            {{ section.settings.heading | escape }}
          </h1>
          <div class="faq-editorial__intro rte">{{ section.settings.intro }}</div>
        </div>

        <aside
          class="faq-editorial-consultation faq-editorial-guide"
          aria-labelledby="faq-editorial-consultation-{{ section.id }}"
        >
          <div class="faq-editorial-consultation__media">
            <img
              src="{{ 'FAQ-photo.png' | asset_img_url: '720x' }}"
              srcset="
                {{ 'FAQ-photo.png' | asset_img_url: '360x' }} 360w,
                {{ 'FAQ-photo.png' | asset_img_url: '540x' }} 540w,
                {{ 'FAQ-photo.png' | asset_img_url: '720x' }} 720w
              "
              sizes="(min-width: 64rem) 18rem, (min-width: 40rem) 42vw, 100vw"
              width="945"
              height="1672"
              alt="{{ section.settings.hero_image_alt | escape }}"
              loading="lazy"
            >
          </div>

          <div class="faq-editorial-consultation__content">
            <p class="faq-editorial-guide__eyebrow">Featured Guide</p>
            <h2 id="faq-editorial-consultation-{{ section.id }}">
              {{ section.settings.consultation_heading | default: 'Wood, Craft & Care' | escape }}
            </h2>
            <p>
              {{
                section.settings.consultation_text
                | default: 'A guide to our materials, finishes, and how to care for your piece for years to come.'
                | escape
              }}
            </p>
            <a class="faq-editorial-consultation__button" href="{{ consultation_url }}">
              <span>{{ section.settings.consultation_link_label | escape }}</span>
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </aside>
      </section>

      <section class="faq-editorial__questions-panel" aria-label="{{ section.settings.questions_label | escape }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category' -%}
            {%- if displayed_questions < question_limit -%}
              {%- if block.settings.question_1 != blank and block.settings.answer_1 != blank -%}
                {%- assign displayed_questions = displayed_questions | plus: 1 -%}
                {% render 'faq-editorial-item',
                  question: block.settings.question_1,
                  answer: block.settings.answer_1,
                  number: displayed_questions,
                  accordion_name: accordion_name,
                  open_by_default: block.settings.open_first_question
                %}
              {%- endif -%}
            {%- endif -%}

            {%- if displayed_questions < question_limit -%}
              {%- if block.settings.question_2 != blank and block.settings.answer_2 != blank -%}
                {%- assign displayed_questions = displayed_questions | plus: 1 -%}
                {% render 'faq-editorial-item',
                  question: block.settings.question_2,
                  answer: block.settings.answer_2,
                  number: displayed_questions,
                  accordion_name: accordion_name
                %}
              {%- endif -%}
            {%- endif -%}

            {%- if displayed_questions < question_limit -%}
              {%- if block.settings.question_3 != blank and block.settings.answer_3 != blank -%}
                {%- assign displayed_questions = displayed_questions | plus: 1 -%}
                {% render 'faq-editorial-item',
                  question: block.settings.question_3,
                  answer: block.settings.answer_3,
                  number: displayed_questions,
                  accordion_name: accordion_name
                %}
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}

        {%- if displayed_questions == 0 -%}
          <div class="faq-editorial__empty">
            <h2>{{ section.settings.empty_heading | escape }}</h2>
            <p>{{ section.settings.empty_text | escape }}</p>
          </div>
        {%- endif -%}
      </section>
    </div>
  </div>

  <section class="faq-editorial-trust" aria-label="Why choose WRYDECO">
    <div class="faq-editorial-trust__inner">
      <div class="faq-editorial-trust__item">
        <span class="faq-editorial-trust__icon" aria-hidden="true">
          <img src="{{ 'ic-footer-1.png' | asset_img_url: '64x' }}" width="64" height="64" alt="Handcrafted Solid Wood">
        </span>
        <div class="faq-editorial-trust__item-content">
          <h2>Handcrafted Solid Wood</h2>
          <p>Sustainably sourced, premium hardwoods built to last.</p>
        </div>
      </div>
      <div class="faq-editorial-trust__item">
        <span class="faq-editorial-trust__icon" aria-hidden="true">
          <img src="{{ 'ic-footer-2.png' | asset_img_url: '64x' }}" width="64" height="64" alt="Made to Order">
        </span>
        <div class="faq-editorial-trust__item-content">
          <h2>Made to Order</h2>
          <p>Every piece is custom-crafted to your space and style.</p>
        </div>
      </div>
      <div class="faq-editorial-trust__item">
        <span class="faq-editorial-trust__icon" aria-hidden="true">
          <img src="{{ 'ic-footer-3.png' | asset_img_url: '64x' }}" width="64" height="64" alt="Thoughtfully Finished">
        </span>
        <div class="faq-editorial-trust__item-content">
          <h2>Thoughtfully Finished</h2>
          <p>Refined by hand with natural oils and lasting care.</p>
        </div>
      </div>
      <div class="faq-editorial-trust__item">
        <span class="faq-editorial-trust__icon" aria-hidden="true">
          <img src="{{ 'ic-footer-4.png' | asset_img_url: '64x' }}" width="64" height="64" alt="White-Glove Delivery">
        </span>
        <div class="faq-editorial-trust__item-content">
          <h2>White-Glove Delivery</h2>
          <p>Carefully delivered and placed with the utmost attention.</p>
        </div>
      </div>
    </div>
  </section>
</main>

<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {%- assign schema_count = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'category' -%}
          {%- if schema_count < question_limit -%}
            {%- if block.settings.question_1 != blank and block.settings.answer_1 != blank -%}
              {%- if schema_count > 0 -%},{%- endif -%}
              {
                "@type": "Question",
                "name": {{ block.settings.question_1 | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.answer_1 | strip_html | strip | json }}
                }
              }
              {%- assign schema_count = schema_count | plus: 1 -%}
            {%- endif -%}
          {%- endif -%}
          {%- if schema_count < question_limit -%}
            {%- if block.settings.question_2 != blank and block.settings.answer_2 != blank -%}
              {%- if schema_count > 0 -%},{%- endif -%}
              {
                "@type": "Question",
                "name": {{ block.settings.question_2 | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.answer_2 | strip_html | strip | json }}
                }
              }
              {%- assign schema_count = schema_count | plus: 1 -%}
            {%- endif -%}
          {%- endif -%}
          {%- if schema_count < question_limit -%}
            {%- if block.settings.question_3 != blank and block.settings.answer_3 != blank -%}
              {%- if schema_count > 0 -%},{%- endif -%}
              {
                "@type": "Question",
                "name": {{ block.settings.question_3 | json }},
                "acceptedAnswer": {
                  "@type": "Answer",
                  "text": {{ block.settings.answer_3 | strip_html | strip | json }}
                }
              }
              {%- assign schema_count = schema_count | plus: 1 -%}
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}
      {%- endfor -%}
    ]
  }
</script>

{% stylesheet %}
  @font-face {
    font-family: 'Fraunces';
    src: url('Fraunces.woff2') format('woff2');
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  .faq-editorial {
    --faq-max-width: calc(var(--layout-max-width) + var(--sp-8) + var(--sp-8));
    --faq-line: color-mix(in srgb, var(--color-linen) 72%, transparent);
    container: faq-editorial / inline-size;
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .faq-editorial__main {
    background-color: #f5f1ed;
  }

  .faq-editorial__layout {
    display: grid;
    inline-size: min(100%, var(--faq-max-width));
    margin-inline: auto;
  }

  .faq-editorial__intro-panel,
  .faq-editorial__questions-panel {
    min-inline-size: 0;
  }

  .faq-editorial__intro-panel {
    display: flex;
    flex-direction: column;
    gap: var(--sp-7);
    padding: var(--sp-7) var(--layout-padding-mobile);
    background: var(--bg-primary);
  }

  .faq-editorial__eyebrow {
    position: relative;
    margin: 0 0 var(--sp-6);
    padding-block-end: var(--sp-3);
    color: var(--color-charcoal);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .faq-editorial__eyebrow::after {
    position: absolute;
    inset-block-end: 0;
    inset-inline-start: 0;
    inline-size: var(--sp-7);
    block-size: 1px;
    background: var(--color-bark);
    content: '';
  }

  .faq-editorial__title {
    max-inline-size: 24ch;
    margin: 0;
    color: var(--color-ebony);
    font-family: var(--font-display-light);
    font-size: clamp(var(--font-size-display-md), 8vw, var(--font-size-display-lg));
    font-weight: 400;
    letter-spacing: var(--letter-spacing-tight);
    word-spacing: 0.15em;
    line-height: var(--line-height-tight);
  }

  .faq-editorial__intro {
    max-inline-size: 52ch;
    margin-block-start: var(--sp-5);
    color: var(--text-secondary);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
  }

  .faq-editorial__intro p,
  .faq-editorial-item__answer p {
    margin: 0;
  }

  .faq-editorial-consultation {
    display: grid;
    overflow: hidden;
    border: 1px solid #e2e2e2;
    border-radius: var(--radius-md);
    background: var(--surface-default);
    box-shadow: var(--shadow-elevation-1);
  }

  .faq-editorial-consultation__media {
    min-block-size: calc(var(--sp-8) * 4);
    overflow: hidden;
    background: var(--bg-secondary);
  }

  .faq-editorial-consultation__media img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: center 58%;
  }

  .faq-editorial-consultation__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    padding: var(--sp-5);
  }

  .faq-editorial-consultation__mark,
  .faq-editorial-trust__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    border: 1px solid var(--color-linen);
    border-radius: var(--radius-full);
    color: var(--color-bark);
  }

  .faq-editorial-consultation__mark,
  .faq-editorial-trust__icon {
    inline-size: var(--sp-8);
    block-size: var(--sp-8);
  }

  .faq-editorial-consultation__mark {
    margin-block-end: var(--sp-4);
  }

  .faq-editorial-consultation__mark svg,
  .faq-editorial-trust__icon svg {
    inline-size: var(--sp-5);
    block-size: var(--sp-5);
  }

  .faq-editorial-consultation h2 {
    margin: 0;
    color: var(--color-ebony);
    font-family: var(--font-display);
    font-size: var(--font-size-display-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-normal);
  }

  .faq-editorial-consultation__content > p {
    max-inline-size: 36ch;
    margin: var(--sp-3) 0 0;
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .faq-editorial-consultation__divider {
    inline-size: var(--sp-8);
    block-size: 1px;
    margin-block: var(--sp-4);
    background: var(--color-clay);
  }

  .faq-editorial-consultation__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    inline-size: 100%;
    min-block-size: var(--sp-7);
    padding: var(--button-padding-vertical) var(--button-padding-horizontal);
    border: 1px solid var(--color-earth-brown);
    border-radius: var(--radius-sm);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    line-height: var(--line-height-normal);
    text-decoration: none;
    text-transform: uppercase;
    white-space: nowrap;
    transition: background-color var(--timing-short) var(--ease-standard),
      border-color var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
  }

  .faq-editorial-consultation__button:hover {
    border-color: var(--color-charcoal);
    background: var(--color-charcoal);
  }

  .faq-editorial-consultation__button:active {
    transform: translateY(var(--radius-sm));
  }

  .faq-editorial-consultation__button:focus-visible,
  .faq-editorial-item__summary:focus-visible {
    outline: 2px solid var(--color-sage);
    outline-offset: var(--radius-sm);
  }

  .faq-editorial__questions-panel {
    padding: var(--sp-6) var(--layout-padding-mobile) var(--sp-8);
    background: #fffaf6;
  }

  .faq-editorial-item {
    border-block-start: 1px solid var(--faq-line);
  }

  .faq-editorial-item:last-of-type {
    border-block-end: 1px solid var(--faq-line);
  }

  .faq-editorial-item__summary {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr) var(--sp-7);
    align-items: center;
    gap: var(--sp-4);
    min-block-size: calc(var(--sp-8) + var(--sp-4));
    padding-block: var(--sp-3);
    cursor: pointer;
    list-style: none;
  }

  .faq-editorial-item__summary::-webkit-details-marker {
    display: none;
  }

  .faq-editorial-item__number {
    min-inline-size: var(--sp-6);
    color: var(--color-bark);
    font-family: var(--font-display);
    font-size: var(--font-size-body-lg);
    line-height: var(--line-height-normal);
  }

  .faq-editorial-item__question {
    color: var(--color-ebony);
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-normal);
  }

  .faq-editorial-item__toggle {
    position: relative;
    inline-size: var(--sp-7);
    block-size: var(--sp-7);
  }

  .faq-editorial-item__toggle::before,
  .faq-editorial-item__toggle::after {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    inline-size: var(--sp-4);
    block-size: 1px;
    background: var(--color-charcoal);
    content: '';
    transform: translate(-50%, -50%);
    transition: transform var(--timing-short) var(--ease-standard);
  }

  .faq-editorial-item__toggle::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .faq-editorial-item[open] .faq-editorial-item__toggle::after {
    transform: translate(-50%, -50%) rotate(0deg);
  }

  .faq-editorial-item__answer {
    max-inline-size: 64ch;
    margin-inline-start: calc(var(--sp-6) + var(--sp-4));
    padding: 0 var(--sp-7) var(--sp-5);
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .faq-editorial-item__answer::before {
    display: block;
    inline-size: var(--sp-8);
    block-size: 1px;
    margin-block-end: var(--sp-4);
    background: var(--color-clay);
    content: '';
  }

  .faq-editorial__empty {
    padding-block: var(--sp-7);
    border-block: 1px solid var(--faq-line);
  }

  .faq-editorial__empty h2 {
    margin: 0 0 var(--sp-3);
    font-family: var(--font-display);
    font-size: var(--font-size-display-sm);
    font-weight: var(--font-weight-regular);
  }

  .faq-editorial__empty p {
    margin: 0;
    color: var(--text-secondary);
    line-height: var(--line-height-generous);
  }

  .faq-editorial-trust {
    border-block-start: 1px solid #dcdbda;
    background: var(--bg-primary);
  }

  .faq-editorial-trust__inner {
    display: grid;
    gap: var(--sp-5);
    inline-size: min(100%, var(--faq-max-width));
    margin-inline: auto;
    padding: var(--sp-6) var(--layout-padding-mobile);
  }

  .faq-editorial-trust__item {
    display: grid;
    grid-template-columns: var(--sp-8) minmax(0, 1fr);
    align-items: center;
    gap: var(--sp-4);
  }

  .faq-editorial-trust__item h2 {
    margin: 0;
    color: var(--color-charcoal);
    font-family: var(--font-display);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .faq-editorial-trust__item p {
    margin: var(--sp-1) 0 0;
    color: var(--text-secondary);
    font-size: 14px;
    line-height: var(--line-height-relaxed);
  }

  @container faq-editorial (min-width: 40rem) {
    .faq-editorial__intro-panel,
    .faq-editorial__questions-panel {
      padding-inline: var(--layout-padding-tablet);
    }

    .faq-editorial-consultation {
      grid-template-columns: minmax(0, 38%) minmax(0, 62%);
    }

    .faq-editorial-consultation__media {
      min-block-size: calc(var(--sp-8) * 5);
    }

    .faq-editorial-trust__inner {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      padding-inline: var(--layout-padding-tablet);
    }

    .faq-editorial-trust__item + .faq-editorial-trust__item {
      padding-inline-start: var(--sp-5);
      border-inline-start: 1px solid var(--faq-line);
    }
  }

  @media screen and (min-width: 64rem) {
    .faq-editorial {
      --faq-max-width: 100%;
      display: grid;
      grid-template-rows: minmax(0, 1fr) auto;
      block-size: 100svh;
      overflow: hidden;
    }

    .faq-editorial__main {
      min-block-size: 0;
    }
  }

  @container faq-editorial (min-width: 64rem) {
    .faq-editorial__layout {
      grid-template-columns: minmax(0, 47.2%) minmax(0, 52.8%);
      align-items: stretch;
      block-size: 100%;
      min-block-size: 0;
    }

    .faq-editorial__intro-panel {
      justify-content: space-between;
      gap: clamp(var(--sp-5), 3.8svh, var(--sp-7));
      min-block-size: 0;
      padding-block: clamp(var(--sp-5), 6.8svh, var(--sp-8)) clamp(var(--sp-5), 5.4svh, var(--sp-7));
      padding-inline: clamp(var(--sp-8), 5.2vw, 96px) clamp(var(--sp-5), 4vw, var(--sp-8));
    }

    .faq-editorial__title {
      max-inline-size: min(100%, 720px);
      font-size: clamp(54px, 3.8vw, 68px);
      font-weight: 300;
      letter-spacing: -0.052em;
      line-height: 1.02;
    }

    .faq-editorial__eyebrow {
      margin-block-end: clamp(var(--sp-5), 3.2svh, var(--sp-6));
      font-size: 16px;
      letter-spacing: 0.045em;
    }

    .faq-editorial__intro {
      margin-block-start: clamp(var(--sp-4), 3svh, var(--sp-6));
      max-inline-size: 53ch;
      font-size: clamp(16px, 1.05vw, 19px);
      line-height: 1.55;
    }

    .faq-editorial__questions-panel {
      min-block-size: 0;
      padding-block: clamp(var(--sp-7), 7.4svh, 72px) clamp(var(--sp-4), 3.2svh, var(--sp-6));
      padding-inline: clamp(var(--sp-5), 2.5vw, 42px) clamp(var(--sp-7), 4.4vw, 76px);
      overflow: hidden;
    }

    .faq-editorial-consultation {
      grid-template-columns: minmax(0, 34.8%) minmax(0, 65.2%);
      inline-size: min(100%, 700px);
      block-size: clamp(300px, 39svh, 350px);
      margin-inline-start: calc(-1 * clamp(var(--sp-4), 1.5vw, var(--sp-5)));
      flex-shrink: 0;
    }

    .faq-editorial-consultation__media {
      min-block-size: 0;
    }

    .faq-editorial-consultation__content {
      padding-block: clamp(var(--sp-5), 2.8svh, var(--sp-6));
      padding-inline: clamp(var(--sp-6), 3vw, var(--sp-7)) clamp(var(--sp-5), 2.4vw, var(--sp-6));
    }

    .faq-editorial-consultation__mark {
      inline-size: 60px;
      block-size: 60px;
      margin-block-end: clamp(var(--sp-4), 2.4svh, var(--sp-5));
    }

    .faq-editorial-consultation__mark svg {
      inline-size: var(--sp-5);
      block-size: var(--sp-5);
    }

    .faq-editorial-consultation h2 {
      font-size: clamp(26px, 1.8vw, 30px);
      font-weight: 300;
      letter-spacing: -0.04em;
      line-height: 1.15;
    }

    .faq-editorial-consultation__content > p {
      margin-block-start: var(--sp-4);
      max-inline-size: 32ch;
      font-size: clamp(14px, 0.95vw, 16px);
      line-height: 1.5;
    }

    .faq-editorial-consultation__divider {
      margin-block: var(--sp-4);
    }

    .faq-editorial-consultation__button {
      min-block-size: 56px;
      padding: var(--sp-4) var(--sp-5);
      border-radius: var(--radius-lg);
      font-size: 14px;
    }

    .faq-editorial-item__summary {
      grid-template-columns: 40px minmax(0, 1fr) var(--sp-7);
      min-block-size: clamp(60px, calc(9.8svh - 18px), 72px);
      padding-block: var(--sp-2);
      column-gap: var(--sp-4);
    }

    .faq-editorial-item__number {
      font-size: clamp(18px, 1.28vw, 23px);
      font-weight: 300;
      text-align: left;
    }

    .faq-editorial-item__question {
      font-size: clamp(20px, 1.55vw, 25px);
      font-weight: 300;
      letter-spacing: -0.035em;
      line-height: 1.2;
    }

    .faq-editorial-item__toggle::before,
    .faq-editorial-item__toggle::after {
      inline-size: 18px;
    }

    .faq-editorial-item__answer {
      max-inline-size: 56ch;
      margin-inline-start: calc(40px + var(--sp-4));
      padding: 0 var(--sp-7) clamp(var(--sp-3), 2svh, var(--sp-5)) 0;
      font-size: clamp(13px, 0.86vw, 16px);
      line-height: 1.48;
    }

    .faq-editorial-item__answer::before {
      margin-block-end: var(--sp-4);
    }

    .faq-editorial-trust__inner {
      inline-size: 100%;
      padding: clamp(var(--sp-4), 2.6svh, var(--sp-6)) clamp(var(--sp-8), 11vw, 212px);
    }

    .faq-editorial-trust__icon {
      inline-size: 64px;
      block-size: 64px;
    }

    .faq-editorial-trust__icon svg {
      inline-size: var(--sp-5);
      block-size: var(--sp-5);
    }

    .faq-editorial-trust__item h2 {
      font-size: 14px;
      letter-spacing: 0.08em;
    }

    .faq-editorial-trust__item p {
      font-size: 13px;
    }
  }

  @media screen and (min-width: 64rem) and (max-height: 760px) {
    .faq-editorial {
      grid-template-rows: minmax(0, 1fr) 84px;
    }

    .faq-editorial__intro-panel {
      justify-content: flex-start;
      gap: var(--sp-6);
      padding-block: 36px 24px;
      padding-inline: clamp(var(--sp-7), 5vw, 78px) clamp(var(--sp-5), 3vw, var(--sp-7));
    }

    .faq-editorial__eyebrow {
      margin-block-end: var(--sp-4);
      font-size: 14px;
    }

    .faq-editorial__title {
      max-inline-size: 660px;
      font-size: clamp(46px, 3.5vw, 54px);
      line-height: 1.02;
    }

    .faq-editorial__intro {
      margin-block-start: var(--sp-4);
      max-inline-size: 52ch;
      font-size: 14px;
      line-height: 1.5;
    }

    .faq-editorial-consultation {
      inline-size: min(100%, 700px);
      block-size: 268px;
      margin-inline-start: calc(-1 * var(--sp-4));
    }

    .faq-editorial-consultation__media img {
      object-position: center 62%;
    }

    .faq-editorial-consultation__content {
      padding-block: var(--sp-5);
      padding-inline: clamp(var(--sp-5), 2.8vw, 40px) var(--sp-5);
    }

    .faq-editorial-consultation__mark {
      inline-size: 48px;
      block-size: 48px;
      margin-block-end: var(--sp-3);
    }

    .faq-editorial-consultation__mark svg {
      inline-size: var(--sp-4);
      block-size: var(--sp-4);
    }

    .faq-editorial-consultation h2 {
      font-size: 24px;
      line-height: 1.12;
    }

    .faq-editorial-consultation__content > p {
      margin-block-start: var(--sp-2);
      font-size: 13px;
      line-height: 1.42;
    }

    .faq-editorial-consultation__divider {
      margin-block: var(--sp-2);
    }

    .faq-editorial-consultation__button {
      min-block-size: 44px;
      padding: var(--sp-3) var(--sp-4);
      font-size: 12px;
      border-radius: var(--radius-md);
    }

    .faq-editorial__questions-panel {
      padding-block: 28px 12px;
      padding-inline: clamp(var(--sp-5), 2.5vw, 40px) clamp(var(--sp-6), 3.6vw, var(--sp-7));
    }

    .faq-editorial-item__summary {
      grid-template-columns: 34px minmax(0, 1fr) var(--sp-6);
      min-block-size: 54px;
      padding-block: var(--sp-1);
      column-gap: var(--sp-4);
    }

    .faq-editorial-item__number {
      font-size: 16px;
      text-align: left;
    }

    .faq-editorial-item__question {
      font-size: 20px;
      line-height: 1.16;
    }

    .faq-editorial-item__toggle {
      inline-size: var(--sp-6);
      block-size: var(--sp-6);
    }

    .faq-editorial-item__answer {
      max-inline-size: 50ch;
      margin-inline-start: calc(34px + var(--sp-4));
      padding: 0 var(--sp-6) var(--sp-3) 0;
      font-size: 12px;
      line-height: 1.4;
    }

    .faq-editorial-item__answer::before {
      inline-size: var(--sp-7);
      margin-block-end: var(--sp-2);
    }

    .faq-editorial-trust__inner {
      padding: 12px clamp(var(--sp-7), 9vw, 132px);
    }

    .faq-editorial-trust__item {
      grid-template-columns: 48px minmax(0, 1fr);
      gap: var(--sp-3);
    }

    .faq-editorial-trust__icon {
      inline-size: 48px;
      block-size: 48px;
    }

    .faq-editorial-trust__icon svg {
      inline-size: var(--sp-4);
      block-size: var(--sp-4);
    }

    .faq-editorial-trust__item h2 {
      font-size: 12px;
      line-height: 1.25;
    }

    .faq-editorial-trust__item p {
      font-size: 11px;
      line-height: 1.35;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-editorial-consultation__button,
    .faq-editorial-item__toggle::before,
    .faq-editorial-item__toggle::after {
      transition: none;
    }
  }

  .faq-editorial {
    --faq-ink: var(--color-earth-brown, #4a2c18);
    --faq-muted: color-mix(in srgb, var(--faq-ink) 72%, #6b5d52);
    --faq-rule: rgba(74, 44, 24, 0.18);
    background: radial-gradient(circle at 12% 0%, rgba(255, 255, 255, 0.78), transparent 30%),
      linear-gradient(180deg, #f8f3ed 0%, #f2ebe4 100%);
    color: var(--faq-ink);
  }

  .faq-editorial__main {
    background: transparent;
  }

  .faq-editorial__layout {
    width: min(100%, var(--page-max-width, 1440px));
    padding: var(--section-padding-y, 80px) var(--container-padding-x, 48px);
  }

  .faq-editorial__intro-panel,
  .faq-editorial__questions-panel {
    background: transparent;
    padding: 0;
  }

  .faq-editorial__eyebrow {
    margin: 0 0 14px;
    padding: 0;
    color: var(--color-brown, #4a2c18);
    font-size: var(--eyebrow-size, 12px);
    font-weight: 600;
    letter-spacing: var(--eyebrow-tracking, 0.3em);
  }

  .faq-editorial__eyebrow::after {
    display: none;
  }

  .faq-editorial__title {
    max-width: 15ch;
    color: var(--color-text, #2b1a11);
    font-family: var(--font-heading);
    font-size: var(--section-heading-size, 48px);
    font-weight: 300;
    line-height: var(--section-heading-line, 1.02);
    letter-spacing: var(--section-heading-tracking, -0.02em);
    word-spacing: 0;
    text-wrap: balance;
  }

  .faq-editorial__intro {
    max-width: 43ch;
    margin-top: 16px;
    color: var(--color-muted, #5f5852);
    font-size: var(--section-subtitle-size, 16px);
    line-height: 1.6;
  }

  .faq-editorial-guide {
    grid-template-columns: minmax(180px, 39%) minmax(0, 61%);
    width: min(100%, 545px);
    margin-top: clamp(28px, 3.4vw, 44px);
    border: 1px solid rgba(74, 44, 24, 0.16);
    border-radius: 12px;
    background: rgba(255, 250, 246, 0.52);
    box-shadow: 0 16px 42px rgba(74, 44, 24, 0.08);
  }

  .faq-editorial-guide .faq-editorial-consultation__media {
    min-height: 0;
  }

  .faq-editorial-guide .faq-editorial-consultation__media img {
    object-position: center;
    filter: sepia(0.08) saturate(0.9);
  }

  .faq-editorial-guide .faq-editorial-consultation__content {
    padding: clamp(24px, 2.3vw, 34px) clamp(24px, 2.8vw, 40px);
  }

  .faq-editorial-guide__eyebrow {
    margin: 0 0 14px;
    color: var(--faq-ink);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  .faq-editorial-guide h2 {
    color: var(--faq-ink);
    font-family: var(--font-display-light, var(--font-display));
    font-size: clamp(26px, 2vw, 34px);
    font-weight: 300;
    line-height: 1.06;
    letter-spacing: -0.045em;
  }

  .faq-editorial-guide .faq-editorial-consultation__content > p {
    max-width: 28ch;
    margin-top: 12px;
    color: var(--faq-muted);
    font-size: clamp(13px, 0.95vw, 15px);
    line-height: 1.55;
  }

  .faq-editorial-guide .faq-editorial-consultation__button {
    width: auto;
    min-height: auto;
    margin-top: clamp(18px, 2.2vw, 28px);
    padding: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
    color: var(--faq-ink);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0;
    text-transform: none;
  }

  .faq-editorial-guide .faq-editorial-consultation__button:hover {
    background: transparent;
    color: var(--color-clay, #a8845c);
  }

  .faq-editorial-item {
    border-top: 1px solid var(--faq-rule);
  }

  .faq-editorial-item:last-of-type {
    border-bottom: 1px solid var(--faq-rule);
  }

  .faq-editorial-item__summary {
    grid-template-columns: minmax(0, 1fr) 34px;
    min-height: clamp(58px, 5.15vw, 72px);
    padding: 0 clamp(8px, 1vw, 18px) 0 clamp(14px, 2vw, 34px);
    gap: 18px;
  }

  .faq-editorial-item__number {
    display: none;
  }

  .faq-editorial-item__question {
    color: var(--faq-ink);
    font-family: var(--font-body);
    font-size: clamp(15px, 1.18vw, 19px);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1.35;
  }

  .faq-editorial-item__toggle {
    width: 34px;
    height: 34px;
  }

  .faq-editorial-item__toggle::before,
  .faq-editorial-item__toggle::after {
    width: 17px;
    background: var(--faq-ink);
  }

  .faq-editorial-item__answer {
    max-width: 62ch;
    margin: -6px 58px 0 clamp(14px, 2vw, 34px);
    padding: 0 0 22px;
    color: var(--faq-muted);
    font-size: 14px;
    line-height: 1.55;
  }

  .faq-editorial-item__answer::before {
    display: none;
  }

  .faq-editorial-trust {
    border-top: 1px solid rgba(74, 44, 24, 0.14);
    border-bottom: 1px solid rgba(74, 44, 24, 0.14);
    background: rgba(245, 241, 237, 0.82);
  }

  .faq-editorial-trust__inner {
    width: min(100%, var(--page-max-width, 1440px));
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: clamp(20px, 2.8vw, 44px);
    padding: clamp(28px, 3vw, 38px) var(--container-padding-x, 48px);
  }

  .faq-editorial-trust__item {
    grid-template-columns: 60px minmax(0, 1fr);
    gap: 18px;
  }

  .faq-editorial-trust__item + .faq-editorial-trust__item {
    padding-left: clamp(18px, 2.4vw, 36px);
    border-left: 1px solid var(--faq-rule);
  }

  .faq-editorial-trust__icon {
    width: 60px;
    height: 60px;
    border-color: color-mix(in srgb, var(--faq-ink) 38%, transparent);
    color: var(--color-clay, #a8845c);
  }

  .faq-editorial-trust__icon svg {
    width: 30px;
    height: 30px;
  }

  .faq-editorial-trust__item h2 {
    color: var(--faq-ink);
    font-family: var(--font-display-light, var(--font-display));
    font-size: clamp(18px, 1.2vw, 23px);
    font-weight: 300;
    letter-spacing: -0.035em;
    line-height: 1.1;
    text-transform: none;
  }

  .faq-editorial-trust__item p {
    max-width: 28ch;
    margin-top: 8px;
    color: var(--faq-muted);
    font-size: clamp(12px, 0.86vw, 14px);
    line-height: 1.42;
  }

  @media screen and (min-width: 64rem) {
    .faq-editorial {
      display: block;
      block-size: auto;
      overflow: visible;
    }

    .faq-editorial__layout {
      grid-template-columns: minmax(0, 42%) minmax(0, 52%);
      justify-content: space-between;
      align-items: start;
      block-size: auto;
      min-block-size: 0;
    }

    .faq-editorial__questions-panel {
      padding-top: 0;
      overflow: visible;
    }
  }

  @media screen and (max-width: 989px) {
    .faq-editorial__layout {
      padding-top: 54px;
    }

    .faq-editorial-guide {
      grid-template-columns: 1fr;
    }

    .faq-editorial-guide .faq-editorial-consultation__media {
      min-height: 220px;
    }

    .faq-editorial__questions-panel {
      margin-top: 34px;
    }

    .faq-editorial-trust__inner {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .faq-editorial-trust__item + .faq-editorial-trust__item {
      padding-left: 0;
      border-left: 0;
    }
  }

  @media screen and (max-width: 640px) {
    .faq-editorial__title {
      max-width: 13ch;
    }

    .faq-editorial-trust__inner {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Editorial FAQ page",
  "tag": "section",
  "class": "section-editorial-faq-page",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Everything to Know Before Choosing a Piece"
    },
    {
      "type": "richtext",
      "id": "intro",
      "label": "Introduction",
      "default": "<p>Beautiful furniture should feel as effortless as it is meaningful. Find clear answers about materials, made-to-order work, delivery, care, and customization.</p>"
    },
    {
      "type": "text",
      "id": "questions_label",
      "label": "Questions region label",
      "default": "Client care questions"
    },
    {
      "type": "range",
      "id": "max_questions",
      "label": "Questions to show",
      "min": 3,
      "max": 12,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Private consultation"
    },
    {
      "type": "text",
      "id": "consultation_heading",
      "label": "Heading",
      "default": "Need personal guidance?"
    },
    {
      "type": "textarea",
      "id": "consultation_text",
      "label": "Text",
      "default": "Our design advisors help you choose a piece, refine proportions, and make it feel at home in your space."
    },
    {
      "type": "text",
      "id": "consultation_link_label",
      "label": "Link label",
      "default": "Book a private consultation"
    },
    {
      "type": "url",
      "id": "consultation_url",
      "label": "Consultation page"
    },
    {
      "type": "text",
      "id": "hero_image_alt",
      "label": "Consultation image alt text",
      "default": "Sculptural solid wood shelving and desk in a warm WRYDECO interior"
    },
    {
      "type": "header",
      "content": "Empty state"
    },
    {
      "type": "text",
      "id": "empty_heading",
      "label": "Heading",
      "default": "Questions are being curated"
    },
    {
      "type": "textarea",
      "id": "empty_text",
      "label": "Text",
      "default": "Add FAQ category blocks in the theme editor to publish answers here."
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "FAQ category",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Internal category name",
          "default": "Questions"
        },
        {
          "type": "checkbox",
          "id": "open_by_default",
          "label": "Keep category open",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "open_first_question",
          "label": "Open first question",
          "default": false
        },
        {
          "type": "header",
          "content": "Question 1"
        },
        {
          "type": "text",
          "id": "question_1",
          "label": "Question",
          "default": "Is each piece made from solid wood?"
        },
        {
          "type": "richtext",
          "id": "answer_1",
          "label": "Answer",
          "default": "<p>WRYDECO focuses on solid natural wood selected for grain, form, strength, and suitability for the design.</p>"
        },
        {
          "type": "header",
          "content": "Question 2"
        },
        {
          "type": "text",
          "id": "question_2",
          "label": "Question",
          "default": "Can I customize the size, finish, or wood tone?"
        },
        {
          "type": "richtext",
          "id": "answer_2",
          "label": "Answer",
          "default": "<p>Depending on the design, we can explore dimensions, wood selection, finish, and proportions.</p>"
        },
        {
          "type": "header",
          "content": "Question 3"
        },
        {
          "type": "text",
          "id": "question_3",
          "label": "Question",
          "default": "How long does a made-to-order piece take?"
        },
        {
          "type": "richtext",
          "id": "answer_3",
          "label": "Answer",
          "default": "<p>We provide a project-specific estimate once the design, materials, and destination are confirmed.</p>"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Editorial FAQ page"
    }
  ]
}
