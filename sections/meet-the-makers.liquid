<div class="meet-makers page-width">
  <div class="meet-makers__header">
    <div class="meet-makers__icon">
      <!-- Wood ring icon -->
      <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="20" r="19" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2"/>
        <circle cx="20" cy="20" r="14" stroke="currentColor" stroke-width="1"/>
        <circle cx="20" cy="20" r="9" stroke="currentColor" stroke-width="1" stroke-dasharray="1 3"/>
        <circle cx="20" cy="20" r="4" stroke="currentColor" stroke-width="1"/>
      </svg>
    </div>
    <p class="meet-makers__eyebrow">{{ section.settings.eyebrow | upcase }}</p>
    <h2 class="meet-makers__heading">{{ section.settings.heading }}</h2>
    <p class="meet-makers__subtitle">{{ section.settings.subtitle | newline_to_br }}</p>
    <div class="meet-makers__leaf-icon">
      <!-- Simple leaf icon -->
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10c0 0 0-4.48 0-10S17.52 2 12 2z"/>
        <path d="M12 22C17.52 22 22 17.52 22 12S17.52 2 12 2"/>
        <path d="M12 2v20"/>
      </svg>
    </div>
  </div>

  <div class="meet-makers__slider">
    {%- for block in section.blocks -%}
      <div class="maker-card" {{ block.shopify_attributes }}>
        <div class="maker-card__body">
          <div class="maker-card__image-col">
            {%- assign asset_name = 'artist-' | append: block.settings.name | replace: ' ', '_' | append: '.webp' -%}
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: class: 'maker-card__img', loading: 'lazy', draggable: 'false' }}
            {%- else -%}
              <img src="{{ asset_name | asset_url }}" alt="{{ block.settings.name }}" class="maker-card__img" loading="lazy" draggable="false">
            {%- endif -%}
          </div>
          <div class="maker-card__text-col">
            <p class="maker-card__role">{{ block.settings.role | upcase }}</p>
            <h3 class="maker-card__name">{{ block.settings.name }}</h3>
            <p class="maker-card__tags">{{ block.settings.tags }}</p>
            <p class="maker-card__bio">{{ block.settings.bio | newline_to_br }}</p>
            
            <div class="maker-card__quote">
              <span class="maker-card__quote-mark">“</span>
              <p><i>{{ block.settings.quote | newline_to_br }}</i></p>
            </div>
            
            <div class="maker-card__features">
              <div class="maker-feature">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                  <circle cx="12" cy="12" r="10" stroke-dasharray="2 2"/>
                  <circle cx="12" cy="12" r="6"/>
                  <circle cx="12" cy="12" r="2"/>
                </svg>
                <span>{{ block.settings.feature_1 | newline_to_br }}</span>
              </div>
              <div class="maker-feature maker-feature--border">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M18 11V6a2 2 0 0 0-4 0v4"/>
                  <path d="M14 10V5a2 2 0 0 0-4 0v5"/>
                  <path d="M10 10.5V4a2 2 0 0 0-4 0v8"/>
                  <path d="M6 14v-2a2 2 0 0 0-4 0v6a6 6 0 0 0 6 6h2a8 8 0 0 0 8-8v-7a2 2 0 0 0-4 0v3"/>
                </svg>
                <span>{{ block.settings.feature_2 | newline_to_br }}</span>
              </div>
              <div class="maker-feature maker-feature--border">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10c0 0 0-4.48 0-10S17.52 2 12 2z"/>
                  <path d="M12 22C17.52 22 22 17.52 22 12S17.52 2 12 2"/>
                  <path d="M12 2v20"/>
                </svg>
                <span>{{ block.settings.feature_3 | newline_to_br }}</span>
              </div>
            </div>
          </div>
        </div>
        <a href="{{ block.settings.link | default: '#' }}" class="maker-card__btn">
          VIEW PROFILE &rarr;
        </a>
      </div>
    {%- endfor -%}
  </div>

  <div class="meet-makers__footer">
    <div class="meet-makers__footer-content">
      <!-- Icon ring -->
      <svg width="20" height="20" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" class="meet-makers__footer-icon">
        <circle cx="20" cy="20" r="19" stroke="currentColor" stroke-width="2" stroke-dasharray="2 2"/>
        <circle cx="20" cy="20" r="12" stroke="currentColor" stroke-width="2"/>
        <circle cx="20" cy="20" r="5" stroke="currentColor" stroke-width="2"/>
      </svg>
      <span class="meet-makers__footer-text">BUILT TO ENDURE</span>
      <span class="meet-makers__footer-sep">|</span>
      <span class="meet-makers__footer-text">CRAFTED ETHICALLY</span>
      <span class="meet-makers__footer-sep">|</span>
      <span class="meet-makers__footer-text">DESIGNED TO BE LIVED IN</span>
      <!-- Leaf icon -->
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="meet-makers__footer-icon">
        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10c0 0 0-4.48 0-10S17.52 2 12 2z"/>
        <path d="M12 22C17.52 22 22 17.52 22 12S17.52 2 12 2"/>
        <path d="M12 2v20"/>
      </svg>
    </div>
  </div>
</div>

{% stylesheet %}
  .meet-makers {
    padding-top: var(--sp-12, 64px);
    padding-bottom: var(--sp-12, 64px);
    background-color: var(--bg-primary, #f5f1ed);
    color: var(--text-primary, #1a1815);
  }

  .meet-makers__header {
    text-align: center;
    margin-bottom: var(--sp-10, 48px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .meet-makers__icon {
    color: var(--text-secondary, #6b5d52);
    margin-bottom: var(--sp-4, 16px);
  }

  .meet-makers__leaf-icon {
    color: var(--text-secondary, #6b5d52);
    margin-top: var(--sp-4, 16px);
  }

  .meet-makers__eyebrow {
    font-family: var(--font-body);
    font-size: var(--font-size-body-xs, 12px);
    letter-spacing: 0.12em;
    color: var(--text-secondary, #6b5d52);
    margin-bottom: var(--sp-2, 8px);
    font-weight: 500;
  }

  .meet-makers__heading {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 52px);
    font-weight: var(--font-weight-regular, 400);
    color: var(--text-primary, #1a1815);
    margin-bottom: var(--sp-3, 12px);
    letter-spacing: var(--letter-spacing-tight, -0.04em);
  }

  .meet-makers__subtitle {
    font-family: var(--font-body);
    font-size: var(--font-size-body-md, 16px);
    color: var(--text-secondary, #6b5d52);
    line-height: var(--line-height-relaxed, 1.5);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Slider Container */
  .meet-makers__slider {
    display: flex;
    gap: var(--sp-5, 20px);
    overflow-x: auto;
    padding-bottom: var(--sp-6, 24px);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
    cursor: grab;
  }

  .meet-makers__slider.is-dragging {
    cursor: grabbing;
  }

  .meet-makers__slider.is-dragging .maker-card {
    user-select: none;
    pointer-events: none; /* Prevents text selection & hover states while dragging */
  }

  .meet-makers__slider::-webkit-scrollbar {
    display: none; /* Chrome, Safari */
  }

  /* Maker Card */
  .maker-card {
    display: flex;
    flex-direction: column;
    flex: 0 0 90%; /* Mobile view shows 90% of card */
    max-width: 750px;
    background-color: #f4efea; /* Slightly lighter than bg */
    border-radius: var(--radius-md, 8px);
    border: 1px solid rgba(107, 93, 82, 0.15);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.02);
  }

  @media screen and (min-width: 768px) {
    .maker-card {
      flex: 0 0 80%;
    }
  }

  @media screen and (min-width: 1024px) {
    .maker-card {
      flex: 0 0 45vw;
    }
  }

  .maker-card__body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  @media screen and (min-width: 600px) {
    .maker-card__body {
      flex-direction: row;
    }
  }

  .maker-card__image-col {
    width: 100%;
    position: relative;
    background-color: #e8e3df; /* placeholder color */
  }

  @media screen and (min-width: 600px) {
    .maker-card__image-col {
      width: 45%;
      flex-shrink: 0;
    }
  }

  .maker-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 300px;
    -webkit-user-drag: none; /* Disable image dragging */
    user-select: none;
  }

  .maker-card__text-col {
    padding: var(--sp-6, 24px) var(--sp-5, 20px);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .maker-card__role {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-secondary, #6b5d52);
    margin-bottom: 8px;
    font-weight: 600;
  }

  .maker-card__name {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: var(--font-weight-regular, 400);
    margin-bottom: 8px;
    color: var(--text-primary, #1a1815);
  }

  .maker-card__tags {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-secondary, #6b5d52);
    margin-bottom: 16px;
  }

  .maker-card__bio {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary, #6b5d52);
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .maker-card__quote {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
  }

  .maker-card__quote-mark {
    font-family: var(--font-display);
    font-size: 36px;
    color: var(--text-secondary, #6b5d52);
    line-height: 0.8;
  }

  .maker-card__quote p {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary, #6b5d52);
    line-height: 1.6;
    margin: 0;
  }

  /* Features */
  .maker-card__features {
    display: flex;
    border-top: 1px solid rgba(107, 93, 82, 0.15);
    padding-top: 16px;
    margin-top: auto;
  }

  .maker-feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
    gap: 8px;
    color: var(--text-secondary, #6b5d52);
  }

  .maker-feature--border {
    border-left: 1px solid rgba(107, 93, 82, 0.15);
  }

  .maker-feature svg {
    opacity: 0.8;
  }

  .maker-feature span {
    font-family: var(--font-body);
    font-size: 9px;
    letter-spacing: 0.05em;
    font-weight: 500;
    line-height: 1.3;
  }

  /* Card Footer Button */
  .maker-card__btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 14px;
    background-color: var(--color-earth-brown, #442c1a);
    color: #fff;
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.1em;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .maker-card__btn:hover {
    background-color: #2c1c11;
  }

  /* Section Footer */
  .meet-makers__footer {
    margin-top: var(--sp-10, 48px);
    display: flex;
    justify-content: center;
  }

  .meet-makers__footer-content {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 16px;
    color: var(--text-secondary, #6b5d52);
  }

  .meet-makers__footer-text {
    font-family: var(--font-body);
    font-size: 13px;
    letter-spacing: 0.1em;
    font-weight: 600;
  }
  
  .meet-makers__footer-sep {
    font-size: 10px;
    opacity: 0.5;
  }
  
  .meet-makers__footer-icon {
    opacity: 0.8;
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', () => {
    const sliders = document.querySelectorAll('.meet-makers__slider');
    sliders.forEach(slider => {
      let isDown = false;
      let startX;
      let scrollLeft;

      slider.addEventListener('mousedown', (e) => {
        isDown = true;
        slider.classList.add('is-dragging');
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
      });

      slider.addEventListener('mouseleave', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
      });

      slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
      });

      slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 2; // scroll-fast
        slider.scrollLeft = scrollLeft - walk;
      });
      
      // Prevent link clicks if dragging occurred
      let isDragging = false;
      slider.addEventListener('mousemove', (e) => {
        if(isDown) isDragging = true;
      });
      slider.addEventListener('mousedown', () => {
        isDragging = false;
      });
      slider.addEventListener('click', (e) => {
        if(isDragging) {
          e.preventDefault();
        }
      });
    });
  });
{% endjavascript %}

