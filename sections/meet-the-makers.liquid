{% javascript %}
  document.addEventListener('DOMContentLoaded', () => {
    const sliders = document.querySelectorAll('.meet-makers__slider');
    sliders.forEach((slider) => {
      const carousel = slider.closest('[data-maker-carousel]');
      const prevButton = carousel ? carousel.querySelector('[data-maker-prev]') : null;
      const nextButton = carousel ? carousel.querySelector('[data-maker-next]') : null;
      const dots = carousel ? Array.from(carousel.querySelectorAll('[data-maker-dot]')) : [];
      const cards = Array.from(slider.querySelectorAll('.maker-card'));
      const desktopQuery = window.matchMedia('(min-width: 1200px)');
      let activeFrame = 0;

      const getCardsPerFrame = () => (desktopQuery.matches ? 2 : 1);
      const getFrameCount = () => Math.max(1, Math.ceil(cards.length / getCardsPerFrame()));

      const getFrameLeft = (frame) => {
        const targetCard = cards[Math.min(frame * getCardsPerFrame(), cards.length - 1)];
        if (!targetCard) return 0;
        return targetCard.offsetLeft - slider.offsetLeft;
      };

      const updateCarouselState = () => {
        const frameCount = getFrameCount();
        activeFrame = Math.min(Math.max(activeFrame, 0), frameCount - 1);

        if (prevButton) prevButton.disabled = activeFrame === 0;
        if (nextButton) nextButton.disabled = activeFrame >= frameCount - 1;

        dots.forEach((dot, index) => {
          const isActive = index === activeFrame;
          dot.classList.toggle('is-active', isActive);
          dot.setAttribute('aria-pressed', isActive ? 'true' : 'false');
          dot.hidden = index >= frameCount;
        });
      };

      const goToFrame = (frame, behavior = 'smooth') => {
        activeFrame = Math.min(Math.max(frame, 0), getFrameCount() - 1);
        slider.scrollTo({ left: getFrameLeft(activeFrame), behavior });
        updateCarouselState();
      };

      prevButton?.addEventListener('click', () => goToFrame(activeFrame - 1));
      nextButton?.addEventListener('click', () => goToFrame(activeFrame + 1));
      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const frame = Number(dot.dataset.makerFrame || 0);
          goToFrame(frame);
        });
      });

      slider.addEventListener(
        'scroll',
        () => {
          if (!desktopQuery.matches) return;
          const frameCount = getFrameCount();
          let closestFrame = 0;
          let closestDistance = Infinity;
          for (let frame = 0; frame < frameCount; frame += 1) {
            const distance = Math.abs(slider.scrollLeft - getFrameLeft(frame));
            if (distance < closestDistance) {
              closestDistance = distance;
              closestFrame = frame;
            }
          }
          activeFrame = closestFrame;
          updateCarouselState();
        },
        { passive: true }
      );

      const handleResize = () => goToFrame(activeFrame, 'auto');
      window.addEventListener('resize', handleResize);
      desktopQuery.addEventListener?.('change', handleResize);
      updateCarouselState();

      let isDown = false;
      let startX;
      let scrollLeft;

      slider.addEventListener('mousedown', (e) => {
        isDown = true;
        slider.classList.add('is-dragging');
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
      });

      slider.addEventListener('mouseleave', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
      });

      slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
      });

      slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 2; // scroll-fast
        slider.scrollLeft = scrollLeft - walk;
      });

      // Prevent link clicks if dragging occurred
      let isDragging = false;
      slider.addEventListener('mousemove', (e) => {
        if (isDown) isDragging = true;
      });
      slider.addEventListener('mousedown', () => {
        isDragging = false;
      });
      slider.addEventListener('click', (e) => {
        if (isDragging) {
          e.preventDefault();
        }
      });
    });
  });
{% endjavascript %}

