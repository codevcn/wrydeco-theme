<div class="custom-section-divider"></div>

<div class="meet-makers">
  <div class="meet-makers__inner">
  <div class="meet-makers__header">
    <p class="meet-makers__eyebrow">{{ section.settings.eyebrow | upcase }}</p>
    <h2 class="meet-makers__heading">{{ section.settings.heading | escape }}</h2>
    <p class="meet-makers__subtitle">
      {{ section.settings.subtitle | default: 'Our pieces are shaped by the hands, heritage, and heart of our artisans. Each maker brings a lifetime of dedication to every curve, grain, and detail.' | newline_to_br }}
    </p>
  </div>

  <div class="meet-makers__carousel" data-maker-carousel>
    <button class="meet-makers__nav meet-makers__nav--prev" type="button" aria-label="Previous makers" data-maker-prev>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M15 5L8 12L15 19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="meet-makers__track">
      <div class="meet-makers__slider" data-maker-slider>
        {%- for block in section.blocks -%}
          {%- assign maker_name = block.settings.name | default: 'WRYDECO Maker' -%}
          {%- assign fallback_index = forloop.index -%}
          {%- assign asset_name = 'sli-' | append: fallback_index | append: '.webp' -%}
          {%- case maker_name -%}
            {%- when 'Huan Ngo' -%}
              {%- assign asset_name = 'artist-Huan_Ngo.webp' -%}
            {%- when 'Trung Le' -%}
              {%- assign asset_name = 'artist-Trung_Le.webp' -%}
            {%- when 'Alex Nguyen' -%}
              {%- assign asset_name = 'artist-Alex_Nguyen.webp' -%}
            {%- when 'Dien Luc' -%}
              {%- assign asset_name = 'artist-Dien_Luc.webp' -%}
            {%- when 'Kiet Phac' -%}
              {%- assign asset_name = 'artist-Kiet_Phac.webp' -%}
            {%- when 'Ngoc Vo' -%}
              {%- assign asset_name = 'artist-Ngoc_Vo.webp' -%}
          {%- endcase -%}
          <div class="maker-card" {{ block.shopify_attributes }}>
            <div class="maker-card__body">
              <div class="maker-card__image-col">
                {%- if block.settings.link != blank -%}
                  <a href="{{ block.settings.link }}" class="maker-card__img-link" aria-label="View {{ maker_name | escape }}'s profile">
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 600
                    | image_tag: class: 'maker-card__img', loading: 'lazy', draggable: 'false', alt: maker_name
                  }}
                {%- else -%}
                  <img
                    src="{{ asset_name | file_url }}"
                    alt="{{ maker_name | escape }}"
                    class="maker-card__img"
                    loading="lazy"
                    draggable="false"
                    width="600"
                    height="600"
                  >
                {%- endif -%}
                {%- if block.settings.link != blank -%}
                  </a>
                {%- endif -%}
              </div>
              <div class="maker-card__text-col">
                <h3 class="maker-card__name">{{ maker_name | escape }}</h3>
                <p class="maker-card__role">{{ block.settings.role | default: 'Master Craftsperson' | upcase }}</p>
                <p class="maker-card__bio">{{ block.settings.bio | newline_to_br }}</p>

                <div class="maker-card__features">
                  <div class="maker-feature">
                    <svg width="25" height="25" viewBox="0 0 25 25" fill="none" aria-hidden="true">
                      <circle cx="12.5" cy="12.5" r="10.5" stroke="currentColor" stroke-width="1"/>
                      <path d="M12.5 5.7v7.1l4.2 2.5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    <span>{{ block.settings.feature_1 | newline_to_br }}</span>
                  </div>
                  <div class="maker-feature">
                    <svg
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M19 4c-6.5.8-10.8 4.3-12.8 10.5"/>
                      <path d="M5.8 14.2c3.7.7 7.3-.3 10-3.2 1.9-2.1 2.8-4.5 3.2-7-3 .3-5.6 1.2-7.7 2.8-2.8 2.1-4.7 4.8-5.5 7.4Z"/>
                      <path d="M4.5 19.5c1.4-3.2 3.5-5.7 6.2-7.7"/>
                    </svg>
                    <span>{{ block.settings.feature_2 | newline_to_br }}</span>
                  </div>
                  <div class="maker-feature">
                    <svg
                      width="24"
                      height="24"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="1"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <path d="M7 21h10"/>
                      <path d="M8 21V9.5a4 4 0 0 1 8 0V21"/>
                      <path d="M6 13h12"/>
                      <path d="M9.5 5.5 8 3.2"/>
                      <path d="m14.5 5.5 1.5-2.3"/>
                    </svg>
                    <span>{{ block.settings.feature_3 | newline_to_br }}</span>
                  </div>
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

      <div class="meet-makers__dots" aria-label="Maker slides">
        {%- for block in section.blocks -%}
          {%- assign dot_remainder = forloop.index0 | modulo: 2 -%}
          {%- if dot_remainder == 0 -%}
            <button
              class="meet-makers__dot{% if forloop.first %} is-active{% endif %}"
              type="button"
              aria-label="Go to maker slide {{ forloop.index0 | divided_by: 2 | plus: 1 }}"
              aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
              data-maker-dot
              data-maker-frame="{{ forloop.index0 | divided_by: 2 }}"
            ></button>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <button class="meet-makers__nav meet-makers__nav--next" type="button" aria-label="Next makers" data-maker-next>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M9 5L16 12L9 19" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  <div class="meet-makers__footer">
    <p class="meet-makers__quote" aria-label="Maker statement">
      <span class="meet-makers__quote-mark" aria-hidden="true">“</span>
      <span>{{ section.settings.footer_quote | default: "We don't just build furniture. We create pieces that carry stories forward." | escape }}</span>
      <span class="meet-makers__quote-mark" aria-hidden="true">”</span>
    </p>
    <p class="meet-makers__credit">{{ section.settings.footer_credit | default: 'The WRYDECO Makers' | escape }}</p>
    {%- assign cta_label = section.settings.cta_label | default: 'View Craftsmanship' -%}
    {%- if cta_label != blank -%}
      <script>
        function randomMakerRedirect() {
          var links = [];
          {%- for block in section.blocks -%}
            {%- if block.settings.link != blank -%}
              links.push({{ block.settings.link | json }});
            {%- endif -%}
          {%- endfor -%}
          
          if (links.length > 0) {
            var randomLink = links[Math.floor(Math.random() * links.length)];
            window.location.href = randomLink;
          } else {
            window.location.href = {{ section.settings.cta_link | default: '/pages/about-us' | json }};
          }
        }
      </script>
      <button class="meet-makers__cta" type="button" onclick="randomMakerRedirect()">
        <span>{{ cta_label | escape }}</span>
        <span aria-hidden="true">→</span>
      </button>
    {%- endif -%}
  </div>
  </div>
</div>

{% stylesheet %}
  @font-face {
    font-family: 'Fraunces';
    src: url('Fraunces.woff2') format('woff2');
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  .meet-makers {
    padding-top: var(--sp-12, 64px);
    padding-bottom: var(--sp-12, 64px);
    background-color: var(--bg-primary, #f5f1ed);
    color: var(--text-primary, #1a1815);
    margin-top: var(--sp-6, 64px);
    margin-bottom: var(--sp-5, 64px);
    overflow: clip;
  }

  .meet-makers__header {
    text-align: center;
    margin-bottom: var(--sp-10, 48px);
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .meet-makers__icon {
    color: var(--text-secondary, #6b5d52);
    margin-bottom: var(--sp-4, 16px);
  }

  .meet-makers__leaf-icon {
    color: var(--text-secondary, #6b5d52);
    margin-top: var(--sp-4, 16px);
  }

  .meet-makers__eyebrow {
    font-family: var(--font-body);
    font-size: var(--font-size-body-xs, 12px);
    letter-spacing: 0.12em;
    color: var(--text-secondary, #6b5d52);
    margin-bottom: var(--sp-2, 8px);
    font-weight: 500;
  }

  .meet-makers__heading {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 52px);
    font-weight: var(--font-weight-regular, 400);
    color: var(--text-primary, #1a1815);
    margin-bottom: var(--sp-3, 12px);
    letter-spacing: var(--letter-spacing-tight, -0.04em);
  }

  .meet-makers__subtitle {
    font-family: var(--font-body);
    font-size: var(--font-size-body-md, 16px);
    color: var(--text-secondary, #6b5d52);
    line-height: var(--line-height-relaxed, 1.5);
    max-width: 600px;
    margin: 0 auto;
  }

  /* Slider Container */
  .meet-makers__slider {
    display: flex;
    gap: var(--sp-5, 20px);
    overflow-x: auto;
    padding-bottom: var(--sp-6, 24px);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
    cursor: grab;
  }

  .meet-makers__slider.is-dragging {
    cursor: grabbing;
  }

  .meet-makers__slider.is-dragging .maker-card {
    user-select: none;
    pointer-events: none; /* Prevents text selection & hover states while dragging */
  }

  .meet-makers__slider::-webkit-scrollbar {
    display: none; /* Chrome, Safari */
  }

  .meet-makers__carousel {
    position: relative;
    overflow: clip;
  }

  .meet-makers__track {
    position: relative;
  }

  .meet-makers__nav,
  .meet-makers__dots {
    display: none;
  }

  /* Maker Card */
  .maker-card {
    display: flex;
    flex-direction: column;
    flex: 0 0 90%; /* Mobile view shows 90% of card */
    max-width: 750px;
    background-color: #f4efea; /* Slightly lighter than bg */
    border-radius: var(--radius-md, 8px);
    border: 1px solid rgba(107, 93, 82, 0.15);
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.02);
  }

  @media screen and (min-width: 768px) {
    .maker-card {
      flex: 0 0 80%;
    }
  }

  @media screen and (min-width: 1024px) {
    .maker-card {
      flex: 0 0 45vw;
    }
  }

  .maker-card__body {
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  @media screen and (min-width: 600px) {
    .maker-card__body {
      flex-direction: row;
    }
  }

  .maker-card__image-col {
    width: 100%;
    position: relative;
    background-color: #e8e3df; /* placeholder color */
    overflow: hidden;
  }

  @media screen and (min-width: 600px) {
    .maker-card__image-col {
      width: 45%;
      flex-shrink: 0;
    }
  }

  .maker-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    min-height: 300px;
    -webkit-user-drag: none; /* Disable image dragging */
    user-select: none;
    transition: transform var(--timing-long, 0.4s) var(--ease-out, ease-out);
  }

  .maker-card__img-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
    outline: none;
  }
  
  .maker-card__img-link:hover .maker-card__img,
  .maker-card__img-link:focus .maker-card__img {
    transform: scale(1.05);
  }

  .maker-card__text-col {
    padding: var(--sp-6, 24px) var(--sp-5, 20px);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .maker-card__role {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.1em;
    color: var(--text-secondary, #6b5d52);
    margin-bottom: 8px;
    font-weight: 600;
  }

  .maker-card__name {
    font-family: var(--font-display);
    font-size: clamp(24px, 3vw, 32px);
    font-weight: var(--font-weight-regular, 400);
    margin-bottom: 8px;
    color: var(--text-primary, #1a1815);
  }

  .maker-card__tags {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--text-secondary, #6b5d52);
    margin-bottom: 16px;
  }

  .maker-card__bio {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-secondary, #6b5d52);
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .maker-card__quote {
    display: flex;
    gap: 8px;
    margin-bottom: 24px;
  }

  .maker-card__quote-mark {
    font-family: var(--font-display);
    font-size: 36px;
    color: var(--text-secondary, #6b5d52);
    line-height: 0.8;
  }

  .maker-card__quote p {
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--text-secondary, #6b5d52);
    line-height: 1.6;
    margin: 0;
  }

  /* Features */
  .maker-card__features {
    display: flex;
    border-top: 1px solid rgba(107, 93, 82, 0.15);
    padding-top: 16px;
    margin-top: auto;
  }

  .maker-feature {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
    gap: 8px;
    color: var(--text-secondary, #6b5d52);
  }

  .maker-feature--border {
    border-left: 1px solid rgba(107, 93, 82, 0.15);
  }

  .maker-feature svg {
    opacity: 0.8;
  }

  .maker-feature span {
    font-family: var(--font-body);
    font-size: 9px;
    letter-spacing: 0.05em;
    font-weight: 500;
    line-height: 1.3;
  }

  /* Card Footer Button */
  .maker-card__btn {
    display: block;
    width: 100%;
    text-align: center;
    padding: 14px;
    background-color: var(--color-earth-brown, #442c1a);
    color: #fff;
    font-family: var(--font-body);
    font-size: 12px;
    letter-spacing: 0.1em;
    font-weight: 500;
    text-decoration: none;
    transition: background-color 0.2s;
  }

  .maker-card__btn:hover {
    background-color: #2c1c11;
  }

  @media screen and (min-width: 1200px) {
    .meet-makers {
      width: 100%;
      max-width: none;
      min-height: auto;
      height: auto;
      padding: clamp(72px, 6vw, 104px) clamp(64px, 5vw, 94px);
      overflow: clip;
    }

    .meet-makers__header {
      margin-bottom: clamp(28px, 3.5svh, 34px);
    }

    .meet-makers__icon {
      margin-bottom: clamp(10px, 1.3svh, 12px);
    }

    .meet-makers__icon svg {
      width: 36px;
      height: 36px;
      opacity: 0.58;
    }

    .meet-makers__eyebrow {
      margin-bottom: clamp(12px, 1.8svh, 16px);
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.28em;
      color: var(--color-bark, #6b5d52);
    }

    .meet-makers__heading {
      margin-bottom: clamp(14px, 1.8svh, 16px);
      font-size: clamp(64px, 4.7vw, 78px);
      font-weight: 300;
      letter-spacing: -0.055em;
      line-height: 0.96;
    }

    .meet-makers__subtitle {
      max-width: 580px;
      font-size: clamp(15px, 0.95vw, 17px);
      line-height: 1.5;
    }

    .meet-makers__leaf-icon {
      position: relative;
      display: flex;
      align-items: center;
      gap: var(--sp-4);
      margin-top: clamp(18px, 2.4svh, 24px);
      color: var(--color-bark, #6b5d52);
    }

    .meet-makers__leaf-icon::before,
    .meet-makers__leaf-icon::after {
      width: 80px;
      height: 1px;
      background: rgba(107, 93, 82, 0.3);
      content: '';
    }

    .meet-makers__leaf-icon svg {
      width: 20px;
      height: 20px;
    }

    .meet-makers__carousel {
      min-height: auto;
    }

    .meet-makers__slider {
      display: flex;
      gap: clamp(14px, 0.95vw, 16px);
      min-height: 0;
      padding-bottom: 0;
      overflow-x: auto;
      scroll-behavior: smooth;
      scroll-snap-type: x mandatory;
      cursor: default;
    }

    .maker-card {
      display: grid;
      grid-template-rows: minmax(0, 1fr) 48px;
      flex: 0 0 calc((100% - clamp(14px, 0.95vw, 16px)) / 2);
      max-width: none;
      min-width: 0;
      height: auto;
      min-height: 520px;
      border-color: rgba(107, 93, 82, 0.18);
      border-radius: var(--radius-lg, 8px);
      background: color-mix(in srgb, var(--bg-primary, #f5f1ed) 92%, #ffffff);
      box-shadow: none;
      scroll-snap-align: start;
    }

    .maker-card__body {
      display: grid;
      grid-template-columns: minmax(0, 49.5%) minmax(0, 50.5%);
      min-height: 0;
    }

    .maker-card__image-col {
      width: auto;
      min-height: 0;
    }

    .maker-card__img {
      min-height: 0;
      height: 100%;
      filter: grayscale(1) contrast(1.06);
      object-position: center center;
    }

    .maker-card__text-col {
      min-height: 0;
      padding: clamp(32px, 3.9svh, 38px) clamp(36px, 3vw, 44px) clamp(22px, 2.5svh, 26px);
    }

    .maker-card__role {
      margin-bottom: clamp(16px, 2svh, 20px);
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.18em;
      color: var(--color-bark, #6b5d52);
    }

    .maker-card__name {
      margin-bottom: clamp(12px, 1.5svh, 14px);
      font-size: clamp(40px, 2.7vw, 46px);
      font-weight: 300;
      letter-spacing: -0.055em;
      line-height: 0.98;
    }

    .maker-card__tags {
      margin-bottom: clamp(22px, 2.9svh, 28px);
      font-size: 15px;
      line-height: 1.45;
    }

    .maker-card__bio {
      max-width: 34ch;
      margin-bottom: clamp(18px, 2.6svh, 24px);
      font-size: 14px;
      line-height: 1.6;
      flex-grow: 0;
    }

    .maker-card__quote {
      gap: var(--sp-2);
      margin-bottom: clamp(20px, 2.8svh, 28px);
    }

    .maker-card__quote-mark {
      font-size: 44px;
      color: var(--color-earth-brown, #4a2c18);
    }

    .maker-card__quote p {
      font-family: var(--font-display);
      font-size: clamp(16px, 1.08vw, 18px);
      line-height: 1.35;
      color: var(--color-earth-brown, #4a2c18);
    }

    .maker-card__features {
      padding-top: 0;
      border-top: 0;
      margin-top: auto;
    }

    .maker-feature {
      gap: var(--sp-2);
    }

    .maker-feature--border {
      border-left-color: rgba(107, 93, 82, 0.32);
    }

    .maker-feature svg {
      width: 28px;
      height: 28px;
      color: var(--color-bark, #6b5d52);
    }

    .maker-feature span {
      font-size: 10px;
      font-weight: 600;
      letter-spacing: 0.06em;
      line-height: 1.32;
      color: var(--color-earth-brown, #4a2c18);
    }

    .maker-card__btn {
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 48px;
      padding: 0;
      background: var(--color-earth-brown, #4a2c18);
      color: var(--text-inverse, #f5f1ed);
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.18em;
    }

    .meet-makers__nav {
      position: absolute;
      z-index: 3;
      top: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 44px;
      height: 44px;
      border: 1px solid rgba(107, 93, 82, 0.36);
      border-radius: var(--radius-full);
      background: color-mix(in srgb, var(--bg-primary, #f5f1ed) 82%, white);
      color: var(--color-earth-brown, #4a2c18);
      cursor: pointer;
      transform: translateY(-50%);
      transition: background-color var(--timing-short) var(--ease-standard),
        border-color var(--timing-short) var(--ease-standard), opacity var(--timing-short) var(--ease-standard),
        transform var(--timing-short) var(--ease-standard);
    }

    .meet-makers__nav:hover {
      border-color: rgba(74, 44, 24, 0.65);
      background: var(--color-milk, #f7f2ec);
      transform: translateY(-50%) scale(1.04);
    }

    .meet-makers__nav:focus-visible,
    .meet-makers__dot:focus-visible {
      outline: 2px solid var(--color-sage);
      outline-offset: var(--sp-1);
    }

    .meet-makers__nav[disabled] {
      opacity: 0.34;
      cursor: default;
      pointer-events: none;
    }

    .meet-makers__nav--prev {
      left: var(--sp-3);
    }

    .meet-makers__nav--next {
      right: var(--sp-3);
    }

    .meet-makers__dots {
      position: static;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--sp-2);
      margin-top: var(--sp-5);
      margin-bottom: var(--sp-4);
      transform: none;
    }

    .meet-makers__dot {
      width: 8px;
      height: 8px;
      padding: 0;
      border: 1px solid rgba(107, 93, 82, 0.46);
      border-radius: var(--radius-full);
      background: transparent;
      cursor: pointer;
      transition: width var(--timing-short) var(--ease-standard),
        background-color var(--timing-short) var(--ease-standard), border-color var(--timing-short) var(--ease-standard);
    }

    .meet-makers__dot.is-active {
