{% comment %}
  Server-rendered PDP editorial gallery highlighting the natural variation of solid wood.
{% endcomment %}

<section
  class="wood-alike"
  aria-labelledby="WoodAlikeHeading-{{ section.id }}"
>
  <div class="wood-alike__inner">
    <figure class="wood-alike__main-media">
      <img
        class="wood-alike__image"
        src="{{ 'no-two-woods-alike-1.png' | file_url }}"
        alt="{{ section.settings.main_image_alt | escape }}"
        width="1200"
        height="1440"
        loading="lazy"
        decoding="async"
      >
    </figure>

    <header class="wood-alike__header">
      {% if section.settings.eyebrow != blank %}
        <p class="wood-alike__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {% endif %}

      <h2 class="wood-alike__heading" id="WoodAlikeHeading-{{ section.id }}">
        {{ section.settings.heading | escape }}
      </h2>

      {% if section.settings.description != blank %}
        <p class="wood-alike__description">{{ section.settings.description | escape }}</p>
      {% endif %}
    </header>

    <div class="wood-alike__details">
      <figure class="wood-alike__detail">
        <img
          class="wood-alike__image"
          src="{{ 'no-two-woods-alike-4.png' | file_url }}"
          alt="{{ section.settings.grain_label | escape }}"
          width="720"
          height="500"
          loading="lazy"
          decoding="async"
        >
        <figcaption class="wood-alike__label">{{ section.settings.grain_label | escape }}</figcaption>
      </figure>

      <figure class="wood-alike__detail">
        <img
          class="wood-alike__image"
          src="{{ 'no-two-woods-alike-3.png' | file_url }}"
          alt="{{ section.settings.knots_label | escape }}"
          width="720"
          height="500"
          loading="lazy"
          decoding="async"
        >
        <figcaption class="wood-alike__label">{{ section.settings.knots_label | escape }}</figcaption>
      </figure>

      <figure class="wood-alike__detail">
        <img
          class="wood-alike__image"
          src="{{ 'no-two-woods-alike-2.png' | file_url }}"
          alt="{{ section.settings.edge_label | escape }}"
          width="720"
          height="500"
          loading="lazy"
          decoding="async"
        >
        <figcaption class="wood-alike__label">{{ section.settings.edge_label | escape }}</figcaption>
      </figure>

      <figure class="wood-alike__detail">
        <img
          class="wood-alike__image"
          src="{{ 'no-two-woods-alike-5.png' | file_url }}"
          alt="{{ section.settings.rings_label | escape }}"
          width="720"
          height="500"
          loading="lazy"
          decoding="async"
        >
        <figcaption class="wood-alike__label">{{ section.settings.rings_label | escape }}</figcaption>
      </figure>
    </div>
  </div>
</section>

{% stylesheet %}
  .wood-alike {
    display: block;
    box-sizing: border-box;
    height: 100svh;
    max-height: var(--layout-hero-wide-height);
    padding: clamp(var(--sp-3), 2.5svh, var(--sp-5)) var(--container-padding-x);
    padding-top: var(--sp-8);
    background-color: var(--color-white-cream);
    color: var(--text-primary);
  }

  .wood-alike__inner {
    display: grid;
    grid-template-areas:
      'main header'
      'main details';
    grid-template-columns: minmax(var(--sp-0), 1.03fr) minmax(var(--sp-0), 1fr);
    grid-template-rows: auto minmax(var(--sp-0), 1fr);
    gap: clamp(var(--sp-2), 1.5svh, var(--sp-5)) var(--sp-7);
    width: 100%;
    height: 100%;
    max-width: var(--page-max-width);
    min-height: var(--sp-0);
    margin-inline: auto;
  }

  .wood-alike__main-media,
  .wood-alike__detail {
    position: relative;
    min-width: var(--sp-0);
    min-height: var(--sp-0);
    margin: var(--sp-0);
    overflow: hidden;
    border-radius: var(--radius-xl);
    background-color: var(--bg-secondary);
  }

  .wood-alike__main-media {
    grid-area: main;
    aspect-ratio: auto;
  }

  .wood-alike__header {
    grid-area: header;
    align-self: end;
  }

  .wood-alike__eyebrow {
    margin: var(--sp-0) var(--sp-0) clamp(var(--sp-2), 2svh, var(--sp-5));
    color: var(--color-clay);
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .wood-alike__heading {
    max-width: var(--layout-hero-copy-width);
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-display-light);
    font-size: clamp(var(--font-size-display-lg), 7svh, var(--font-size-display-2xl));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-snug);
    line-height: var(--line-height-display);
  }

  .wood-alike__description {
    max-width: calc(var(--layout-hero-copy-width) - var(--sp-12));
    margin: clamp(var(--sp-2), 2svh, var(--sp-5)) var(--sp-0) var(--sp-0);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: clamp(var(--font-size-body-md), 2.4svh, var(--font-size-body-xl));
    line-height: var(--line-height-relaxed);
  }

  .wood-alike__details {
    display: grid;
    grid-area: details;
    grid-template-columns: repeat(2, minmax(var(--sp-0), 1fr));
    grid-template-rows: repeat(2, minmax(var(--sp-0), 1fr));
    gap: var(--sp-3);
    min-height: var(--sp-0);
  }

  .wood-alike__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .wood-alike__label {
    position: absolute;
    inset-block-end: var(--sp-3);
    inset-inline-start: var(--sp-3);
    margin: var(--sp-0);
    padding: var(--sp-2) var(--sp-3);
    border-radius: var(--radius-md);
    background-color: color-mix(in srgb, var(--color-earth-brown) 82%, transparent);
    color: var(--text-inverse);
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-medium);
    letter-spacing: var(--letter-spacing-wide);
    line-height: var(--line-height-tight);
    text-transform: uppercase;
  }

  @media screen and (max-width: 900px) {
    .wood-alike {
      height: auto;
      max-height: none;
      padding: var(--sp-8) var(--layout-padding-tablet) var(--sp-6);
    }

    .wood-alike__inner {
      grid-template-areas:
        'header'
        'main'
        'details';
      grid-template-columns: minmax(var(--sp-0), 1fr);
      grid-template-rows: auto auto auto;
      gap: var(--sp-5);
      height: auto;
    }

    .wood-alike__header {
      align-self: auto;
      max-width: var(--layout-hero-copy-width);
    }

    .wood-alike__main-media {
      aspect-ratio: 5 / 4;
    }

    .wood-alike__details {
      grid-template-rows: repeat(2, minmax(var(--sp-12), 1fr));
    }
  }

  @media screen and (max-width: 640px) {
    .wood-alike {
      padding: var(--sp-6) var(--layout-padding-mobile) var(--sp-5);
    }

    .wood-alike__inner {
      gap: var(--sp-4);
    }

    .wood-alike__eyebrow {
      margin-block-end: var(--sp-3);
      font-size: var(--font-size-caption);
    }

    .wood-alike__heading {
      font-size: var(--font-size-display-sm);
    }

    .wood-alike__description {
      margin-block-start: var(--sp-3);
      font-size: var(--font-size-body-sm);
    }

    .wood-alike__main-media {
      aspect-ratio: 4 / 5;
    }

    .wood-alike__details {
      gap: var(--sp-2);
    }

    .wood-alike__label {
      inset-block-end: var(--sp-2);
      inset-inline-start: var(--sp-2);
      padding: var(--sp-1) var(--sp-2);
      font-size: var(--font-size-caption);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "No two pieces alike",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Soul of solid wood"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "No Two Pieces Are Ever Truly Alike"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every slab carries its own grain, knots, and natural movement-shaped by time, never repeated."
    },
    {
      "type": "text",
      "id": "main_image_alt",
      "label": "Main image alt text",
      "default": "Handcrafted solid wood furniture with expressive natural grain"
    },
    {
      "type": "text",
      "id": "grain_label",
      "label": "Grain image label",
      "default": "Unique grain"
    },
    {
      "type": "text",
      "id": "knots_label",
      "label": "Knots image label",
      "default": "Natural knots"
    },
    {
      "type": "text",
      "id": "edge_label",
      "label": "Edge image label",
      "default": "Live edge"
    },
    {
      "type": "text",
      "id": "rings_label",
      "label": "Rings image label",
      "default": "Timeworn rings"
    }
  ],
  "presets": [
    {
      "name": "No two pieces alike"
    }
  ]
}
{% endschema %}
