<section class="signature-pieces" aria-labelledby="SignaturePiecesHeading-{{ section.id }}">
  <div class="signature-pieces__inner">
    <header class="signature-pieces__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="signature-pieces__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="signature-pieces__heading" id="SignaturePiecesHeading-{{ section.id }}">
        {{ section.settings.heading | escape }}
      </h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="signature-pieces__subtitle">{{ section.settings.subtitle | newline_to_br }}</p>
      {%- endif -%}
    </header>

    {%- assign collection = section.settings.collection -%}
    {%- if collection == blank -%}
      {%- assign collection = collections['signature-pieces'] -%}
    {%- endif -%}

    <div class="signature-pieces__grid" role="list">
      {%- for product in collection.products limit: 4 -%}
        {%- assign display_title = product.metafields.custom.artwork_name.value | default: product.title -%}
        {%- liquid
          assign artist = ''
          assign author = product.metafields.custom.author_info.value
          if author != blank and author.author_name.value != blank
            assign artist = author.author_name.value
          elsif product.vendor != blank and product.vendor != shop.name
            assign artist = product.vendor
          endif
        -%}
        {%- assign material = product.metafields.custom.product_material.value | default: section.settings.material_default -%}
        {%- assign finish = product.metafields.custom.finish.value | default: section.settings.finish_default -%}
        {%- comment -%} Show a "New" badge for products in the "new-arrivals" collection. {%- endcomment -%}
        {%- assign is_new = false -%}
        {%- for coll in product.collections -%}
          {%- if coll.handle == 'new-arrivals' -%}
            {%- assign is_new = true -%}
            {%- break -%}
          {%- endif -%}
        {%- endfor -%}

        <article class="signature-pieces__card" role="listitem">
          <div class="signature-pieces__media">
            <a class="signature-pieces__image-link" href="{{ product.url }}" aria-label="{{ display_title | escape }}">
              {%- if product.featured_media != blank -%}
                {{
                  product.featured_media.preview_image
                  | image_url: width: 900
                  | image_tag:
                    class: 'signature-pieces__image',
                    loading: 'lazy',
                    widths: '360, 540, 720, 900',
                    sizes: '(min-width: 80rem) 23vw, (min-width: 48rem) 46vw, 88vw'
                }}
              {%- else -%}
                {%- assign fallback_asset = 'sli-' | append: forloop.index | append: '.webp' -%}
                <img
                  class="signature-pieces__image"
                  src="{{ fallback_asset | file_url }}"
                  alt="{{ display_title | escape }}"
                  width="900"
                  height="1080"
                  loading="lazy"
                >
              {%- endif -%}
            </a>

            {%- if is_new -%}
              <span class="signature-pieces__new">
                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 36 36">
                  <path d="M0 0h36v36H0z" fill="none" />
                  <path fill="currentColor" d="m34.11 24.49l-3.92-6.62l3.88-6.35a1 1 0 0 0-.85-1.52H2a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h31.25a1 1 0 0 0 .86-1.51m-23.6-3.31H9.39l-3.26-4.34v4.35H5V15h1.13l3.27 4.35V15h1.12ZM16.84 16h-3.53v1.49h3.2v1h-3.2v1.61h3.53v1h-4.66V15h4.65Zm8.29 5.16H24l-1.55-4.59l-1.55 4.61h-1.12l-2-6.18H19l1.32 4.43L21.84 15h1.22l1.46 4.43L25.85 15h1.23Z" class="clr-i-solid clr-i-solid-path-1" />
                  <path fill="none" d="M0 0h36v36H0z" />
                </svg>
                <span class="signature-pieces__new-text">New</span>
              </span>
            {%- endif -%}

            {%- if product.available -%}
              <button
                class="signature-pieces__quick"
                data-add-to-cart-signature
                data-variant-id="{{ product.variants.first.id }}"
                aria-label="Add {{ display_title | escape }} to cart"
                type="button"
              >
                {{ 'icon-cart.svg' | inline_asset_content }}
              </button>
            {%- else -%}
              <span class="signature-pieces__quick" aria-hidden="true">
                {{ 'icon-cart.svg' | inline_asset_content }}
              </span>
            {%- endif -%}
          </div>

          <div class="signature-pieces__content">
            <h3 class="signature-pieces__title">
              <a href="{{ product.url }}">{{ display_title | escape }}</a>
            </h3>
            {%- if artist != blank -%}
              <p class="signature-pieces__artist">by {{ artist | escape }}</p>
            {%- endif -%}
            {%- comment -%}
              Judge.me star rating, server-rendered from the product's judgeme.badge metafield.
              Judge.me hides the badge for products with no reviews; the CSS collapses the row then.
            {%- endcomment -%}
            {%- if product.metafields.judgeme.badge != blank -%}
              <div class="signature-pieces__rating">
                {{ product.metafields.judgeme.badge }}
              </div>
            {%- endif -%}
            <p class="signature-pieces__meta">
              {{ material | escape }}
              <span aria-hidden="true">·</span> {{ finish | escape }}
            </p>
            <p class="signature-pieces__price">
              {{ section.settings.price_prefix | escape }}
              {{ product.price | money_without_trailing_zeros }}
            </p>
            <div class="signature-pieces__actions">
              {%- if product.available -%}
                <button type="button" class="signature-pieces__primary" data-quick-customize>
                  {{- section.settings.customize_label | escape -}}
                </button>
              {%- else -%}
                <a class="signature-pieces__primary" href="{{ product.url }}">
                  {{- section.settings.customize_label | escape -}}
                </a>
              {%- endif -%}
              <a class="signature-pieces__secondary" href="{{ product.url }}">
                {{- section.settings.details_label | escape -}}
              </a>
            </div>
          </div>

          <script type="application/json" class="signature-pieces__data">
            {
              "id": {{ product.id | json }},
              "title": {{ display_title | json }},
              "url": {{ product.url | json }},
              "image": {{ product.featured_image | image_url: width: 800 | json }},
              "images": [
                {%- for img in product.images -%}
                  {%- unless forloop.first %},{% endunless -%}{{ img | image_url: width: 800 | json }}
                {%- endfor -%}
              ],
              "options": {{ product.options | json }},
              "variants": [
                {%- for v in product.variants -%}
                  {%- unless forloop.first %},{% endunless -%}
                  {
                    "id": {{ v.id | json }},
                    "available": {{ v.available | json }},
                    "options": {{ v.options | json }},
                    "price_formatted": {{ v.price | money | json }},
                    "compare_at_formatted": {% if v.compare_at_price != blank and v.compare_at_price > v.price %}{{ v.compare_at_price | money | json }}{% else %}null{% endif %}
                  }
                {%- endfor -%}
              ]
            }
          </script>
        </article>
      {%- else -%}
        {%- for i in (1..4) -%}
          {%- case i -%}
            {%- when 1 -%}
              {%- assign card_title = 'Walnut Lounge Chair' -%}
              {%- assign card_artist = 'Huan Ngo' -%}
              {%- assign card_price = '$2,650' -%}
              {%- assign card_badge = section.settings.best_seller_badge -%}
            {%- when 2 -%}
              {%- assign card_title = 'Live Edge Dining Table' -%}
              {%- assign card_artist = 'Trung Le' -%}
              {%- assign card_price = '$5,900' -%}
              {%- assign card_badge = section.settings.made_to_order_badge -%}
            {%- when 3 -%}
              {%- assign card_title = 'Sculpted Console Table' -%}
              {%- assign card_artist = 'Alex Nguyen' -%}
              {%- assign card_price = '$3,250' -%}
              {%- assign card_badge = blank -%}
            {%- else -%}
              {%- assign card_title = 'Treeform Bookshelf' -%}
              {%- assign card_artist = 'Dien Luc' -%}
              {%- assign card_price = '$3,850' -%}
              {%- assign card_badge = section.settings.best_seller_badge -%}
          {%- endcase -%}

          <article class="signature-pieces__card" role="listitem">
            <div class="signature-pieces__media">
              <span class="signature-pieces__image-link">
                <img
                  class="signature-pieces__image"
                  src="{{ 'sli-' | append: i | append: '.webp' | file_url }}"
                  alt="{{ card_title | escape }}"
                  width="900"
                  height="1080"
                  loading="lazy"
                >
              </span>

              {%- if card_badge != blank -%}
                <span class="signature-pieces__badge">
                  <svg aria-hidden="true" viewBox="0 0 16 16">
                    <path d="m8 1.7 1.7 3.5 3.9.6-2.8 2.7.7 3.9L8 10.6l-3.5 1.8.7-3.9-2.8-2.7 3.9-.6L8 1.7Z"/>
                  </svg>
                  {{ card_badge | escape }}
                </span>
              {%- endif -%}

              <span class="signature-pieces__quick" aria-hidden="true">
                {{ 'icon-cart.svg' | inline_asset_content }}
              </span>
            </div>

            <div class="signature-pieces__content">
              <h3 class="signature-pieces__title">{{ card_title }}</h3>
              <p class="signature-pieces__artist">by {{ card_artist }}</p>
              <p class="signature-pieces__meta">
                {{ section.settings.material_default | escape }}
                <span aria-hidden="true">·</span> {{ section.settings.finish_default | escape }}
              </p>
              <p class="signature-pieces__price">
                {{ section.settings.price_prefix | escape }}
                {{ card_price }}
              </p>
              <div class="signature-pieces__actions">
                <span class="signature-pieces__primary">{{ section.settings.customize_label | escape }}</span>
                <span class="signature-pieces__secondary">{{ section.settings.details_label | escape }}</span>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="signature-pieces__footer">
        <a
          class="signature-pieces__button"
          href="{{ section.settings.button_link | default: collection.url | default: routes.collections_url }}"
        >
          <span>{{ section.settings.button_label | escape }}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Quick customize popup — variant picker + price + add to cart. {%- endcomment -%}
  <div class="sp-quick" data-quick-modal hidden aria-hidden="true">
    <div class="sp-quick__overlay" data-quick-close></div>
    <div
      class="sp-quick__panel"
      role="dialog"
      aria-modal="true"
      aria-labelledby="SPQuickTitle-{{ section.id }}"
    >
      <button type="button" class="sp-quick__close" aria-label="Close" data-quick-close>
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M6 6l12 12M18 6 6 18"></path>
        </svg>
      </button>

      <div class="sp-quick__media" data-quick-media>
        <div class="sp-quick__media-main">
          <img data-quick-image src="" alt="" width="800" height="800" loading="lazy">
        </div>
        <div class="sp-quick__thumbs" data-quick-thumbs hidden></div>
      </div>

      <div class="sp-quick__body custom-scrollbar">
        <p class="sp-quick__eyebrow">{{ section.settings.quick_eyebrow | escape }}</p>
        <h3 class="sp-quick__title" id="SPQuickTitle-{{ section.id }}" data-quick-title></h3>

        <div class="sp-quick__options" data-quick-options></div>

        <div class="sp-quick__price">
          <span class="sp-quick__price-current" data-quick-price></span>
          <span class="sp-quick__price-compare" data-quick-compare hidden></span>
        </div>

        <button type="button" class="sp-quick__add" data-quick-add>
          {{- section.settings.quick_add_label | default: 'Add to cart' | escape -}}
        </button>

        <a class="sp-quick__details" data-quick-details href="#">{{ section.settings.details_label | escape }}</a>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .signature-pieces {
    width: 100%;
    padding: var(--section-padding-y, 80px) 16px;
    background: radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 42%),
      linear-gradient(180deg, #f7f3ee 0%, #f5f1ed 100%);
    color: var(--text-primary);
    overflow: hidden;
  }

  .signature-pieces__inner {
    /* Match the visible content width of sections that carry their padding
       inside a page-max-width box (collections, projects, FAQ). */
    width: min(100%, calc(var(--page-max-width, 1440px) - var(--container-padding-x, 48px) * 2));
    margin-inline: auto;
  }

  .signature-pieces__header {
    max-width: 660px;
    margin: 0 auto clamp(32px, 3.5vw, 48px);
    text-align: center;
  }

  .signature-pieces__eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-body);
    font-size: var(--eyebrow-size, 12px);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--eyebrow-tracking, 0.3em);
    text-transform: uppercase;
    color: var(--color-brown);
  }

  .signature-pieces__heading {
    margin: 0 0 18px;
    font-family: var(--font-heading);
    font-size: var(--section-heading-size, 48px);
    font-weight: var(--font-weight-light);
    line-height: var(--section-heading-line, 1.02);
    letter-spacing: var(--section-heading-tracking, -0.02em);
    color: var(--color-text, #2e1d14);
    text-wrap: balance;
  }

  .signature-pieces__subtitle {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--section-subtitle-size, 16px);
    line-height: 1.6;
    color: var(--color-muted, #635d58);
    text-wrap: balance;
  }

  .signature-pieces__grid {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(292px, 84vw);
    gap: 14px;
    overflow-x: auto;
    padding: 0 0 12px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .signature-pieces__grid::-webkit-scrollbar {
    display: none;
  }

  .signature-pieces__card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
    scroll-snap-align: start;
    border: 1px solid var(--color-border, rgba(76, 48, 30, 0.14));
    border-radius: var(--card-radius, 6px);
    background: rgba(255, 252, 248, 0.72);
    box-shadow: 0 18px 42px rgba(62, 39, 25, 0.05);
    transition: transform var(--timing-base) var(--ease-standard), box-shadow var(--timing-base) var(--ease-standard),
      border-color var(--timing-base) var(--ease-standard);
  }

  .signature-pieces__media {
    position: relative;
    aspect-ratio: 1 / 1.08;
    overflow: hidden;
    background: #e5dbd0;
  }

  .signature-pieces__image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .signature-pieces__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-standard);
  }

  .signature-pieces__badge {
    position: absolute;
    top: 13px;
    left: 13px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 31px;
    padding: 0 13px;
    border: 1px solid rgba(74, 44, 24, 0.1);
    border-radius: 999px;
    background: rgba(255, 252, 247, 0.9);
    box-shadow: 0 8px 22px rgba(42, 28, 18, 0.08);
    color: #4a2c18;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: var(--font-weight-medium);
    line-height: 1;
    backdrop-filter: blur(8px);
  }

  .signature-pieces__badge svg {
    width: 13px;
    height: 13px;
    fill: currentColor;
    flex: 0 0 auto;
  }

  .signature-pieces__quick {
    position: absolute;
    top: 13px;
    right: 13px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    background: rgba(255, 252, 247, 0.94);
    color: #4a2c18;
    text-decoration: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
  }

  .signature-pieces__quick.is-loading {
    pointer-events: none;
    opacity: 0.7;
  }

  .signature-pieces__new {
    position: absolute;
    top: 13px;
    left: 13px;
    z-index: 1;
    display: flex;
    align-items: center;
    padding: 0 8px;
    border-radius: 99px;
    background: var(--color-milk, #fffdf9);
    color: var(--color-earth-brown, #4a2c18);
    font-family: var(--font-body);
    font-weight: var(--font-weight-bold);
    font-size: 14px;
    line-height: 1;
    letter-spacing: 0.02em;
  }
  .signature-pieces__new svg {
    display: flex;
    width: 24px;
    height: 24px;
    margin-right: 4px;
    fill: currentColor;
  }

  .signature-pieces__quick svg {
    width: 18px;
    height: 18px;
  }

  .signature-pieces__content {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    padding: 20px var(--card-padding, 24px) 20px;
  }

  .signature-pieces__title {
    margin: 0 0 8px;
    font-family: var(--font-heading);
    font-size: clamp(20px, 1.5vw, 24px);
    font-weight: var(--font-weight-regular);
    line-height: 1.12;
    letter-spacing: 0;
    color: var(--color-text, #352117);
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .signature-pieces__title a {
    color: inherit;
    text-decoration: none;
    font-size: 20px;
  }

  .signature-pieces__artist {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    font-weight: var(--font-weight-regular);
    line-height: 1.2;
    color: var(--color-muted, #6a625c);
  }

  .signature-pieces__rating {
    margin: 0 0 10px;
    line-height: 1;
    /* Colour the Judge.me stars with the theme's star-rating token. */
    --jm-review-widget-star-and-histogram-color: var(--color-star-rating, #cba077);
  }

  /* The judgeme.badge metafield ships the badge as display:none (meant to be revealed
     by Judge.me's own widget JS, which doesn't hydrate this static copy). Reveal it here
     so the server-rendered stars show immediately. */
  .signature-pieces__rating .jdgm-prev-badge {
    display: inline-flex !important;
    align-items: center;
    gap: 5px;
    font-size: 13px;
  }

  .signature-pieces__rating .jdgm-star {
    color: var(--color-star-rating, #cba077) !important;
  }

  /* Replace Judge.me's verbose "N reviews" label with a compact count, e.g. (11). */
  .signature-pieces__rating .jdgm-prev-badge__text {
    display: none;
  }

  .signature-pieces__rating .jdgm-prev-badge::after {
    content: '(' attr(data-number-of-reviews) ')';
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1;
    color: var(--color-muted, #6a625c);
  }

  /* Hide the row entirely for products with no reviews (don't show empty stars). */
  .signature-pieces__rating:has(.jdgm-prev-badge[data-number-of-reviews='0']) {
    display: none;
  }

  .signature-pieces__meta {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.45;
    color: #6a625c;
  }

  .signature-pieces__price {
    margin: 16px 0 0;
    padding-top: 14px;
    border-top: 1px solid var(--color-border, rgba(74, 44, 24, 0.16));
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: var(--font-weight-medium);
    line-height: 1.4;
    color: #352117;
    font-variant-numeric: tabular-nums;
  }

  .signature-pieces__actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 16px;
    margin-top: 18px;
  }

  .signature-pieces__primary,
  .signature-pieces__secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: var(--font-weight-medium);
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard), border-color var(--timing-short) var(--ease-standard),
      transform var(--timing-short) var(--ease-standard);
  }

  .signature-pieces__primary {
    padding: 0 18px;
    border: 1px solid #4a2c18;
    border-radius: 3px;
    background: #4a2c18;
    color: #fff8f0;
  }

  .signature-pieces__secondary {
    min-height: 30px;
    border-bottom: 1px solid currentColor;
    color: #352117;
  }

  .signature-pieces__footer {
    display: flex;
    justify-content: center;
    margin-top: 36px;
  }

  .signature-pieces__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    min-width: 260px;
    min-height: var(--btn-height, 52px);
    padding: 0 var(--btn-padding-x, 32px);
    border-radius: var(--btn-radius, 4px);
    background: var(--color-brown, #4a2c18);
    color: #fff8f0;
    font-family: var(--font-body);
    font-size: var(--btn-font-size, 14px);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    box-shadow: 0 14px 30px rgba(59, 31, 15, 0.13);
    transition: transform var(--timing-short) var(--ease-standard),
      background-color var(--timing-short) var(--ease-standard), box-shadow var(--timing-short) var(--ease-standard);
  }

  .signature-pieces__button svg {
    width: 20px;
    height: 20px;
    transition: transform var(--timing-short) var(--ease-standard);
  }

  .signature-pieces :is(a, button):focus-visible {
    outline: 3px solid rgba(122, 137, 104, 0.38);
    outline-offset: 4px;
  }

  @media (hover: hover) {
    .signature-pieces__card:hover {
      transform: translateY(-4px);
      border-color: rgba(74, 44, 24, 0.24);
      box-shadow: 0 22px 54px rgba(62, 39, 25, 0.11);
    }

    .signature-pieces__card:hover .signature-pieces__image {
      transform: scale(1.025);
    }

    .signature-pieces__quick:hover {
      transform: scale(1.04);
      background: #4a2c18;
      color: #fff8f0;
    }

    .signature-pieces__primary:hover,
    .signature-pieces__button:hover {
      transform: translateY(-2px);
    }

    .signature-pieces__primary:hover {
      background: #2f1a0d;
      border-color: #2f1a0d;
      color: #fff8f0;
    }

    .signature-pieces__secondary:hover {
      color: #8a5d37;
    }

    .signature-pieces__button:hover {
      color: #fff8f0;
      background: var(--color-brown-dark, #2f1a0d);
      box-shadow: 0 18px 34px rgba(59, 31, 15, 0.18);
    }

    .signature-pieces__button:hover svg {
      transform: translateX(4px);
    }
  }

  @media screen and (min-width: 48rem) {
    .signature-pieces {
      padding-inline: 32px;
    }

    .signature-pieces__grid {
      grid-auto-columns: calc((100% - 16px) / 2);
      gap: 16px;
    }
  }

  @media screen and (min-width: 75rem) {
    .signature-pieces {
      padding-inline: var(--container-padding-x, 64px);
    }

    .signature-pieces__grid {
      grid-auto-flow: initial;
      grid-auto-columns: initial;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      overflow: visible;
      padding-bottom: 0;
    }
  }

  @media screen and (max-width: 28rem) {
    .signature-pieces__actions {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .signature-pieces__secondary {
      justify-self: start;
    }

    .signature-pieces__button {
      width: 100%;
      min-width: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .signature-pieces__card,
    .signature-pieces__image,
    .signature-pieces__quick,
    .signature-pieces__primary,
    .signature-pieces__secondary,
    .signature-pieces__button,
    .signature-pieces__button svg {
      transition-duration: 0s;
    }
  }

  /* ---------------- Quick customize popup ---------------- */
  html.sp-quick-open {
    overflow: hidden;
  }

  /* Hide the live-chat launcher while the popup is open so it doesn't overlap the
     dialog. The chat widget renders at a near-max z-index, so hiding it is more
     reliable than out-stacking it. */
  .sp-quick-open #shopify-chat,
  .sp-quick-open .shopify-chat,
  .sp-quick-open #chat-widget-container,
  .sp-quick-open iframe[title*='chat' i],
  .sp-quick-open iframe[id*='chat' i] {
    opacity: 0 !important;
    visibility: hidden !important;
    pointer-events: none !important;
  }

  .sp-quick {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal, 1000);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--sp-5);
  }

  .sp-quick[hidden] {
    display: none;
  }

  .sp-quick__overlay {
    position: absolute;
    inset: 0;
    background: var(--bg-overlay, rgba(30, 20, 12, 0.55));
    opacity: 0;
    transition: opacity var(--timing-base) var(--ease-standard);
  }

  .sp-quick.is-open .sp-quick__overlay {
    opacity: 1;
  }

  .sp-quick__panel {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    grid-template-rows: minmax(0, 1fr);
    max-width: 80vw;
    max-height: calc(100dvh - var(--sp-8));
    overflow: hidden;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background: var(--surface-elevated, #fffcf8);
    box-shadow: var(--shadow-modal, 0 30px 80px rgba(30, 20, 12, 0.28));
    opacity: 0;
    transform: translateY(var(--sp-3));
    transition: opacity var(--timing-base) var(--ease-standard), transform var(--timing-base) var(--ease-out);
  }

  .sp-quick.is-open .sp-quick__panel {
    opacity: 1;
    transform: none;
  }

  .sp-quick__close {
    position: absolute;
    top: var(--sp-3);
    right: var(--sp-3);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-7);
    height: var(--sp-7);
    padding: 0;
    border: none;
    border-radius: var(--radius-full);
    background: color-mix(in srgb, var(--surface-elevated) 88%, transparent);
    color: var(--color-bark, #4a2c18);
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard);
  }

  .sp-quick__close:hover {
    background: var(--color-cream, #f0e9e1);
  }

  .sp-quick__close svg {
    width: var(--sp-5);
    height: var(--sp-5);
  }

  .sp-quick__media {
    display: flex;
    flex-direction: column;
    min-height: 0;
    overflow: hidden;
    background: var(--color-stone, #e5dbd0);
  }

  .sp-quick__media[hidden] {
    display: none;
  }

  .sp-quick__media-main {
    position: relative;
    flex: 1 1 auto;
    min-height: 0;
    overflow: hidden;
  }

  .sp-quick__media-main img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sp-quick__thumbs {
    display: flex;
    flex: 0 0 auto;
    gap: var(--sp-2);
    padding: var(--sp-2);
    background: var(--surface-elevated, #fffcf8);
    border-top: 1px solid var(--border-light);
    overflow-x: auto;
    scrollbar-width: none;
  }

  .sp-quick__thumbs::-webkit-scrollbar {
    display: none;
  }

  .sp-quick__thumbs[hidden] {
    display: none;
  }

  .sp-quick__thumb {
    flex: 0 0 auto;
    width: var(--sp-8);
    height: var(--sp-8);
    padding: 0;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--color-stone, #e5dbd0);
    cursor: pointer;
    opacity: 0.7;
    transition: opacity var(--timing-short) var(--ease-standard), border-color var(--timing-short) var(--ease-standard);
  }

  .sp-quick__thumb img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sp-quick__thumb:hover {
    opacity: 1;
  }

  .sp-quick__thumb[aria-current='true'] {
    opacity: 1;
    border-color: var(--color-earth-brown, #4a2c18);
  }

  .sp-quick__body {
    display: flex;
    flex-direction: column;
    padding: var(--sp-6);
    overflow-y: auto;
    min-height: 0;
    height: 100%;
  }

  .sp-quick__eyebrow {
    margin: 0 0 var(--sp-2);
    color: var(--color-earth-brown, #4a2c18);
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--eyebrow-tracking, 0.3em);
    text-transform: uppercase;
  }

  .sp-quick__title {
    margin: 0 0 var(--sp-4);
    color: var(--color-text, #2e1d14);
    font-family: var(--font-heading);
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: var(--font-weight-semibold);
    line-height: 1.12;
  }

  .sp-quick__options {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    margin-bottom: var(--sp-5);
  }

  .sp-quick__option {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .sp-quick__option-label {
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--text-secondary);
  }

  .sp-quick__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }

  .sp-quick__pill {
    min-height: var(--sp-7);
    padding: var(--sp-2) var(--sp-4);
    border: 1px solid var(--border-dark, rgba(74, 44, 24, 0.4));
    border-radius: var(--radius-sm);
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    cursor: pointer;
    transition: var(--transition-fast);
  }

  .sp-quick__pill:hover {
    border-color: var(--color-earth-brown, #4a2c18);
  }

  .sp-quick__pill[aria-pressed='true'] {
    border-color: var(--color-earth-brown, #4a2c18);
    background: var(--color-earth-brown, #4a2c18);
    color: var(--text-inverse, #fff8f0);
  }

  .sp-quick__price {
    display: flex;
    align-items: baseline;
    gap: var(--sp-3);
    margin-top: auto;
    padding-top: var(--sp-4);
    border-top: 1px solid var(--border-light);
  }

  .sp-quick__price-current {
    color: var(--color-text, #2e1d14);
    font-family: var(--font-body);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-semibold);
    font-variant-numeric: tabular-nums;
  }

  .sp-quick__price-compare {
    color: var(--text-secondary);
    font-size: var(--font-size-body-md);
    text-decoration: line-through;
    font-variant-numeric: tabular-nums;
  }

  .sp-quick__price-compare[hidden] {
    display: none;
  }

  .sp-quick__add {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: var(--sp-7);
    margin-top: var(--sp-4);
    padding: var(--sp-3) var(--sp-5);
    border: 1px solid var(--color-earth-brown, #4a2c18);
    border-radius: var(--radius-sm);
    background: var(--color-earth-brown, #4a2c18);
    color: var(--text-inverse, #fff8f0);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard);
  }

  .sp-quick__add:hover:not(:disabled) {
    background: var(--color-charcoal, #2f1a0d);
    border-color: var(--color-charcoal, #2f1a0d);
  }

  .sp-quick__add:disabled,
  .sp-quick__add.is-loading {
    opacity: 0.55;
    cursor: not-allowed;
  }

  .sp-quick__details {
    margin-top: var(--sp-3);
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
    text-align: center;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .sp-quick__details:hover {
    color: var(--color-earth-brown, #4a2c18);
  }

  .sp-quick :focus-visible {
