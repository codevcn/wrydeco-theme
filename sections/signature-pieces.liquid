{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    var cartRoot = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) || '/';

    function toast(message, type) {
      if (window.showToast) window.showToast({ message: message, type: type, position: 'bottom-right' });
    }

    function addVariantToCart(variantId, button, onDone) {
      fetch(cartRoot + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/javascript' },
        body: JSON.stringify({ id: variantId, quantity: 1 }),
      })
        .then(function (res) {
          return res.json();
        })
        .then(function (data) {
          if (data.status) throw new Error(data.description || 'Could not add to cart');
          toast('Item added to your cart.', 'success');
          document.dispatchEvent(new CustomEvent('cart:updated', { detail: { open: true } }));
          if (onDone) onDone(true);
        })
        .catch(function (err) {
          toast(err.message, 'error');
          if (onDone) onDone(false);
        });
    }

    // --- Quick add (cart icon on the card) ---
    document.querySelectorAll('[data-add-to-cart-signature]').forEach(function (btn) {
      if (btn.dataset.init === 'true') return;
      btn.dataset.init = 'true';
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        if (btn.disabled || btn.classList.contains('is-loading')) return;
        var variantId = btn.dataset.variantId;
        if (!variantId) return;
        btn.classList.add('is-loading');
        addVariantToCart(variantId, btn, function () {
          btn.classList.remove('is-loading');
        });
      });
    });

    // --- Quick customize popup (variant picker + price + add to cart) ---
    var modal = document.querySelector('[data-quick-modal]');
    if (!modal) return;

    var titleEl = modal.querySelector('[data-quick-title]');
    var mediaEl = modal.querySelector('[data-quick-media]');
    var imageEl = modal.querySelector('[data-quick-image]');
    var thumbsEl = modal.querySelector('[data-quick-thumbs]');
    var optionsEl = modal.querySelector('[data-quick-options]');
    var priceEl = modal.querySelector('[data-quick-price]');
    var compareEl = modal.querySelector('[data-quick-compare]');
    var addBtn = modal.querySelector('[data-quick-add]');
    var detailsEl = modal.querySelector('[data-quick-details]');
    var addLabel = addBtn.textContent.trim();
    var lastFocused = null;
    var state = null; // { data, selected: [], variant }

    function findVariant(data, selected) {
      for (var i = 0; i < data.variants.length; i++) {
        var v = data.variants[i];
        var match = true;
        for (var j = 0; j < v.options.length; j++) {
          if (v.options[j] !== selected[j]) {
            match = false;
            break;
          }
        }
        if (match) return v;
      }
      return null;
    }

    function updateSelection() {
      var variant = findVariant(state.data, state.selected);
      state.variant = variant;
      if (variant) {
        priceEl.textContent = variant.price_formatted;
        if (variant.compare_at_formatted) {
          compareEl.textContent = variant.compare_at_formatted;
          compareEl.hidden = false;
        } else {
          compareEl.hidden = true;
        }
        addBtn.disabled = !variant.available;
        addBtn.textContent = variant.available ? addLabel : 'Sold out';
      } else {
        priceEl.textContent = '';
        compareEl.hidden = true;
        addBtn.disabled = true;
        addBtn.textContent = 'Unavailable';
      }
    }

    function renderOptions() {
      optionsEl.innerHTML = '';
      var data = state.data;
      var isSingleDefault = data.variants.length === 1 && data.options.length === 1 && data.options[0] === 'Title';
      if (isSingleDefault) return;

      data.options.forEach(function (optName, oi) {
        var group = document.createElement('div');
        group.className = 'sp-quick__option';

        var label = document.createElement('span');
        label.className = 'sp-quick__option-label';
        label.textContent = optName;
        group.appendChild(label);

        var pills = document.createElement('div');
        pills.className = 'sp-quick__pills';

        var values = [];
        data.variants.forEach(function (v) {
          if (values.indexOf(v.options[oi]) === -1) values.push(v.options[oi]);
        });

        values.forEach(function (val) {
          var pill = document.createElement('button');
          pill.type = 'button';
          pill.className = 'sp-quick__pill';
          pill.textContent = val;
          if (state.selected[oi] === val) pill.setAttribute('aria-pressed', 'true');
          pill.addEventListener('click', function () {
            state.selected[oi] = val;
            Array.prototype.forEach.call(pills.children, function (c) {
              c.removeAttribute('aria-pressed');
            });
            pill.setAttribute('aria-pressed', 'true');
            updateSelection();
          });
          pills.appendChild(pill);
        });

        group.appendChild(pills);
        optionsEl.appendChild(group);
      });
    }

    function openModal() {
      modal.hidden = false;
      modal.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('sp-quick-open');
      window.requestAnimationFrame(function () {
        modal.classList.add('is-open');
      });
    }

    function closeModal() {
      modal.classList.remove('is-open');
      modal.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('sp-quick-open');
      window.setTimeout(function () {
        modal.hidden = true;
      }, 240);
      if (lastFocused && typeof lastFocused.focus === 'function') lastFocused.focus();
    }

    document.querySelectorAll('[data-quick-customize]').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        e.preventDefault();
        var card = btn.closest('.signature-pieces__card');
        var script = card && card.querySelector('.signature-pieces__data');
        if (!script) return;
        var data;
        try {
          data = JSON.parse(script.textContent);
        } catch (err) {
          return;
        }
        if (!data.variants || !data.variants.length) return;

        lastFocused = btn;
        var initial = null;
        for (var i = 0; i < data.variants.length; i++) {
          if (data.variants[i].available) {
            initial = data.variants[i];
            break;
          }
        }
        if (!initial) initial = data.variants[0];
        state = { data: data, selected: initial.options.slice(), variant: initial };

        titleEl.textContent = data.title;

        // Build the gallery: one large image + a row of thumbnails.
        var gallery = data.images && data.images.length ? data.images : data.image ? [data.image] : [];
        thumbsEl.innerHTML = '';
        if (gallery.length) {
          imageEl.src = gallery[0];
          imageEl.alt = data.title;
          mediaEl.hidden = false;
        } else {
          mediaEl.hidden = true;
        }

        if (gallery.length > 1) {
          gallery.forEach(function (src, idx) {
            var thumb = document.createElement('button');
            thumb.type = 'button';
            thumb.className = 'sp-quick__thumb';
            thumb.setAttribute('aria-label', 'View image ' + (idx + 1));
            if (idx === 0) thumb.setAttribute('aria-current', 'true');
            var timg = document.createElement('img');
            timg.src = src;
            timg.alt = '';
            timg.loading = 'lazy';
            thumb.appendChild(timg);
            thumb.addEventListener('click', function () {
              imageEl.src = src;
              Array.prototype.forEach.call(thumbsEl.children, function (c) {
                c.removeAttribute('aria-current');
              });
              thumb.setAttribute('aria-current', 'true');
            });
            thumbsEl.appendChild(thumb);
          });
          thumbsEl.hidden = false;
        } else {
          thumbsEl.hidden = true;
        }

        detailsEl.setAttribute('href', data.url || '#');

        renderOptions();
        updateSelection();
        openModal();

        var firstPill = optionsEl.querySelector('.sp-quick__pill');
        (firstPill || addBtn).focus();
      });
    });

    modal.querySelectorAll('[data-quick-close]').forEach(function (el) {
      el.addEventListener('click', closeModal);
    });

    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape' && !modal.hidden) closeModal();
    });

    addBtn.addEventListener('click', function () {
      if (!state || !state.variant || addBtn.disabled || addBtn.classList.contains('is-loading')) return;
      addBtn.classList.add('is-loading');
      addBtn.textContent = 'Adding…';
      addVariantToCart(state.variant.id, addBtn, function (ok) {
        addBtn.classList.remove('is-loading');
        if (ok) closeModal();
        else updateSelection();
      });
    });
  });
{% endjavascript %}

