<section class="signature-pieces" aria-labelledby="SignaturePiecesHeading-{{ section.id }}">
  <div class="signature-pieces__inner">
    <header class="signature-pieces__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="signature-pieces__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="signature-pieces__heading" id="SignaturePiecesHeading-{{ section.id }}">
        {{ section.settings.heading | escape }}
      </h2>
      {%- if section.settings.subtitle != blank -%}
        <p class="signature-pieces__subtitle">{{ section.settings.subtitle | newline_to_br }}</p>
      {%- endif -%}
    </header>

    {%- assign collection = section.settings.collection -%}
    {%- if collection == blank -%}
      {%- assign collection = collections['signature-pieces'] -%}
    {%- endif -%}

    <div class="signature-pieces__grid" role="list">
      {%- for product in collection.products limit: 4 -%}
        {%- assign display_title = product.metafields.custom.artwork_name.value | default: product.title -%}
        {%- liquid
          assign artist = ''
          assign author = product.metafields.custom.author_info.value | first
          if author != blank and author.author_name.value != blank
            assign artist = author.author_name.value
          elsif product.vendor != blank and product.vendor != shop.name
            assign artist = product.vendor
          endif
        -%}
        {%- assign lead = product.metafields.custom.lead_time_weeks.value
          | default: section.settings.lead_time_default
        -%}
        {%- assign material = product.metafields.custom.material.value | default: section.settings.material_default -%}
        {%- assign finish = product.metafields.custom.finish.value | default: section.settings.finish_default -%}
        {%- assign badge_label = section.settings.made_to_order_badge -%}
        {%- assign badge_icon = 'clock' -%}
        {%- if forloop.index == 1 or forloop.index == 4 -%}
          {%- assign badge_label = section.settings.best_seller_badge -%}
          {%- assign badge_icon = 'star' -%}
        {%- endif -%}

        <article class="signature-pieces__card" role="listitem">
          <div class="signature-pieces__media">
            <a class="signature-pieces__image-link" href="{{ product.url }}" aria-label="{{ display_title | escape }}">
              {%- if product.featured_media != blank -%}
                {{
                  product.featured_media.preview_image
                  | image_url: width: 900
                  | image_tag:
                    class: 'signature-pieces__image',
                    loading: 'lazy',
                    widths: '360, 540, 720, 900',
                    sizes: '(min-width: 80rem) 23vw, (min-width: 48rem) 46vw, 88vw'
                }}
              {%- else -%}
                {%- assign fallback_asset = 'sli-' | append: forloop.index | append: '.webp' -%}
                <img
                  class="signature-pieces__image"
                  src="{{ fallback_asset | asset_url }}"
                  alt="{{ display_title | escape }}"
                  width="900"
                  height="1080"
                  loading="lazy"
                >
              {%- endif -%}
            </a>

            {%- if badge_label != blank -%}
              <span class="signature-pieces__badge">
                {%- if badge_icon == 'star' -%}
                  <svg aria-hidden="true" viewBox="0 0 16 16">
                    <path d="m8 1.7 1.7 3.5 3.9.6-2.8 2.7.7 3.9L8 10.6l-3.5 1.8.7-3.9-2.8-2.7 3.9-.6L8 1.7Z"/>
                  </svg>
                {%- else -%}
                  <svg aria-hidden="true" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="5.6" stroke="currentColor" stroke-width="1.2"/>
                    <path d="M8 4.8v3.4l2.2 1.2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
                {{ badge_label | escape }}
              </span>
            {%- endif -%}

            {%- if product.available -%}
              <button class="signature-pieces__quick" data-add-to-cart-signature data-variant-id="{{ product.variants.first.id }}" aria-label="Add {{ display_title | escape }} to cart" type="button">
                {{ 'icon-cart.svg' | inline_asset_content }}
              </button>
            {%- else -%}
              <span class="signature-pieces__quick" aria-hidden="true">
                {{ 'icon-cart.svg' | inline_asset_content }}
              </span>
            {%- endif -%}
          </div>

          <div class="signature-pieces__content">
            <h3 class="signature-pieces__title">
              <a href="{{ product.url }}">{{ display_title | escape }}</a>
            </h3>
            {%- if artist != blank -%}
              <p class="signature-pieces__artist">by {{ artist | escape }}</p>
            {%- endif -%}
            <p class="signature-pieces__meta">
              {{ material | escape }}
              <span aria-hidden="true">·</span> {{ finish | escape }}
            </p>
            <p class="signature-pieces__price">
              {{ section.settings.price_prefix | escape }}
              {{ product.price | money_without_trailing_zeros }}
              {%- if lead != blank -%}
                <span aria-hidden="true">·</span> {{ lead | escape }}
              {%- endif -%}
            </p>
            <div class="signature-pieces__actions">
              <a class="signature-pieces__primary" href="{{ product.url }}">
                {{- section.settings.customize_label | escape -}}
              </a>
              <a class="signature-pieces__secondary" href="{{ product.url }}">
                {{- section.settings.details_label | escape -}}
              </a>
            </div>
          </div>
        </article>
      {%- else -%}
        {%- for i in (1..4) -%}
          {%- case i -%}
            {%- when 1 -%}
              {%- assign card_title = 'Walnut Lounge Chair' -%}
              {%- assign card_artist = 'Huan Ngo' -%}
              {%- assign card_price = '$2,650' -%}
              {%- assign card_lead = '8-10 weeks' -%}
              {%- assign card_badge = section.settings.best_seller_badge -%}
            {%- when 2 -%}
              {%- assign card_title = 'Live Edge Dining Table' -%}
              {%- assign card_artist = 'Trung Le' -%}
              {%- assign card_price = '$5,900' -%}
              {%- assign card_lead = '10-12 weeks' -%}
              {%- assign card_badge = section.settings.made_to_order_badge -%}
            {%- when 3 -%}
              {%- assign card_title = 'Sculpted Console Table' -%}
              {%- assign card_artist = 'Alex Nguyen' -%}
              {%- assign card_price = '$3,250' -%}
              {%- assign card_lead = '8-10 weeks' -%}
              {%- assign card_badge = blank -%}
            {%- else -%}
              {%- assign card_title = 'Treeform Bookshelf' -%}
              {%- assign card_artist = 'Dien Luc' -%}
              {%- assign card_price = '$3,850' -%}
              {%- assign card_lead = '10-12 weeks' -%}
              {%- assign card_badge = section.settings.best_seller_badge -%}
          {%- endcase -%}

          <article class="signature-pieces__card" role="listitem">
            <div class="signature-pieces__media">
              <span class="signature-pieces__image-link">
                <img
                  class="signature-pieces__image"
                  src="{{ 'sli-' | append: i | append: '.webp' | asset_url }}"
                  alt="{{ card_title | escape }}"
                  width="900"
                  height="1080"
                  loading="lazy"
                >
              </span>

              {%- if card_badge != blank -%}
                <span class="signature-pieces__badge">
                  <svg aria-hidden="true" viewBox="0 0 16 16">
                    <path d="m8 1.7 1.7 3.5 3.9.6-2.8 2.7.7 3.9L8 10.6l-3.5 1.8.7-3.9-2.8-2.7 3.9-.6L8 1.7Z"/>
                  </svg>
                  {{ card_badge | escape }}
                </span>
              {%- endif -%}

              <span class="signature-pieces__quick" aria-hidden="true">
                {{ 'icon-cart.svg' | inline_asset_content }}
              </span>
            </div>

            <div class="signature-pieces__content">
              <h3 class="signature-pieces__title">{{ card_title }}</h3>
              <p class="signature-pieces__artist">by {{ card_artist }}</p>
              <p class="signature-pieces__meta">
                {{ section.settings.material_default | escape }}
                <span aria-hidden="true">·</span> {{ section.settings.finish_default | escape }}
              </p>
              <p class="signature-pieces__price">
                {{ section.settings.price_prefix | escape }}
                {{ card_price }}
                <span aria-hidden="true">·</span> {{ card_lead }}
              </p>
              <div class="signature-pieces__actions">
                <span class="signature-pieces__primary">{{ section.settings.customize_label | escape }}</span>
                <span class="signature-pieces__secondary">{{ section.settings.details_label | escape }}</span>
              </div>
            </div>
          </article>
        {%- endfor -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="signature-pieces__footer">
        <a
          class="signature-pieces__button"
          href="{{ section.settings.button_link | default: collection.url | default: routes.collections_url }}"
        >
          <span>{{ section.settings.button_label | escape }}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .signature-pieces {
    width: 100%;
    padding: var(--section-padding-y, 80px) 16px;
    background: radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.78), rgba(255, 255, 255, 0) 42%),
      linear-gradient(180deg, #f7f3ee 0%, #f5f1ed 100%);
    color: var(--text-primary);
    overflow: hidden;
  }

  .signature-pieces__inner {
    /* Match the visible content width of sections that carry their padding
       inside a page-max-width box (collections, projects, FAQ). */
    width: min(100%, calc(var(--page-max-width, 1440px) - var(--container-padding-x, 48px) * 2));
    margin-inline: auto;
  }

  .signature-pieces__header {
    max-width: 660px;
    margin: 0 auto clamp(32px, 3.5vw, 48px);
    text-align: center;
  }

  .signature-pieces__eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-body);
    font-size: var(--eyebrow-size, 12px);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--eyebrow-tracking, 0.3em);
    text-transform: uppercase;
    color: var(--color-brown);
  }

  .signature-pieces__heading {
    margin: 0 0 18px;
    font-family: var(--font-heading);
    font-size: var(--section-heading-size, 48px);
    font-weight: var(--font-weight-light);
    line-height: var(--section-heading-line, 1.02);
    letter-spacing: var(--section-heading-tracking, -0.02em);
    color: var(--color-text, #2e1d14);
    text-wrap: balance;
  }

  .signature-pieces__subtitle {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--section-subtitle-size, 16px);
    line-height: 1.6;
    color: var(--color-muted, #635d58);
    text-wrap: balance;
  }

  .signature-pieces__grid {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(292px, 84vw);
    gap: 14px;
    overflow-x: auto;
    padding: 0 0 12px;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .signature-pieces__grid::-webkit-scrollbar {
    display: none;
  }

  .signature-pieces__card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
    scroll-snap-align: start;
    border: 1px solid var(--color-border, rgba(76, 48, 30, 0.14));
    border-radius: var(--card-radius, 6px);
    background: rgba(255, 252, 248, 0.72);
    box-shadow: 0 18px 42px rgba(62, 39, 25, 0.05);
    transition: transform var(--timing-base) var(--ease-standard), box-shadow var(--timing-base) var(--ease-standard),
      border-color var(--timing-base) var(--ease-standard);
  }

  .signature-pieces__media {
    position: relative;
    aspect-ratio: 1 / 1.08;
    overflow: hidden;
    background: #e5dbd0;
  }

  .signature-pieces__image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .signature-pieces__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 700ms var(--ease-standard);
  }

  .signature-pieces__badge {
    position: absolute;
    top: 13px;
    left: 13px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    gap: 7px;
    min-height: 31px;
    padding: 0 13px;
    border: 1px solid rgba(74, 44, 24, 0.1);
    border-radius: 999px;
    background: rgba(255, 252, 247, 0.9);
    box-shadow: 0 8px 22px rgba(42, 28, 18, 0.08);
    color: #4a2c18;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: var(--font-weight-medium);
    line-height: 1;
    backdrop-filter: blur(8px);
  }

  .signature-pieces__badge svg {
    width: 13px;
    height: 13px;
    fill: currentColor;
    flex: 0 0 auto;
  }

  .signature-pieces__quick {
    position: absolute;
    top: 13px;
    right: 13px;
    z-index: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 999px;
    background: rgba(255, 252, 247, 0.94);
    color: #4a2c18;
    text-decoration: none;
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
  }

  .signature-pieces__quick.is-loading {
    pointer-events: none;
    opacity: 0.7;
  }

  .signature-pieces__quick svg {
    width: 18px;
    height: 18px;
  }

  .signature-pieces__content {
    display: flex;
    flex: 1 1 auto;
    flex-direction: column;
    padding: 20px var(--card-padding, 24px) 20px;
  }

  .signature-pieces__title {
    margin: 0 0 8px;
    font-family: var(--font-heading);
    font-size: clamp(20px, 1.5vw, 24px);
    font-weight: var(--font-weight-regular);
    line-height: 1.12;
    letter-spacing: 0;
    color: var(--color-text, #352117);
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .signature-pieces__title a {
    color: inherit;
    text-decoration: none;
    font-size: 20px;
  }

  .signature-pieces__artist {
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 13px;
    font-weight: var(--font-weight-regular);
    line-height: 1.2;
    color: var(--color-muted, #6a625c);
  }

  .signature-pieces__meta {
    margin: 0;
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.45;
    color: #6a625c;
  }

  .signature-pieces__price {
    margin: 16px 0 0;
    padding-top: 14px;
    border-top: 1px solid var(--color-border, rgba(74, 44, 24, 0.16));
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: var(--font-weight-medium);
    line-height: 1.4;
    color: #352117;
    font-variant-numeric: tabular-nums;
  }

  .signature-pieces__actions {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
    gap: 16px;
    margin-top: 18px;
  }

  .signature-pieces__primary,
  .signature-pieces__secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: var(--font-weight-medium);
    line-height: 1;
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard), border-color var(--timing-short) var(--ease-standard),
      transform var(--timing-short) var(--ease-standard);
  }

  .signature-pieces__primary {
    padding: 0 18px;
    border: 1px solid #4a2c18;
    border-radius: 3px;
    background: #4a2c18;
    color: #fff8f0;
  }

  .signature-pieces__secondary {
    min-height: 30px;
    border-bottom: 1px solid currentColor;
    color: #352117;
  }

  .signature-pieces__footer {
    display: flex;
    justify-content: center;
    margin-top: 36px;
  }

  .signature-pieces__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    min-width: 260px;
    min-height: var(--btn-height, 52px);
    padding: 0 var(--btn-padding-x, 32px);
    border-radius: var(--btn-radius, 4px);
    background: var(--color-brown, #4a2c18);
    color: #fff8f0;
    font-family: var(--font-body);
    font-size: var(--btn-font-size, 14px);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    box-shadow: 0 14px 30px rgba(59, 31, 15, 0.13);
    transition: transform var(--timing-short) var(--ease-standard),
      background-color var(--timing-short) var(--ease-standard), box-shadow var(--timing-short) var(--ease-standard);
  }

  .signature-pieces__button svg {
    width: 20px;
    height: 20px;
    transition: transform var(--timing-short) var(--ease-standard);
  }

  .signature-pieces :is(a, button):focus-visible {
    outline: 3px solid rgba(122, 137, 104, 0.38);
    outline-offset: 4px;
  }

  @media (hover: hover) {
    .signature-pieces__card:hover {
      transform: translateY(-4px);
      border-color: rgba(74, 44, 24, 0.24);
      box-shadow: 0 22px 54px rgba(62, 39, 25, 0.11);
    }

    .signature-pieces__card:hover .signature-pieces__image {
      transform: scale(1.025);
    }

    .signature-pieces__quick:hover {
      transform: scale(1.04);
      background: #4a2c18;
      color: #fff8f0;
    }

    .signature-pieces__primary:hover,
    .signature-pieces__button:hover {
      transform: translateY(-2px);
    }

    .signature-pieces__primary:hover {
      background: #2f1a0d;
      border-color: #2f1a0d;
      color: #fff8f0;
    }

    .signature-pieces__secondary:hover {
      color: #8a5d37;
    }

    .signature-pieces__button:hover {
      color: #fff8f0;
      background: var(--color-brown-dark, #2f1a0d);
      box-shadow: 0 18px 34px rgba(59, 31, 15, 0.18);
    }

    .signature-pieces__button:hover svg {
      transform: translateX(4px);
    }
  }

  @media screen and (min-width: 48rem) {
    .signature-pieces {
      padding-inline: 32px;
    }

    .signature-pieces__grid {
      grid-auto-columns: calc((100% - 16px) / 2);
      gap: 16px;
    }
  }

  @media screen and (min-width: 75rem) {
    .signature-pieces {
      padding-inline: var(--container-padding-x, 64px);
    }

    .signature-pieces__grid {
      grid-auto-flow: initial;
      grid-auto-columns: initial;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 14px;
      overflow: visible;
      padding-bottom: 0;
    }
  }

  @media screen and (max-width: 28rem) {
    .signature-pieces__actions {
      grid-template-columns: 1fr;
      gap: 12px;
    }

    .signature-pieces__secondary {
      justify-self: start;
    }

    .signature-pieces__button {
      width: 100%;
      min-width: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .signature-pieces__card,
    .signature-pieces__image,
    .signature-pieces__quick,
    .signature-pieces__primary,
    .signature-pieces__secondary,
    .signature-pieces__button,
    .signature-pieces__button svg {
      transition-duration: 0s;
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function() {
    document.querySelectorAll('[data-add-to-cart-signature]').forEach(function(btn) {
      if (btn.dataset.init === 'true') return;
      btn.dataset.init = 'true';
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        if (btn.disabled || btn.classList.contains('is-loading')) return;
        var variantId = btn.dataset.variantId;
        if (!variantId) return;

        btn.classList.add('is-loading');
        fetch(window.Shopify.routes.root + 'cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', Accept: 'application/javascript' },
          body: JSON.stringify({ id: variantId, quantity: 1 })
        })
        .then(function(res) { return res.json(); })
        .then(function(data) {
          if (data.status) throw new Error(data.description || 'Could not add to cart');
          if (window.showToast) {
            window.showToast({ message: 'Item added to your cart.', type: 'success', position: 'bottom-right' });
          }
          document.dispatchEvent(new CustomEvent('cart:updated', { detail: { open: true } }));
        })
        .catch(function(err) {
          if (window.showToast) {
            window.showToast({ message: err.message, type: 'error', position: 'bottom-right' });
          }
        })
        .finally(function() {
          btn.classList.remove('is-loading');
        });
      });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Signature Pieces",
  "tag": "section",
  "class": "section section-signature-pieces",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Crafted to last generations"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Signature Pieces"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Timeless designs, masterfully handcrafted in solid wood.\nEach piece is made to your specifications and built to be lived with."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "material_default",
      "label": "Default material",
      "default": "Solid walnut"
    },
    {
      "type": "text",
      "id": "finish_default",
      "label": "Default finish",
      "default": "hand-rubbed oil finish"
    },
    {
      "type": "text",
      "id": "custom_line",
      "label": "Custom line",
      "default": "Custom size available"
    },
    {
      "type": "text",
      "id": "lead_time_default",
      "label": "Default lead time",
      "default": "8-10 weeks"
    },
    {
      "type": "text",
      "id": "price_prefix",
      "label": "Price prefix",
      "default": "From"
    },
    {
      "type": "text",
      "id": "best_seller_badge",
      "label": "Best seller badge",
      "default": "Best Seller"
    },
    {
      "type": "text",
      "id": "made_to_order_badge",
      "label": "Made to order badge",
      "default": "Made to Order"
    },
    {
      "type": "text",
      "id": "customize_label",
      "label": "Customize button label",
      "default": "Customize This Piece"
    },
