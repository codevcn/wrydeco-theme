      grid-template-rows: auto;
      width: 100%;
      max-height: 92dvh;
      overflow-y: auto;
      border-radius: var(--radius-lg) var(--radius-lg) 0 0;
      transform: translateY(100%);
      max-width: 95vw;
    }

    .sp-quick.is-open .sp-quick__panel {
      transform: none;
    }

    .sp-quick__media {
      min-height: 0;
    }

    .sp-quick__media-main {
      flex: 0 0 auto;
      height: 42vh;
    }

    .sp-quick__body {
      min-height: 0;
