<div class="signature-pieces page-width">
  <header class="signature-pieces__header">
    <p class="signature-pieces__eyebrow">{{ section.settings.eyebrow | upcase }}</p>
    <h2 class="signature-pieces__heading">{{ section.settings.heading }}</h2>
    <p class="signature-pieces__subtitle">{{ section.settings.subtitle | newline_to_br }}</p>
  </header>

  {%- assign collection = section.settings.collection -%}
  {%- if collection == blank -%}
    {%- assign collection = collections['signature-pieces'] -%}
  {%- endif -%}

  <div class="signature-pieces__carousel" data-signature-slider>
    <button
      class="signature-pieces__nav signature-pieces__nav--prev"
      type="button"
      aria-label="Previous products"
      aria-controls="SignaturePiecesTrack-{{ section.id }}"
      data-signature-prev
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
        <path d="M15 18 9 12l6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div
      class="signature-pieces__grid"
      id="SignaturePiecesTrack-{{ section.id }}"
      role="list"
      data-signature-track
      tabindex="0"
    >

    {%- for product in collection.products limit: 10 -%}
      {%- assign display_title = product.metafields.custom.artwork_name.value | default: product.title -%}
      <article class="signature-pieces__card" role="listitem">
        <div class="signature-pieces__image-wrapper">
          <a href="{{ product.url }}" class="signature-pieces__image-link" tabindex="-1">
            {%- if product.featured_media != blank -%}
              {{
                product.featured_media.preview_image
                | image_url: width: 900
                | image_tag:
                  class: 'signature-pieces__img',
                  loading: 'lazy',
                  widths: '320, 480, 640, 900',
                  sizes: '(min-width: 64rem) 25vw, (min-width: 48rem) 50vw, 82vw'
              }}
            {%- else -%}
              {{ 'product-' | append: forloop.index | placeholder_svg_tag: 'signature-pieces__img placeholder-svg' }}
            {%- endif -%}
          </a>

        </div>

        <div class="signature-pieces__content">
          <h3 class="signature-pieces__title">
            <a href="{{ product.url }}">{{ display_title }}</a>
          </h3>
          <p class="signature-pieces__price">From {{ product.price | money_without_trailing_zeros }}</p>

          <hr class="signature-pieces__divider">

          <p class="signature-pieces__meta">
            {%- assign tag_count = product.tags.size -%}
            {%- if tag_count > 0 -%}
              {%- assign tag_1 = product.tags[0] -%}
              {%- if tag_count > 1 -%}
                {%- assign tag_2 = product.tags[1] -%}
                {{ tag_1 }} &bull; {{ tag_2 }}
              {%- else -%}
                {{ tag_1 }} &bull; Made to order
              {%- endif -%}
            {%- else -%}
              Solid walnut &bull; Made to order
            {%- endif -%}
          </p>
        </div>
      </article>
    {%- else -%}
      {%- for i in (1..10) -%}
        {%- assign placeholder_index = i | minus: 1 | modulo: 6 | plus: 1 -%}
        <article class="signature-pieces__card" role="listitem">
          <div class="signature-pieces__image-wrapper">
            <div class="signature-pieces__image-link">
              {{ 'product-' | append: placeholder_index | placeholder_svg_tag: 'signature-pieces__img placeholder-svg' }}
            </div>
          </div>
          <div class="signature-pieces__content">
            <h3 class="signature-pieces__title">
              <a href="#">Example Signature Piece</a>
            </h3>
            <p class="signature-pieces__price">From $2,450</p>
            <hr class="signature-pieces__divider">
            <p class="signature-pieces__meta">Solid walnut &bull; Made to order</p>
          </div>
        </article>
      {%- endfor -%}
    {%- endfor -%}
    </div>

    <button
      class="signature-pieces__nav signature-pieces__nav--next"
      type="button"
      aria-label="Next products"
      aria-controls="SignaturePiecesTrack-{{ section.id }}"
      data-signature-next
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
        <path d="m9 18 6-6-6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>
  </div>

  {%- if section.settings.button_label != blank -%}
    <div class="signature-pieces__footer">
      <a
        href="{{ section.settings.button_link | default: collection.url | default: '#' }}"
        class="signature-pieces__btn"
      >
        {{ section.settings.button_label }}
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="signature-pieces__btn-icon"
        >
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .signature-pieces {
    width: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--layout-max-width));
    margin-inline: auto;
    padding-block: var(--sp-6);
    background-color: var(--bg-primary);
    color: var(--text-primary);
    margin-bottom: var(--sp-4);
    margin-top: var(--sp-4);
  }

  .signature-pieces__header {
    text-align: center;
    margin-bottom: var(--sp-6);
  }

  .signature-pieces__eyebrow {
    font-family: var(--font-body);
    font-size: var(--font-size-caption);
    letter-spacing: calc(var(--letter-spacing-wide) * 5);
    color: var(--text-secondary);
    margin: 0 0 var(--sp-3);
    font-weight: var(--font-weight-medium);
  }

  .signature-pieces__heading {
    font-family: var(--font-display);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
    margin: 0 0 var(--sp-4);
    letter-spacing: var(--letter-spacing-tight);
    text-wrap: balance;
  }

  .signature-pieces__subtitle {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
    line-height: var(--line-height-relaxed);
    margin: 0 auto;
    max-width: calc(var(--layout-max-width) / 2);
    text-wrap: balance;
  }

  .signature-pieces__carousel {
    position: relative;
  }

  .signature-pieces__grid {
    display: flex;
    gap: var(--sp-4);
    overflow-x: auto;
    padding-bottom: var(--sp-3);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
    overscroll-behavior-inline: contain;
  }

  .signature-pieces__grid::-webkit-scrollbar {
    display: none;
  }

  .signature-pieces__card {
    display: flex;
    flex-direction: column;
    flex: 0 0 82%;
    min-width: 0;
    border: 1px solid color-mix(in srgb, var(--color-linen) 48%, transparent);
    border-radius: var(--radius-lg);
    overflow: hidden;
    scroll-snap-align: start;
    background-color: var(--bg-primary);
    transition: box-shadow var(--timing-base) var(--ease-standard),
      transform var(--timing-base) var(--ease-standard);
  }

  .signature-pieces__image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1.04;
    overflow: hidden;
    background-color: var(--bg-secondary);
  }

  .signature-pieces__image-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .signature-pieces__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--timing-extra-long) var(--ease-standard);
    -webkit-user-drag: none;
  }

  .signature-pieces__content {
    padding: var(--sp-4);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .signature-pieces__title {
    font-family: var(--font-display);
    font-size: var(--font-size-body-2xl);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-normal);
    margin: 0 0 var(--sp-2);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .signature-pieces__title a {
    color: var(--text-primary);
    text-decoration: none;
  }

  .signature-pieces__title a:hover {
    color: var(--color-earth-brown);
  }

  .signature-pieces__price {
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-medium);
    color: var(--color-clay);
    margin: 0 0 var(--sp-4);
    font-variant-numeric: tabular-nums;
  }

  .signature-pieces__divider {
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--color-linen) 48%, transparent);
    margin: auto 0 var(--sp-4);
  }

  .signature-pieces__meta {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-normal);
    color: var(--text-secondary);
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .signature-pieces__footer {
    display: flex;
    justify-content: center;
    margin-top: var(--sp-5);
  }

  .signature-pieces__nav {
    position: absolute;
    top: 50%;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-7);
    height: var(--sp-7);
    padding: 0;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-full);
    background-color: var(--bg-primary);
    color: var(--text-primary);
    box-shadow: var(--shadow-card);
    cursor: pointer;
    transform: translateY(-50%);
    transition: color var(--timing-short) var(--ease-standard),
      background-color var(--timing-short) var(--ease-standard),
      opacity var(--timing-short) var(--ease-standard);
  }

  .signature-pieces__nav svg {
    width: var(--sp-5);
    height: var(--sp-5);
  }

  .signature-pieces__nav--prev {
    left: var(--sp-2);
  }

  .signature-pieces__nav--next {
    right: var(--sp-2);
  }

  .signature-pieces__nav:hover:not(:disabled) {
    background-color: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .signature-pieces__nav:disabled {
    opacity: 0.35;
    cursor: default;
    pointer-events: none;
  }

  .signature-pieces__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: var(--sp-7);
    background-color: var(--color-earth-brown);
    color: var(--text-inverse);
    padding-inline: var(--sp-8);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    transition: background-color var(--timing-short) var(--ease-standard),
      transform var(--timing-short) var(--ease-standard);
    border-radius: var(--radius-sm);
  }

  .signature-pieces__btn:hover {
    color: var(--text-inverse);
    background-color: var(--color-ebony);
    transform: translateY(calc(var(--sp-1) * -0.5));
  }

  .signature-pieces__btn:active {
    transform: translateY(0);
  }

  .signature-pieces__btn-icon {
    margin-left: var(--sp-2);
    transition: transform var(--timing-short) var(--ease-standard);
  }

  .signature-pieces__btn:hover .signature-pieces__btn-icon {
    transform: translateX(var(--sp-1));
  }

  .signature-pieces :is(a, button):focus-visible {
    outline: var(--radius-sm) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  @media screen and (min-width: 48rem) {
    .signature-pieces {
      width: min(calc(100% - (var(--layout-padding-tablet) * 2)), var(--layout-max-width));
      padding-block: var(--sp-6);
    }

    .signature-pieces__heading {
      font-size: var(--font-size-display-lg);
    }

    .signature-pieces__subtitle {
      font-size: var(--font-size-body-md);
    }

    .signature-pieces__card {
      flex-basis: calc((100% - var(--sp-4)) / 2);
    }

    .signature-pieces__content {
      padding: var(--sp-5);
    }
  }

  @media screen and (min-width: 64rem) {
    .signature-pieces {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
      grid-template-rows: auto minmax(0, 1fr) auto;
      width: min(calc(100% - (var(--sp-8) * 2)), var(--layout-showcase-max-width));
      height: 100svh;
      min-height: 0;
      padding-block: var(--sp-7);
    }

    .signature-pieces__header {
      margin-bottom: var(--sp-7);
    }

    .signature-pieces__heading {
      font-size: var(--font-size-display-xl);
    }

    .signature-pieces__carousel {
      width: 100%;
      min-height: 0;
      min-width: 0;
    }

    .signature-pieces__grid {
      height: 100%;
      min-height: 0;
      padding-bottom: 0;
    }

    .signature-pieces__card {
      flex-basis: calc((100% - (var(--sp-4) * 3)) / 4);
      height: 100%;
    }

    .signature-pieces__content {
      padding-block: var(--sp-5);
      padding-inline: var(--sp-6);
    }

    .signature-pieces__title {
      font-size: var(--font-size-display-sm);
      line-height: var(--line-height-tight);
    }

    .signature-pieces__image-wrapper {
      flex: 1 1 auto;
      min-height: 0;
    }

    .signature-pieces__nav--prev {
      left: calc(var(--sp-7) * -0.5);
    }

    .signature-pieces__nav--next {
      right: calc(var(--sp-7) * -0.5);
    }

    .signature-pieces__carousel .signature-pieces__nav {
      opacity: 0;
      pointer-events: none;
    }

    .signature-pieces__carousel:hover .signature-pieces__nav:not(:disabled),
    .signature-pieces__carousel:focus-within .signature-pieces__nav:not(:disabled) {
      opacity: 1;
      pointer-events: auto;
    }

    .signature-pieces__card:hover {
      box-shadow: var(--shadow-card);
      transform: translateY(calc(var(--sp-1) * -1));
    }

    .signature-pieces__card:hover .signature-pieces__img {
      transform: scale(1.025);
    }

    .signature-pieces__btn {
      min-width: calc(var(--sp-8) * 4);
    }
  }

  @media screen and (min-width: 64rem) and (max-height: 51.25rem) {
    .signature-pieces {
      padding-block: var(--sp-5);
    }

    .signature-pieces__header {
      margin-bottom: var(--sp-5);
    }

    .signature-pieces__heading {
      font-size: var(--font-size-display-lg);
    }

    .signature-pieces__footer {
      margin-top: var(--sp-5);
    }
  }

  @media screen and (min-width: 100rem) {
    .signature-pieces {
      width: min(calc(100% - (var(--sp-8) * 2)), var(--layout-showcase-max-width));
    }

    .signature-pieces__header {
      margin-bottom: var(--sp-7);
    }

    .signature-pieces__grid {
      gap: var(--sp-4);
    }

    .signature-pieces__card {
      flex-basis: calc((100% - (var(--sp-4) * 3)) / 4);
    }

    .signature-pieces__footer {
      margin-top: var(--sp-6);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .signature-pieces__card,
    .signature-pieces__img,
    .signature-pieces__btn,
    .signature-pieces__btn-icon,
    .signature-pieces__nav {
      transition-duration: 0s;
    }
  }
{% endstylesheet %}

{% javascript %}
  const initializeSignaturePieces = (root = document) => {
    root.querySelectorAll('[data-signature-slider]:not([data-signature-ready])').forEach((slider) => {
      const track = slider.querySelector('[data-signature-track]');
      const previousButton = slider.querySelector('[data-signature-prev]');
      const nextButton = slider.querySelector('[data-signature-next]');

      if (!track || !previousButton || !nextButton) return;

      slider.dataset.signatureReady = 'true';

      const updateNavigation = () => {
        const maximumScroll = track.scrollWidth - track.clientWidth;
        const hasOverflow = maximumScroll > 1;

        previousButton.hidden = !hasOverflow;
        nextButton.hidden = !hasOverflow;
        previousButton.disabled = track.scrollLeft <= 1;
        nextButton.disabled = track.scrollLeft >= maximumScroll - 1;
      };

      const scrollPage = (direction) => {
        const card = track.querySelector('.signature-pieces__card');
        if (!card) return;

        const styles = window.getComputedStyle(track);
        const gap = Number.parseFloat(styles.columnGap || styles.gap) || 0;
        const cardStep = card.getBoundingClientRect().width + gap;
        const visibleCards = Math.max(1, Math.round(track.clientWidth / cardStep));

        track.scrollBy({
          left: direction * cardStep * visibleCards,
          behavior: 'smooth'
        });
      };

      previousButton.addEventListener('click', () => scrollPage(-1));
      nextButton.addEventListener('click', () => scrollPage(1));
      track.addEventListener('keydown', (event) => {
        if (event.key === 'ArrowLeft') {
          event.preventDefault();
          scrollPage(-1);
        }

        if (event.key === 'ArrowRight') {
          event.preventDefault();
          scrollPage(1);
        }
      });
      track.addEventListener('scroll', updateNavigation, { passive: true });
      window.addEventListener('resize', updateNavigation);
      updateNavigation();
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => initializeSignaturePieces());
  } else {
    initializeSignaturePieces();
  }

  document.addEventListener('shopify:section:load', (event) => initializeSignaturePieces(event.target));
{% endjavascript %}

{% schema %}
{
  "name": "Signature Pieces",
  "tag": "section",
  "class": "section section-signature-pieces",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "SIGNATURE PIECES"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Signature Pieces"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Timeless designs, masterfully handcrafted.\nEach piece is a statement of nature, artistry, and enduring quality."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "View All Pieces"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Signature Pieces"
    }
  ]
}
{% endschema %}
