<div class="mood-slider page-width">
  <div class="mood-slider__header">
    <h2 class="mood-slider__heading">{{ section.settings.heading }}</h2>
  </div>
  <div class="mood-slider__track" id="MoodSliderTrack-{{ section.id }}">
    {%- for block in section.blocks -%}
      <div class="mood-slider__card" {{ block.shopify_attributes }}>
        <div class="mood-slider__mosaic">
          {%- if block.settings.image_1 != blank -%}
            <div class="mood-slider__img-1" style="background-image: url('{{ block.settings.image_1 | asset_url }}');"></div>
          {%- endif -%}
          {%- if block.settings.image_2 != blank -%}
            <div class="mood-slider__img-2" style="background-image: url('{{ block.settings.image_2 | asset_url }}');"></div>
          {%- endif -%}
          {%- if block.settings.image_3 != blank -%}
            <div class="mood-slider__img-3" style="background-image: url('{{ block.settings.image_3 | asset_url }}');"></div>
          {%- endif -%}
        </div>
        <div class="mood-slider__content">
          <h3 class="mood-slider__title">{{ block.settings.title | escape }}</h3>
          <p class="mood-slider__subtitle">{{ block.settings.subtitle | escape }}</p>
        </div>
      </div>
    {%- endfor -%}
  </div>
</div>

{% stylesheet %}
  .mood-slider {
    padding-block: var(--space-8, 16px);
  }
  .mood-slider__header {
    padding-bottom: var(--space-6, 12px);
  }
  .mood-slider__heading {
    font-size: var(--text-lg, 35px);
    font-weight: var(--font-weight-500, 500);
    margin: 0;
  }
  .mood-slider__heading em {
    color: var(--color-2, #e60023);
    font-style: italic;
  }

  /* Disable text selection and image dragging */
  .mood-slider__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    gap: var(--space-6, 12px);
    padding-bottom: var(--space-4, 10px);
    /* Hide scrollbar for cleaner look */
    scrollbar-width: none;
    user-select: none;
    -webkit-user-select: none;
    margin-left: 5px;
  }
  .mood-slider__track::-webkit-scrollbar {
    display: none;
  }

  /* When javascript adds 'is-dragging' class */
  .mood-slider__track.is-dragging {
    scroll-snap-type: none;
    cursor: grabbing;
  }
  .mood-slider__track:not(.is-dragging) {
    cursor: grab;
  }

  .mood-slider__card {
    flex: 0 0 85%;
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    gap: var(--space-4, 10px);
  }

  .mood-slider__mosaic {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 6px;
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    aspect-ratio: 4 / 3;
    pointer-events: none; /* Prevents images from stealing drag events */
  }

  .mood-slider__img-1,
  .mood-slider__img-2,
  .mood-slider__img-3 {
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
  }

  .mood-slider__img-1 {
    grid-row: 1 / 3;
    grid-column: 1 / 2;
  }
  .mood-slider__img-2 {
    grid-row: 1 / 2;
    grid-column: 2 / 3;
  }
  .mood-slider__img-3 {
    grid-row: 2 / 3;
    grid-column: 2 / 3;
  }

  .mood-slider__title {
    font-size: var(--text-base, 15px);
    font-weight: var(--font-weight-700, 700);
    margin: 0 0 4px 0;
  }
  .mood-slider__subtitle {
    font-size: var(--text-sm, 14px);
    color: var(--color-3, #767676);
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .mood-slider__card {
      flex: 0 0 350px;
    }
    .mood-slider__heading {
      font-size: var(--text-xl, 46px);
    }
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', function () {
    const sliders = document.querySelectorAll('.mood-slider__track');

    sliders.forEach((slider) => {
      let isDown = false;
      let startX;
      let scrollLeft;

      slider.addEventListener('mousedown', (e) => {
        isDown = true;
        slider.classList.add('is-dragging');
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
      });

      slider.addEventListener('mouseleave', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
      });

      slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
      });

      slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 1.5; // Drag speed multiplier
        slider.scrollLeft = scrollLeft - walk;
      });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Mood Collections",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "html",
      "id": "heading",
      "label": "Heading (HTML allowed)",
      "default": "Collections by <em>mood</em>"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Collection Card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Title"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "10 pieces • 100 saves"
        },
        {
          "type": "text",
          "id": "image_1",
          "label": "Image 1 Filename"
        },
        {
          "type": "text",
          "id": "image_2",
          "label": "Image 2 Filename"
        },
        {
          "type": "text",
          "id": "image_3",
          "label": "Image 3 Filename"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Mood Collections",
      "blocks": [{ "type": "card" }]
    }
  ]
}
{% endschema %}
