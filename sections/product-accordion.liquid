{% stylesheet %}
  .product-accordion-section {
    padding: 0 16px 8px;
    margin: 0 auto;
    max-width: 800px; /* or a suitable max-width */
  }

  .product-accordion-section__title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 32px;
    line-height: 1.15;
    color: #1a1a1a;
    margin: 0 0 16px 0;
    letter-spacing: -0.02em;
    font-weight: 400;
  }
  .product-accordion-section__title em {
    font-style: italic;
    color: #df3e3e;
  }
  /* Remove default p margins from richtext */
  .product-accordion-section__title p {
    margin: 0;
  }

  .product-accordion-container {
    border: 1px solid #e2dcd2;
    border-radius: 6px;
    background-color: #fff; /* Slight off-white/beige from image */
    overflow: hidden;
    box-shadow: 0 2px 6px rgba(0, 0, 0, 0.2); /* subtle shadow for depth */
  }

  .product-accordion-item {
    border-bottom: 1px solid #e2dcd2;
    font-weight: 700;
  }

  .product-accordion-item:last-child {
    border-bottom: none;
  }

  .product-accordion-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    cursor: pointer;
    font-family: var(--font-display);
    font-size: 13px;
    letter-spacing: 0.05em;
    color: #1a2b3c;
    text-transform: uppercase;
    list-style: none; /* Removes default arrow in most browsers */
  }

  .product-accordion-summary::-webkit-details-marker {
    display: none; /* Removes default arrow in Safari */
  }

  .product-accordion-summary:hover {
    background-color: #fdf6ec;
  }

  .product-accordion-icon {
    position: relative;
    width: 14px;
    height: 14px;
  }

  .product-accordion-icon::before,
  .product-accordion-icon::after {
    content: '';
    position: absolute;
    background-color: currentColor;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    transition: transform 0.3s ease;
  }

  .product-accordion-icon::before {
    width: 14px;
    height: 1.5px;
  }

  .product-accordion-icon::after {
    height: 14px;
    width: 1.5px;
  }

  /* When details is open, rotate the vertical line to form a minus */
  details[open] > .product-accordion-summary .product-accordion-icon::after {
    transform: translate(-50%, -50%) rotate(90deg);
  }

  .product-accordion-content {
    padding: 0 20px 20px 20px;
    font-size: 14px;
    line-height: 1.6;
    color: #444;
  }

  /* Grid styles inside accordion */
  .accordion-drawer-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin: 16px 0 0;
  }
  .accordion-drawer-grid button {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: #fdf6ec;
    border: 1px solid #e2dcd2;
    border-radius: 8px;
    padding: 16px 8px;
    font-size: 13px;
    font-family: var(--font-body, inherit);
    font-weight: 700;
    color: #1a1a1a;
    cursor: pointer;
    transition: background-color 0.2s, transform 0.2s;
    aspect-ratio: 1 / 1;
  }
  .accordion-drawer-grid button:hover {
    background-color: #f7ede1;
    transform: translateY(-2px);
  }
  .accordion-drawer-grid button svg {
    width: 28px;
    height: 28px;
    margin-bottom: 12px;
    color: #1a1a1a;
  }

  /* Bottom Drawer Styles */
  .bottom-drawer {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 9999;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    visibility: hidden;
    opacity: 0;
    transition: visibility 0.3s, opacity 0.3s;
    font-family: var(--font-body, inherit);
  }
  .bottom-drawer[aria-hidden='false'] {
    visibility: visible;
    opacity: 1;
  }
  .bottom-drawer__overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.5);
  }
  .bottom-drawer__content {
    position: relative;
    background: #fff;
    border-radius: 20px 20px 0 0;
    padding: 24px;
    transform: translateY(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    max-height: 85vh;
    overflow-y: auto;
  }
  .bottom-drawer[aria-hidden='false'] .bottom-drawer__content {
    transform: translateY(0);
  }
  .bottom-drawer__handle {
    width: 40px;
    height: 4px;
    background: #e2dcd2;
    border-radius: 2px;
    margin: 0 auto 20px;
  }
  .bottom-drawer__close {
    position: absolute;
    top: 16px;
    right: 16px;
    border: none;
    border-radius: 50%;
    font-size: 32px;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1a1a1a;
    background-color: transparent;
  }
  .bottom-drawer__title {
    font-family: var(--font-display, 'Playfair Display', serif);
    font-size: 24px;
    margin: 0 0 16px;
    color: #1a1a1a;
    font-weight: 700;
  }
  .bottom-drawer__subtitle {
    font-size: 16px;
    margin: 20px 0 8px;
    font-weight: 700;
    color: #1a1a1a;
  }
  .bottom-drawer__body p {
    font-size: 15px;
    line-height: 1.6;
    color: #444;
    margin-bottom: 16px;
  }

  @media screen and (min-width: 720px) {
    .product-accordion-section {
      display: grid;
      grid-template-columns: minmax(0, 4fr) minmax(0, 8fr);
      align-items: start;
      gap: var(--sp-6);
      max-width: var(--layout-max-width);
    }

    .product-accordion-section__title {
      margin: 0;
      font-size: var(--font-size-display-md);
      color: var(--text-primary);
      text-wrap: balance;
    }

    .product-accordion-container {
      border-color: var(--border-light);
      border-radius: 8px;
      background-color: var(--surface-elevated);
      box-shadow: var(--shadow-elevation-1);
      overflow: hidden;
    }

    .product-accordion-summary {
      min-height: calc(var(--sp-7) + var(--sp-1));
      padding: var(--sp-4) var(--sp-5);
      font-family: var(--font-body);
      font-size: var(--font-size-body-sm);
      color: var(--text-primary);
    }

    .product-accordion-content {
      padding: 0 var(--sp-5) var(--sp-5);
      font-size: var(--font-size-body-md);
      line-height: var(--line-height-generous);
      color: var(--text-secondary);
    }

    .accordion-drawer-grid {
      gap: var(--sp-3);
      margin-block-start: var(--sp-5);
    }

    .accordion-drawer-grid button {
      min-height: calc(var(--sp-8) + var(--sp-7));
      padding: var(--sp-4) var(--sp-2);
      border-color: var(--border-light);
      border-radius: var(--radius-sm);
      background-color: var(--color-cream);
      color: var(--text-primary);
    }

    .bottom-drawer {
      align-items: center;
      justify-content: center;
      padding: var(--sp-6);
    }

    .bottom-drawer__overlay {
      background: var(--bg-overlay);
    }

    .bottom-drawer__content {
      width: min(100%, 40rem);
      max-height: 80dvh;
      padding: var(--sp-6);
      border-radius: var(--radius-sm);
      background: var(--surface-elevated);
      box-shadow: var(--shadow-modal);
      transform: translateY(var(--sp-4)) scale(0.98);
    }

    .bottom-drawer[aria-hidden='false'] .bottom-drawer__content {
      transform: translateY(0) scale(1);
    }

    .bottom-drawer__handle {
      display: none;
    }

    .bottom-drawer__close {
      top: var(--sp-4);
      right: var(--sp-4);
      width: calc(var(--sp-5) + var(--sp-5) - var(--sp-1));
      height: calc(var(--sp-5) + var(--sp-5) - var(--sp-1));
      color: var(--text-primary);
    }

    .bottom-drawer__title {
      margin-block-end: var(--sp-4);
      font-size: var(--font-size-display-sm);
      color: var(--text-primary);
    }

    .bottom-drawer__subtitle,
    .bottom-drawer__body p {
      font-size: var(--font-size-body-md);
    }
  }

  @media screen and (min-width: 1024px) {
    .product-accordion-section {
      gap: var(--sp-8);
      padding: var(--section-spacing-desktop) 0;
    }
  }
{% endstylesheet %}

<div class="product-accordion-section page-width">
  <h2 class="product-accordion-section__title">
    {{ section.settings.title }}
  </h2>
  <div class="product-accordion-container">
    {% for block in section.blocks %}
      <details class="product-accordion-item" {{ block.shopify_attributes }}>
        <summary class="product-accordion-summary">
          {{ block.settings.heading | escape }}
          <span class="product-accordion-icon"></span>
        </summary>
        <div class="product-accordion-content">
          {% if block.type == 'description' %}
            {{ product.description }}
          {% elsif block.type == 'shipping_returns' %}
            {{ block.settings.content }}
            <div class="accordion-drawer-grid">
              <button type="button" data-drawer-trigger="drawer-delivery-time">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                Delivery Timeline
              </button>
              <button type="button" data-drawer-trigger="drawer-shipping-cost">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="1" y="3" width="15" height="13"></rect><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon><circle cx="5.5" cy="18.5" r="2.5"></circle><circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
                Shipping Cost
              </button>
              <button type="button" data-drawer-trigger="drawer-returns">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="1.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <polyline points="9 14 4 9 9 4"></polyline><path d="M20 20v-7a4 4 0 0 0-4-4H4"></path>
                </svg>
                30-Day Returns
              </button>
            </div>
          {% else %}
            {{ block.settings.content }}
            {% if block.settings.show_benefits %}
              {% render 'product-benefits', product: product, section: section %}
            {% endif %}
          {% endif %}
        </div>
      </details>
    {% endfor %}
  </div>
</div>

<!-- Drawers -->
<div class="bottom-drawer" id="drawer-delivery-time" aria-hidden="true">
  <div class="bottom-drawer__overlay" data-drawer-close></div>
  <div class="bottom-drawer__content">
    <div class="bottom-drawer__handle" data-drawer-close></div>
    <button type="button" class="bottom-drawer__close" data-drawer-close>&times;</button>
    <div class="bottom-drawer__body">
      <h3 class="bottom-drawer__title">Delivery Timeline</h3>
      <h4 class="bottom-drawer__subtitle">From Our Workshop to Your Door</h4>
      <p>
        Your handcrafted piece is made to order in Vietnam. Please allow 4-6 weeks for production as our master
        craftsmen meticulously shape, assemble, and finish your item.
      </p>
      <h4 class="bottom-drawer__subtitle">Transit Times</h4>
      <p>
        Once completed, shipping takes an additional 2-4 weeks depending on your location and customs clearance. You
        will receive a tracking link as soon as your piece leaves our workshop.
      </p>
    </div>
  </div>
</div>

<div class="bottom-drawer" id="drawer-shipping-cost" aria-hidden="true">
  <div class="bottom-drawer__overlay" data-drawer-close></div>
  <div class="bottom-drawer__content">
    <div class="bottom-drawer__handle" data-drawer-close></div>
    <button type="button" class="bottom-drawer__close" data-drawer-close>&times;</button>
    <div class="bottom-drawer__body">
      <h3 class="bottom-drawer__title">Shipping Cost</h3>
      <h4 class="bottom-drawer__subtitle">Calculated at Checkout</h4>
      <p>
        Because each piece is crafted from solid natural wood, the shipping cost varies based on the final weight,
        dimensions, and your delivery destination.
      </p>
      <h4 class="bottom-drawer__subtitle">White Glove Delivery (Optional)</h4>
      <p>
        For large furniture items, we offer a premium White Glove delivery service for an additional fee. This includes
        bringing the item into your room of choice, complete unboxing, and assembly if required.
      </p>
    </div>
  </div>
</div>

<div class="bottom-drawer" id="drawer-returns" aria-hidden="true">
  <div class="bottom-drawer__overlay" data-drawer-close></div>
  <div class="bottom-drawer__content">
    <div class="bottom-drawer__handle" data-drawer-close></div>
    <button type="button" class="bottom-drawer__close" data-drawer-close>&times;</button>
    <div class="bottom-drawer__body">
      <h3 class="bottom-drawer__title">30-Day Returns</h3>
      <h4 class="bottom-drawer__subtitle">Returns</h4>
      <p>
        You may return your standard catalog item within 30 days of delivery. Items must be unused, in original
        condition, and with all packaging included.
      </p>
      <p>Custom or personalized items are non-returnable.</p>
      <p>To start a return, contact our concierge team with your order number and reason.</p>
      <h4 class="bottom-drawer__subtitle">Return Shipping</h4>
      <p>
        Customers are responsible for the return shipping costs, unless the item arrived defective, damaged, or
        incorrect. Due to the high value and weight of solid wood furniture, we recommend using an insured freight
        service.
      </p>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const triggers = document.querySelectorAll('[data-drawer-trigger]');
    const closeBtns = document.querySelectorAll('[data-drawer-close]');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', (e) => {
        e.preventDefault();
        const drawerId = trigger.getAttribute('data-drawer-trigger');
        const drawer = document.getElementById(drawerId);
        if (drawer) {
          drawer.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden'; // Prevent background scrolling
        }
      });
    });

    closeBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const drawer = e.target.closest('.bottom-drawer');
        if (drawer) {
          drawer.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = ''; // Restore scrolling
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Accordion",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title"
    }
  ],
  "blocks": [
    {
      "type": "accordion",
      "name": "Accordion Item",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Accordion title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Content",
          "default": "<p>Provide details, material info, or care instructions here.</p>"
        },
        {
          "type": "checkbox",
          "id": "show_benefits",
          "label": "Show Product Benefits",
          "default": false
        }
      ]
    },
    {
      "type": "description",
      "name": "Product Description",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "DESCRIPTION"
        }
      ]
    },
    {
      "type": "shipping_returns",
      "name": "Shipping & Returns",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "SHIPPING & RETURNS"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Intro Text",
          "default": "<p>Learn more about our delivery timeline, shipping costs, and return policy.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Accordion",
      "blocks": [
        {
          "type": "description",
          "settings": {
            "heading": "DESCRIPTION"
          }
        },
        {
          "type": "accordion",
          "settings": {
            "heading": "MATERIALS & CARE",
            "content": "<p>Wipe clean with a soft, dry cloth. Keep away from direct sunlight and extreme temperatures to preserve the finish.</p>"
          }
        },
        {
          "type": "shipping_returns",
          "settings": {
            "heading": "SHIPPING & RETURNS",
            "content": "<p>Learn more about our delivery timeline, shipping costs, and return policy.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
