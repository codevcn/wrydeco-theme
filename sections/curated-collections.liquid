<div class="curated-collections page-width">
  <div class="curated-collections__header">
    <div class="curated-collections__icon">
      <svg width="32" height="32" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="20" r="19" stroke="currentColor" stroke-width="1" stroke-dasharray="2 2"/>
        <circle cx="20" cy="20" r="14" stroke="currentColor" stroke-width="1"/>
        <circle cx="20" cy="20" r="9" stroke="currentColor" stroke-width="1" stroke-dasharray="1 3"/>
        <circle cx="20" cy="20" r="4" stroke="currentColor" stroke-width="1"/>
      </svg>
    </div>
    <h2 class="curated-collections__heading">{{ section.settings.heading }}</h2>
    <p class="curated-collections__subtitle">{{ section.settings.subtitle | newline_to_br }}</p>
  </div>

  <div class="curated-collections__grid">
    {%- for block in section.blocks -%}
      <a
        href="{{ block.settings.link | default: '#' }}"
        class="curated-collections__card curated-collections__card--{{ forloop.index }}"
        {{ block.shopify_attributes }}
      >
        <div class="curated-collections__card-bg">
          {%- if block.settings.image != blank -%}
            {{
              block.settings.image
              | image_url: width: 800
              | image_tag: class: 'curated-collections__img', loading: 'lazy'
            }}
          {%- else -%}
            {%- assign asset_img = 'curated-collections-img-' | append: forloop.index | append: '.png' -%}
            <img
              src="{{ asset_img | asset_url }}"
              alt="{{ block.settings.title }}"
              class="curated-collections__img"
              loading="lazy"
              width="800"
              height="1000"
            >
          {%- endif -%}
          <div class="curated-collections__card-overlay"></div>
        </div>
        <div class="curated-collections__card-content">
          <div class="curated-collections__card-text">
            <h3 class="curated-collections__card-title">{{ block.settings.title }}</h3>
            <p class="curated-collections__card-subtitle">{{ block.settings.subtitle | newline_to_br }}</p>
          </div>
          <div class="curated-collections__card-arrow">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>
      </a>
    {%- endfor -%}
  </div>

  <div class="curated-collections__footer">
    <div class="curated-collections__divider">
      <span class="curated-collections__footer-text">Crafted by nature. Designed to endure.</span>
    </div>
  </div>
</div>

<div class="custom-section-divider"></div>

{% stylesheet %}
  @font-face {
    font-family: 'Fraunces';
    src: url('Fraunces.woff2') format('woff2');
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  .curated-collections {
    padding-top: var(--sp-8, 64px);
    padding-bottom: var(--sp-8, 64px);
    background-color: var(--bg-primary, #f5f1ed);
    color: var(--text-primary, #1a1815);
    margin-top: var(--sp-6, 64px);
    margin-bottom: var(--sp-3, 64px);
  }

  .curated-collections__header {
    text-align: center;
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .curated-collections__icon {
    color: var(--text-secondary, #6b5d52);
    margin-bottom: var(--sp-4, 16px);
  }

  .curated-collections__heading {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 48px);
    font-weight: var(--font-weight-regular, 400);
    letter-spacing: var(--letter-spacing-tight, -0.06em);
    margin-bottom: var(--sp-3, 12px);
    color: var(--text-primary, #1a1815);
  }

  .curated-collections__subtitle {
    font-family: var(--font-body);
    font-size: var(--font-size-body-md, 16px);
    color: var(--text-secondary, #6b5d52);
    max-width: 480px;
    margin: 0 auto;
    line-height: var(--line-height-relaxed, 1.5);
  }

  /* Grid Layout - Mobile First */
  .curated-collections__grid {
    display: flex;
    gap: var(--sp-4, 16px);
    overflow-x: auto;
    padding-bottom: var(--sp-4, 16px);
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none; /* Firefox */
  }
  .curated-collections__grid .curated-collections__card:first-child {
    margin-left: 64px;
  }
  .curated-collections__grid .curated-collections__card:last-child {
    margin-right: 64px;
  }

  .curated-collections__grid::-webkit-scrollbar {
    display: none; /* Chrome, Safari */
  }

  .curated-collections__card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    border-radius: var(--radius-md, 8px);
    overflow: hidden;
    text-decoration: none;
    scroll-snap-align: start;
    flex: 0 0 85%; /* Mobile: show 1 full card and peek of next */
    min-height: 480px;
    transition: transform 0.3s ease;
  }

  /* Desktop Horizontal Scroll Grid */
  @media screen and (min-width: 768px) {
    .curated-collections__grid {
      display: flex;
      flex-wrap: nowrap;
      overflow-x: auto;
      margin-top: 30px;
    }
    .curated-collections__card {
      /* Show ~2.5 cards */
      flex: 0 0 calc(40% - 16px);
      min-height: 560px;
    }
    .curated-collections__card:hover {
      transform: translateY(-4px);
    }
  }

  @media screen and (min-width: 1200px) {
    .curated-collections {
      display: grid;
      grid-template-rows: auto minmax(0, 1fr) auto;
      width: 100%;
      max-width: none;
      min-height: 100svh;
      height: 100svh;
      padding: clamp(36px, 4.8svh, 48px) clamp(44px, 2.7vw, 48px) clamp(32px, 4svh, 40px);
      overflow: hidden;
    }

    .curated-collections__header {
      margin-bottom: clamp(34px, 5svh, 48px);
    }

    .curated-collections__icon {
      margin-bottom: clamp(12px, 1.7svh, 16px);
    }

    .curated-collections__icon svg {
      width: 36px;
      height: 36px;
      opacity: 0.55;
    }

    .curated-collections__heading {
      font-size: clamp(56px, 4.4vw, 74px);
      font-weight: 300;
      line-height: 0.98;
      letter-spacing: -0.052em;
      margin-bottom: clamp(18px, 2.5svh, 24px);
    }

    .curated-collections__subtitle {
      max-width: 520px;
      font-size: clamp(16px, 1.02vw, 18px);
      line-height: 1.55;
    }

    .curated-collections__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.98fr) repeat(3, minmax(0, 0.96fr));
      gap: clamp(16px, 1.05vw, 18px);
      min-height: 0;
      margin-top: 0;
      padding-bottom: 0;
      overflow: visible;
    }

    .curated-collections__grid .curated-collections__card:first-child,
    .curated-collections__grid .curated-collections__card:last-child {
      margin-left: 0;
      margin-right: 0;
    }

    .curated-collections__card {
      flex: none;
      min-height: 0;
      height: 100%;
      border-radius: var(--radius-lg, 8px);
      transform: translateY(0);
    }

    .curated-collections__card:hover {
      transform: translateY(-4px);
    }

    .curated-collections__card-overlay {
      background: linear-gradient(
        to top,
        rgba(26, 24, 21, 0.74) 0%,
        rgba(26, 24, 21, 0.38) 28%,
        rgba(26, 24, 21, 0.04) 62%
      );
    }

    .curated-collections__card-content {
      padding: clamp(24px, 1.8vw, 32px);
      gap: var(--sp-4, 16px);
    }

    .curated-collections__card-title {
      font-size: clamp(25px, 1.62vw, 30px);
      font-weight: 300;
      letter-spacing: -0.04em;
      line-height: 1.08;
    }

    .curated-collections__card-subtitle {
      font-size: clamp(15px, 0.95vw, 17px);
      line-height: 1.55;
      color: rgba(245, 241, 237, 0.92);
    }

    .curated-collections__card-arrow {
      width: 46px;
      height: 46px;
      border-color: rgba(245, 241, 237, 0.72);
    }

    .curated-collections__footer {
      width: min(100%, 560px);
      max-width: none;
      margin-top: clamp(42px, 6.2svh, 64px);
      padding: 0;
    }

    .curated-collections__divider {
      align-items: center;
      gap: 24px;
      border-top: 0;
    }

    .curated-collections__divider::before,
    .curated-collections__divider::after {
      flex: 1;
      height: 1px;
      background: rgba(107, 93, 82, 0.32);
      content: '';
    }

    .curated-collections__footer-text {
      top: 0;
      padding: 0;
      font-size: 16px;
      line-height: 1.4;
      white-space: nowrap;
    }
  }

  @media screen and (min-width: 1200px) and (max-height: 820px) {
    .curated-collections {
      padding-top: 30px;
      padding-bottom: 28px;
    }

    .curated-collections__header {
      margin-bottom: 28px;
    }

    .curated-collections__icon {
      margin-bottom: 8px;
    }

    .curated-collections__icon svg {
      width: 28px;
      height: 28px;
    }

    .curated-collections__heading {
      font-size: clamp(46px, 3.8vw, 58px);
      margin-bottom: 12px;
    }

    .curated-collections__subtitle {
      font-size: 15px;
      line-height: 1.45;
    }

    .curated-collections__card-content {
      padding: 22px;
    }

    .curated-collections__card-title {
      font-size: clamp(23px, 1.7vw, 28px);
    }

    .curated-collections__card-subtitle {
      font-size: 14px;
      line-height: 1.45;
    }

    .curated-collections__card-arrow {
      width: 40px;
      height: 40px;
    }

    .curated-collections__footer {
      margin-top: 26px;
    }
  }

  .curated-collections__card-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .curated-collections__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
    -webkit-user-drag: none;
  }

  .curated-collections__card:hover .curated-collections__img {
    transform: scale(1.03);
  }

  .curated-collections__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26, 24, 21, 0.85) 0%, rgba(26, 24, 21, 0.4) 30%, rgba(26, 24, 21, 0) 60%);
    z-index: 1;
  }

  .curated-collections__card-content {
    position: relative;
    z-index: 2;
    padding: var(--sp-6, 24px);
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    color: var(--text-inverse, #f5f1ed);
  }

  .curated-collections__card-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-right: var(--sp-4, 16px);
  }

  .curated-collections__card-title {
    font-family: var(--font-display);
    font-size: var(--font-size-display-sm, 24px);
    font-weight: var(--font-weight-regular, 400);
    margin: 0;
    line-height: var(--line-height-tight, 1.2);
    color: var(--text-inverse, #f5f1ed);
  }

  .curated-collections__card-subtitle {
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm, 14px);
    margin: 0;
    color: rgba(245, 241, 237, 0.85);
  }

  .curated-collections__card-arrow {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(245, 241, 237, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background-color 0.3s ease, border-color 0.3s ease;
  }

  .curated-collections__card:hover .curated-collections__card-arrow {
    background-color: rgba(245, 241, 237, 0.15);
    border-color: rgba(245, 241, 237, 0.8);
  }

  /* Footer Divider */
  .curated-collections__footer {
    margin-top: 28px;
    padding: 0 var(--sp-4, 16px);
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .curated-collections__divider {
    position: relative;
    text-align: center;
    border-top: 1px solid rgba(107, 93, 82, 0.2);
    display: flex;
    justify-content: center;
  }

  .curated-collections__footer-text {
    position: relative;
    top: -10px;
    background-color: var(--bg-primary, #f5f1ed);
    padding: 0 var(--sp-4, 16px);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm, 13px);
    color: var(--text-secondary, #6b5d52);
  }
  .curated-collections__grid.is-dragging {
    cursor: grabbing;
  }
  .curated-collections__grid.is-dragging .curated-collections__card {
    pointer-events: none;
    user-select: none;
  }
{% endstylesheet %}

{% javascript %}
  document.addEventListener('DOMContentLoaded', () => {
    const sliders = document.querySelectorAll('.curated-collections__grid');
    sliders.forEach((slider) => {
      let isDown = false;
      let startX;
      let scrollLeft;

      slider.addEventListener('mousedown', (e) => {
        isDown = true;
        slider.classList.add('is-dragging');
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
      });

      slider.addEventListener('mouseleave', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
      });

      slider.addEventListener('mouseup', () => {
        isDown = false;
        slider.classList.remove('is-dragging');
      });

      slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        const x = e.pageX - slider.offsetLeft;
        const walk = (x - startX) * 2;
        slider.scrollLeft = scrollLeft - walk;
      });

      let isDragging = false;
      slider.addEventListener('mousemove', (e) => {
        if (isDown) isDragging = true;
      });
      slider.addEventListener('mousedown', () => {
        isDragging = false;
      });
      slider.addEventListener('click', (e) => {
        if (isDragging) {
          e.preventDefault();
        }
      });
    });
  });
{% endjavascript %}

{% schema %}
{
  "name": "Curated Collections",
  "tag": "section",
  "class": "section section-curated-collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated Collections"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Timeless designs, thoughtfully crafted from solid wood\nfor spaces that inspire and endure."
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Title"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Collection description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Curated Collections",
      "blocks": [
        {
          "type": "collection_card",
          "settings": {
            "title": "Raw & Rooted",
            "subtitle": "Solid wood. Untamed beauty."
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Sculpted Storage",
            "subtitle": "Form meets function."
          }
        },
        {
          "type": "collection_card",
          "settings": {
            "title": "Statement Shelving",
