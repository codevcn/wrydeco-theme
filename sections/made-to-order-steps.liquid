<section class="mto" aria-labelledby="MadeToOrderHeading-{{ section.id }}">
  <div class="mto__inner">
    <header class="mto__intro">
      {%- if section.settings.eyebrow != blank -%}
        <p class="mto__eyebrow">{{ section.settings.eyebrow | escape }}</p>
      {%- endif -%}
      <h2 class="mto__heading" id="MadeToOrderHeading-{{ section.id }}">
        {{ section.settings.heading | escape }}
      </h2>
      {%- if section.settings.subtext != blank -%}
        <p class="mto__subtext">{{ section.settings.subtext | newline_to_br }}</p>
      {%- endif -%}
    </header>

    <ol class="mto__steps" aria-label="{{ section.settings.heading | escape }}">
      {%- for block in section.blocks limit: 5 -%}
        <li class="mto__step" {{ block.shopify_attributes }}>
          <div class="mto__step-head">
          <div class="mto__icon-wrap" aria-hidden="true">
            <span class="mto__step-icon">
              {%- case forloop.index -%}
                {%- when 1 -%}
                  <svg viewBox="0 0 48 48" fill="none">
                    <path d="M15.4 31.8 12 36.2l7-2.1c1.5.7 3.2 1.1 5 1.1 7 0 12.6-5 12.6-11.2S31 12.8 24 12.8 11.4 17.8 11.4 24c0 3 1.5 5.8 4 7.8Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                  </svg>
                {%- when 2 -%}
                  <svg viewBox="0 0 48 48" fill="none">
                    <circle cx="24" cy="24" r="5.2" stroke="currentColor" stroke-width="2"/>
                    <circle cx="24" cy="24" r="10.5" stroke="currentColor" stroke-width="1.8" stroke-dasharray="5 4"/>
                    <path d="M24 7.8v4.4M24 35.8v4.4M7.8 24h4.4M35.8 24h4.4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                {%- when 3 -%}
                  <svg viewBox="0 0 48 48" fill="none">
                    <rect x="14" y="18" width="20" height="10" rx="1.2" stroke="currentColor" stroke-width="2"/>
                    <path d="M18 18v5M22 18v4M26 18v5M30 18v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  </svg>
                {%- when 4 -%}
                  <svg viewBox="0 0 48 48" fill="none">
                    <path d="M18 25.5V18a2.4 2.4 0 0 1 4.8 0v6.3M22.8 24.3V15.8a2.4 2.4 0 0 1 4.8 0v8.5M27.6 24.4v-6.9a2.4 2.4 0 0 1 4.8 0v10.8c0 6.4-4.2 10.4-10.1 10.4h-.9c-3.1 0-5.6-1.2-7.7-3.5l-4.2-4.7a2.7 2.7 0 0 1 3.9-3.7l3.7 3.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 48 48" fill="none">
                    <path d="M11 17h19v13H11V17ZM30 21h5.6l4.4 4.5V30H30v-9Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
                    <circle cx="17" cy="33" r="2.5" stroke="currentColor" stroke-width="2"/>
                    <circle cx="34" cy="33" r="2.5" stroke="currentColor" stroke-width="2"/>
                  </svg>
              {%- endcase -%}
            </span>
          </div>
          <span class="mto__step-num" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
          </div>
          <h3 class="mto__step-title">{{ block.settings.title | escape }}</h3>
          <p class="mto__step-text">{{ block.settings.text | escape }}</p>
        </li>
      {%- endfor -%}
    </ol>

    <div class="mto__footer">
      {%- if section.settings.note != blank -%}
        <aside class="mto__note" aria-label="Process approval note">
          <span class="mto__note-icon" aria-hidden="true">
            <svg viewBox="0 0 28 28" fill="none">
              <path d="M14 25c6-2.4 9.4-6.7 9.4-12.5V6.3L14 3 4.6 6.3v6.2C4.6 18.3 8 22.6 14 25Z" stroke="currentColor" stroke-width="1.25" stroke-linejoin="round"/>
              <path d="m10.4 14.1 2.4 2.4 5-5.1" stroke="currentColor" stroke-width="1.35" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <p>{{ section.settings.note | escape }}</p>
        </aside>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a class="mto__btn" href="{{ section.settings.button_link | default: routes.root_url }}">
          <span>{{ section.settings.button_label | escape }}</span>
          <svg aria-hidden="true" viewBox="0 0 24 24" fill="none">
            <path d="M5 12h14m-6-6 6 6-6 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .mto {
    width: 100%;
    padding: var(--section-padding-y, 80px) 24px;
    background:
      radial-gradient(circle at 82% 0%, rgba(255, 255, 255, 0.72), transparent 38%),
      linear-gradient(180deg, #f6f1ea 0%, #f3ece3 100%);
    color: var(--color-text, #2f2118);
    overflow: hidden;
  }

  .mto__inner {
    width: min(100%, calc(var(--page-max-width, 1440px) - var(--container-padding-x, 48px) * 2));
    margin-inline: auto;
  }

  .mto__intro {
    display: block;
    max-width: 900px;
    margin: 0 0 clamp(32px, 3.5vw, 48px);
  }

  .mto__eyebrow {
    margin: 0 0 14px;
    font-family: var(--font-body);
    font-size: var(--eyebrow-size, 12px);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--eyebrow-tracking, 0.3em);
    text-transform: uppercase;
    color: var(--color-brown);
  }

  .mto__heading {
    margin: 0 0 18px;
    font-family: var(--font-heading);
    font-size: var(--section-heading-size, 48px);
    font-weight: var(--font-weight-light);
    line-height: var(--section-heading-line, 1.02);
    letter-spacing: var(--section-heading-tracking, -0.02em);
    color: var(--color-text, #2d1c13);
    text-wrap: balance;
  }

  .mto__subtext {
    max-width: 560px;
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--section-subtitle-size, 16px);
    line-height: 1.6;
    color: var(--color-muted, #3e3732);
    text-wrap: pretty;
  }

  .mto__steps {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(190px, 70vw);
    gap: 18px;
    margin: 0;
    padding: 0 0 12px;
    overflow-x: auto;
    list-style: none;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
  }

  .mto__steps::-webkit-scrollbar {
    display: none;
  }

  .mto__step {
    position: relative;
    display: flex;
    flex-direction: column;
    min-width: 0;
    margin: 0;
    text-align: left;
    scroll-snap-align: start;
    padding-left: clamp(14px, 1.3vw, 22px);
    border-left: 1px solid var(--color-border, rgba(74, 44, 24, 0.16));
  }

  .mto__step-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 18px;
  }

  .mto__icon-wrap {
    display: grid;
    place-items: center;
    width: 52px;
    height: 52px;
    border: 1px solid rgba(91, 60, 39, 0.4);
    border-radius: 999px;
    background: rgba(255, 252, 248, 0.55);
    color: #6b4a33;
    transition: background-color var(--timing-short) var(--ease-standard),
      border-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard);
  }

  .mto__step:hover .mto__icon-wrap {
    border-color: var(--color-brown, #4a2c18);
    background: #fffcf8;
    color: var(--color-brown, #4a2c18);
  }

  .mto__step-icon {
    display: grid;
    place-items: center;
    width: 26px;
    height: 26px;
  }

  .mto__step-icon svg {
    width: 26px;
    height: 26px;
  }

  .mto__step-num {
    display: block;
    font-family: var(--font-heading);
    font-size: clamp(34px, 2.6vw, 44px);
    font-weight: var(--font-weight-light, 300);
    line-height: 1;
    color: rgba(74, 44, 24, 0.28);
    font-variant-numeric: tabular-nums;
  }

  .mto__step-title {
    max-width: 230px;
    margin: 0 0 10px;
    font-family: var(--font-display);
    font-size: clamp(18px, 1.35vw, 21px);
    font-weight: var(--font-weight-regular);
    line-height: 1.12;
    letter-spacing: 0;
    color: var(--color-text, #2d1c13);
    text-wrap: balance;
  }

  .mto__step-text {
    max-width: 230px;
    margin: 0;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-muted, #3f3934);
    text-wrap: pretty;
  }

  .mto__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    flex-wrap: wrap;
    margin-top: clamp(32px, 3.5vw, 48px);
    padding-top: clamp(22px, 2.2vw, 30px);
    border-top: 1px solid var(--color-border, rgba(74, 44, 24, 0.16));
  }

  .mto__note {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    align-items: center;
    gap: 14px;
    flex: 1 1 380px;
    margin: 0;
  }

  .mto__note-icon {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(91, 60, 39, 0.24);
    border-radius: 999px;
    color: #5c3d29;
    background: rgba(255, 252, 248, 0.64);
  }

  .mto__note-icon svg {
    width: 21px;
    height: 21px;
  }

  .mto__note p {
    margin: 0;
    max-width: 52ch;
    font-family: var(--font-body);
    font-size: 13px;
    line-height: 1.5;
    color: var(--color-muted, #332a24);
  }

  .mto__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    min-width: min(100%, 260px);
    min-height: var(--btn-height, 52px);
    padding: 0 var(--btn-padding-x, 32px);
    border-radius: var(--btn-radius, 4px);
    background: var(--color-brown, #4a2c18);
    color: #fff8f0;
    font-family: var(--font-body);
    font-size: var(--btn-font-size, 14px);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    box-shadow: 0 14px 30px rgba(59, 31, 15, 0.12);
    transition:
      transform var(--timing-short) var(--ease-standard),
      background-color var(--timing-short) var(--ease-standard),
      box-shadow var(--timing-short) var(--ease-standard);
  }

  .mto__btn svg {
    width: 16px;
    height: 16px;
    transition: transform var(--timing-short) var(--ease-standard);
  }

  .mto__btn:focus-visible {
    outline: 3px solid rgba(122, 137, 104, 0.38);
    outline-offset: 4px;
  }

  @media (hover: hover) {
    .mto__btn:hover {
      color: #fff8f0;
      background: var(--color-brown-dark, #2f1a0d);
      transform: translateY(-2px);
      box-shadow: 0 18px 34px rgba(59, 31, 15, 0.18);
    }

    .mto__btn:hover svg {
      transform: translateX(4px);
    }
  }

  @media screen and (min-width: 48rem) {
    .mto {
      padding-inline: 40px;
    }

    .mto__steps {
      grid-auto-columns: minmax(196px, 32vw);
      gap: 22px;
    }
  }

  @media screen and (min-width: 75rem) {
    .mto {
      padding-inline: var(--container-padding-x, 64px);
    }

    .mto__heading {
      white-space: nowrap;
    }

    .mto__steps {
      grid-auto-flow: initial;
      grid-auto-columns: initial;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      gap: clamp(20px, 2vw, 32px);
      overflow: visible;
      padding-bottom: 0;
    }
  }

  @media screen and (max-width: 40rem) {
    .mto {
      padding-inline: 18px;
    }

    .mto__intro {
      display: block;
      margin-bottom: 32px;
    }

    .mto__eyebrow {
      margin: 0 0 14px;
    }

    .mto__subtext {
      max-width: none;
    }

    .mto__step {
      padding-left: 16px;
    }

    .mto__btn {
      width: 100%;
      min-width: 0;
      min-height: 56px;
      font-size: 14px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .mto__btn,
    .mto__btn svg {
      transition-duration: 0s;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Made-to-Order Steps",
  "tag": "section",
  "class": "section section-mto",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our process" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "How Custom Orders Work" },
    { "type": "textarea", "id": "subtext", "label": "Subtext", "default": "A thoughtful, collaborative experience--designed around your space,\nyour style, and the way you live." },
    { "type": "text", "id": "button_label", "label": "Button label", "default": "Start Your Custom Request" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "textarea", "id": "note", "label": "Note bar", "default": "No piece enters production until you approve the final design, dimensions, materials, and finish." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "consult", "label": "Choose / consult" },
            { "value": "ruler", "label": "Finish & size" },
            { "value": "artisan", "label": "Handcraft" },
            { "value": "truck", "label": "Delivery" },
            { "value": "wood", "label": "Wood" }
          ],
          "default": "consult"
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Step title" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Step description." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Made-to-Order Steps",
      "blocks": [
        { "type": "step", "settings": { "icon": "consult", "title": "Share Your Space", "text": "Send us your inspiration, measurements, and photos of your space." } },
        { "type": "step", "settings": { "icon": "wood", "title": "Choose Materials & Details", "text": "Select your wood, finish, dimensions, and the details that matter most." } },
        { "type": "step", "settings": { "icon": "ruler", "title": "Receive Design & Quote", "text": "We'll create a custom design tailored to your space and provide a clear quote." } },
        { "type": "step", "settings": { "icon": "artisan", "title": "Approve & Craft", "text": "Once approved, our artisans handcraft your piece with care and precision." } },
        { "type": "step", "settings": { "icon": "truck", "title": "Deliver & Enjoy", "text": "We deliver and install with care, so you can enjoy your piece for years to come." } }
      ]
    }
  ]
}
{% endschema %}
