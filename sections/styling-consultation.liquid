{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: var(--sp-12, 64px);
    padding-bottom: var(--sp-12, 64px);
  }

  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: calc(var(--sp-12, 64px) * 1.5);
      padding-bottom: calc(var(--sp-12, 64px) * 1.5);
      padding-left: 140px;
      padding-right: 140px;
    }
  }

  .styling-consultation {
    display: flex;
    justify-content: center;
    position: relative;
    color: var(--text-primary, #1a1815);
    background-color: #f1eae2; /* Fallback color */
    background-size: cover;
    background-position: left bottom;
    background-repeat: no-repeat;
  }

  {% if section.settings.bg_image != blank %}
  .styling-consultation {
    background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
  }
  {% else %}
  /* Fallback preset image */
  .styling-consultation {
    background-image: url('{{ 'private-styling-consultation.png' | asset_url }}');
  }
  {% endif %}

  /* Optional overlay for text readability */
  .styling-consultation::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(255, 255, 255, 0.09);
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(1px);
    pointer-events: none;
  }

  .styling-consultation__inner {
    height: 559px;
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--sp-10, 48px);
  }

  @media screen and (min-width: 900px) {
    .styling-consultation__inner {
      flex-direction: row;
      align-items: stretch;
      justify-content: space-between;
      gap: 3vw;
    }
  }

  @media screen and (min-width: 100rem) {
    .styling-consultation__inner {
      justify-content: center;
    }
  }

  /* Left Column */
  .styling-consultation__left {
    flex: 1;
    max-width: 500px;
  }

  .styling__eyebrow {
    font-family: var(--font-body);
    font-size: 11px;
    letter-spacing: 0.15em;
    font-weight: 600;
    margin-bottom: 12px;
    text-transform: uppercase;
    color: var(--text-secondary, #6b5d52);
    display: block;
  }

  .styling__heading {
    font-family: var(--font-display);
    font-size: clamp(36px, 4vw, 56px);
    font-weight: var(--font-weight-regular, 400);
    line-height: 1.1;
    margin: 0 0 14px 0;
    letter-spacing: -0.02em;
  }

  .styling__desc {
    font-family: var(--font-body);
    font-size: 15px;
    line-height: 1.6;
    color: #221f1d;
    margin: 0 0 18px 0;
  }

  .styling__service-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 18px;
  }

  .styling__service-item {
    display: flex;
    align-items: center;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: var(--radius-sm, 6px);
    padding: 12px 16px;
    transition: background 0.3s ease;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }

  .styling__service-item:hover {
    background: rgba(255, 255, 255, 0.7);
  }

  .styling__service-icon {
    flex: 0 0 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid rgba(107, 93, 82, 0.2);
    margin-right: 16px;
  }

  .styling__service-icon svg {
    width: 24px;
    height: 24px;
    opacity: 0.8;
  }

  .styling__service-text {
    flex: 1;
  }

  .styling__service-title {
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 4px 0;
  }

  .styling__service-desc {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--text-secondary, #6b5d52);
    margin: 0;
    line-height: 1.4;
  }

  .styling__service-arrow {
    margin-left: 16px;
    opacity: 0.5;
  }

  .styling__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #554437;
    color: #fcf9f6;
    font-family: var(--font-body);
    font-size: 14px;
    padding: 14px 32px;
    border-radius: var(--radius-sm, 6px);
    text-decoration: none;
    transition: transform 0.3s ease;
    border: none;
    cursor: pointer;
    width: 100%;
  }

  @media screen and (min-width: 600px) {
    .styling__btn {
      width: auto;
    }
  }

  .styling__btn:hover {
    color: #f1eae2;
    transform: scale(1.05);
  }

  .styling__btn svg {
    margin-left: 12px;
    width: 16px;
    height: 16px;
  }

  /* Right Column (Advisor Card) */
  .styling-consultation__right {
    flex: 1;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  @media screen and (min-width: 100rem) {
    .styling-consultation__right {
      flex: none;
    }
  }

  .advisor-card {
    background-color: #6c533f;
    color: #f1eae2;
    border-radius: var(--radius-lg, 12px);
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
    height: 100%;
    aspect-ratio: 3 / 3.5;
  }

  .advisor-card__top {
    padding: 32px;
    display: flex;
    gap: var(--sp-6, 24px);
    flex-direction: column;
  }

  @media screen and (min-width: 500px) {
    .advisor-card__top {
      flex-direction: row;
    }
  }

  .advisor-card__img-wrapper {
    flex: 0 0 230px;
    height: fit-content;
    border-radius: 8px;
    overflow: hidden;
  }

  .advisor-card__img {
    width: 100%;
    aspect-ratio: 3 / 4;
    object-fit: cover;
    border-radius: var(--radius-sm, 6px);
    display: block;
  }

  .advisor-card__info {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .advisor-card__eyebrow {
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    opacity: 0.9;
    margin-bottom: 12px;
  }

  .advisor-card__name {
    font-family: var(--font-display);
    font-size: 28px;
    margin: 0 0 4px 0;
    font-weight: 400;
    color: inherit;
  }

  .advisor-card__title {
    font-size: 12px;
    opacity: 0.8;
    word-spacing: 0.1em;
    margin: 0 0 20px 0;
  }

  .advisor-card__quote-mark {
    font-family: var(--font-display);
    font-size: 60px;
    font-weight: 700;
    line-height: 0.5;
    opacity: 0.8;
    margin-bottom: 8px;
    transform: translateY(15px);
  }

  .advisor-card__quote {
    font-size: 14px;
    font-style: italic;
    font-family: var(--font-display);
    line-height: 1.5;
    opacity: 0.9;
    margin: 0;
  }

  .advisor-card__divider {
    height: 2.5px;
    background-color: rgba(242, 232, 220, 0.26);
    margin: 0 32px;
  }
  .advisor-card__divider.under-title {
    margin: 0 0 10px 0;
  }

  .advisor-card__stats {
    display: flex;
    padding: 24px 32px;
  }

  .advisor-card__stat-item {
    flex: 1;
    text-align: center;
    position: relative;
  }

  .advisor-card__stat-item:not(:last-child)::after {
    content: '';
    position: absolute;
    right: 0;
    top: 10%;
    height: 80%;
    width: 1px;
    background-color: rgba(241, 234, 226, 0.15);
  }

  .advisor-card__stat-num {
    font-family: var(--font-roboto);
    font-size: 24px;
    margin: 0 0 4px 0;
    color: #f1eae2;
    opacity: 0.8;
  }

  .advisor-card__stat-label {
    font-size: 10px;
    opacity: 0.7;
    margin: 0;
  }

  .advisor-card__bottom {
    background-color: #3b2f26; /* Darker brown */
    padding: 24px 32px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .advisor-card__bottom-icon {
    flex: 0 0 40px;
    height: 40px;
    opacity: 0.6;
  }

  .advisor-card__bottom-icon svg {
    width: 100%;
    height: 100%;
  }

  .advisor-card__bottom-text h4 {
    font-size: 12px;
    letter-spacing: 0.15em;
    margin: 0 0 4px 0;
    font-weight: 600;
    color: #f1eae2;
    opacity: 0.8;
  }

  .advisor-card__bottom-text p {
    font-size: 14px;
    opacity: 0.8;
    margin: 0;
    line-height: 1.4;
    color: #f1eae2;
  }
{%- endstyle -%}

<div class="styling-consultation section-{{ section.id }}-padding">
  <div class="styling-consultation__inner page-width">
    <!-- Left Column -->
    <div class="styling-consultation__left">
      <span class="styling__eyebrow">{{ section.settings.eyebrow }}</span>
      <h2 class="styling__heading">{{ section.settings.heading | newline_to_br }}</h2>
      <p class="styling__desc">{{ section.settings.description }}</p>

      <div class="styling__service-list">
        {%- for block in section.blocks -%}
          <a href="#" class="styling__service-item" {{ block.shopify_attributes }}>
            <div class="styling__service-icon">
              {%- if block.settings.icon == 'blueprint' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <path d="M4 4h16v16H4z M4 9h16 M9 4v16"/>
                  <circle cx="14" cy="14" r="1.5" fill="currentColor"/>
                </svg>
              {%- elsif block.settings.icon == 'video' -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
                  <rect x="2" y="6" width="14" height="12" rx="2"/>
                  <path d="M22 8l-6 4 6 4V8z"/>
                </svg>
              {%- else -%}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                  <circle cx="12" cy="12" r="9" stroke-dasharray="2 2"/>
                  <circle cx="12" cy="12" r="5"/>
                  <circle cx="12" cy="12" r="1.5" fill="currentColor"/>
                </svg>
              {%- endif -%}
            </div>
            <div class="styling__service-text">
              <h3 class="styling__service-title">{{ block.settings.title }}</h3>
              <p class="styling__service-desc">{{ block.settings.description }}</p>
            </div>
            <div class="styling__service-arrow">
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        {%- endfor -%}
      </div>

      <a href="{{ section.settings.button_link | default: '#' }}" class="styling__btn">
        {{ section.settings.button_label }}
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M5 12h14M12 5l7 7-7 7"/>
        </svg>
      </a>
    </div>

    <!-- Right Column -->
    <div class="styling-consultation__right">
      <div class="advisor-card">
        <div class="advisor-card__top">
          <div class="advisor-card__img-wrapper">
            {%- if section.settings.advisor_image != blank -%}
              {{
                section.settings.advisor_image
                | image_url: width: 400
                | image_tag: class: 'advisor-card__img', loading: 'lazy'
              }}
            {%- else -%}
              <img
                src="{{ 'design-advisor.png' | asset_url }}"
                alt="Mr. Nguyen"
                class="advisor-card__img"
                loading="lazy"
              >
            {%- endif -%}
          </div>
          <div class="advisor-card__info">
            <span class="advisor-card__eyebrow">{{ section.settings.advisor_eyebrow }}</span>
            <h3 class="advisor-card__name">{{ section.settings.advisor_name }}</h3>
            <p class="advisor-card__title">{{ section.settings.advisor_title }}</p>
            <span class="advisor-card__divider under-title"></span>
            <div class="advisor-card__quote-mark">“</div>
            <p class="advisor-card__quote">{{ section.settings.advisor_quote }}</p>
          </div>
        </div>

        <div class="advisor-card__divider"></div>

        <div class="advisor-card__stats">
          <div class="advisor-card__stat-item">
            <h4 class="advisor-card__stat-num">{{ section.settings.stat_1_num }}</h4>
            <p class="advisor-card__stat-label">{{ section.settings.stat_1_label }}</p>
          </div>
          <div class="advisor-card__stat-item">
            <h4 class="advisor-card__stat-num">{{ section.settings.stat_2_num }}</h4>
            <p class="advisor-card__stat-label">{{ section.settings.stat_2_label }}</p>
          </div>
          <div class="advisor-card__stat-item">
            <h4 class="advisor-card__stat-num">{{ section.settings.stat_3_num }}</h4>
            <p class="advisor-card__stat-label">{{ section.settings.stat_3_label }}</p>
          </div>
        </div>

        <div class="advisor-card__bottom">
          <div class="advisor-card__bottom-icon">
            <svg viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M20 5C12 5 5 12 5 20s7 15 15 15 15-7 15-15" stroke-dasharray="2 4"/>
              <path d="M20 10c-6 0-10 4-10 10s4 10 10 10 10-4 10-10" stroke-dasharray="4 4"/>
              <circle cx="20" cy="20" r="5"/>
              <circle cx="20" cy="20" r="2" fill="currentColor"/>
            </svg>
          </div>
          <div class="advisor-card__bottom-text">
            <h4>{{ section.settings.footer_heading }}</h4>
            <p>{{ section.settings.footer_text }}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Styling Consultation",
  "tag": "section",
  "class": "section section-styling-consultation",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "GUIDANCE FOR YOUR SPACE"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Private Styling\nConsultation"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Choosing a sculptural wooden piece is a personal journey. Our design experts help you find the perfect piece that complements your space, style, and story."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Book a Private Consultation"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Advisor Card"
    },
    {
      "type": "image_picker",
      "id": "advisor_image",
      "label": "Advisor Image"
    },
    {
      "type": "text",
      "id": "advisor_eyebrow",
      "label": "Advisor Eyebrow",
      "default": "YOUR DESIGN ADVISOR"
    },
    {
      "type": "text",
      "id": "advisor_name",
      "label": "Advisor Name",
      "default": "Mr. Nguyen"
    },
    {
      "type": "text",
      "id": "advisor_title",
      "label": "Advisor Title",
      "default": "Lead Design Consultant"
    },
    {
      "type": "textarea",
      "id": "advisor_quote",
      "label": "Advisor Quote",
      "default": "Every piece we create carries nature's story. My role is to help you find the one that belongs in your space."
    },
    {
      "type": "text",
      "id": "stat_1_num",
      "label": "Stat 1 Number",
      "default": "12+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "Years of Experience"
    },
    {
      "type": "text",
      "id": "stat_2_num",
      "label": "Stat 2 Number",
      "default": "500+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Homes Styled"
    },
    {
      "type": "text",
      "id": "stat_3_num",
      "label": "Stat 3 Number",
      "default": "98%"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Client Satisfaction"
    },
    {
      "type": "text",
      "id": "footer_heading",
      "label": "Card Footer Heading",
      "default": "BESPOKE. PERSONAL. EXCEPTIONAL."
    },
    {
      "type": "text",
      "id": "footer_text",
      "label": "Card Footer Text",
      "default": "Discreet service. Thoughtful guidance. Timeless results."
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "limit": 3,
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "blueprint", "label": "Blueprint/Room" },
            { "value": "video", "label": "Video Camera" },
            { "value": "wood", "label": "Wood Rings" }
          ],
          "default": "blueprint"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service Title"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Service description goes here."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Private Styling Consultation",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "icon": "blueprint",
            "title": "Share Your Space",
            "description": "Send us photos and measurements of your space. We'll provide tailored piece recommendations."
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "video",
            "title": "Schedule a Video Consultation",
            "description": "Discuss your vision with our design expert in a personalized 1:1 session."
          }
        },
        {
          "type": "service",
          "settings": {
            "icon": "wood",
            "title": "Trade & Design Support",
            "description": "For interior designers, architects, and trade professionals. Get dedicated support."
          }
        }
      ]
    }
  ]
}
{% endschema %}
