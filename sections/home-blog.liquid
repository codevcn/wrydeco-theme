{%- liquid
  assign home_blog = section.settings.blog
  if home_blog == blank
    assign home_blog = blogs.news
  endif
-%}

{%- if home_blog != blank and home_blog.articles.size > 0 -%}
  <section
    class="home-journal"
    id="HomeJournal-{{ section.id }}"
    aria-labelledby="HomeJournalTitle-{{ section.id }}"
  >
    <div class="home-journal__inner">
      <header class="home-journal__header">
        <p class="home-journal__eyebrow">
          <span class="home-journal__eyebrow-desktop">{{ section.settings.eyebrow | escape }}</span>
          <span class="home-journal__eyebrow-mobile">{{ section.settings.mobile_eyebrow | escape }}</span>
        </p>
        <span class="home-journal__header-rule" aria-hidden="true"></span>
        <h2 class="home-journal__heading" id="HomeJournalTitle-{{ section.id }}">
          {{ section.settings.heading | escape }}
        </h2>
        <p class="home-journal__intro home-journal__intro--desktop">
          {{ section.settings.intro | escape }}
        </p>
        <p class="home-journal__intro home-journal__intro--mobile">
          {{ section.settings.mobile_intro | escape | newline_to_br }}
        </p>
      </header>

      <div class="home-journal__list" role="list">
        {%- for article in home_blog.articles limit: 4 -%}
          {%- liquid
            assign article_excerpt = article.excerpt | strip_html | strip
            if article_excerpt == blank
              assign article_excerpt = article.content | strip_html | strip
            endif
            assign article_excerpt = article_excerpt | truncatewords: 22
            assign article_image_alt = article.image.alt | default: article.title
            assign article_label = article.tags | first
            if article_label == blank
              assign article_label = section.settings.fallback_label
            endif
          -%}

          <article class="home-journal__card" role="listitem">
            <a
              class="home-journal__media"
              href="{{ article.url }}"
              aria-label="{{ article.title | escape }}"
            >
              {%- if article.image -%}
                {{
                  article.image
                  | image_url: width: 1200
                  | image_tag:
                    class: 'home-journal__image',
                    loading: 'lazy',
                    widths: '320, 480, 640, 800, 1000, 1200',
                    sizes: '(max-width: 767px) 44vw, 565px',
                    alt: article_image_alt
                }}
              {%- else -%}
                <span class="home-journal__placeholder" aria-hidden="true"></span>
              {%- endif -%}
            </a>

            <div class="home-journal__content">
              <p class="home-journal__article-label">{{ article_label | escape }}</p>
              <h3 class="home-journal__article-title">
                <a href="{{ article.url }}">{{ article.title | escape }}</a>
              </h3>
              {%- if article_excerpt != blank -%}
                <p class="home-journal__excerpt">{{ article_excerpt | escape }}</p>
              {%- endif -%}
              <a class="home-journal__article-link" href="{{ article.url }}">
                <span>{{ section.settings.article_link_label | escape }}</span>
                <span class="home-journal__arrow" aria-hidden="true">
                  <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 1024 1024">
                    <path d="M0 0h1024v1024H0z" fill="none" />
                    <path fill="currentColor" d="M754.8 480H160a32 32 0 1 0 0 64h594.8L521.3 777.3a32 32 0 0 0 45.4 45.4l288-288a32 32 0 0 0 0-45.4l-288-288a32 32 0 1 0-45.4 45.4z" />
                  </svg>
                </span>
              </a>
            </div>
          </article>
        {%- endfor -%}
      </div>

      <a class="home-journal__view-all styling__btn" href="{{ home_blog.url }}">
        {{ section.settings.view_all_label | escape }}
        <svg
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M5 12h14M12 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
  .home-journal {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    background: radial-gradient(circle at 50% 16%, rgba(255, 255, 255, 0.72), transparent 43%), #f8f4ef;
    color: var(--color-text, #2b1a11);
    font-family: var(--font-body);
  }

  .home-journal::before,
  .home-journal::after {
    position: absolute;
    z-index: -1;
    width: clamp(180px, 15vw, 250px);
    height: clamp(230px, 20vw, 330px);
    border-radius: 44% 56% 58% 42%;
    background: repeating-radial-gradient(
      ellipse at center,
      transparent 0,
      transparent 14px,
      color-mix(in srgb, var(--color-clay) 18%, transparent) 14px,
      color-mix(in srgb, var(--color-clay) 18%, transparent) 17px
    );
    content: '';
    opacity: 0.72;
    pointer-events: none;
  }

  .home-journal::before {
    top: 19%;
    left: clamp(-120px, -7vw, -72px);
    transform: rotate(-14deg);
  }

  .home-journal::after {
    right: clamp(-126px, -7.5vw, -76px);
    bottom: 16%;
    border-radius: 57% 43% 39% 61%;
    transform: rotate(17deg);
  }

  .home-journal__inner {
    position: relative;
    z-index: 1;
    width: min(100%, 1230px);
    margin-inline: auto;
    padding: 60px 50px 60px;
    display: flex;
    flex-direction: column;
  }

  .home-journal__header {
    display: flex;
    align-items: center;
    flex-direction: column;
    margin: 0 auto clamp(30px, 3vw, 38px);
    text-align: center;
  }

  .home-journal__eyebrow,
  .home-journal__article-label {
    margin: 0;
    color: var(--color-brown, #4a2c18);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.28em;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .home-journal__eyebrow-mobile {
    display: none;
  }

  .home-journal__header-rule {
    width: 25px;
    height: 1px;
    margin: 13px 0 14px;
    background: color-mix(in srgb, var(--color-brown, #4a2c18) 82%, transparent);
  }

  .home-journal__heading {
    margin: 0;
    color: var(--color-text, #2b1a11);
    font-family: var(--font-display-light, var(--font-display));
    font-size: clamp(42px, 3.5vw, 58px);
    font-weight: 300;
    letter-spacing: -0.035em;
    line-height: 1.06;
  }

  .home-journal__intro {
    margin: 14px 0 0;
    color: var(--text-secondary, #6b5d52);
    font-size: 16px;
    line-height: 1.6;
  }

  .home-journal__intro--mobile {
    display: none;
  }

  .home-journal__list {
    display: grid;
    gap: 12px;
  }

  .home-journal__card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    height: 280px;
    overflow: hidden;
    border: 1px solid rgba(92, 58, 35, 0.2);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.23);
  }

  .home-journal__media {
    display: block;
    min-width: 0;
    overflow: hidden;
    color: inherit;
    text-decoration: none;
  }

  .home-journal__image,
  .home-journal__placeholder {
    display: block;
    width: 100%;
    height: 100%;
    min-height: 0;
    object-fit: cover;
    transition: transform 500ms ease;
  }

  .home-journal__placeholder {
    background: linear-gradient(135deg, #ded3c6, #eee7df);
  }

  .home-journal__card:hover .home-journal__image {
    transform: scale(1.018);
  }

  .home-journal__content {
    display: flex;
    align-items: flex-start;
    flex-direction: column;
    min-width: 0;
    overflow: hidden;
    padding: 22px 36px 20px;
  }

  .home-journal__article-label {
    margin-bottom: 8px;
  }

  .home-journal__article-title {
    display: -webkit-box;
    overflow: hidden;
    margin: 0;
    font-family: var(--font-display-light, var(--font-display));
    font-size: clamp(27px, 2vw, 30px);
    font-weight: 300;
    letter-spacing: -0.03em;
    line-height: 1.1;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .home-journal__article-title a {
    color: inherit;
    text-decoration: none;
  }

  .home-journal__excerpt {
    display: -webkit-box;
    overflow: hidden;
    margin: 8px 0 10px;
    color: var(--text-secondary, #6b5d52);
    font-size: 14px;
    line-height: 1.45;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  .home-journal__article-link {
    display: inline-flex;
    align-items: center;
    gap: 22px;
    color: var(--color-text, #2b1a11);
    font-size: 15px;
    font-weight: 600;
    line-height: 1.2;
    text-decoration: none;
  }

  .home-journal__article-link {
    margin-top: auto;
  }
  .home-journal__article-link:hover {
    text-decoration: underline;
  }

  .home-journal__arrow {
    display: inline-block;
    font-size: 20px;
    font-weight: 400;
    line-height: 1;
    transition: transform 180ms ease;
  }

  .home-journal__article-link:hover,
  .home-journal__article-title a:hover {
    color: var(--color-brown, #4a2c18);
  }

  .home-journal__article-link:hover .home-journal__arrow {
    transform: translateX(4px);
  }

  .home-journal__view-all.styling__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: fit-content;
    min-height: var(--btn-height, 52px);
    margin-top: 28px;
    padding: 0 var(--btn-padding-x, 32px);
    border: none;
    border-radius: var(--btn-radius, 4px);
    background-color: var(--color-brown, #4a2c18);
    color: #fcf9f6;
    font-family: var(--font-body);
    font-size: var(--btn-font-size, 14px);
    font-weight: var(--font-weight-medium, 500);
    line-height: 1.2;
    text-decoration: none;
    cursor: pointer;
    transition: transform 0.3s ease, background-color 0.3s ease;
    margin-inline: auto;
  }

  .home-journal__view-all.styling__btn:hover {
    color: #f1eae2;
    background-color: var(--color-brown-dark, #2f1a0d);
    transform: translateY(-2px);
  }

  .home-journal__view-all.styling__btn svg {
    width: 16px;
    height: 16px;
    margin-left: 12px;
  }

  @media (prefers-reduced-motion: reduce) {
    .home-journal__image,
    .home-journal__arrow {
      transition: none;
    }
  }

  @media screen and (max-width: 767px) {
    .home-journal::before,
    .home-journal::after {
      width: 116px;
      height: 152px;
      background: repeating-radial-gradient(
        ellipse at center,
        transparent 0,
        transparent 9px,
        color-mix(in srgb, var(--color-clay) 15%, transparent) 9px,
        color-mix(in srgb, var(--color-clay) 15%, transparent) 11px
      );
      opacity: 0.58;
    }

    .home-journal::before {
      top: 8%;
      left: -82px;
    }

    .home-journal::after {
      right: -84px;
      bottom: 7%;
    }

    .home-journal__inner {
      width: 100%;
      padding: 51px 32px 56px;
    }

    .home-journal__header {
      align-items: flex-start;
      margin-bottom: 39px;
      text-align: left;
    }

    .home-journal__eyebrow {
      font-size: 10px;
      letter-spacing: 0.27em;
    }

    .home-journal__eyebrow-desktop,
    .home-journal__header-rule,
    .home-journal__intro--desktop {
      display: none;
    }

    .home-journal__eyebrow-mobile,
    .home-journal__intro--mobile {
      display: inline;
    }

    .home-journal__heading {
      margin-top: 10px;
      font-size: clamp(35px, 10.5vw, 46px);
      line-height: 1.08;
    }

    .home-journal__intro {
      margin-top: 15px;
      font-size: 15px;
      line-height: 1.6;
    }

    .home-journal__list {
      gap: 13px;
    }

    .home-journal__card {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.02fr);
      height: auto;
      min-height: 162px;
      border-radius: 10px;
    }

    .home-journal__image,
    .home-journal__placeholder {
      min-height: 162px;
    }

    .home-journal__content {
      overflow: visible;
      padding: 17px 16px 14px 20px;
    }

    .home-journal__article-label {
      margin-bottom: 8px;
      font-size: 8px;
      letter-spacing: 0.22em;
    }

    .home-journal__article-title {
      display: -webkit-box;
      overflow: hidden;
      font-size: clamp(18px, 5vw, 22px);
      line-height: 1.08;
      -webkit-box-orient: vertical;
      -webkit-line-clamp: 2;
      line-clamp: 2;
    }

    .home-journal__excerpt {
      margin: 10px 0 12px;
      font-size: 11px;
      line-height: 1.45;
      -webkit-line-clamp: 3;
      line-clamp: 3;
    }

    .home-journal__article-link {
      gap: 14px;
      font-size: 11px;
    }

    .home-journal__arrow {
      font-size: 16px;
    }

    .home-journal__view-all.styling__btn {
      justify-content: flex-start;
      min-height: auto;
      margin-top: 24px;
      padding: 0 0 8px;
      border-bottom: 1px solid rgba(43, 26, 17, 0.45);
      border-radius: 0;
      background: transparent;
      color: var(--color-text, #2b1a11);
      font-size: 14px;
    }

    .home-journal__view-all.styling__btn:hover {
      background: transparent;
      color: var(--color-brown, #4a2c18);
      transform: none;
    }
  }

  @media screen and (max-width: 420px) {
    .home-journal__inner {
      padding-inline: 20px;
    }

    .home-journal__card {
      grid-template-columns: minmax(0, 46%) minmax(0, 54%);
      min-height: 174px;
    }

    .home-journal__image,
    .home-journal__placeholder {
      min-height: 174px;
    }

    .home-journal__content {
      padding: 16px 13px 13px 15px;
    }

    .home-journal__article-title {
      font-size: 18px;
    }

    .home-journal__excerpt {
      font-size: 10.5px;
      -webkit-line-clamp: 3;
      line-clamp: 3;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Homepage blog",
  "tag": "section",
  "class": "section section-home-blog",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Blog"
    },
    {
      "type": "text",
      "id": "mobile_eyebrow",
      "label": "Eyebrow on mobile",
      "default": "WRYDECO Journal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Journal"
    },
    {
      "type": "text",
      "id": "intro",
      "label": "Intro",
      "default": "Insights on craftsmanship, design, and caring for the pieces you love."
    },
    {
      "type": "textarea",
      "id": "mobile_intro",
      "label": "Intro on mobile",
      "default": "Thoughts on craftsmanship, material beauty,\nand the art of living with wood."
    },
    {
      "type": "text",
      "id": "fallback_label",
      "label": "Article label when no tag exists",
      "default": "WRYDECO Journal"
    },
    {
      "type": "text",
      "id": "article_link_label",
      "label": "Article link label",
      "default": "Read Article"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "View all label",
      "default": "View All Journal"
    }
  ],
  "presets": [
    {
      "name": "Homepage blog"
    }
  ]
}
{% endschema %}
