<div class="shopping-nav">
  <div class="shopping-nav__banner">
    <div class="shopping-nav__banner-inner page-width">
      <div class="shopping-nav__cta">
        <h2 class="shopping-nav__heading">{{ section.settings.heading | escape }}</h2>
        <a href="{{ section.settings.link }}" class="shopping-nav__btn" aria-label="{{ section.settings.heading | escape }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-arrow-right"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
        </a>
      </div>
      
      {%- if section.settings.store_text != blank -%}
      <div class="shopping-nav__store">
        <span>{{ section.settings.store_text | escape }}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-chevron-up"><polyline points="18 15 12 9 6 15"></polyline></svg>
      </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.blocks.size > 0 -%}
  <div class="shopping-nav__pills-wrapper page-width">
    <div class="shopping-nav__pills">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link }}" class="shopping-nav__pill" {{ block.shopify_attributes }}>
          {{ block.settings.title | escape }}
        </a>
      {%- endfor -%}
    </div>
  </div>
  {%- endif -%}
</div>

{% stylesheet %}
  .shopping-nav {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  /* Banner Area */
  .shopping-nav__banner {
    background-color: var(--color-1, #36210A);
    color: var(--color-10, #FFF);
    padding-block: var(--space-8, 16px);
  }

  .shopping-nav__banner-inner {
    display: flex;
    flex-direction: column;
    padding-inline: var(--space-4, 10px);
  }

  .shopping-nav__cta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: var(--space-6, 12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .shopping-nav__heading {
    font-size: var(--text-lg, 35px);
    font-weight: var(--font-weight-700, 700);
    margin: 0;
    color: inherit;
  }

  .shopping-nav__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full, 50%);
    background-color: var(--color-10, #FFF);
    color: var(--color-1, #36210A);
    text-decoration: none;
    transition: transform var(--duration-fast, 0.15s) ease;
  }

  .shopping-nav__btn:hover {
    transform: translateX(4px);
  }

  .shopping-nav__btn svg {
    width: 24px;
    height: 24px;
  }

  .shopping-nav__store {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: var(--space-6, 12px);
    font-size: var(--text-base, 15px);
    font-weight: var(--font-weight-500, 500);
  }

  .shopping-nav__store svg {
    width: 20px;
    height: 20px;
  }

  /* Pills Area */
  .shopping-nav__pills-wrapper {
    padding-block: var(--space-6, 12px);
    padding-inline: var(--space-4, 10px);
    overflow: hidden;
  }

  .shopping-nav__pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3, 8px);
    justify-content: center;
  }

  .shopping-nav__pill {
    display: inline-flex;
    align-items: center;
    padding: var(--space-2, 6px) var(--space-5, 11px);
    background-color: var(--color-10, #FFF);
    color: var(--color-1, #36210A);
    border: 1px solid var(--color-8, #EFEFEF);
    border-radius: var(--radius-xl, 46px);
    font-size: var(--text-sm, 14px);
    font-weight: var(--font-weight-500, 500);
    text-decoration: none;
    white-space: nowrap;
    transition: background-color var(--duration-fast, 0.15s) ease, border-color var(--duration-fast, 0.15s) ease;
  }

  .shopping-nav__pill:hover {
    background-color: var(--bg-card, #EDEDED);
    border-color: var(--color-3, #767676);
  }

  @media screen and (min-width: 750px) {
    .shopping-nav__banner-inner,
    .shopping-nav__pills-wrapper {
      padding-inline: var(--space-8, 16px);
    }

    .shopping-nav__heading {
      font-size: var(--text-xl, 46px);
    }
    
    .shopping-nav__pills {
      justify-content: center;
      gap: var(--space-4, 10px);
      padding-block: var(--space-6, 12px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Shopping Navigation",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Go shopping"
    },
    {
      "type": "url",
      "id": "link",
      "label": "CTA Link"
    },
    {
      "type": "text",
      "id": "store_text",
      "label": "Store text",
      "default": "Store: Wrydeco(EN)"
    }
  ],
  "blocks": [
    {
      "type": "pill",
      "name": "Collection Pill",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Collection Name"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shopping Navigation",
      "blocks": [
        { "type": "pill", "settings": { "title": "+ Trending" } },
        { "type": "pill", "settings": { "title": "Reading Nook" } },
        { "type": "pill", "settings": { "title": "Surfaces" } },
        { "type": "pill", "settings": { "title": "Bath & Sink" } },
        { "type": "pill", "settings": { "title": "Bed Essentials" } },
        { "type": "pill", "settings": { "title": "Mood Makers" } }
      ]
    }
  ]
}
{% endschema %}
