{%- liquid
  assign materials_url = section.settings.materials_url | default: pages['materials'].url | default: routes.root_url
  assign consultation_url = section.settings.consultation_url | default: pages['customization'].url | default: routes.root_url
  assign chat_url = section.settings.chat_url | default: pages['contact'].url | default: routes.root_url
-%}

<section class="about-craft" aria-labelledby="about-craft-title-{{ section.id }}">
  <div class="about-craft__inner">
    <div class="about-craft__overview">
      <header class="about-craft__intro">
        <p class="about-craft__eyebrow">{{ section.settings.eyebrow | escape }}</p>
        <h2 id="about-craft-title-{{ section.id }}">
          <span>{{ section.settings.heading_first_line | escape }}</span>
          <span>{{ section.settings.heading_second_line | escape }}</span>
        </h2>
        <span class="about-craft__accent" aria-hidden="true"></span>
        <div class="about-craft__description rte">{{ section.settings.description }}</div>
        <a class="about-craft__text-link" href="{{ materials_url }}">
          {{ section.settings.materials_link_label | escape }}
          <span aria-hidden="true">&rarr;</span>
        </a>
      </header>

      <div class="about-craft__values">
        {%- for block in section.blocks -%}
          {%- if block.type == 'craft_value' -%}
            <article class="about-craft-value" {{ block.shopify_attributes }}>
              <span class="about-craft-value__icon" aria-hidden="true">
                {% render 'about-craft-icon', icon: block.settings.icon %}
              </span>
              <h3>{{ block.settings.heading | escape }}</h3>
              <p>{{ block.settings.text | escape | newline_to_br }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="about-craft__trust-strip" aria-label="{{ section.settings.trust_region_label | escape }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'trust_point' -%}
          <article class="about-craft-trust" {{ block.shopify_attributes }}>
            <span class="about-craft-trust__icon" aria-hidden="true">
              {% render 'about-craft-icon', icon: block.settings.icon %}
            </span>
            <div>
              <h3>{{ block.settings.heading | escape }}</h3>
              <p>{{ block.settings.text | escape }}</p>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="about-craft__consultation">
      <div class="about-craft__consultation-media">
        <img
          src="{{ 'about-us-private-book.png' | asset_url }}"
          width="1792"
          height="1024"
          alt="{{ section.settings.consultation_image_alt | escape }}"
          loading="lazy"
        >
      </div>
      <div class="about-craft__consultation-copy">
        <h2>
          <span>{{ section.settings.consultation_heading_first_line | escape }}</span>
          <span>{{ section.settings.consultation_heading_second_line | escape }}</span>
        </h2>
        <span class="about-craft__accent" aria-hidden="true"></span>
        <p>{{ section.settings.consultation_text | escape }}</p>
      </div>
      <div class="about-craft__consultation-actions">
        <a class="about-craft__button" href="{{ consultation_url }}">
          {{ section.settings.consultation_button_label | escape }}
          <span aria-hidden="true">&rarr;</span>
        </a>
        <a class="about-craft__chat-link" href="{{ chat_url }}">
          <span aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16v12H9l-5 4V4Z"/><path d="M8 10h.01M12 10h.01M16 10h.01"/></svg>
          </span>
          {{ section.settings.chat_link_label | escape }}
        </a>
      </div>
    </div>

    <div class="about-craft__service-strip" aria-label="{{ section.settings.service_region_label | escape }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'service_point' -%}
          <article class="about-craft-service" {{ block.shopify_attributes }}>
            <span class="about-craft-service__icon" aria-hidden="true">
              {% render 'about-craft-icon', icon: block.settings.icon %}
            </span>
            <div>
              <h3>{{ block.settings.heading | escape }}</h3>
              <p>{{ block.settings.text | escape }}</p>
            </div>
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .about-craft {
    background: var(--bg-primary);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .about-craft__inner {
    display: grid;
    gap: var(--sp-5);
    inline-size: min(calc(100% - (var(--sp-8) * 2)), var(--layout-showcase-max-width));
    margin-inline: auto;
    padding-block: var(--sp-7) var(--sp-8);
  }

  .about-craft__overview {
    display: grid;
    grid-template-columns: minmax(0, 34%) minmax(0, 66%);
    gap: var(--sp-6);
  }

  .about-craft__intro {
    padding-inline: var(--sp-5);
  }

  .about-craft__eyebrow {
    margin: var(--sp-0) var(--sp-0) var(--sp-4);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 3);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .about-craft__intro h2,
  .about-craft__consultation-copy h2 {
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-display-light);
    font-size: var(--font-size-display-lg);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
  }

  .about-craft__intro h2 span,
  .about-craft__consultation-copy h2 span {
    display: block;
  }

  .about-craft__accent {
    display: block;
    inline-size: var(--sp-6);
    block-size: calc(var(--border-width) * 2);
    margin-block: var(--sp-4);
    background: var(--color-clay);
  }

  .about-craft__description {
    max-inline-size: 46ch;
    color: var(--color-charcoal);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .about-craft__description p {
    margin: var(--sp-0);
  }

  .about-craft__text-link {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    min-block-size: var(--sp-7);
    margin-block-start: var(--sp-4);
    border-block-end: var(--border-width) solid var(--color-bark);
    color: var(--color-charcoal);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-decoration: none;
    text-transform: uppercase;
  }

  .about-craft__values {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .about-craft-value {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-block-size: calc(var(--sp-8) * 4);
    padding: var(--sp-5);
    border-inline-start: var(--border-width) solid var(--border-light);
    text-align: center;
  }

  .about-craft-value__icon {
    display: inline-flex;
    inline-size: var(--sp-8);
    block-size: var(--sp-8);
    margin-block-end: var(--sp-4);
    color: var(--color-clay);
  }

  .about-craft-value__icon svg,
  .about-craft-trust__icon svg,
  .about-craft-service__icon svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .about-craft-value h3 {
    max-inline-size: 12ch;
    margin: var(--sp-0) var(--sp-0) var(--sp-3);
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-body-xl);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
  }

  .about-craft-value p {
    margin: var(--sp-0);
    color: var(--color-charcoal);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-generous);
  }

  .about-craft__trust-strip,
  .about-craft__service-strip {
    display: grid;
    overflow: hidden;
    border: var(--border-width) solid var(--border-light);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--bg-tertiary) 38%, transparent);
  }

  .about-craft__trust-strip {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .about-craft-trust,
  .about-craft-service {
    display: grid;
    grid-template-columns: var(--sp-8) minmax(0, 1fr);
    align-items: center;
    gap: var(--sp-4);
    min-block-size: var(--sp-10);
    padding: var(--sp-3) var(--sp-6);
  }

  .about-craft-trust + .about-craft-trust,
  .about-craft-service + .about-craft-service {
    border-inline-start: var(--border-width) solid var(--border-light);
  }

  .about-craft-trust__icon,
  .about-craft-service__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: var(--sp-8);
    block-size: var(--sp-8);
    padding: var(--sp-3);
    border: var(--border-width) solid var(--color-linen);
    border-radius: var(--radius-full);
    color: var(--color-clay);
  }

  .about-craft-trust h3,
  .about-craft-service h3 {
    margin: var(--sp-0) var(--sp-0) var(--sp-1);
    color: var(--color-charcoal);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .about-craft-trust p,
  .about-craft-service p {
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-relaxed);
  }

  .about-craft__consultation {
    display: grid;
    grid-template-columns: minmax(0, 34%) minmax(0, 31%) minmax(0, 35%);
    overflow: hidden;
    min-block-size: calc(var(--sp-8) * 3);
    border: var(--border-width) solid var(--border-light);
    border-radius: var(--radius-lg);
    background-color: color-mix(in srgb, var(--bg-tertiary) 48%, transparent);
    margin-top: var(--sp-8);
  }

  .about-craft__consultation-media {
    overflow: hidden;
  }

  .about-craft__consultation-media img {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  .about-craft__consultation-copy,
  .about-craft__consultation-actions {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: var(--sp-6);
  }

  .about-craft__consultation-copy h2 {
    font-size: var(--font-size-display-md);
  }

  .about-craft__consultation-copy p {
    margin: var(--sp-0);
    color: var(--color-charcoal);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .about-craft__button {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    min-block-size: var(--sp-8);
    padding: var(--sp-3) var(--sp-6);
    border-radius: var(--radius-md);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: var(--letter-spacing-wide);
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
  }

  .about-craft__button:hover {
    background: var(--color-charcoal);
  }

  .about-craft__button:active {
    transform: translateY(var(--border-width));
  }

  .about-craft__chat-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    min-block-size: var(--sp-7);
    margin-block-start: var(--sp-3);
    color: var(--color-bark);
    font-size: var(--font-size-body-sm);
    text-decoration: none;
  }

  .about-craft__chat-link > span {
    display: inline-flex;
    inline-size: var(--sp-6);
    block-size: var(--sp-6);
  }

  .about-craft__chat-link svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .about-craft__button:focus-visible,
  .about-craft__chat-link:focus-visible,
  .about-craft__text-link:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  .about-craft__service-strip {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  @media screen and (max-width: 75rem) {
    .about-craft__inner {
      inline-size: min(calc(100% - (var(--layout-padding-desktop) * 2)), var(--layout-showcase-max-width));
    }

    .about-craft__overview {
      grid-template-columns: minmax(0, 1fr);
    }

    .about-craft__intro {
      padding-inline: var(--sp-0);
    }
  }

  @media screen and (max-width: 64rem) {
    .about-craft__values,
    .about-craft__service-strip {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .about-craft-value:nth-child(odd),
    .about-craft-service:nth-child(odd) {
      border-inline-start: var(--sp-0);
    }

    .about-craft__trust-strip {
      grid-template-columns: minmax(0, 1fr);
    }

    .about-craft-trust + .about-craft-trust {
      border-block-start: var(--border-width) solid var(--border-light);
      border-inline-start: var(--sp-0);
    }

    .about-craft__consultation {
      grid-template-columns: minmax(0, 42%) minmax(0, 58%);
    }

    .about-craft__consultation-actions {
      grid-column: 1 / -1;
      padding-block-start: var(--sp-0);
    }
  }

  @media screen and (max-width: 48rem) {
    .about-craft__inner {
      gap: var(--sp-4);
      inline-size: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--layout-showcase-max-width));
      padding-block: var(--sp-7);
    }

    .about-craft__intro h2,
    .about-craft__consultation-copy h2 {
      font-size: var(--font-size-display-md);
    }

    .about-craft__values,
    .about-craft__service-strip,
    .about-craft__consultation {
      grid-template-columns: minmax(0, 1fr);
    }

    .about-craft-value {
      min-block-size: calc(var(--sp-8) * 3);
      border-block-start: var(--border-width) solid var(--border-light);
      border-inline-start: var(--sp-0);
    }

    .about-craft__consultation-media {
      aspect-ratio: 16 / 9;
    }

    .about-craft__consultation-copy,
    .about-craft__consultation-actions {
      padding: var(--sp-5);
    }

    .about-craft__consultation-actions {
      grid-column: auto;
      padding-block-start: var(--sp-0);
    }

    .about-craft-service + .about-craft-service {
      border-block-start: var(--border-width) solid var(--border-light);
      border-inline-start: var(--sp-0);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "About craftsmanship",
  "tag": "section",
  "class": "section-about-craftsmanship",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Our craftsmanship" },
    { "type": "text", "id": "heading_first_line", "label": "Heading first line", "default": "Honest Materials." },
    { "type": "text", "id": "heading_second_line", "label": "Heading second line", "default": "Timeless Craft." },
    { "type": "richtext", "id": "description", "label": "Description", "default": "<p>We use solid, natural wood sourced responsibly. Each slab is hand-selected for its grain, character, and integrity. Our makers shape, refine, and finish every detail by hand—creating heirloom-quality furniture meant to be cherished for generations.</p>" },
    { "type": "text", "id": "materials_link_label", "label": "Materials link label", "default": "Explore our materials" },
    { "type": "url", "id": "materials_url", "label": "Materials page" },
    { "type": "text", "id": "trust_region_label", "label": "Trust strip label", "default": "Craftsmanship principles" },
    { "type": "header", "content": "Private consultation" },
    { "type": "text", "id": "consultation_heading_first_line", "label": "Heading first line", "default": "Let’s create something" },
    { "type": "text", "id": "consultation_heading_second_line", "label": "Heading second line", "default": "for your space." },
    { "type": "textarea", "id": "consultation_text", "label": "Text", "default": "From custom sizing to bespoke designs, we're here to bring your vision to life." },
    { "type": "text", "id": "consultation_image_alt", "label": "Image alt text", "default": "Sculptural solid wood console styled with branches and warm natural objects" },
    { "type": "text", "id": "consultation_button_label", "label": "Button label", "default": "Book a private consultation" },
    { "type": "url", "id": "consultation_url", "label": "Consultation page" },
    { "type": "text", "id": "chat_link_label", "label": "Chat link label", "default": "Prefer to chat? Message us" },
    { "type": "url", "id": "chat_url", "label": "Contact page" },
    { "type": "text", "id": "service_region_label", "label": "Service strip label", "default": "WRYDECO service promises" }
  ],
  "blocks": [
    {
      "type": "craft_value",
      "name": "Craft value",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "wood", "label": "Wood" }, { "value": "handmade", "label": "Handmade" }, { "value": "leaf", "label": "Leaf" }, { "value": "eye", "label": "Eye" }], "default": "wood" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Solid Natural Wood" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Never veneers.\nAlways authentic." }
      ]
    },
    {
      "type": "trust_point",
      "name": "Trust point",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "responsible", "label": "Responsible sourcing" }, { "value": "vietnam", "label": "Vietnam craftsmanship" }, { "value": "thoughtful", "label": "Thoughtfully made" }], "default": "responsible" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Sustainably sourced" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "We choose responsibly managed wood and minimize waste." }
      ]
    },
    {
      "type": "service_point",
      "name": "Service promise",
      "settings": [
        { "type": "select", "id": "icon", "label": "Icon", "options": [{ "value": "chair", "label": "Chair" }, { "value": "globe", "label": "Globe" }, { "value": "shield", "label": "Shield" }, { "value": "diamond", "label": "Diamond" }], "default": "chair" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "Complimentary design advice" },
        { "type": "textarea", "id": "text", "label": "Text", "default": "Personalized guidance from our design team." }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [{ "name": "About craftsmanship" }]
}
{% endschema %}
