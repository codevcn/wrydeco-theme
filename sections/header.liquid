{% stylesheet %}
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4, 10px);
    padding-inline: var(--space-4, 10px);
    background-color: transparent;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 99;
  }

  .header__left {
    display: flex;
    align-items: center;
    gap: var(--space-12, 24px);
  }

  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    gap: 20px;
    margin: 0 18px;
    padding: 0;
    list-style: none;
    align-items: center;
  }
  .header__nav-list li {
    margin: 0;
    position: static;
  }

  .header__nav-item {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--color-earth-brown, #333);
    font-family: var(--font-roboto, sans-serif);
    font-size: 20px;
    font-weight: 700;
    text-transform: uppercase;
    transition: color var(--transition-fast, 0.2s);
    padding: 10px 0;
  }

  .header__nav-item .icon-caret {
    width: 12px;
    height: auto;
    fill: currentColor;
    opacity: 0.8;
    transition: transform 0.2s ease;
  }

  .header__nav-item:hover {
    color: var(--text-secondary, #666);
  }

  /* Mega Menu Styles */
  .header__nav-item-has-mega-menu:hover .header__mega-menu,
  .header__nav-item-has-mega-menu:focus-within .header__mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .header__mega-menu {
    display: flex;
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    background-color: var(--color-milk, #f7f2ec);
    border-top: 1px solid rgba(0, 0, 0, 0.05);
    box-shadow: 0 10px 20px rgba(0, 0, 0, 0.05);
    opacity: 0;
    visibility: hidden;
    transform: translateY(5px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 100;
    padding-block: 0;
    padding-inline: 0;
    font-family: var(--font-roboto, sans-serif);
  }

  .header__mega-menu .page-width {
    flex: 4;
    padding: 0;
    max-width: 1200px; /* Force bounds for the border grid to align perfectly */
    border-left: 1px solid var(--border-light, #e8e4df);
    border-right: 1px solid var(--border-light, #e8e4df);
  }

  .header__mega-menu .right-banner {
    flex: 1;
  }

  .mega-menu__content {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
  }

  .mega-menu__column {
    padding: 20px 24px 14px;
    border-right: 1px solid var(--border-light, #e8e4df);
    border-bottom: 1px solid var(--border-light, #e8e4df);
  }

  .mega-menu__column:nth-child(5n) {
    border-right: none;
  }

  .mega-menu__column:nth-last-child(-n + 4) {
    border-bottom: none;
  }

  .mega-menu__title-wrapper {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 24px;
  }

  .mega-menu__icon-wrapper {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid var(--color-earth-brown, #4a2c18);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-earth-brown, #4a2c18);
  }

  .mega-menu__icon-wrapper svg {
    width: 14px;
    height: 14px;
  }

  .mega-menu__title {
    margin: 0;
    font-size: 14px;
    text-transform: uppercase;
    font-weight: 500;
    font-family: var(--font-display, serif);
    color: var(--color-earth-brown, #4a2c18);
    position: relative;
    padding-bottom: 8px;
    line-height: 1.3;
  }

  .mega-menu__title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 30px;
    height: 1px;
    background-color: var(--color-earth-brown, #4a2c18);
  }

  .mega-menu__title a {
    color: inherit;
    text-decoration: none;
  }

  .mega-menu__list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    list-style: none;
  }

  .mega-menu__list li {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .mega-menu__link {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 12px;
    margin-left: -12px;
    margin-right: -12px;
    border-radius: 4px;
    color: var(--text-primary, #333);
    text-decoration: none;
    font-size: 14px;
    transition: background-color 0.2s ease;
  }

  .mega-menu__link:hover {
    background-color: var(--color-stone, #e8e4df);
    text-decoration: none;
  }

  .mega-menu__link-icon {
    opacity: 0;
    transition: opacity 0.2s ease;
    width: 10px;
    height: 10px;
  }

  .mega-menu__link:hover .mega-menu__link-icon {
    opacity: 1;
  }

  .mega-menu__column--promo {
    padding: 0;
    border-right: none;
    border-bottom: none;
    display: flex;
    align-items: stretch;
  }

  .mega-menu__promo-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .mega-menu__promo-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .header__right {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-4, 10px);
  }

  .header__heading {
    margin: 0;
    display: flex;
    align-items: center;
  }

  .header__heading-link {
    text-decoration: none;
    color: var(--color-1, #000);
    display: block;
    line-height: 1;
  }

  .header__heading-logo {
    max-width: 100%;
    height: auto;
    width: 150px;
  }

  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-1, #000);
    background: transparent;
    border: none;
    cursor: pointer;
    text-decoration: none;
    position: relative;
    -webkit-tap-highlight-color: transparent;
  }
  .header__icon:focus {
    outline: none;
  }
  .header__icon:focus-visible {
    outline: 2px solid var(--color-1, #000);
    outline-offset: 2px;
  }

  .header__icon.header__icon--cart {
    color: var(--color-cream, #f5f1ed);
  }

  /* Gray circle background for icons like in the screenshot */
  .header__icon--search,
  .header__icon--menu {
    border-radius: var(--radius-full, 50%);
  }

  .header__icon--search {
    color: var(--color-cream, #f5f1ed);
  }

  .header__icon svg {
    width: 24px;
    height: 24px;
  }

  .cart-count-bubble {
    position: absolute;
    top: 5px;
    right: 5px;
    background-color: var(--color-2, #e60023);
    color: var(--color-10, #fff);
    font-size: var(--text-sm, 14px);
    font-weight: bold;
    border-radius: var(--radius-full, 50%);
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(25%, -25%);
  }

  @media screen and (min-width: 750px) {
    .header {
      padding-inline: 32px;
      padding-block: var(--space-6, 12px);
    }

    .header__icon--menu {
      display: none;
    }

    .header__nav {
      display: block;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "logo_asset",
      "label": "Local Asset Logo",
      "info": "Filename of an image in the assets folder e.g. logo.png"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Mega Menu Promotion"
    },
    {
      "type": "image_picker",
      "id": "mega_menu_image",
      "label": "Promotion Image"
    },
    {
      "type": "url",
      "id": "mega_menu_link",
      "label": "Promotion Link"
    }
  ]
}
{% endschema %}
