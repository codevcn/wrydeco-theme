{% render 'search-popup' %}

<script>
  (function () {
    function initMegaMenu() {
      var groups = Array.prototype.slice.call(document.querySelectorAll('[data-mega-group]'));
      groups.forEach(function (group) {
        var toggle = group.querySelector('[data-mega-toggle]');
        if (!toggle || toggle.dataset.init === 'true') return;
        toggle.dataset.init = 'true';
        toggle.addEventListener('click', function (e) {
          e.preventDefault();
          var willOpen = !group.classList.contains('is-open');
          // Single-open accordion: collapse the others first.
          groups.forEach(function (other) {
            if (other === group) return;
            other.classList.remove('is-open');
            var t = other.querySelector('[data-mega-toggle]');
            if (t) t.setAttribute('aria-expanded', 'false');
          });
          group.classList.toggle('is-open', willOpen);
          toggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initMegaMenu);
    } else {
      initMegaMenu();
    }
  })();
</script>

{% stylesheet %}
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4, 10px);
    padding-inline: var(--space-4, 10px);
    background-color: transparent;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 99;
  }

  .header__left {
    display: flex;
    align-items: center;
    gap: var(--space-12, 24px);
  }

  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    gap: 20px;
    margin: 0 18px;
    padding: 0;
    list-style: none;
    align-items: center;
  }
  .header__nav-list li {
    margin: 0;
    position: static;
    padding-block: 8px;
  }

  .header__nav-item {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--color-earth-brown, #333);
    font-family: var(--font-roboto, sans-serif);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    transition: color var(--transition-fast, 0.2s);
    padding: 10px 0;
  }

  .header__nav-item .icon-caret {
    width: 12px;
    height: auto;
    fill: currentColor;
    opacity: 0.8;
    transition: transform 0.2s ease;
  }

  .header__nav-item:hover {
    color: var(--text-secondary, #666);
  }

  /* Mega Menu Styles */
  .header__nav-item-has-mega-menu:hover .header__mega-menu,
  .header__nav-item-has-mega-menu:focus-within .header__mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* Collections popover — anchored to the header so it sits 26.5px from the viewport's left edge */
  .header__mega-menu {
    position: absolute;
    top: 80%;
    left: 26.5px;
    width: fit-content;
    max-width: 1400px;
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transform: translateY(5px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    font-family: var(--font-body);
  }

  .cmega {
    margin: 0 auto;
    display: flex;
    width: fit-content;
    max-width: 1180px;
    max-height: calc(100dvh - 96px);
    overflow: hidden auto;
    background-color: var(--color-milk);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-elevation-3);
  }

  /* Category column */
  .cmega__cats {
    flex: 1;
    min-width: 0;
    padding: var(--sp-6) var(--sp-6) var(--sp-4);
    height: 477px;
  }
  .cmega__heading {
    margin: 0 0 var(--sp-2);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .cmega__groups-wrap {
    display: grid;
    grid-template-columns: repeat(2, minmax(236px, 1fr));
    align-items: start;
  }
  .cmega__groups {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    list-style: none;
    min-width: 0;
  }
  .cmega__groups:first-child {
    padding-right: var(--sp-4);
    border-right: 1px solid var(--border-light);
  }
  .cmega__groups:last-child {
    padding-left: var(--sp-4);
  }
  .cmega__group + .cmega__group {
    border-top: 1px solid var(--border-light);
  }
  .cmega__group-head {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    width: 100%;
    padding: var(--sp-3) var(--sp-4);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: var(--text-primary);
    border-radius: var(--radius-md);
    transition: background-color var(--timing-short) var(--ease-standard);
  }
  .cmega__group-head:hover,
  .cmega__group.is-open > .cmega__group-head {
    background-color: var(--color-cream);
  }
  .cmega__group-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 30px;
    height: 30px;
    color: var(--color-earth-brown);
  }
  .cmega__group-icon svg {
    width: 24px;
    height: 24px;
  }
  .cmega__group-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1 1 auto;
    min-width: 0;
  }
  .cmega__group-name {
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }
  .cmega__group-desc {
    font-size: var(--font-size-caption);
    color: var(--text-secondary);
  }
  .cmega__group-caret {
    display: flex;
    flex: 0 0 auto;
    color: var(--text-secondary);
    transition: transform var(--timing-short) var(--ease-standard), color var(--timing-short) var(--ease-standard);
  }
  .cmega__group-caret svg {
    width: 16px;
    height: 16px;
  }
  .cmega__group.is-open .cmega__group-caret {
    transform: rotate(90deg);
    color: var(--color-earth-brown);
  }

  /* Accordion panel (animated collapse via grid-template-rows) */
  .cmega__panel {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows var(--timing-base) var(--ease-standard);
  }
  .cmega__group.is-open .cmega__panel {
    grid-template-rows: 1fr;
  }
  .cmega__collections {
    overflow: hidden;
    min-height: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cmega__collections li {
    margin: 0;
  }
  .cmega__collections a {
    display: block;
    padding: var(--sp-2) var(--sp-4) var(--sp-2) calc(var(--sp-4) + 30px + var(--sp-4));
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--timing-short) var(--ease-standard),
      background-color var(--timing-short) var(--ease-standard);
  }
  .cmega__collections a:hover {
    color: var(--color-earth-brown);
    background-color: var(--color-cream);
  }
  .cmega__collections li:last-child a {
    padding-bottom: var(--sp-3);
  }

  /* Feature column */
  .cmega__feature {
    flex: 0.5;
    display: flex;
    padding: var(--sp-6);
    border-left: 1px solid var(--border-light);
    background-color: var(--color-cream);
  }
  .cmega__feature-link {
    display: flex;
    flex-direction: column;
    width: 100%;
    height: fit-content;
    color: inherit;
    text-decoration: none;
  }
  .cmega__feature-media {
    display: block;
    overflow: hidden;
    border-radius: var(--radius-lg);
    aspect-ratio: 4 / 3;
    background-color: var(--bg-secondary);
  }
  .cmega__feature-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cmega__feature-body {
    padding-top: var(--sp-5);
  }
  .cmega__feature-title {
    display: block;
    font-family: var(--font-display);
    font-size: var(--font-size-display-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .cmega__feature-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    margin-top: var(--sp-4);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-earth-brown);
  }
  .cmega__feature-arrow {
    display: inline-flex;
  }
  .cmega__feature-arrow svg {
    width: 16px;
    height: 16px;
    transition: transform var(--timing-short) var(--ease-standard);
  }
  .cmega__feature-link:hover .cmega__feature-arrow svg {
    transform: translateX(3px);
  }

  /* Narrow viewports: stack the feature under the category list */
  @media screen and (max-width: 900px) {
    .cmega {
      flex-direction: column;
      width: 100%;
      max-width: 620px;
    }
    .cmega__groups-wrap {
      grid-template-columns: 1fr;
    }
    .cmega__groups:first-child {
      padding-right: 0;
      border-right: none;
    }
    .cmega__groups:last-child {
      padding-left: 0;
    }
    .cmega__feature {
      border-left: none;
      border-top: 1px solid var(--border-light);
    }
    .cmega__feature-media {
      aspect-ratio: 16 / 7;
    }
  }

  .header__right {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-4, 10px);
  }

  .header__heading {
    margin: 0;
    display: flex;
    align-items: center;
  }

  .header__heading-link {
    text-decoration: none;
    color: var(--color-1, #000);
    display: block;
    line-height: 1;
  }

  .header__heading-logo {
    max-width: 100%;
    height: auto;
    width: 150px;
  }

  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-1, #000);
    background: transparent;
    border: none;
    cursor: pointer;
    text-decoration: none;
    position: relative;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.2s ease;
  }
  .header__icon:hover {
    transform: scale(1.1);
  }
  .header__icon:focus {
    outline: none;
  }
  .header__icon:focus-visible {
    outline: 2px solid var(--color-1, #000);
    outline-offset: 2px;
  }

  .header__icon.header__icon--cart {
    color: var(--color-cream, #f5f1ed);
  }

  /* Gray circle background for icons like in the screenshot */
  .header__icon--search,
  .header__icon--menu {
    border-radius: var(--radius-full, 50%);
  }

  .header__icon--search {
    color: var(--color-cream, #f5f1ed);
  }
  .header__icon--search:hover {
    color: var(--color-cream, #f5f1ed);
  }

  .header__icon svg {
    width: 24px;
    height: 24px;
  }

  .cart-count-bubble {
    position: absolute;
    top: 5px;
    right: 5px;
    background-color: var(--color-2, #e60023);
    color: var(--color-10, #fff);
    font-size: var(--text-sm, 14px);
    font-weight: bold;
    border-radius: var(--radius-full, 50%);
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(25%, -25%);
  }

  @media screen and (min-width: 750px) {
    .header {
      padding-inline: 32px;
      padding-block: var(--space-6, 12px);
    }

    .header__icon--menu {
      display: none;
    }

    .header__nav {
      display: block;
    }
  }
{% endstylesheet %}

