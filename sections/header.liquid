<header class="header page-width">
  <div class="header__left">
    {%- comment -%}
      The logo is never an H1. Each template already exposes its own single H1: the homepage uses
      the hero headline (hero-banner), and other templates use the page's own title
      (product, collection, article, page…). Wrapping the logo in a plain <div> keeps every page
      to exactly one H1. See doc/SEO-diagnose.md #1 and audit SEO-01.
    {%- endcomment -%}
    {%- assign header_heading_tag = 'div' -%}
    {%- assign logo_alt = section.settings.logo.alt | default: shop.name -%}
    <{{ header_heading_tag }} class="header__heading">
      <a href="{{ routes.root_url }}" class="header__heading-link">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 400
            | image_tag:
              class: 'header__heading-logo',
              widths: '100, 200, 300, 400',
              height: section.settings.logo.height,
              width: section.settings.logo.width,
              alt: logo_alt
          }}
        {%- elsif section.settings.logo_asset != blank -%}
          <img
            src="{{ section.settings.logo_asset | file_url }}"
            class="header__heading-logo"
            alt="{{ shop.name | escape }}"
            width="200"
            height="52"
          >
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </{{ header_heading_tag }}>

    {%- capture room_nav_data -%}
      Living Room::Modern Wooden Floating Shelves=floating-shelf-modern|Rustic Wooden Floating Shelves=floating-shelf-rustic
      ||Bedroom::Wooden Bed Frames With Headboards=bed-frame-with-headboard
      ||Kitchen::Wooden Fruit Bowls=wooden-fruit-bowl
      ||Home Office::Modern Wooden Bookshelves=bookshelf-modern|Rustic Wooden Bookshelves=bookshelf-rustic
      ||Kid's Room::
      ||Entryway::
      ||Business Decor::Wooden Floor Sculptures=wooden-floor-sculpture|Modern Wooden Coffee Tables=coffee-table-modern|Modern Wooden Bookshelves=bookshelf-modern
    {%- endcapture -%}
    {%- assign room_nav_items = room_nav_data | strip | split: '||' -%}

    <nav class="header__nav" aria-label="Rooms">
      <ul class="header__nav-list">
        {%- for room_nav_item in room_nav_items -%}
          {%- liquid
            assign room_nav_parts = room_nav_item | strip | split: '::'
            assign room_title = room_nav_parts[0] | strip
            assign room_collections_value = room_nav_parts[1] | strip
            assign room_collections = room_collections_value | split: '|'
          -%}
          {%- if room_collections_value == blank -%}
            {%- continue -%}
          {%- endif -%}
          <li class="header__nav-item-has-mega-menu">
            <button type="button" class="header__nav-item" aria-haspopup="true">
              {{ room_title }}
              <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
                <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
              </svg>
            </button>
            <div class="header__mega-menu">
              <div class="cmega cmega--room custom-scrollbar">
                <div class="cmega__cats">
                  <p class="cmega__heading">{{ room_title }}</p>
                  {%- if room_collections_value != blank -%}
                    <ul class="cmega__collections cmega__collections--room">
                      {%- for room_collection in room_collections -%}
                        {%- assign room_collection_parts = room_collection | split: '=' -%}
                        {%- assign room_collection_title = room_collection_parts[0] | strip -%}
                        {%- assign room_collection_handle = room_collection_parts[1] | strip -%}
                        {%- assign coll = collections[room_collection_handle] -%}
                        {%- assign coll_image = coll.image | default: coll.products.first.featured_image -%}
                        <li>
                          <a class="cmega__collection-link" href="{{ routes.collections_url }}/{{ room_collection_handle }}">
                            <div class="cmega__collection-image-wrapper">
                              {%- if coll_image != blank -%}
                                <img src="{{ coll_image | image_url: width: 400 }}" alt="{{ room_collection_title | escape }}" loading="lazy" class="cmega__collection-image">
                              {%- else -%}
                                {{ 'collection-1' | placeholder_svg_tag: 'cmega__collection-image placeholder-svg' }}
                              {%- endif -%}
                            </div>
                            <span class="cmega__collection-title">{{ room_collection_title }}</span>
                          </a>
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- else -%}
                    <p class="cmega__empty">Coming soon.</p>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </li>
        {%- endfor -%}


      </ul>
    </nav>

    <div class="header__mega-menu header__mobile-menu" id="MobileMenuDrawer-{{ section.id }}" data-mobile-menu-drawer>
      <button
        type="button"
        class="mobile-menu__overlay"
        aria-label="Close menu"
        data-mobile-menu-close
        tabindex="-1"
      ></button>
      <div class="cmega custom-scrollbar">
        <div class="mobile-menu__bar">
          <span class="mobile-menu__title">
            <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 24 24">
              <path d="M0 0h24v24H0z" fill="none" />
              <path fill="currentColor" d="M3 18v-2h18v2zm0-5v-2h18v2zm0-5V6h18v2z" />
            </svg>
          </span>
          <button type="button" class="mobile-menu__close" aria-label="Close menu" data-mobile-menu-close>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M0 0h24v24H0z" fill="none" />
              <path fill="currentColor" d="M6.4 19L5 17.6l5.6-5.6L5 6.4L6.4 5l5.6 5.6L17.6 5L19 6.4L13.4 12l5.6 5.6l-1.4 1.4l-5.6-5.6z" />
            </svg>
          </button>
        </div>

        <div class="cmega__consultation">
          <a
            href="/pages/customization"
            class="header__consultation-link cmega__consultation-link"
            data-mobile-menu-close
          >
            Book Consultation
          </a>
        </div>

        <div class="cmega__account">
          <p class="cmega__heading">Account</p>
          {%- if customer -%}
            <a class="cmega__account-btn" href="{{ routes.account_url }}">
              <span>My account</span>
            </a>
            <a class="cmega__account-logout" href="{{ routes.account_logout_url }}">Log out</a>
          {%- else -%}
            <a class="cmega__account-btn" href="{{ routes.account_login_url }}" data-mobile-menu-close>
              <span>Sign in</span>
            </a>
            <p class="cmega__account-note">Secure passwordless sign-in. We email you a one-time code.</p>
          {%- endif -%}
        </div>

        <div class="cmega__localization">
          <p class="cmega__heading">{{ 'general.localization.country_label' | t }}</p>
          {% render 'localization-selector', variant: 'drawer', id: 'mobile-drawer' %}
        </div>

        <div class="cmega__cats">
          <p class="cmega__heading">Shop by Room</p>
          <div class="cmega__groups-wrap">
            <ul class="cmega__groups">
              {%- for room_nav_item in room_nav_items -%}
                {%- liquid
                  assign room_nav_parts = room_nav_item | strip | split: '::'
                  assign room_title = room_nav_parts[0] | strip
                  assign room_collections_value = room_nav_parts[1] | strip
                  assign room_collections = room_collections_value | split: '|'
                -%}
                {%- if room_collections_value == blank -%}
                  {%- continue -%}
                {%- endif -%}
                <li class="cmega__group" data-mega-group>
                  <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                    <span class="cmega__group-text">
                      <span class="cmega__group-name">{{ room_title }}</span>
                      <span class="cmega__group-desc">
                        {%- if room_collections_value != blank -%}
                          {{ room_collections.size }} collections
                        {%- else -%}
                          Coming soon
                        {%- endif -%}
                      </span>
                    </span>
                    <span class="cmega__group-caret" aria-hidden="true">
                      <svg
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="1.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <polyline points="9 6 15 12 9 18"/>
                      </svg>
                    </span>
                  </button>
                  <div class="cmega__panel">
                    {%- if room_collections_value != blank -%}
                      <ul class="cmega__collections cmega__collections--room">
                        {%- for room_collection in room_collections -%}
                          {%- assign room_collection_parts = room_collection | split: '=' -%}
                          {%- assign room_collection_title = room_collection_parts[0] | strip -%}
                          {%- assign room_collection_handle = room_collection_parts[1] | strip -%}
                          {%- assign coll = collections[room_collection_handle] -%}
                          {%- assign coll_image = coll.image | default: coll.products.first.featured_image -%}
                          <li>
                            <a
                              href="{{ routes.collections_url }}/{{ room_collection_handle }}"
                              data-mobile-menu-close
                              class="cmega__collection-link"
                            >
                              <div class="cmega__collection-image-wrapper">
                                {%- if coll_image != blank -%}
                                  <img src="{{ coll_image | image_url: width: 400 }}" alt="{{ room_collection_title | escape }}" loading="lazy" class="cmega__collection-image">
                                {%- else -%}
                                  {{ 'collection-1' | placeholder_svg_tag: 'cmega__collection-image placeholder-svg' }}
                                {%- endif -%}
                              </div>
                              <span class="cmega__collection-title">{{ room_collection_title }}</span>
                            </a>
                          </li>
                        {%- endfor -%}
                      </ul>
                    {%- else -%}
                      <p class="cmega__empty">Coming soon.</p>
                    {%- endif -%}
                  </div>
                </li>
              {%- endfor -%}


            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="header__right">
    <a href="/pages/customization" class="header__consultation-link">Book Consultation</a>

    <div class="header__localization">
      {% render 'localization-selector', variant: 'header', id: 'header' %}
    </div>

    <a
      href="{{ routes.search_url }}"
      class="header__icon header__icon--search"
      aria-label="Search"
      onclick="window.openSearchPopup(event)"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-search"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </a>

    {% render 'wishlist-heart' %}

    <a
      href="{{ routes.cart_url }}"
      class="header__icon header__icon--cart"
      aria-label="Cart"
      data-cart-drawer-open
    >
      {{ 'icon-cart.svg' | inline_asset_content }}
      {%- if cart.item_count > 0 -%}
        <div class="cart-count-bubble">
          <span>{{ cart.item_count }}</span>
        </div>
      {%- endif -%}
    </a>

    <button
      class="header__icon header__icon--menu"
      aria-haspopup="dialog"
      aria-controls="MobileMenuDrawer-{{ section.id }}"
      aria-expanded="false"
      aria-label="Open menu"
      data-mobile-menu-open
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-hamburger"
        aria-hidden="true"
      >
        <line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <a
      href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
      class="header__icon header__icon--account"
      aria-label="{% if customer %}My account{% else %}Sign in{% endif %}"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        fill="currentColor"
        class="icon"
        viewBox="0 0 16 16"
        aria-hidden="true"
      >
        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
      </svg>
    </a>
  </div>
</header>

{% render 'search-popup' %}

{% javascript %}
  (function () {
    function initMegaMenu() {
      var groups = Array.prototype.slice.call(document.querySelectorAll('[data-mega-group]'));
      groups.forEach(function (group) {
        var toggle = group.querySelector('[data-mega-toggle]');
        var panel = group.querySelector('.cmega__panel');
        if (!toggle || toggle.dataset.init === 'true') return;
        toggle.dataset.init = 'true';
        if (panel) panel.inert = true;
        toggle.addEventListener('click', function (e) {
          e.preventDefault();
          var willOpen = !group.classList.contains('is-open');
          // Single-open accordion: collapse the others first.
          groups.forEach(function (other) {
            if (other === group) return;
            other.classList.remove('is-open');
            var t = other.querySelector('[data-mega-toggle]');
            var otherPanel = other.querySelector('.cmega__panel');
            if (t) t.setAttribute('aria-expanded', 'false');
            if (otherPanel) otherPanel.inert = true;
          });
          group.classList.toggle('is-open', willOpen);
          toggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          if (panel) panel.inert = !willOpen;
        });
      });
    }

    function initMobileMenu() {
      var trigger = document.querySelector('[data-mobile-menu-open]');
      var drawer = document.querySelector('[data-mobile-menu-drawer]');
      if (!trigger || !drawer || drawer.dataset.mobileMenuInit === 'true') return;

      drawer.dataset.mobileMenuInit = 'true';
      var panel = drawer.querySelector('.cmega');
      var closeButtons = Array.prototype.slice.call(drawer.querySelectorAll('[data-mobile-menu-close]'));
      var mobileQuery = window.matchMedia('(max-width: 46.8125rem)');
      var previousFocus = null;

      function closeMenu(restoreFocus) {
        drawer.classList.remove('is-mobile-open');
        trigger.setAttribute('aria-expanded', 'false');
        document.documentElement.classList.remove('mobile-menu-is-open');
        if (mobileQuery.matches) drawer.setAttribute('aria-hidden', 'true');
        if (restoreFocus && previousFocus instanceof HTMLElement) previousFocus.focus();
      }

      function openMenu() {
        if (!mobileQuery.matches) return;
        previousFocus = document.activeElement;
        drawer.classList.add('is-mobile-open');
        drawer.setAttribute('aria-hidden', 'false');
        trigger.setAttribute('aria-expanded', 'true');
        document.documentElement.classList.add('mobile-menu-is-open');
        window.requestAnimationFrame(function () {
          var closeButton = drawer.querySelector('.mobile-menu__close');
          if (closeButton) closeButton.focus();
        });
      }

      function syncMode() {
        closeMenu(false);
        if (mobileQuery.matches) {
          drawer.setAttribute('role', 'dialog');
          drawer.setAttribute('aria-modal', 'true');
          drawer.setAttribute('aria-label', 'Shop by category');
          drawer.setAttribute('aria-hidden', 'true');
        } else {
          drawer.removeAttribute('role');
          drawer.removeAttribute('aria-modal');
          drawer.removeAttribute('aria-label');
          drawer.removeAttribute('aria-hidden');
        }
      }

      trigger.addEventListener('click', openMenu);
      closeButtons.forEach(function (button) {
        button.addEventListener('click', function () {
          closeMenu(true);
        });
      });

      drawer.addEventListener('click', function (event) {
        if (event.target.closest('a') && mobileQuery.matches) closeMenu(false);
      });

      document.addEventListener('keydown', function (event) {
        if (!drawer.classList.contains('is-mobile-open')) return;
        if (event.key === 'Escape') {
          closeMenu(true);
          return;
        }
        if (event.key !== 'Tab' || !panel) return;

        var focusable = Array.prototype.slice
          .call(panel.querySelectorAll('a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])'))
          .filter(function (element) {
            return element.offsetParent !== null && !element.closest('[inert]');
          });
        if (!focusable.length) return;
        var first = focusable[0];
        var last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      });

      if (mobileQuery.addEventListener) mobileQuery.addEventListener('change', syncMode);
      syncMode();
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        initMegaMenu();
        initMobileMenu();
      });
    } else {
      initMegaMenu();
      initMobileMenu();
    }
  })();
{% endjavascript %}

{% stylesheet %}
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4, 10px);
    padding-inline: var(--space-4, 10px);
    background-color: transparent;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 99;
  }

  /* Prevent injected elements (like Shopify's clear:both div) from breaking flex layout */
  .header > :not(.header__left):not(.header__right) {
    display: none !important;
  }

  .header__left {
    display: flex;
    align-items: center;
    gap: var(--space-12, 24px);
  }

  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    gap: 20px;
    margin: 0 18px;
    padding: 0;
    list-style: none;
    align-items: center;
  }
  .header__nav-list li {
    margin: 0;
    position: relative;
    padding-block: 8px;
  }

  .header__nav-item {
    display: flex;
    align-items: center;
    gap: 6px;
    border: 0;
    background: transparent;
    text-decoration: none;
    color: var(--color-earth-brown, #333);
    font-family: var(--font-roboto, sans-serif);
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05rem;
    transition: color var(--transition-fast, 0.2s);
    padding: 10px 0;
    white-space: nowrap;
    position: relative;
    cursor: pointer;
  }

  .header__nav-item::after {
    content: '';
    position: absolute;
    bottom: 6px;
    left: 0;
    width: 0;
    height: 1.5px;
    background-color: currentColor;
    transition: width 0.3s ease;
  }

  .header__nav-item:hover::after,
  .header__nav-item:focus::after {
    width: 100%;
  }

  .header__nav-item .icon-caret {
    width: 12px;
    height: auto;
    fill: currentColor;
    opacity: 0.8;
    transition: transform 0.2s ease;
  }

  /* Mega Menu Styles */
  .header__nav-item-has-mega-menu:hover .header__mega-menu,
  .header__nav-item-has-mega-menu:focus-within .header__mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
  }

  /* Room popovers are anchored to each navigation item. */
  .header__mega-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    width: fit-content;
    max-width: 900px;
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transform: translateX(-50%) translateY(5px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    font-family: var(--font-body);
  }

  .header__mobile-menu {
    display: none;
  }

  .mobile-menu__overlay,
  .mobile-menu__bar,
  .cmega__consultation,
  .cmega__account,
  .cmega__localization {
    display: none;
  }

  .cmega {
    margin: 0 auto;
    display: flex;
    width: fit-content;
    max-width: 1180px;
    max-height: calc(100dvh - 136px);
    overflow: hidden auto;
    background-color: var(--color-milk);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-elevation-3);
    padding: var(--sp-4) var(--sp-3) var(--sp-2);
  }

  /* Category column */
  .cmega__cats {
    min-width: 0;
    height: fit-content;
  }
  .cmega__heading {
    margin: 0 0 var(--sp-2);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-black);
    font-family: var(--font-roboto);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .cmega__groups-wrap {
    display: grid;
    grid-template-columns: repeat(1, minmax(236px, 1fr));
    align-items: start;
  }
  .cmega__groups {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    list-style: none;
    min-width: 0;
  }
  .cmega__groups:first-child {
    padding-right: var(--sp-4);
    border-right: 1px solid var(--border-light);
  }
  .cmega__groups:last-child {
    padding-left: var(--sp-4);
  }
  .cmega__group + .cmega__group {
    border-top: 1px solid var(--border-light);
  }
  .cmega__group-head {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    width: 100%;
    padding: var(--sp-3) var(--sp-4);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: var(--text-primary);
    border-radius: var(--radius-md);
    transition: background-color var(--timing-short) var(--ease-standard);
  }
  .cmega__group-head:hover,
  .cmega__group.is-open > .cmega__group-head {
    background-color: var(--color-cream);
  }
  .cmega__group-text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1 1 auto;
    min-width: 0;
  }
  .cmega__group-name {
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }
  .cmega__group-desc {
    font-size: var(--font-size-caption);
    color: var(--text-secondary);
  }
  .cmega__group-caret {
    display: flex;
    flex: 0 0 auto;
    color: var(--text-secondary);
    transition: transform var(--timing-short) var(--ease-standard), color var(--timing-short) var(--ease-standard);
  }
  .cmega__group-caret svg {
    width: 16px;
    height: 16px;
  }
  .cmega__group.is-open .cmega__group-caret {
    transform: rotate(90deg);
    color: var(--color-earth-brown);
  }

  /* Accordion panel (animated collapse via grid-template-rows) */
  .cmega__panel {
    display: grid;
    grid-template-rows: minmax(var(--sp-0), 0fr);
    overflow: hidden;
    transition: grid-template-rows var(--timing-base) var(--ease-standard);
  }
  .cmega__group.is-open .cmega__panel {
    grid-template-rows: minmax(var(--sp-0), 1fr);
  }
  .cmega__collections {
    overflow: hidden;
    min-height: 0;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cmega__collections li {
    margin: 0;
  }
  .cmega__collections a {
    position: relative;
    display: block;
    padding: var(--sp-2) var(--sp-4) var(--sp-2) calc(var(--sp-4) + 30px + var(--sp-4));
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--timing-short) var(--ease-standard),
      background-color var(--timing-short) var(--ease-standard);
  }
  .cmega__collections a:hover {
    color: var(--color-earth-brown);
    background-color: var(--color-cream);
  }
  .cmega__collections a::after {
    content: '';
    position: absolute;
    left: var(--sp-4);
    bottom: var(--sp-2);
    width: 0;
    height: var(--border-width);
    background-color: currentColor;
    transition: width var(--timing-short) var(--ease-standard);
  }
  .cmega__collections a:hover::after,
  .cmega__collections a:focus-visible::after {
    width: calc(100% - (var(--sp-4) * 2));
  }
  .cmega__collections li:last-child a {
    padding-bottom: var(--sp-3);
  }

  .cmega__collections--room {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4, 16px);
  }

  .cmega__collections--room li {
    flex: 0 0 auto;
    margin: 0;
  }

  .cmega__collections--room a {
    position: relative;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    height: 160px;
    aspect-ratio: 5 / 3;
    padding: var(--sp-4);
    border-radius: var(--radius-md, 8px);
    overflow: hidden;
    text-decoration: none;
    background-color: var(--color-milk, #f5f5f5);
  }

  .cmega__collections--room a:hover {
    background-color: var(--color-milk, #f5f5f5);
  }

  .cmega__collections--room a::after {
    display: none;
  }

  .cmega__collection-image-wrapper {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .cmega__collection-image-wrapper::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0) 50%);
    z-index: 1;
  }

  .cmega__collection-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  
  .placeholder-svg {
    background-color: #f1f1f1;
  }

  .cmega__collection-title {
    position: relative;
    z-index: 2;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: var(--font-size-body-md, 14px);
    font-weight: var(--font-weight-bold, 700);
    text-align: center;
    line-height: 1.3;
    text-shadow: 0 1px 3px rgba(0,0,0,0.5);
    transition: transform 0.3s ease;
  }

  .cmega__collections--room a:hover .cmega__collection-title {
    transform: translateY(-5px);
    color: #ffffff;
  }

  .cmega__empty {
    margin: var(--sp-2) 0 var(--sp-2) !important;
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-normal);
    max-width: 100%;
    width: max-content;
    overflow-wrap: anywhere;
    padding: var(--sp-3) var(--sp-4);
  }

  @media screen and (max-width: 900px) {
    .cmega {
      flex-direction: column;
      width: 100%;
      max-width: 620px;
    }
    .cmega__groups-wrap {
      grid-template-columns: 1fr;
    }
    .cmega__groups:first-child {
      padding-right: 0;
      border-right: none;
    }
    .cmega__groups:last-child {
      padding-left: 0;
    }
  }

  @media screen and (max-width: 46.8125rem) {
    .cmega__collections--room {
      gap: 12px;
      padding: var(--sp-2) 0;
      flex-direction: column;
    }
    .cmega__collections--room a {
      width: 100% !important;
      height: 150px;
      padding: var(--sp-3);
    }
    .cmega__collection-title {
      font-size: var(--font-size-body-sm, 12px);
    }
    
    .mobile-menu-is-open {
      overflow: hidden;
    }

    .header__nav {
      position: absolute;
      display: block;
      inline-size: var(--sp-0);
      block-size: var(--sp-0);
    }

    .header__nav-list {
      display: block;
      margin: var(--sp-0);
      padding: var(--sp-0);
    }

    .header__nav-list > li:not(.header__nav-item-has-mega-menu) {
      display: none;
    }

    .header__nav-item-has-mega-menu {
      padding: var(--sp-0) !important;
    }

    .header__nav-item-has-mega-menu > .header__nav-item {
      display: none;
    }

    .header__nav-item-has-mega-menu:hover .header__mega-menu,
    .header__nav-item-has-mega-menu:focus-within .header__mega-menu,
    .header__mega-menu {
      position: fixed;
      inset: var(--sp-0);
      z-index: var(--z-overlay);
      display: flex;
      justify-content: flex-end;
      inline-size: 100%;
      max-inline-size: none;
      block-size: 100dvh;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transform: none;
      transition: opacity var(--timing-base) var(--ease-standard), visibility var(--timing-base) var(--ease-standard);
    }

    .header__nav-item-has-mega-menu:hover .header__mega-menu.is-mobile-open,
    .header__nav-item-has-mega-menu:focus-within .header__mega-menu.is-mobile-open,
    .header__mega-menu.is-mobile-open {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .mobile-menu__overlay {
      position: absolute;
      inset: var(--sp-0);
      display: block;
      inline-size: 100%;
      block-size: 100%;
      padding: var(--sp-0);
      border: 0;
      background: var(--bg-overlay);
      cursor: pointer;
    }

    .header__mega-menu .cmega {
      position: relative;
      z-index: var(--z-drawer);
      display: block;
      inline-size: calc(100% - var(--sp-4));
      max-inline-size: calc(var(--sp-12) * 3);
      block-size: 100dvh;
      max-block-size: 100dvh;
      margin: var(--sp-0) var(--sp-0) var(--sp-0) auto;
      overflow: hidden auto;
      overscroll-behavior: contain;
      border: 0;
      border-inline-start: var(--border-width) solid var(--border-light);
      border-radius: var(--radius-none);
      background: var(--color-milk);
      box-shadow: var(--shadow-modal);
      transform: translateX(100%);
      transition: transform var(--timing-long) var(--ease-out);
      padding: var(--sp-2) var(--sp-3) var(--sp-2);
    }

    .header__mega-menu.is-mobile-open .cmega {
      transform: translateX(var(--sp-0));
    }

    .mobile-menu__bar {
      inset-block-start: var(--sp-0);
      z-index: 2;
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-block-size: var(--sp-7);
      padding-inline: var(--sp-4) var(--sp-1);
      border-block-end: var(--border-width) solid var(--border-light);
      background: var(--color-milk);
    }

    .mobile-menu__title {
      color: var(--color-earth-brown);
      font-family: var(--font-display);
      font-size: var(--font-size-body-xl);
      font-weight: var(--font-weight-medium);
    }

    .mobile-menu__close {
      position: relative;
      inline-size: var(--sp-7);
      block-size: var(--sp-7);
      padding: var(--sp-0);
      border: 0;
      border-radius: var(--radius-full);
      background: transparent;
      color: var(--color-earth-brown);
      cursor: pointer;
    }
    .mobile-menu__close svg {
      height: 28px;
      width: 28px;
      margin: auto;
    }

    .mobile-menu__close::after {
      transform: translate(-50%, -50%) rotate(-45deg);
    }

    .mobile-menu__close:focus-visible,
    .cmega__group-head:focus-visible,
    .cmega__collections a:focus-visible {
      outline: calc(var(--border-width) * 2) solid var(--color-sage);
      outline-offset: calc(var(--border-width) * -2);
    }

    .header__mega-menu .cmega__cats {
      block-size: auto;
      padding: var(--sp-5) var(--sp-4) var(--sp-2);
    }

    .header__mega-menu .cmega__heading {
      margin-block-end: var(--sp-3);
      color: var(--color-earth-brown);
      font-size: var(--font-size-caption);
      letter-spacing: calc(var(--letter-spacing-wide) * 5);
    }

    .header__mega-menu .cmega__groups-wrap {
      display: block;
    }

    .header__mega-menu .cmega__groups:first-child,
    .header__mega-menu .cmega__groups:last-child {
      padding-inline: var(--sp-0);
      border: 0;
    }

    .header__mega-menu .cmega__groups:last-child .cmega__group:first-child {
      border-block-start: var(--border-width) solid var(--border-light);
    }

    .header__mega-menu .cmega__group-head {
      gap: var(--sp-4);
      min-block-size: calc(var(--sp-8) + var(--sp-3));
      padding: var(--sp-3) var(--sp-2);
      border-radius: var(--radius-none);
    }

    .header__mega-menu .cmega__group-name {
      color: var(--text-primary);
      font-family: var(--font-display);
      font-size: var(--font-size-body-lg);
      font-weight: var(--font-weight-medium);
      line-height: var(--line-height-tight);
    }

    .header__mega-menu .cmega__group-desc {
      color: var(--text-secondary);
      font-size: var(--font-size-caption);
      line-height: var(--line-height-normal);
    }

    .header__mega-menu .cmega__group-caret svg {
      inline-size: var(--sp-5);
      block-size: var(--sp-5);
    }

    .header__mega-menu .cmega__collections a {
      min-block-size: var(--sp-7);
      padding: var(--sp-3) var(--sp-4);
      color: var(--text-secondary);
      font-size: var(--font-size-body-sm);
    }

    /* Account icon lives inside the drawer on mobile, not in the header bar.
       Scoped to .header__right to outrank the later base .header__icon rule. */
    .header__right .header__icon--account {
      display: none;
      color: var(--color-milk);
    }

    .cmega__consultation {
      display: block;
      padding: var(--sp-4);
      border-block-end: var(--border-width) solid var(--border-light);
      background: var(--color-milk);
    }

    .cmega__consultation .cmega__consultation-link {
      display: flex;
      inline-size: 100%;
      min-block-size: var(--sp-7);
      margin: var(--sp-0);
      padding-inline: var(--sp-4);
    }

    /* Dedicated account section pinned to the top of the drawer (above the
       category list) so it is reachable without scrolling. */
    .cmega__account,
    .cmega__localization {
      display: block;
      padding: var(--sp-5) var(--sp-4);
      border-block-end: var(--border-width) solid var(--border-light);
      background: var(--color-milk);
    }

    .cmega__account .cmega__heading {
      margin-block-end: var(--sp-3);
      color: var(--color-earth-brown);
      font-family: var(--font-roboto);
      font-size: var(--font-size-caption);
      font-weight: var(--font-weight-semibold);
      letter-spacing: calc(var(--letter-spacing-wide) * 5);
      text-transform: uppercase;
    }

    .cmega__account-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--sp-3);
      inline-size: 100%;
      min-block-size: var(--sp-7);
      padding-inline: var(--sp-5);
      border: 0;
      border-radius: var(--radius-md);
      background: var(--color-earth-brown);
      color: var(--text-inverse);
      font-family: var(--font-body);
      font-size: var(--font-size-body-md);
      font-weight: var(--font-weight-semibold);
      letter-spacing: var(--letter-spacing-wide);
      text-decoration: none;
      cursor: pointer;
      transition: background-color var(--timing-short) var(--ease-standard);
    }

    .cmega__account-btn:hover {
      background: var(--color-charcoal);
    }

    .cmega__account-btn-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    .cmega__account-note {
      margin: var(--sp-3) var(--sp-0) var(--sp-0);
      color: var(--text-secondary);
      font-size: var(--font-size-body-sm);
      line-height: var(--line-height-normal);
    }

    .cmega__account-logout {
      display: inline-block;
      margin-block-start: var(--sp-3);
      color: var(--text-secondary);
      font-size: var(--font-size-body-sm);
      text-decoration: underline;
      text-underline-offset: 3px;
    }

    .cmega__account-logout:hover {
      color: var(--color-earth-brown);
    }
  }

  .header__right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .header__localization {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .header__localization {
      display: inline-flex;
      margin-right: var(--space-2, 10px);
    }
  }

  .cmega__localization .cmega__heading {
    margin-block-end: var(--sp-3);
  }

  .header__consultation-link {
    display: none;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    border: 1px solid color-mix(in srgb, var(--color-earth-brown) 54%, transparent);
    border-radius: var(--radius-full);
    background-color: rgba(247, 242, 236, 0.62);
    color: var(--color-earth-brown);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
    margin-right: 10px;
  }

  .header__consultation-link:hover {
    background-color: var(--color-earth-brown);
    color: var(--color-cream);
    transform: translateY(-1px);
  }

  .header__heading {
    margin: 0;
    display: flex;
    align-items: center;
  }

  .header__heading-link {
    text-decoration: none;
    color: var(--color-1, #000);
    display: block;
    line-height: 1;
  }

  .header__heading-logo {
    max-width: fit-content;
    height: 52px;
  }

  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    text-decoration: none;
    position: relative;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.2s ease;
  }
  .header__icon:hover {
    transform: scale(1.1);
  }
  .header__icon:focus {
    outline: none;
  }
  .header__icon:focus-visible {
    outline: 2px solid var(--color-1, #000);
    outline-offset: 2px;
  }

  .header__icon.header__icon--cart {
    color: var(--color-cream, #f5f1ed);
  }

  /* Gray circle background for icons like in the screenshot */
  .header__icon--search,
  .header__icon--menu {
    border-radius: var(--radius-full, 50%);
  }

  .header__icon--search {
    color: var(--color-cream, #f5f1ed);
  }
  .header__icon--search:hover {
    color: var(--color-cream, #f5f1ed);
  }

  .header__icon svg {
    width: 24px;
    height: 24px;
  }

  .cart-count-bubble {
    position: absolute;
    top: 5px;
    right: 5px;
    background-color: var(--color-2, #e60023);
    color: var(--color-10, #fff);
    font-size: var(--text-sm, 14px);
    font-weight: bold;
    border-radius: var(--radius-full, 50%);
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(25%, -25%);
  }

  @media screen and (min-width: 750px) {
    .header__right {
      gap: var(--space-2, 10px);
    }

    .header {
      padding-inline: 32px;
      padding-block: var(--space-9, 12px) calc(var(--space-9, 12px) - 3px);
    }

    .header__icon--menu {
      display: none;
    }

    .header__nav {
      display: block;
    }
  }

  @media screen and (min-width: 1180px) {
    .header__consultation-link {
      display: inline-flex;
    }
  }

  @media screen and (max-width: 1180px) and (min-width: 750px) {
    .header__nav-list {
      gap: 14px;
      margin-inline: 12px;
    }

    .header__nav-item {
      font-size: 11px;
      letter-spacing: 0.07em;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "text",
      "id": "logo_asset",
      "label": "Local Asset Logo",
      "info": "Filename of an image in the assets folder e.g. logo.png"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Mega Menu Promotion"
    },
    {
      "type": "image_picker",
      "id": "mega_menu_image",
      "label": "Promotion Image"
    },
    {
      "type": "url",
      "id": "mega_menu_link",
      "label": "Promotion Link"
    }
  ]
}
{% endschema %}
