<header class="header page-width">
  <div class="header__left">
    <h1 class="header__heading">
      <a href="{{ routes.root_url }}" class="header__heading-link">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 400
            | image_tag:
              class: 'header__heading-logo',
              widths: '100, 200, 300, 400',
              height: section.settings.logo.height,
              width: section.settings.logo.width,
              alt: section.settings.logo.alt
            | default: shop.name
            | escape
          }}
        {%- elsif section.settings.logo_asset != blank -%}
          <img
            src="{{ section.settings.logo_asset | asset_url }}"
            class="header__heading-logo"
            alt="{{ shop.name | escape }}"
            width="150"
            height="auto"
          >
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </h1>

    <nav class="header__nav">
      <ul class="header__nav-list">
        <li><a href="{{ pages['faq'].url }}?view=faq" class="header__nav-item">FAQ</a></li>
        <li><a href="{{ pages['about-us'].url }}?view=about-us" class="header__nav-item">About Us</a></li>
        <li class="header__nav-item-has-mega-menu">
          <a href="/pages/collections/all" class="header__nav-item">
            Collections
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
            </svg>
          </a>

          {%- capture cm_ico_room -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 11V8.5A2.5 2.5 0 0 1 7.5 6h9A2.5 2.5 0 0 1 19 8.5V11"/><path d="M4 12a2 2 0 0 1 2 2v2h12v-2a2 2 0 0 1 4 0v4a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-4a2 2 0 0 1 2-2Z"/><path d="M6 19v1.5"/><path d="M18 19v1.5"/></svg>
          {%- endcapture -%}
          {%- capture cm_ico_tables -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h18"/><path d="M5 8l-1 12"/><path d="M19 8l1 12"/><path d="M9 8v12"/><path d="M15 8v12"/></svg>
          {%- endcapture -%}
          {%- capture cm_ico_storage -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="7" y1="20" x2="7" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="17" y1="20" x2="17" y2="13"/></svg>
          {%- endcapture -%}
          {%- capture cm_ico_decor -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3h8"/><path d="M9 3c0 2.5-2.5 3.5-2.5 8A5.5 5.5 0 0 0 12 21a5.5 5.5 0 0 0 5.5-10c0-4.5-2.5-5.5-2.5-8"/></svg>
          {%- endcapture -%}
          {%- capture cm_chevron -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
          {%- endcapture -%}
          {%- capture cm_arrow -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="12" x2="20" y2="12"/><polyline points="13 5 20 12 13 19"/></svg>
          {%- endcapture -%}
          {%- capture cm_leaf -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
          {%- endcapture -%}
          {%- capture cm_badge -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="9" r="6"/><path d="M9 14.2 8 22l4-2.4L16 22l-1-7.8"/></svg>
          {%- endcapture -%}
          {%- capture cm_truck -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="1" y="5" width="13" height="11" rx="1"/><path d="M14 8h4l3 3v5h-7z"/><circle cx="5.5" cy="18" r="1.7"/><circle cx="17.5" cy="18" r="1.7"/></svg>
          {%- endcapture -%}
          {%- capture cm_shield -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6z"/><path d="M9 12l2 2 4-4"/></svg>
          {%- endcapture -%}

          <div class="header__mega-menu">
            <div class="collections-popover">
              <div class="cp-top">
                <div class="cp-main">
                  <div class="cp-head">
                    <h2 class="cp-head__title">Collections</h2>
                    <p class="cp-head__subtitle">Timeless designs, thoughtfully crafted for every space.</p>
                    <span class="cp-head__rule" aria-hidden="true"></span>
                  </div>

                  <div class="cp-cols">
                    <div class="cp-col">
                      <span class="cp-col__icon">{{ cm_ico_room }}</span>
                      <h3 class="cp-col__title">Shop by Room</h3>
                      <ul class="cp-col__list">
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/bedroom-furniture"
                            ><span>Bedroom Furniture</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/living-room-furniture"
                            ><span>Living Room Furniture</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/dining-room-furniture"
                            ><span>Dining Room Furniture</span>{{ cm_chevron -}}
                          </a>
                        </li>
                      </ul>
                    </div>

                    <div class="cp-col">
                      <span class="cp-col__icon">{{ cm_ico_tables }}</span>
                      <h3 class="cp-col__title">Tables &amp; Surfaces</h3>
                      <ul class="cp-col__list">
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/coffee-table"
                            ><span>Coffee Table</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/console-table"
                            ><span>Console Table</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/end-table"
                            ><span>End Table</span>{{ cm_chevron -}}
                          </a>
                        </li>
                      </ul>
                    </div>

                    <div class="cp-col">
                      <span class="cp-col__icon">{{ cm_ico_storage }}</span>
                      <h3 class="cp-col__title">Shelving &amp; Storage</h3>
                      <ul class="cp-col__list">
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/bookshelf"
                            ><span>Bookshelf</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/floating-shelf"
                            ><span>Floating Shelf</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/wall-shelf"
                            ><span>Wall Shelf</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/storage-cabinet"
                            ><span>Storage Cabinet</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/entryway-shoe-bench-rack"
                            ><span>Entryway Shoe Bench Rack</span>{{ cm_chevron -}}
                          </a>
                        </li>
                      </ul>
                    </div>

                    <div class="cp-col">
                      <span class="cp-col__icon">{{ cm_ico_decor }}</span>
                      <h3 class="cp-col__title">Decor &amp; Specialty</h3>
                      <ul class="cp-col__list">
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/wooden-fruit-bowl"
                            ><span>Wooden Fruit Bowl</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/wooden-plant-stand"
                            ><span>Wooden Plant Stand</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/wooden-lamp-base"
                            ><span>Wooden Lamp Base</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/jewelry-tree-organizer-stand"
                            ><span>Jewelry Tree Organizer Stand</span>{{ cm_chevron -}}
                          </a>
                        </li>
                        <li class="cp-col__item">
                          <a class="cp-col__link" href="/collections/wine-rack"
                            ><span>Wine Rack</span>{{ cm_chevron -}}
                          </a>
                        </li>
                      </ul>
                    </div>
                  </div>
                </div>

                <div class="cp-feature">
                  <span class="cp-feature__media">
                    <img
                      class="cp-feature__img"
                      src="{{ 'search-popup-bedroom.png' | asset_url }}"
                      alt="Bedroom Furniture"
                      width="720"
                      height="450"
                      loading="lazy"
                    >
                  </span>
                  <div class="cp-feature__body">
                    <h3 class="cp-feature__title">Bedroom Furniture</h3>
                    <p class="cp-feature__desc">Restful. Refined. Timeless pieces designed for true comfort.</p>
                    <a class="cp-feature__cta" href="/collections/bedroom-furniture">
                      <span>Shop Bedroom</span>
                      <span class="cp-feature__arrow">{{ cm_arrow }}</span>
                    </a>
                  </div>
                </div>
              </div>

              <div class="cp-footer">
                <div class="cp-trust">
                  <span class="cp-trust__icon">{{ cm_leaf }}</span>
                  <span class="cp-trust__body">
                    <span class="cp-trust__title">Sustainable Craftsmanship</span>
                    <span class="cp-trust__desc">Ethical materials, built to last.</span>
                  </span>
                </div>
                <div class="cp-trust">
                  <span class="cp-trust__icon">{{ cm_badge }}</span>
                  <span class="cp-trust__body">
                    <span class="cp-trust__title">Timeless Design</span>
                    <span class="cp-trust__desc">Elevate your space for years.</span>
                  </span>
                </div>
                <div class="cp-trust">
                  <span class="cp-trust__icon">{{ cm_truck }}</span>
                  <span class="cp-trust__body">
                    <span class="cp-trust__title">White Glove Delivery</span>
                    <span class="cp-trust__desc">Carefully delivered to your home.</span>
                  </span>
                </div>
                <div class="cp-trust">
                  <span class="cp-trust__icon">{{ cm_shield }}</span>
                  <span class="cp-trust__body">
                    <span class="cp-trust__title">Secure Shopping</span>
                    <span class="cp-trust__desc">Encrypted checkout you can trust.</span>
                  </span>
                </div>
              </div>
            </div>
          </div>
        </li>
      </ul>
    </nav>
  </div>

  <div class="header__right">
    <a
      href="{{ routes.search_url }}"
      class="header__icon header__icon--search"
      aria-label="{{ 'general.search.search' | t | default: 'Search' }}"
      onclick="window.openSearchPopup(event)"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-search"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </a>

    <a
      href="{{ routes.cart_url }}"
      class="header__icon header__icon--cart"
      aria-label="{{ 'templates.cart.cart' | t | default: 'Cart' }}"
      aria-haspopup="dialog"
      aria-controls="CartDrawer"
      data-cart-drawer-open
    >
      {{ 'icon-cart.svg' | inline_asset_content }}
      {%- if cart.item_count > 0 -%}
        <div class="cart-count-bubble">
          <span>{{ cart.item_count }}</span>
        </div>
      {%- endif -%}
    </a>

    <button class="header__icon header__icon--menu" aria-haspopup="dialog" aria-label="Menu">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-hamburger"
        aria-hidden="true"
      >
        <line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

{% render 'search-popup' %}

{% stylesheet %}
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4, 10px);
    padding-inline: var(--space-4, 10px);
    background-color: transparent;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 99;
  }

  .header__left {
    display: flex;
    align-items: center;
    gap: var(--space-12, 24px);
  }

  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    gap: 20px;
    margin: 0 18px;
    padding: 0;
    list-style: none;
    align-items: center;
  }
  .header__nav-list li {
    margin: 0;
    position: static;
    padding-block: 8px;
  }

  .header__nav-item {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--color-earth-brown, #333);
    font-family: var(--font-roboto, sans-serif);
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    transition: color var(--transition-fast, 0.2s);
    padding: 10px 0;
  }

  .header__nav-item .icon-caret {
    width: 12px;
    height: auto;
    fill: currentColor;
    opacity: 0.8;
    transition: transform 0.2s ease;
  }

  .header__nav-item:hover {
    color: var(--text-secondary, #666);
  }

  /* Mega Menu Styles */
  .header__nav-item-has-mega-menu:hover .header__mega-menu,
  .header__nav-item-has-mega-menu:focus-within .header__mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* Collections popover — anchored to the header so it sits 26.5px from the viewport's left edge */
  .header__mega-menu {
    position: absolute;
    top: 80%;
    left: 26.5px;
    width: calc(100% - 53px);
    max-width: 1400px;
    z-index: 100;
    opacity: 0;
    visibility: hidden;
    transform: translateY(5px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    font-family: var(--font-body);
  }

  .collections-popover {
    width: 100%;
    max-height: calc(100dvh - 88px);
    overflow: hidden auto;
    background-color: var(--color-milk);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-elevation-3);
  }

  /* Top region: category columns + featured card */
  .cp-top {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-7);
    padding: var(--sp-6) var(--sp-7);
  }
  .cp-main {
    flex: 1 1 auto;
    min-width: 0;
  }

  .cp-head__title {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--color-earth-brown);
  }
  .cp-head__subtitle {
    margin: var(--sp-3) 0 0;
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }
  .cp-head__rule {
    display: block;
    width: 40px;
    height: 2px;
    margin: var(--sp-4) 0 var(--sp-6);
    border-radius: var(--radius-full);
    background-color: var(--color-clay);
  }

  /* Category columns */
  .cp-cols {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    column-gap: var(--sp-6);
    align-items: stretch;
  }
  .cp-col {
    min-width: 0;
    padding-left: var(--sp-6);
    border-left: 1px solid var(--border-light);
  }
  .cp-col:nth-child(4n + 1) {
    padding-left: 0;
    border-left: none;
  }
  .cp-col__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    margin-bottom: var(--sp-3);
    border: 1px solid var(--color-clay);
    border-radius: var(--radius-full);
    color: var(--color-earth-brown);
  }
  .cp-col__icon svg {
    width: 20px;
    height: 20px;
  }
  .cp-col__title {
    margin: 0 0 var(--sp-3);
    font-family: var(--font-display-light);
    font-size: var(--font-size-body-lg);
    font-weight: 700;
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .cp-col__list {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cp-col__item {
    border-bottom: 1px solid var(--border-light);
  }
  .cp-col__item:last-child {
    border-bottom: none;
  }
  .cp-col__link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-2) 0;
    font-size: var(--font-size-body-md);
    color: var(--text-primary);
    text-decoration: none;
    letter-spacing: -0.03em;
    word-spacing: 0.2rem;
    transition: color var(--timing-short) var(--ease-standard);
  }
  .cp-col__link svg {
    flex: 0 0 auto;
    width: 16px;
    height: 16px;
    color: var(--text-secondary);
    transition: transform var(--timing-short) var(--ease-standard), color var(--timing-short) var(--ease-standard);
  }
  .cp-col__link:hover {
    color: var(--color-earth-brown);
  }
  .cp-col__link:hover svg {
    color: var(--color-earth-brown);
    transform: translateX(3px);
  }

  /* Featured card */
  .cp-feature {
    flex: 0 0 280px;
    width: 280px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
  }
  .cp-feature__media {
    display: block;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background-color: var(--bg-secondary);
  }
  .cp-feature__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cp-feature__body {
    padding: var(--sp-4) var(--sp-5) var(--sp-5);
  }
  .cp-feature__title {
    margin: 0 0 var(--sp-2);
    font-family: var(--font-display);
    font-size: 24px;
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .cp-feature__desc {
    margin: 0 0 var(--sp-4);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }
  .cp-feature__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-medium);
    color: var(--color-earth-brown);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .cp-feature__arrow {
    display: inline-flex;
  }
  .cp-feature__arrow svg {
    width: 16px;
    height: 16px;
    transition: transform var(--timing-short) var(--ease-standard);
  }
  .cp-feature__cta:hover .cp-feature__arrow svg {
    transform: translateX(3px);
  }

  /* Footer trust bar */
  .cp-footer {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--border-light);
    background-color: var(--color-cream);
  }
  .cp-trust {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-6) var(--sp-5);
    border-left: 1px solid var(--border-light);
  }
  .cp-trust:nth-child(4n + 1) {
    border-left: none;
  }
  .cp-trust__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 44px;
    height: 44px;
    border: 1px solid var(--border-default);
    border-radius: var(--radius-full);
    color: var(--color-earth-brown);
  }
  .cp-trust__icon svg {
    width: 20px;
    height: 20px;
  }
  .cp-trust__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-width: 0;
  }
  .cp-trust__title {
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    color: var(--text-primary);
  }
  .cp-trust__desc {
    font-size: var(--font-size-body-sm);
    color: var(--text-secondary);
  }

  @media screen and (max-width: 1200px) {
    .cp-top {
      gap: var(--sp-7);
    }
    .cp-feature {
      flex-basis: 300px;
      width: 300px;
    }
  }

  @media screen and (max-width: 1024px) {
    .cp-top {
      flex-direction: column;
    }
    .cp-feature {
      width: 100%;
      flex-basis: auto;
    }
    .cp-cols {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      row-gap: var(--sp-6);
    }
    .cp-col {
      padding-left: var(--sp-6);
      border-left: 1px solid var(--border-light);
    }
    .cp-col:nth-child(2n + 1) {
      padding-left: 0;
      border-left: none;
    }
    .cp-footer {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .cp-trust:nth-child(4n + 1) {
      border-left: 1px solid var(--border-light);
    }
    .cp-trust:nth-child(2n + 1) {
      border-left: none;
    }
  }

  @media screen and (max-width: 768px) {
    .cp-cols {
      grid-template-columns: minmax(0, 1fr);
    }
    .cp-col {
      padding-left: 0;
      border-left: none;
    }
    .cp-footer {
      grid-template-columns: minmax(0, 1fr);
    }
    .cp-trust {
      border-left: none;
    }
    .cp-trust:nth-child(2n + 1) {
      border-left: none;
    }
  }

  /* Compact the menu only when the full-size layout would overflow the viewport:
     - any width on a short viewport, or
     - mid widths (narrow columns wrap → taller) on a not-tall viewport.
     Wide viewports keep the full-size, design-accurate layout. */
  @media screen and (max-height: 739px),
    screen and (min-width: 1025px) and (max-width: 1439px) and (max-height: 959px) {
    .cp-top {
      padding-top: var(--sp-6);
      padding-bottom: var(--sp-4);
    }
    .cp-head__title {
      font-size: var(--font-size-display-sm);
    }
    .cp-head__rule {
      margin: var(--sp-3) 0 var(--sp-4);
    }
    .cp-col__icon {
      width: 34px;
      height: 34px;
      margin-bottom: var(--sp-2);
    }
    .cp-col__icon svg {
      width: 18px;
      height: 18px;
    }
    .cp-col__title {
      margin-bottom: var(--sp-2);
      font-size: var(--font-size-body-md);
    }
    .cp-col__link {
      padding: var(--sp-1) 0;
      font-size: var(--font-size-body-sm);
      line-height: var(--line-height-tight);
    }
    .cp-feature__media {
      aspect-ratio: 1/1;
    }
    .cp-feature__body {
      padding-top: var(--sp-4);
    }
    .cp-feature__title {
      margin-bottom: var(--sp-2);
      font-size: 24px;
    }
    .cp-feature__desc {
      margin-bottom: var(--sp-3);
    }
    .cp-trust {
      padding-block: var(--sp-3);
    }
    .cp-trust__desc {
      font-size: var(--font-size-caption);
    }
  }

  /* Very short viewports: tighten further. */
  @media screen and (max-height: 660px) {
    .cp-top {
      gap: var(--sp-5);
      padding-block: var(--sp-4);
    }
    .cp-head__subtitle {
      margin-top: var(--sp-1);
      font-size: var(--font-size-body-sm);
    }
    .cp-col__link {
      padding: 2px 0;
    }
    .cp-feature__media {
      aspect-ratio: 2 / 1;
    }
    .cp-trust {
      padding-block: var(--sp-2);
    }
  }

  .header__right {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-4, 10px);
  }

  .header__heading {
    margin: 0;
    display: flex;
    align-items: center;
  }

  .header__heading-link {
    text-decoration: none;
    color: var(--color-1, #000);
    display: block;
    line-height: 1;
  }

  .header__heading-logo {
    max-width: 100%;
    height: auto;
    width: 150px;
  }

  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-1, #000);
    background: transparent;
    border: none;
    cursor: pointer;
    text-decoration: none;
    position: relative;
    -webkit-tap-highlight-color: transparent;
  }
  .header__icon:focus {
    outline: none;
  }
  .header__icon:focus-visible {
    outline: 2px solid var(--color-1, #000);
    outline-offset: 2px;
  }

  .header__icon.header__icon--cart {
    color: var(--color-cream, #f5f1ed);
  }

  /* Gray circle background for icons like in the screenshot */
  .header__icon--search,
  .header__icon--menu {
    border-radius: var(--radius-full, 50%);
  }

  .header__icon--search {
    color: var(--color-cream, #f5f1ed);
  }
  .header__icon--search:hover {
    color: var(--color-cream, #f5f1ed);
  }

  .header__icon svg {
    width: 24px;
    height: 24px;
  }

  .cart-count-bubble {
    position: absolute;
    top: 5px;
    right: 5px;
    background-color: var(--color-2, #e60023);
    color: var(--color-10, #fff);
    font-size: var(--text-sm, 14px);
    font-weight: bold;
    border-radius: var(--radius-full, 50%);
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(25%, -25%);
  }

  @media screen and (min-width: 750px) {
    .header {
      padding-inline: 32px;
      padding-block: var(--space-6, 12px);
    }

    .header__icon--menu {
      display: none;
    }

    .header__nav {
      display: block;
    }
  }
{% endstylesheet %}

