<header class="header page-width">
  <div class="header__left">
    {%- comment -%}
      The logo is never an H1. Each template already exposes its own single H1: the homepage uses
      the hero headline (hero-banner), and other templates use the page's own title
      (product, collection, article, page…). Wrapping the logo in a plain <div> keeps every page
      to exactly one H1. See doc/SEO-diagnose.md #1 and audit SEO-01.
    {%- endcomment -%}
    {%- assign header_heading_tag = 'div' -%}
    {%- assign logo_alt = section.settings.logo.alt | default: shop.name -%}
    <{{ header_heading_tag }} class="header__heading">
      <a href="{{ routes.root_url }}" class="header__heading-link">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 400
            | image_tag:
              class: 'header__heading-logo',
              widths: '100, 200, 300, 400',
              height: section.settings.logo.height,
              width: section.settings.logo.width,
              alt: logo_alt
          }}
        {%- elsif section.settings.logo_asset != blank -%}
          <img
            src="{{ section.settings.logo_asset | file_url }}"
            class="header__heading-logo"
            alt="{{ shop.name | escape }}"
            height="auto"
          >
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </{{ header_heading_tag }}>

    <nav class="header__nav">
      <ul class="header__nav-list">
        <li class="header__nav-item-has-mega-menu">
          <a href="{{ routes.collections_url }}" class="header__nav-item">
            Collections
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
            </svg>
          </a>

          {%- capture mm_ico_tables -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h18"/><path d="M5 8l-1 12"/><path d="M19 8l1 12"/><path d="M9 8v12"/><path d="M15 8v12"/></svg>
          {%- endcapture -%}
          {%- capture mm_ico_shelving -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="4" width="16" height="16" rx="1"/><path d="M4 9.5h16"/><path d="M4 15h16"/></svg>
          {%- endcapture -%}
          {%- capture mm_ico_storage -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="3" width="16" height="18" rx="1"/><path d="M4 12h16"/><path d="M10 7.5h1.5"/><path d="M10 16.5h1.5"/></svg>
          {%- endcapture -%}
          {%- capture mm_ico_decor -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3h8"/><path d="M9 3c0 2.5-2.5 3.5-2.5 8A5.5 5.5 0 0 0 12 21a5.5 5.5 0 0 0 5.5-10c0-4.5-2.5-5.5-2.5-8"/></svg>
          {%- endcapture -%}
          {%- capture mm_ico_lighting -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8 3h8l2.5 7h-13z"/><path d="M12 10v8"/><path d="M9 21h6"/><path d="M10 21v-3h4v3"/></svg>
          {%- endcapture -%}
          {%- capture mm_ico_plant -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 21v-8"/><path d="M12 13c0-3.3-2.2-5.5-5.5-5.5C6.5 10.8 8.7 13 12 13Z"/><path d="M12 14c0-3.3 2.2-5.5 5.5-5.5C17.5 11.8 15.3 14 12 14Z"/><path d="M8.5 21h7"/></svg>
          {%- endcapture -%}
          {%- capture mm_ico_wine -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 2h4v4l1.4 2.8a3 3 0 0 1 .3 1.3V21a1 1 0 0 1-1 1H9.3a1 1 0 0 1-1-1V10.1a3 3 0 0 1 .3-1.3L10 6z"/><path d="M8.5 13h7"/></svg>
          {%- endcapture -%}
          {%- capture mm_ico_pet -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="7" cy="9" r="1.6"/><circle cx="12" cy="7.2" r="1.6"/><circle cx="17" cy="9" r="1.6"/><path d="M12 12.5c-2.4 0-4.3 1.8-4.3 3.9 0 1.3 1 1.9 2.3 1.9.8 0 1.3-.4 2-.4s1.2.4 2 .4c1.3 0 2.3-.6 2.3-1.9 0-2.1-1.9-3.9-4.3-3.9Z"/></svg>
          {%- endcapture -%}
          {%- capture mm_ico_bed -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 18v-5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v5"/><path d="M3 14h18"/><path d="M7 11V9a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v2"/><path d="M3 18v2"/><path d="M21 18v2"/></svg>
          {%- endcapture -%}
          {%- capture mm_chevron -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="9 6 15 12 9 18"/></svg>
          {%- endcapture -%}
          {%- capture mm_arrow -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="4" y1="12" x2="20" y2="12"/><polyline points="13 5 20 12 13 19"/></svg>
          {%- endcapture -%}

          {%- liquid
            assign explore_link = section.settings.mega_menu_link | default: routes.collections_url
          -%}

          <div class="header__mega-menu" id="MobileMenuDrawer-{{ section.id }}" data-mobile-menu-drawer>
            <button
              type="button"
              class="mobile-menu__overlay"
              aria-label="Close menu"
              data-mobile-menu-close
              tabindex="-1"
            ></button>
            <div class="cmega custom-scrollbar">
              <div class="mobile-menu__bar">
                <span class="mobile-menu__title">Menu</span>
                <button type="button" class="mobile-menu__close" aria-label="Close menu" data-mobile-menu-close>
                  <span aria-hidden="true"></span>
                </button>
              </div>

              {%- comment -%} Account — shown only inside the mobile drawer (the header icon is hidden on mobile). {%- endcomment -%}
              <div class="cmega__account">
                <p class="cmega__heading">Account</p>
                {%- if customer -%}
                  <a class="cmega__account-btn" href="{{ routes.account_url }}">
                    <span class="cmega__account-btn-icon" aria-hidden="true">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        fill="currentColor"
                        viewBox="0 0 16 16"
                      >
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                      </svg>
                    </span>
                    <span>My account</span>
                  </a>
                  <a class="cmega__account-logout" href="{{ routes.account_logout_url }}">Log out</a>
                {%- else -%}
                  <a class="cmega__account-btn" href="{{ routes.account_login_url }}" data-mobile-menu-close>
                    <span class="cmega__account-btn-icon" aria-hidden="true">
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="18"
                        height="18"
                        fill="currentColor"
                        viewBox="0 0 16 16"
                      >
                        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
                      </svg>
                    </span>
                    <span>Sign in</span>
                  </a>
                  <p class="cmega__account-note">Secure passwordless sign-in — we email you a one-time code.</p>
                {%- endif -%}
              </div>

              {%- comment -%} Country / currency selector — mobile drawer copy. {%- endcomment -%}
              {%- if localization.available_countries.size > 1 -%}
                <div class="cmega__localization">
                  <p class="cmega__heading">{{ 'general.localization.country_label' | t }}</p>
                  {% render 'localization-selector', variant: 'drawer', id: 'mobile-drawer' %}
                </div>
              {%- endif -%}

              {%- comment -%} Primary nav links — mirrors the desktop header nav (hidden on desktop). {%- endcomment -%}
              <nav class="cmega__nav" aria-label="Main">
                <ul class="cmega__nav-list">
                  <li class="cmega__nav-item">
                    <a class="cmega__nav-link" href="/collections/all" data-mobile-menu-close>Explore All Pieces</a>
                  </li>
                  <li class="cmega__nav-item">
                    <a
                      class="cmega__nav-link"
                      href="{{ pages['faq'].url | default: '/pages/faq' }}?view=faq"
                      data-mobile-menu-close
                      >FAQ</a
                    >
                  </li>
                  <li class="cmega__nav-item">
                    <a
                      class="cmega__nav-link"
                      href="{{ pages['about-us'].url | default: '/pages/about-us' }}?view=about-us"
                      data-mobile-menu-close
                      >About Us</a
                    >
                  </li>
                  <li class="cmega__nav-item">
                    <a
                      class="cmega__nav-link"
                      href="{{ pages['contact'].url | default: '/pages/contact' }}"
                      data-mobile-menu-close
                      >Contact</a
                    >
                  </li>
                </ul>
              </nav>

              <div class="cmega__cats">
                <p class="cmega__heading">Shop by Category</p>
                <div class="cmega__groups-wrap">
                  <ul class="cmega__groups">
                    <li class="cmega__group" data-mega-group>
                      <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                        <span class="cmega__group-icon">{{ mm_ico_tables }}</span>
                        <span class="cmega__group-text">
                          <span class="cmega__group-name">Tables &amp; Surfaces</span>
                          <span class="cmega__group-desc">Coffee tables, console tables &amp; more</span>
                        </span>
                        <span class="cmega__group-caret">{{ mm_chevron }}</span>
                      </button>
                      <div class="cmega__panel">
                        <ul class="cmega__collections">
                          <li><a href="/collections/coffee-table-modern">Coffee Table (Modern)</a></li>
                          <li><a href="/collections/coffee-table-rustic">Coffee Table (Rustic)</a></li>
                          <li><a href="/collections/console-table">Console Table</a></li>
                          <li><a href="/collections/end-table">End Table</a></li>
                        </ul>
                      </div>
                    </li>

                    <li class="cmega__group" data-mega-group>
                      <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                        <span class="cmega__group-icon">{{ mm_ico_shelving }}</span>
                        <span class="cmega__group-text">
                          <span class="cmega__group-name">Shelving &amp; Display</span>
                          <span class="cmega__group-desc">Bookshelves, shelves &amp; mantels</span>
                        </span>
                        <span class="cmega__group-caret">{{ mm_chevron }}</span>
                      </button>
                      <div class="cmega__panel">
                        <ul class="cmega__collections">
                          <li><a href="/collections/bookshelf-modern">Bookshelf (Modern)</a></li>
                          <li><a href="/collections/bookshelf-rustic">Bookshelf (Rustic)</a></li>
                          <li><a href="/collections/fireplace-mantel-shelf">Fireplace Mantel Shelf</a></li>
                          <li><a href="/collections/floating-shelf-boho">Floating Shelf (Boho)</a></li>
                          <li><a href="/collections/floating-shelf-modern">Floating Shelf (Modern)</a></li>
                          <li><a href="/collections/floating-shelf-rustic">Floating Shelf (Rustic)</a></li>
                          <li><a href="/collections/wall-shelf-gothic">Wall Shelf (Gothic)</a></li>
                          <li><a href="/collections/wall-shelf-rustic">Wall Shelf (Rustic)</a></li>
                        </ul>
                      </div>
                    </li>

                    <li class="cmega__group" data-mega-group>
                      <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                        <span class="cmega__group-icon">{{ mm_ico_storage }}</span>
                        <span class="cmega__group-text">
                          <span class="cmega__group-name">Storage &amp; Organization</span>
                          <span class="cmega__group-desc">Cabinets, coat racks &amp; benches</span>
                        </span>
                        <span class="cmega__group-caret">{{ mm_chevron }}</span>
                      </button>
                      <div class="cmega__panel">
                        <ul class="cmega__collections">
                          <li><a href="/collections/coat-rack">Coat Rack</a></li>
                          <li><a href="/collections/entryway-shoe-bench-rack">Entryway Shoe Bench Rack</a></li>
                          <li><a href="/collections/storage-cabinet">Storage Cabinet</a></li>
                          <li><a href="/collections/tree-coat-rack">Tree Coat Rack</a></li>
                        </ul>
                      </div>
                    </li>

                    <li class="cmega__group" data-mega-group>
                      <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                        <span class="cmega__group-icon">{{ mm_ico_decor }}</span>
                        <span class="cmega__group-text">
                          <span class="cmega__group-name">Decorative Wood Accents</span>
                          <span class="cmega__group-desc">Sculptures, bowls &amp; organizers</span>
                        </span>
                        <span class="cmega__group-caret">{{ mm_chevron }}</span>
                      </button>
                      <div class="cmega__panel">
                        <ul class="cmega__collections">
                          <li><a href="/collections/jewelry-tree-organizer-stand">Jewelry Tree Organizer Stand</a></li>
                          <li><a href="/collections/wall-decorative-sculpture">Wall Decorative Sculpture</a></li>
                          <li><a href="/collections/wooden-floor-sculpture">Wooden Floor Sculpture</a></li>
                          <li><a href="/collections/wooden-fruit-bowl">Wooden Fruit Bowl</a></li>
                        </ul>
                      </div>
                    </li>

                    <li class="cmega__group" data-mega-group>
                      <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                        <span class="cmega__group-icon">{{ mm_ico_lighting }}</span>
                        <span class="cmega__group-text">
                          <span class="cmega__group-name">Lighting &amp; Bases</span>
                          <span class="cmega__group-desc">Wooden lamps &amp; floor lamp bases</span>
                        </span>
                        <span class="cmega__group-caret">{{ mm_chevron }}</span>
                      </button>
                      <div class="cmega__panel">
                        <ul class="cmega__collections">
                          <li><a href="/collections/wood-floor-lamp-base">Wood Floor Lamp Base</a></li>
                          <li><a href="/collections/wooden-lamp-base">Wooden Lamp Base</a></li>
                        </ul>
                      </div>
                    </li>
                  </ul>

                  <ul class="cmega__groups">
                    <li class="cmega__group" data-mega-group>
                      <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                        <span class="cmega__group-icon">{{ mm_ico_plant }}</span>
                        <span class="cmega__group-text">
                          <span class="cmega__group-name">Plant &amp; Object Stands</span>
                          <span class="cmega__group-desc">Plant stands &amp; display pieces</span>
                        </span>
                        <span class="cmega__group-caret">{{ mm_chevron }}</span>
                      </button>
                      <div class="cmega__panel">
                        <ul class="cmega__collections">
                          <li><a href="/collections/wooden-plant-stand">Wooden Plant Stand</a></li>
                        </ul>
                      </div>
                    </li>

                    <li class="cmega__group" data-mega-group>
                      <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                        <span class="cmega__group-icon">{{ mm_ico_wine }}</span>
                        <span class="cmega__group-text">
                          <span class="cmega__group-name">Wine &amp; Bar Display</span>
                          <span class="cmega__group-desc">Wine racks &amp; bar display</span>
                        </span>
                        <span class="cmega__group-caret">{{ mm_chevron }}</span>
                      </button>
                      <div class="cmega__panel">
                        <ul class="cmega__collections">
                          <li><a href="/collections/rustic-wine-rack">Rustic Wine Rack</a></li>
                          <li><a href="/collections/tree-wine-rack">Tree Wine Rack</a></li>
                          <li><a href="/collections/wall-mounted-wine-rack">Wall Mounted Wine Rack</a></li>
                        </ul>
                      </div>
                    </li>

                    <li class="cmega__group" data-mega-group>
                      <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                        <span class="cmega__group-icon">{{ mm_ico_pet }}</span>
                        <span class="cmega__group-text">
                          <span class="cmega__group-name">Pet Furniture &amp; Stands</span>
                          <span class="cmega__group-desc">Cat trees, parrot stands &amp; more</span>
                        </span>
                        <span class="cmega__group-caret">{{ mm_chevron }}</span>
                      </button>
                      <div class="cmega__panel">
                        <ul class="cmega__collections">
                          <li><a href="/collections/cat-tree">Cat Tree</a></li>
                          <li><a href="/collections/parrot-tree">Parrot Tree</a></li>
                        </ul>
                      </div>
                    </li>

                    <li class="cmega__group" data-mega-group>
                      <button type="button" class="cmega__group-head" data-mega-toggle aria-expanded="false">
                        <span class="cmega__group-icon">{{ mm_ico_bed }}</span>
                        <span class="cmega__group-text">
                          <span class="cmega__group-name">Bedroom Furniture</span>
                          <span class="cmega__group-desc">Beds, frames &amp; bedside tables</span>
                        </span>
                        <span class="cmega__group-caret">{{ mm_chevron }}</span>
                      </button>
                      <div class="cmega__panel">
                        <ul class="cmega__collections">
                          <li><a href="/collections/bed">Bed</a></li>
                          <li><a href="/collections/bed-frame-with-headboard">Bed Frame With Headboard</a></li>
                          <li><a href="/collections/bedside-table">Bedside Table</a></li>
                        </ul>
                      </div>
                    </li>
                  </ul>
                </div>
              </div>

              <aside class="cmega__feature">
                <a class="cmega__feature-link" href="{{ explore_link }}">
                  <span class="cmega__feature-media">
                    {%- if section.settings.mega_menu_image != blank -%}
                      {{
                        section.settings.mega_menu_image
                        | image_url: width: 760
                        | image_tag: class: 'cmega__feature-img', loading: 'lazy', widths: '380, 560, 760', alt: ''
                      }}
                    {%- else -%}
                      <img
                        class="cmega__feature-img"
                        src="{{ 'mega-menu-photo.png' | file_url }}"
                        alt=""
                        width="760"
                        height="560"
                        loading="lazy"
                      >
                    {%- endif -%}
                  </span>
                  <span class="cmega__feature-body">
                    <span class="cmega__feature-title">Timeless craftsmanship for every space.</span>
                    <span class="cmega__feature-cta">
                      Explore all collections
                      <span class="cmega__feature-arrow">{{ mm_arrow }}</span>
                    </span>
                  </span>
                </a>
              </aside>
            </div>
          </div>
        </li>
        <li><a href="/collections/all" class="header__nav-item">Explore All Pieces</a></li>
        <li><a href="{{ pages['faq'].url }}?view=faq" class="header__nav-item">FAQ</a></li>
        <li><a href="{{ pages['about-us'].url }}?view=about-us" class="header__nav-item">About Us</a></li>
        <li><a href="{{ pages['contact'].url | default: '/pages/contact' }}" class="header__nav-item">Contact</a></li>
      </ul>
    </nav>
  </div>

  <div class="header__right">
    <a href="/pages/customization" class="header__consultation-link">Book Consultation</a>

    <div class="header__localization">
      {% render 'localization-selector', variant: 'header', id: 'header' %}
    </div>

    <a
      href="{{ routes.search_url }}"
      class="header__icon header__icon--search"
      aria-label="Search"
      onclick="window.openSearchPopup(event)"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-search"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </a>

    <a
      href="{{ routes.cart_url }}"
      class="header__icon header__icon--cart"
      aria-label="Cart"
      data-cart-drawer-open
    >
      {{ 'icon-cart.svg' | inline_asset_content }}
      {%- if cart.item_count > 0 -%}
        <div class="cart-count-bubble">
          <span>{{ cart.item_count }}</span>
        </div>
      {%- endif -%}
    </a>

    <button
      class="header__icon header__icon--menu"
      aria-haspopup="dialog"
      aria-controls="MobileMenuDrawer-{{ section.id }}"
      aria-expanded="false"
      aria-label="Open menu"
      data-mobile-menu-open
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-hamburger"
        aria-hidden="true"
      >
        <line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>

    <a
      href="{% if customer %}{{ routes.account_url }}{% else %}{{ routes.account_login_url }}{% endif %}"
      class="header__icon header__icon--account"
      aria-label="{% if customer %}My account{% else %}Sign in{% endif %}"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="22"
        height="22"
        fill="currentColor"
        class="icon"
        viewBox="0 0 16 16"
        aria-hidden="true"
      >
        <path d="M3 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6"/>
      </svg>
    </a>
  </div>
</header>

{% render 'search-popup' %}

{% javascript %}
  (function () {
    function initMegaMenu() {
      var groups = Array.prototype.slice.call(document.querySelectorAll('[data-mega-group]'));
      groups.forEach(function (group) {
        var toggle = group.querySelector('[data-mega-toggle]');
        var panel = group.querySelector('.cmega__panel');
        if (!toggle || toggle.dataset.init === 'true') return;
        toggle.dataset.init = 'true';
        if (panel) panel.inert = true;
        toggle.addEventListener('click', function (e) {
          e.preventDefault();
          var willOpen = !group.classList.contains('is-open');
          // Single-open accordion: collapse the others first.
          groups.forEach(function (other) {
            if (other === group) return;
            other.classList.remove('is-open');
            var t = other.querySelector('[data-mega-toggle]');
            var otherPanel = other.querySelector('.cmega__panel');
            if (t) t.setAttribute('aria-expanded', 'false');
            if (otherPanel) otherPanel.inert = true;
          });
          group.classList.toggle('is-open', willOpen);
          toggle.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
          if (panel) panel.inert = !willOpen;
        });
      });
    }

    function initMobileMenu() {
      var trigger = document.querySelector('[data-mobile-menu-open]');
      var drawer = document.querySelector('[data-mobile-menu-drawer]');
      if (!trigger || !drawer || drawer.dataset.mobileMenuInit === 'true') return;

      drawer.dataset.mobileMenuInit = 'true';
      var panel = drawer.querySelector('.cmega');
      var closeButtons = Array.prototype.slice.call(drawer.querySelectorAll('[data-mobile-menu-close]'));
      var mobileQuery = window.matchMedia('(max-width: 46.8125rem)');
      var previousFocus = null;

      function closeMenu(restoreFocus) {
        drawer.classList.remove('is-mobile-open');
        trigger.setAttribute('aria-expanded', 'false');
        document.documentElement.classList.remove('mobile-menu-is-open');
        if (mobileQuery.matches) drawer.setAttribute('aria-hidden', 'true');
        if (restoreFocus && previousFocus instanceof HTMLElement) previousFocus.focus();
      }

      function openMenu() {
        if (!mobileQuery.matches) return;
        previousFocus = document.activeElement;
        drawer.classList.add('is-mobile-open');
        drawer.setAttribute('aria-hidden', 'false');
        trigger.setAttribute('aria-expanded', 'true');
        document.documentElement.classList.add('mobile-menu-is-open');
        window.requestAnimationFrame(function () {
          var closeButton = drawer.querySelector('.mobile-menu__close');
