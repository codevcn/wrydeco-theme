      font-family: var(--font-roboto);
      font-size: var(--font-size-body-lg);
      font-weight: var(--font-weight-medium);
      line-height: var(--line-height-tight);
      text-decoration: none;
      transition: color var(--timing-short) var(--ease-standard);
    }

    .cmega__nav-link:hover {
      color: var(--color-earth-brown);
    }

    .cmega__nav-link:focus-visible {
      outline: calc(var(--border-width) * 2) solid var(--color-sage);
      outline-offset: calc(var(--border-width) * -2);
    }
  }

  .header__right {
    display: flex;
    justify-content: flex-end;
    align-items: center;
  }

  .header__localization {
    display: none;
  }

  @media screen and (min-width: 750px) {
    .header__localization {
      display: inline-flex;
      margin-right: var(--space-2, 10px);
    }
  }

  .cmega__localization .cmega__heading {
    margin-block-end: var(--sp-3);
  }

  .header__consultation-link {
    display: none;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    border: 1px solid color-mix(in srgb, var(--color-earth-brown) 54%, transparent);
    border-radius: var(--radius-full);
    background-color: rgba(247, 242, 236, 0.62);
    color: var(--color-earth-brown);
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: var(--font-weight-bold);
    letter-spacing: 0.08em;
    text-decoration: none;
    text-transform: uppercase;
    transition: background-color var(--timing-short) var(--ease-standard),
      color var(--timing-short) var(--ease-standard), transform var(--timing-short) var(--ease-standard);
    margin-right: 10px;
  }

  .header__consultation-link:hover {
    background-color: var(--color-earth-brown);
    color: var(--color-cream);
    transform: translateY(-1px);
  }

  .header__heading {
    margin: 0;
    display: flex;
    align-items: center;
  }

  .header__heading-link {
    text-decoration: none;
    color: var(--color-1, #000);
    display: block;
    line-height: 1;
  }

  .header__heading-logo {
    max-width: 100%;
    height: auto;
    height: 52px;
  }

  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: transparent;
    border: none;
    cursor: pointer;
    text-decoration: none;
    position: relative;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.2s ease;
  }
  .header__icon:hover {
    transform: scale(1.1);
  }
  .header__icon:focus {
    outline: none;
  }
  .header__icon:focus-visible {
    outline: 2px solid var(--color-1, #000);
    outline-offset: 2px;
  }

  .header__icon.header__icon--cart {
    color: var(--color-cream, #f5f1ed);
  }

  /* Gray circle background for icons like in the screenshot */
  .header__icon--search,
  .header__icon--menu {
    border-radius: var(--radius-full, 50%);
  }

  .header__icon--search {
    color: var(--color-cream, #f5f1ed);
  }
  .header__icon--search:hover {
    color: var(--color-cream, #f5f1ed);
  }

  .header__icon svg {
    width: 24px;
    height: 24px;
  }

  .cart-count-bubble {
    position: absolute;
    top: 5px;
    right: 5px;
    background-color: var(--color-2, #e60023);
    color: var(--color-10, #fff);
    font-size: var(--text-sm, 14px);
    font-weight: bold;
    border-radius: var(--radius-full, 50%);
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(25%, -25%);
  }

  @media screen and (min-width: 750px) {
    .header__right {
      gap: var(--space-2, 10px);
    }

    .header {
      padding-inline: 32px;
      padding-block: var(--space-6, 12px);
    }

    .header__icon--menu {
      display: none;
    }

    .header__nav {
      display: block;
    }
  }

  @media screen and (min-width: 1180px) {
    .header__consultation-link {
      display: inline-flex;
    }
  }

  @media screen and (max-width: 1180px) and (min-width: 750px) {
    .header__nav-list {
      gap: 14px;
      margin-inline: 12px;
    }

    .header__nav-item {
      font-size: 11px;
      letter-spacing: 0.07em;
    }
  }
{% endstylesheet %}

