<header class="header page-width">
  <div class="header__left">
    <h1 class="header__heading">
      <a href="{{ routes.root_url }}" class="header__heading-link">
        {%- if section.settings.logo != blank -%}
          {{
            section.settings.logo
            | image_url: width: 400
            | image_tag:
              class: 'header__heading-logo',
              widths: '100, 200, 300, 400',
              height: section.settings.logo.height,
              width: section.settings.logo.width,
              alt: section.settings.logo.alt
            | default: shop.name
            | escape
          }}
        {%- elsif section.settings.logo_asset != blank -%}
          <img
            src="{{ section.settings.logo_asset | asset_url }}"
            class="header__heading-logo"
            alt="{{ shop.name | escape }}"
            width="150"
            height="auto"
          >
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </h1>

    <nav class="header__nav">
      <ul class="header__nav-list">
        <li><a href="/pages/faq" class="header__nav-item">FAQ</a></li>
        <li><a href="/pages/about-us" class="header__nav-item">About Us</a></li>
        <li class="header__nav-item-has-mega-menu">
          <a href="/pages/collections/all" class="header__nav-item">
            Collections
            <svg aria-hidden="true" focusable="false" role="presentation" class="icon icon-caret" viewBox="0 0 10 6">
              <path fill-rule="evenodd" clip-rule="evenodd" d="M9.354.646a.5.5 0 00-.708 0L5 4.293 1.354.646a.5.5 0 00-.708.708l4 4a.5.5 0 00.708 0l4-4a.5.5 0 000-.708z" fill="currentColor">
            </svg>
          </a>
          {%- capture cp_leaf -%}
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M1.4 1.7c.217.289.65.84 1.725 1.274 1.093.44 2.885.774 5.834.528 2.02-.168 3.431.51 4.326 1.556C14.161 6.082 14.5 7.41 14.5 8.5q0 .344-.027.734C13.387 8.252 11.877 7.76 10.39 7.5c-2.016-.288-4.188-.445-5.59-2.045-.142-.162-.402-.102-.379.112.108.985 1.104 1.82 1.844 2.308 2.37 1.566 5.772-.118 7.6 3.071.505.8 1.374 2.7 1.75 4.292.07.298-.066.611-.354.715a.7.7 0 0 1-.161.042 1 1 0 0 1-1.08-.794c-.13-.97-.396-1.913-.868-2.77C12.173 13.386 10.565 14 8 14c-1.854 0-3.32-.544-4.45-1.435-1.124-.887-1.889-2.095-2.39-3.383-1-2.562-1-5.536-.65-7.28L.73.806z"/></svg>
          {%- endcapture -%}
          {%- capture cp_ico_bed -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 18v-5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v5"/><path d="M3 14h18"/><path d="M7 11V9a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v2"/><path d="M3 18v2"/><path d="M21 18v2"/></svg>
          {%- endcapture -%}
          {%- capture cp_ico_frame -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 20V6a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v6"/><path d="M8 12h11a1 1 0 0 1 1 1v7"/><path d="M4 16h16"/></svg>
          {%- endcapture -%}
          {%- capture cp_ico_bedside -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="5" y="5" width="14" height="14" rx="1"/><line x1="5" y1="12" x2="19" y2="12"/><line x1="11" y1="8.5" x2="13" y2="8.5"/><line x1="11" y1="15.5" x2="13" y2="15.5"/><path d="M7 19v2"/><path d="M17 19v2"/></svg>
          {%- endcapture -%}
          {%- capture cp_arrow -%}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          {%- endcapture -%}

          <div class="header__mega-menu">
            <div class="collections-popover">
              <div class="cp-feature">
                <div class="cp-feature__intro">
                  <h2 class="cp-feature__title">Bedroom Furniture</h2>
                  <p class="cp-feature__subtitle">Timeless pieces crafted for restful, refined spaces.</p>
                  <ul class="cp-feature__list list-unstyled">
                    <li>
                      <a class="cp-feature__link" href="/collections/a-home-shared-with-life">
                        <span class="cp-feature__ico">{{ cp_ico_bed }}</span>
                        <span>Bed</span>
                      </a>
                    </li>
                    <li>
                      <a class="cp-feature__link" href="/collections/light-carved-from-wood">
                        <span class="cp-feature__ico">{{ cp_ico_frame }}</span>
                        <span>Bed Frame With Headboard</span>
                      </a>
                    </li>
                    <li>
                      <a class="cp-feature__link" href="/collections/rituals-of-a-slower-home">
                        <span class="cp-feature__ico">{{ cp_ico_bedside }}</span>
                        <span>Bedside Table</span>
                      </a>
                    </li>
                  </ul>
                </div>

                <a class="cp-explore" href="/pages/collections/all">
                  <span class="cp-explore__icon">{{ cp_leaf }}</span>
                  <span class="cp-explore__body">
                    <span class="cp-explore__title">Explore our Bedroom Collection</span>
                    <span class="cp-explore__desc">Discover timeless craftsmanship.</span>
                    <span class="cp-explore__cta">Shop all bedroom <span class="cp-explore__arrow">{{ cp_arrow }}</span></span>
                  </span>
                </a>
              </div>

              <hr class="cp-divider">

              <div class="cp-grid">
                <div class="cp-cat">
                  <div class="cp-cat__head">
                    <span class="cp-cat__icon">{{ cp_leaf }}</span>
                    <h3 class="cp-cat__title">Decorative Wood Accents</h3>
                  </div>
                  <ul class="cp-cat__list list-unstyled">
                    <li><a class="cp-cat__link" href="/collections/gathered-around-the-grain">Jewelry Tree Organizer Stand</a></li>
                    <li><a class="cp-cat__link" href="/collections/sleep-beneath-the-branches">Wall Decorative Sculpture</a></li>
                    <li><a class="cp-cat__link" href="/collections/the-listening-room">Wooden Floor Sculpture</a></li>
                    <li><a class="cp-cat__link" href="/collections/the-living-tree">Wooden Fruit Bowl</a></li>
                  </ul>
                </div>

                <div class="cp-cat">
                  <div class="cp-cat__head">
                    <span class="cp-cat__icon">{{ cp_leaf }}</span>
                    <h3 class="cp-cat__title">Lighting &amp; Bases</h3>
                  </div>
                  <ul class="cp-cat__list list-unstyled">
                    <li><a class="cp-cat__link" href="/collections/the-welcoming-threshold">Wood Floor Lamp Base</a></li>
                    <li><a class="cp-cat__link" href="/collections/the-welcoming-threshold">Wooden Lamp Base</a></li>
                  </ul>
                </div>

                <div class="cp-cat">
                  <div class="cp-cat__head">
                    <span class="cp-cat__icon">{{ cp_leaf }}</span>
                    <h3 class="cp-cat__title">Pet Furniture &amp; Stands</h3>
                  </div>
                  <ul class="cp-cat__list list-unstyled">
                    <li><a class="cp-cat__link" href="/collections/a-home-shared-with-life">Cat Tree</a></li>
                    <li><a class="cp-cat__link" href="/collections/gathered-around-the-grain">Parrot Tree</a></li>
                  </ul>
                </div>

                <div class="cp-cat">
                  <div class="cp-cat__head">
                    <span class="cp-cat__icon">{{ cp_leaf }}</span>
                    <h3 class="cp-cat__title">Plant &amp; Object Stands</h3>
                  </div>
                  <ul class="cp-cat__list list-unstyled">
                    <li><a class="cp-cat__link" href="/collections/light-carved-from-wood">Wooden Plant Stand</a></li>
                  </ul>
                </div>

                <div class="cp-cat">
                  <div class="cp-cat__head">
                    <span class="cp-cat__icon">{{ cp_leaf }}</span>
                    <h3 class="cp-cat__title">Shelving &amp; Display</h3>
                  </div>
                  <ul class="cp-cat__list list-unstyled">
                    <li><a class="cp-cat__link" href="/collections/rituals-of-a-slower-home">Bookshelf</a></li>
                    <li><a class="cp-cat__link" href="/collections/sleep-beneath-the-branches">Fireplace Mantel Shelf</a></li>
                    <li><a class="cp-cat__link" href="/collections/the-listening-room">Floating Shelf</a></li>
                    <li><a class="cp-cat__link" href="/collections/the-living-tree">Wall Shelf</a></li>
                  </ul>
                </div>

                <div class="cp-cat">
                  <div class="cp-cat__head">
                    <span class="cp-cat__icon">{{ cp_leaf }}</span>
                    <h3 class="cp-cat__title">Storage &amp; Organization</h3>
                  </div>
                  <ul class="cp-cat__list list-unstyled">
                    <li><a class="cp-cat__link" href="/collections/the-welcoming-threshold">Coat Rack</a></li>
                    <li><a class="cp-cat__link" href="/collections/a-home-shared-with-life">Entryway Shoe Bench Rack</a></li>
                    <li><a class="cp-cat__link" href="/collections/gathered-around-the-grain">Storage Cabinet</a></li>
                    <li><a class="cp-cat__link" href="/collections/light-carved-from-wood">Tree Coat Rack</a></li>
                  </ul>
                </div>

                <div class="cp-cat">
                  <div class="cp-cat__head">
                    <span class="cp-cat__icon">{{ cp_leaf }}</span>
                    <h3 class="cp-cat__title">Tables &amp; Surfaces</h3>
                  </div>
                  <ul class="cp-cat__list list-unstyled">
                    <li><a class="cp-cat__link" href="/collections/rituals-of-a-slower-home">Coffee Table</a></li>
                    <li><a class="cp-cat__link" href="/collections/sleep-beneath-the-branches">Console Table</a></li>
                    <li><a class="cp-cat__link" href="/collections/the-listening-room">End Table</a></li>
                  </ul>
                </div>

                <div class="cp-cat">
                  <div class="cp-cat__head">
                    <span class="cp-cat__icon">{{ cp_leaf }}</span>
                    <h3 class="cp-cat__title">Wine &amp; Bar Display</h3>
                  </div>
                  <ul class="cp-cat__list list-unstyled">
                    <li><a class="cp-cat__link" href="/collections/the-living-tree">Rustic Wine Rack</a></li>
                    <li><a class="cp-cat__link" href="/collections/the-welcoming-threshold">Tree Wine Rack</a></li>
                    <li><a class="cp-cat__link" href="/collections/a-home-shared-with-life">Wall Mounted Wine Rack</a></li>
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </li>
      </ul>
    </nav>
  </div>

  <div class="header__right">
    <a
      href="{{ routes.search_url }}"
      class="header__icon header__icon--search"
      aria-label="{{ 'general.search.search' | t | default: 'Search' }}"
      onclick="window.openSearchPopup(event)"
    >
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-search"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
    </a>

    <a
      href="{{ routes.cart_url }}"
      class="header__icon header__icon--cart"
      aria-label="{{ 'templates.cart.cart' | t | default: 'Cart' }}"
    >
      {{ 'icon-cart.svg' | inline_asset_content }}
      {%- if cart.item_count > 0 -%}
        <div class="cart-count-bubble">
          <span>{{ cart.item_count }}</span>
        </div>
      {%- endif -%}
    </a>

    <button class="header__icon header__icon--menu" aria-haspopup="dialog" aria-label="Menu">
      <svg
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="icon icon-hamburger"
        aria-hidden="true"
      >
        <line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
  </div>
</header>

{% render 'search-popup' %}

{% stylesheet %}
  .header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4, 10px);
    padding-inline: var(--space-4, 10px);
    background-color: transparent;
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 99;
  }

  .header__left {
    display: flex;
    align-items: center;
    gap: var(--space-12, 24px);
  }

  .header__nav {
    display: none;
  }

  .header__nav-list {
    display: flex;
    gap: 20px;
    margin: 0 18px;
    padding: 0;
    list-style: none;
    align-items: center;
  }
  .header__nav-list li {
    margin: 0;
    position: static;
  }

  .header__nav-item {
    display: flex;
    align-items: center;
    gap: 6px;
    text-decoration: none;
    color: var(--color-earth-brown, #333);
    font-family: var(--font-roboto, sans-serif);
    font-size: 20px;
    font-weight: 700;
    text-transform: uppercase;
    transition: color var(--transition-fast, 0.2s);
    padding: 10px 0;
  }

  .header__nav-item .icon-caret {
    width: 12px;
    height: auto;
    fill: currentColor;
    opacity: 0.8;
    transition: transform 0.2s ease;
  }

  .header__nav-item:hover {
    color: var(--text-secondary, #666);
  }

  /* Mega Menu Styles */
  .header__nav-item-has-mega-menu:hover .header__mega-menu,
  .header__nav-item-has-mega-menu:focus-within .header__mega-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  /* Collections popover — anchored to the header so it sits 26.5px from the viewport's left edge */
  .header__mega-menu {
    position: absolute;
    top: 80%;
    left: 26.5px;
    width: calc(100% - 53px);
    max-width: 1400px;
    z-index: 100;
    padding-top: var(--sp-3);
    opacity: 0;
    visibility: hidden;
    transform: translateY(5px);
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    font-family: var(--font-body);
  }

  .collections-popover {
    width: 100%;
    padding: var(--sp-6) 0;
    background-color: var(--color-milk);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-elevation-3);
  }

  /* Featured block */
  .cp-feature {
    display: flex;
    align-items: center;
    justify-content: space-evenly;
    gap: var(--sp-7);
  }
  .cp-feature__intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 0;
    width: fit-content;
  }
  .cp-feature__title {
    margin: 0 0 var(--sp-2);
    font-family: var(--font-display);
    font-size: var(--font-size-display-sm);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    letter-spacing: var(--letter-spacing-wide);
    text-transform: uppercase;
    color: var(--color-earth-brown);
  }
  .cp-feature__subtitle {
    margin: 0 0 var(--sp-5);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-relaxed);
    color: var(--text-secondary);
  }
  .cp-feature__list {
    display: flex;
    flex-direction: row;
    gap: 64px;
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cp-feature__list li {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cp-feature__link {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--font-size-body-md);
    color: var(--text-primary);
    text-decoration: none;
    transition: color var(--timing-short) var(--ease-standard);
    text-underline-offset: 3px;
  }
  .cp-feature__ico {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 24px;
    height: 24px;
    color: var(--color-bark);
  }
  .cp-feature__ico svg {
    width: 22px;
    height: 22px;
  }
  .cp-feature__link:hover {
    color: var(--color-earth-brown);
    text-decoration: underline;
  }

  /* Explore card */
  .cp-explore {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-4);
    padding: var(--sp-5);
    background-color: var(--color-cream);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color var(--timing-short) var(--ease-standard);
    border-color: var(--color-clay);
  }
  .cp-explore__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-earth-brown);
    color: var(--color-earth-brown);
  }
  .cp-explore__icon svg {
    width: 20px;
    height: 20px;
  }
  .cp-explore__body {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-width: 0;
  }
  .cp-explore__title {
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-tight);
    color: var(--text-primary);
  }
  .cp-explore__desc {
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-normal);
    color: var(--text-secondary);
  }
  .cp-explore__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    margin-top: var(--sp-2);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-earth-brown);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .cp-explore__arrow {
    display: inline-flex;
  }
  .cp-explore__arrow svg {
    width: 14px;
    height: 14px;
  }

  /* Divider */
  .cp-divider {
    width: 100%;
    height: 1px;
    margin: var(--sp-6) 0;
    border: none;
    background-color: var(--border-light);
  }

  /* Category grid — all categories on a single row */
  .cp-grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    column-gap: var(--sp-4);
    row-gap: var(--sp-6);
    padding: 0 32px;
  }
  .cp-cat {
    min-width: 0;
  }
  .cp-cat__head {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-2);
    margin-bottom: var(--sp-4);
  }
  .cp-cat__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-earth-brown);
    color: var(--color-earth-brown);
  }
  .cp-cat__icon svg {
    width: 14px;
    height: 14px;
  }
  .cp-cat__title {
    position: relative;
    margin: 0;
    padding-bottom: var(--sp-2);
    font-family: var(--font-display);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-tight);
    text-transform: uppercase;
    color: var(--color-earth-brown);
  }
  .cp-cat__title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    width: 24px;
    height: 1px;
    background-color: var(--color-earth-brown);
  }
  .cp-cat__list {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cp-cat__list li {
    margin: 0;
    padding: 0;
    list-style: none;
  }
  .cp-cat__link {
    font-size: var(--font-size-body-sm);
    color: var(--text-primary);
    text-decoration: none;
    transition: color var(--timing-short) var(--ease-standard);
    text-underline-offset: 3px;
  }
  .cp-cat__link:hover {
    color: var(--color-earth-brown);
    text-decoration: underline;
  }

  /* 8 columns only fit on wide screens; fall back gracefully */
  @media screen and (max-width: 1280px) {
    .cp-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  @media screen and (max-width: 900px) {
    .header__mega-menu {
      width: calc(100% - 53px);
    }
    .cp-feature {
      gap: var(--sp-5);
    }
    .collections-popover {
      padding: var(--sp-5);
    }
    .cp-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .header__right {
    display: flex;
    justify-content: flex-end;
    gap: var(--space-4, 10px);
  }

  .header__heading {
    margin: 0;
    display: flex;
    align-items: center;
  }

  .header__heading-link {
    text-decoration: none;
    color: var(--color-1, #000);
    display: block;
    line-height: 1;
  }

  .header__heading-logo {
    max-width: 100%;
    height: auto;
    width: 150px;
  }

  .header__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-1, #000);
    background: transparent;
    border: none;
    cursor: pointer;
    text-decoration: none;
    position: relative;
    -webkit-tap-highlight-color: transparent;
  }
  .header__icon:focus {
    outline: none;
  }
  .header__icon:focus-visible {
    outline: 2px solid var(--color-1, #000);
    outline-offset: 2px;
  }

  .header__icon.header__icon--cart {
    color: var(--color-cream, #f5f1ed);
  }

  /* Gray circle background for icons like in the screenshot */
  .header__icon--search,
  .header__icon--menu {
    border-radius: var(--radius-full, 50%);
  }

  .header__icon--search {
    color: var(--color-cream, #f5f1ed);
  }
  .header__icon--search:hover {
    color: var(--color-cream, #f5f1ed);
  }

  .header__icon svg {
    width: 24px;
    height: 24px;
  }

  .cart-count-bubble {
    position: absolute;
    top: 5px;
    right: 5px;
    background-color: var(--color-2, #e60023);
    color: var(--color-10, #fff);
    font-size: var(--text-sm, 14px);
    font-weight: bold;
    border-radius: var(--radius-full, 50%);
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    transform: translate(25%, -25%);
  }

  @media screen and (min-width: 750px) {
    .header {
      padding-inline: 32px;
      padding-block: var(--space-6, 12px);
    }

    .header__icon--menu {
      display: none;
    }

    .header__nav {
      display: block;
    }
  }
{% endstylesheet %}

