      pointer-events: none;
      transform: none;
      transition: opacity var(--timing-base) var(--ease-standard), visibility var(--timing-base) var(--ease-standard);
    }

    .header__nav-item-has-mega-menu:hover .header__mega-menu.is-mobile-open,
    .header__nav-item-has-mega-menu:focus-within .header__mega-menu.is-mobile-open,
    .header__mega-menu.is-mobile-open {
