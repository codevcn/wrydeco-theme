{%- liquid
  assign gallery_title_id = 'custom-gallery-title-' | append: section.id
  assign before_one_alt = section.settings.before_one.alt | default: section.settings.card_one_title | append: ' before custom design'
  assign after_one_alt = section.settings.after_one.alt | default: section.settings.card_one_title | append: ' after custom design'
  assign before_two_alt = section.settings.before_two.alt | default: section.settings.card_two_title | append: ' before custom design'
  assign after_two_alt = section.settings.after_two.alt | default: section.settings.card_two_title | append: ' after custom design'
-%}

<section class="custom-gallery" aria-labelledby="{{ gallery_title_id }}">
  <div class="custom-gallery__inner">
    <header class="custom-gallery__header">
      <p class="custom-gallery__eyebrow"><span aria-hidden="true">&#10022;</span>{{ section.settings.eyebrow }}</p>
      <div class="custom-gallery__rule" aria-hidden="true"><span></span><b>&#10022;</b><span></span></div>
      <h2 id="{{ gallery_title_id }}">{{ section.settings.heading }}</h2>
      <p class="custom-gallery__intro">{{ section.settings.description }}</p>
    </header>

    <div class="custom-gallery__grid">
      <article class="custom-gallery__card">
        <div class="custom-gallery__comparison" data-before-after style="--comparison-position: 50%;">
          <div class="custom-gallery__media custom-gallery__media--before">
            {%- if section.settings.before_one != blank -%}
              {{
                section.settings.before_one
                | image_url: width: 1448
                | image_tag:
                  widths: '480, 720, 960, 1200, 1448',
                  sizes: '(max-width: 48rem) calc(100vw - 32px), 50vw',
                  loading: 'lazy',
                  class: 'custom-gallery__image',
                  alt: before_one_alt
              }}
            {%- else -%}
              <img
                class="custom-gallery__image"
                src="{{ 'book-consultation-before-2.png' | file_url }}"
                width="1448"
                height="1086"
                loading="lazy"
                alt="{{ before_one_alt | escape }}"
              >
            {%- endif -%}
            <span class="custom-gallery__label custom-gallery__label--before">{{ section.settings.before_label }}</span>
          </div>

          <div class="custom-gallery__media custom-gallery__media--after">
            {%- if section.settings.after_one != blank -%}
              {{
                section.settings.after_one
                | image_url: width: 1448
                | image_tag:
                  widths: '480, 720, 960, 1200, 1448',
                  sizes: '(max-width: 48rem) calc(100vw - 32px), 50vw',
                  loading: 'lazy',
                  class: 'custom-gallery__image',
                  alt: after_one_alt
              }}
            {%- else -%}
              <img
                class="custom-gallery__image"
                src="{{ 'book-consultation-after-2.png' | file_url }}"
                width="1448"
                height="1086"
                loading="lazy"
                alt="{{ after_one_alt | escape }}"
              >
            {%- endif -%}
            <span class="custom-gallery__label custom-gallery__label--after">{{ section.settings.after_label }}</span>
          </div>

          <span class="custom-gallery__divider" aria-hidden="true">
            <span class="custom-gallery__handle">
              <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 24 24">
                <path d="M0 0h24v24H0z" fill="none" />
                <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m16.25 17l3.94-3.94c.292-.292.439-.676.439-1.06M16.25 7l3.94 3.94c.292.292.439.676.439 1.06M7.75 17l-3.94-3.94A1.5 1.5 0 0 1 3.372 12M7.75 7l-3.94 3.94A1.5 1.5 0 0 0 3.371 12m0 0H20.63" />
              </svg>
            </span>
          </span>
          <label class="custom-gallery__range-label" for="comparison-one-{{ section.id }}"
            >Compare before and after for {{ section.settings.card_one_title -}}
          </label>
          <input
            id="comparison-one-{{ section.id }}"
            class="custom-gallery__range"
            type="range"
            min="0"
            max="100"
            value="50"
            data-comparison-range
          >
        </div>

        <div class="custom-gallery__caption">
          <span class="custom-gallery__caption-mark" aria-hidden="true">&#10022;</span>
          <div>
            <h3>{{ section.settings.card_one_title }}</h3>
            <span class="custom-gallery__caption-rule" aria-hidden="true"></span>
            <p>{{ section.settings.card_one_text }}</p>
          </div>
        </div>
      </article>

      <article class="custom-gallery__card">
        <div class="custom-gallery__comparison" data-before-after style="--comparison-position: 50%;">
          <div class="custom-gallery__media custom-gallery__media--before">
            {%- if section.settings.before_two != blank -%}
              {{
                section.settings.before_two
                | image_url: width: 1448
                | image_tag:
                  widths: '480, 720, 960, 1200, 1448',
                  sizes: '(max-width: 48rem) calc(100vw - 32px), 50vw',
                  loading: 'lazy',
                  class: 'custom-gallery__image',
                  alt: before_two_alt
              }}
            {%- else -%}
              <img
                class="custom-gallery__image"
                src="{{ 'book-consultation-before-1.png' | file_url }}"
                width="1448"
                height="1086"
                loading="lazy"
                alt="{{ before_two_alt | escape }}"
              >
            {%- endif -%}
            <span class="custom-gallery__label custom-gallery__label--before">{{ section.settings.before_label }}</span>
          </div>

          <div class="custom-gallery__media custom-gallery__media--after">
            {%- if section.settings.after_two != blank -%}
              {{
                section.settings.after_two
                | image_url: width: 1448
                | image_tag:
                  widths: '480, 720, 960, 1200, 1448',
                  sizes: '(max-width: 48rem) calc(100vw - 32px), 50vw',
                  loading: 'lazy',
                  class: 'custom-gallery__image',
                  alt: after_two_alt
              }}
            {%- else -%}
              <img
                class="custom-gallery__image"
                src="{{ 'book-consultation-after-1.png' | file_url }}"
                width="1448"
                height="1086"
                loading="lazy"
                alt="{{ after_two_alt | escape }}"
              >
            {%- endif -%}
            <span class="custom-gallery__label custom-gallery__label--after">{{ section.settings.after_label }}</span>
          </div>

          <span class="custom-gallery__divider" aria-hidden="true">
            <span class="custom-gallery__handle">
              <svg xmlns="http://www.w3.org/2000/svg" width="1.2em" height="1.2em" viewBox="0 0 24 24">
                <path d="M0 0h24v24H0z" fill="none" />
                <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="m16.25 17l3.94-3.94c.292-.292.439-.676.439-1.06M16.25 7l3.94 3.94c.292.292.439.676.439 1.06M7.75 17l-3.94-3.94A1.5 1.5 0 0 1 3.372 12M7.75 7l-3.94 3.94A1.5 1.5 0 0 0 3.371 12m0 0H20.63" />
              </svg>
            </span>
          </span>
          <label class="custom-gallery__range-label" for="comparison-two-{{ section.id }}"
            >Compare before and after for {{ section.settings.card_two_title -}}
          </label>
          <input
            id="comparison-two-{{ section.id }}"
            class="custom-gallery__range"
            type="range"
            min="0"
            max="100"
            value="50"
            data-comparison-range
          >
        </div>

        <div class="custom-gallery__caption">
          <span class="custom-gallery__caption-mark" aria-hidden="true">&#10022;</span>
          <div>
            <h3>{{ section.settings.card_two_title }}</h3>
            <span class="custom-gallery__caption-rule" aria-hidden="true"></span>
            <p>{{ section.settings.card_two_text }}</p>
          </div>
        </div>
      </article>
    </div>

    <footer class="custom-gallery__signature" aria-label="WRYDECO design promise">
      <span aria-hidden="true"></span>
      <b>W</b>
      <p>{{ section.settings.signature }}</p>
      <span aria-hidden="true"></span>
    </footer>
  </div>
</section>

{% stylesheet %}
  .custom-gallery {
    background: var(--bg-primary);
    color: var(--text-primary);
  }

  .custom-gallery__inner {
    inline-size: min(calc(100% - (var(--layout-padding-desktop) * 2)), var(--layout-showcase-max-width));
    margin-inline: auto;
    padding-block: var(--sp-4) var(--sp-7);
    margin-block: var(--sp-0) var(--sp-0);
  }

  .custom-gallery__header {
    max-inline-size: var(--layout-hero-copy-width);
    margin-inline: auto;
    text-align: center;
  }

  .custom-gallery__eyebrow {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-4);
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 5);
    text-transform: uppercase;
  }

  .custom-gallery__eyebrow span {
    color: var(--color-clay);
    font-size: var(--font-size-display-sm);
  }

  .custom-gallery__rule {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: var(--sp-3);
    inline-size: min(100%, calc(var(--sp-12) * 2));
    margin: var(--sp-3) auto;
    color: var(--color-clay);
  }

  .custom-gallery__rule span,
  .custom-gallery__caption-rule,
  .custom-gallery__signature > span {
    block-size: var(--border-width);
    background: var(--color-clay);
  }

  .custom-gallery__rule b {
    font-weight: var(--font-weight-regular);
  }

  .custom-gallery__header h2 {
    margin: var(--sp-0);
    font-family: var(--font-display-light);
    font-size: var(--font-size-display-xl);
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
    text-transform: uppercase;
  }

  .custom-gallery__intro {
    max-inline-size: calc(var(--layout-max-width) / 2);
    margin: var(--sp-4) auto var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
  }

  .custom-gallery__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--sp-6);
    margin-block-start: var(--sp-6);
  }

  .custom-gallery__card {
    overflow: hidden;
    border: var(--border-width) solid var(--color-clay);
    border-radius: var(--radius-xl);
    background: color-mix(in srgb, var(--bg-tertiary) 42%, transparent);
    box-shadow: var(--shadow-card);
  }

  .custom-gallery__comparison {
    position: relative;
    container-type: inline-size;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--bg-secondary);
    cursor: ew-resize;
    touch-action: pan-y;
  }

  .custom-gallery__media,
  .custom-gallery__image {
    inline-size: 100%;
    block-size: 100%;
  }

  .custom-gallery__media {
    position: absolute;
    inset: var(--sp-0);
  }

  .custom-gallery__media--before {
    clip-path: inset(0 calc(100% - var(--comparison-position)) 0 0);
  }

  .custom-gallery__media--after {
    inset-inline-start: var(--comparison-position);
    inline-size: auto;
    overflow: hidden;
  }

  .custom-gallery__media--after .custom-gallery__image {
    position: absolute;
    inset-block: var(--sp-0);
    inset-inline-end: var(--sp-0);
    inline-size: 100cqi;
    max-inline-size: none;
  }

  .custom-gallery__image {
    display: block;
    object-fit: cover;
  }

  .custom-gallery__label {
    position: absolute;
    inset-block-start: var(--sp-4);
    z-index: 1;
    min-inline-size: var(--sp-10);
    padding: var(--sp-2) var(--sp-4);
    border: var(--border-width) solid color-mix(in srgb, var(--color-clay) 60%, transparent);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-earth-brown) 88%, transparent);
    box-shadow: var(--shadow-card);
    color: var(--text-inverse);
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    letter-spacing: calc(var(--letter-spacing-wide) * 3);
    text-align: center;
    text-transform: uppercase;
  }

  .custom-gallery__label--before {
    font-family: var(--font-roboto);
    inset-inline-start: var(--sp-4);
  }

  .custom-gallery__label--after {
    font-family: var(--font-roboto);
    inset-inline-end: var(--sp-4);
  }

  .custom-gallery__divider {
    position: absolute;
    inset-block: var(--sp-0);
    inset-inline-start: var(--comparison-position);
    z-index: 2;
    inline-size: calc(var(--border-width) * 2);
    background: var(--bg-tertiary);
    box-shadow: var(--shadow-card);
    pointer-events: none;
  }

  .custom-gallery__handle {
    position: absolute;
    inset-block-start: 50%;
    inset-inline-start: 50%;
    display: grid;
    place-items: center;
    inline-size: var(--sp-7);
    block-size: var(--sp-7);
    border: var(--border-width) solid var(--color-clay);
    border-radius: var(--radius-full);
    background: var(--bg-tertiary);
    box-shadow: var(--shadow-elevation-2);
    color: var(--color-earth-brown);
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    transform: translate(-50%, -50%);
  }

  .custom-gallery__range {
    position: absolute;
    inset: var(--sp-0);
    z-index: 3;
    inline-size: 100%;
    block-size: 100%;
    margin: var(--sp-0);
    opacity: 0;
    cursor: ew-resize;
  }

  .custom-gallery__range:focus-visible + * {
    outline: none;
  }

  .custom-gallery__range-label {
    position: absolute;
    inline-size: var(--border-width);
    block-size: var(--border-width);
    margin: calc(var(--border-width) * -1);
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
  }

  .custom-gallery__caption {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--sp-4);
    padding: var(--sp-5);
  }

  .custom-gallery__caption-mark {
    color: var(--color-clay);
    font-size: var(--font-size-display-sm);
  }

  .custom-gallery__caption h3 {
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 4);
    line-height: var(--line-height-snug);
    text-transform: uppercase;
  }

  .custom-gallery__caption-rule {
    display: block;
    inline-size: var(--sp-8);
    margin-block: var(--sp-3);
  }

  .custom-gallery__caption p {
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .custom-gallery__signature {
    display: grid;
    grid-template-columns: minmax(var(--sp-7), 1fr) auto auto minmax(var(--sp-7), 1fr);
    align-items: center;
    gap: var(--sp-5);
    margin-block-start: var(--sp-5);
    color: var(--color-earth-brown);
  }

  .custom-gallery__signature > span {
    background: var(--border-default);
  }

  .custom-gallery__signature b {
    font-family: var(--font-display);
    font-size: var(--font-size-display-md);
    font-weight: var(--font-weight-light);
  }

  .custom-gallery__signature p {
    margin: var(--sp-0);
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 4);
    text-transform: uppercase;
  }

  @media screen and (max-width: 64rem) {
    .custom-gallery__inner {
      inline-size: min(calc(100% - (var(--layout-padding-tablet) * 2)), var(--layout-showcase-max-width));
      padding-block-start: var(--sp-4);
    }

    .custom-gallery__header h2 {
      font-size: var(--font-size-display-xl);
    }

    .custom-gallery__grid {
      gap: var(--sp-5);
    }

    .custom-gallery__caption {
      padding: var(--sp-4);
    }
  }

  @media screen and (max-width: 48rem) {
    .custom-gallery__inner {
      inline-size: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--layout-showcase-max-width));
      padding-block: var(--sp-4) var(--sp-6);
    }

    .custom-gallery__eyebrow {
      gap: var(--sp-3);
      font-size: var(--font-size-caption);
      letter-spacing: calc(var(--letter-spacing-wide) * 3);
    }

    .custom-gallery__header h2 {
      font-size: var(--font-size-display-lg);
    }

    .custom-gallery__intro {
      font-size: var(--font-size-body-sm);
    }

    .custom-gallery__grid {
      grid-template-columns: minmax(0, 1fr);
      margin-block-start: var(--sp-6);
    }

    .custom-gallery__signature {
      grid-template-columns: minmax(var(--sp-5), 1fr) auto minmax(var(--sp-5), 1fr);
      gap: var(--sp-3);
      text-align: center;
    }

    .custom-gallery__signature b {
      display: none;
    }
  }

  @media screen and (max-width: 30rem) {
    .custom-gallery__header h2 {
      font-size: var(--font-size-display-md);
    }

    .custom-gallery__caption h3 {
      font-size: var(--font-size-body-sm);
      letter-spacing: calc(var(--letter-spacing-wide) * 3);
    }

    .custom-gallery__label {
      inset-block-start: var(--sp-3);
      min-inline-size: var(--sp-9);
      padding: var(--sp-2) var(--sp-3);
    }

    .custom-gallery__label--before {
      inset-inline-start: var(--sp-3);
    }

    .custom-gallery__label--after {
      inset-inline-end: var(--sp-3);
    }

    .custom-gallery__signature p {
      font-size: var(--font-size-caption);
      letter-spacing: calc(var(--letter-spacing-wide) * 2);
    }
  }
{% endstylesheet %}

{% javascript %}
  const initializeBeforeAfterGalleries = () => {
    document.querySelectorAll('[data-before-after]:not([data-comparison-ready])').forEach((comparison) => {
      const range = comparison.querySelector('[data-comparison-range]');
      if (!range) return;

      comparison.dataset.comparisonReady = 'true';

      const updateComparison = () => {
        comparison.style.setProperty('--comparison-position', `${range.value}%`);
      };

      range.addEventListener('input', updateComparison);
      updateComparison();
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeBeforeAfterGalleries, { once: true });
  } else {
    initializeBeforeAfterGalleries();
  }

  document.addEventListener('shopify:section:load', initializeBeforeAfterGalleries);
{% endjavascript %}

{% schema %}
{
  "name": "Before after gallery",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Custom transformations" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Before / After Gallery" },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Every space has potential. See how thoughtful design, tailored proportions, and handcrafted solid wood turn a vision into a timeless reality."
    },
    { "type": "text", "id": "before_label", "label": "Before label", "default": "Before" },
    { "type": "text", "id": "after_label", "label": "After label", "default": "After" },
    { "type": "header", "content": "First transformation" },
    { "type": "image_picker", "id": "before_one", "label": "Before image" },
    { "type": "image_picker", "id": "after_one", "label": "After image" },
    { "type": "text", "id": "card_one_title", "label": "Title", "default": "Dining room transformation" },
    {
      "type": "textarea",
      "id": "card_one_text",
      "label": "Description",
      "default": "Custom solid walnut dining table, tailored to your space. Scaled for perfect flow. Finished in a rich, natural oil."
    },
    { "type": "header", "content": "Second transformation" },
    { "type": "image_picker", "id": "before_two", "label": "Before image" },
    { "type": "image_picker", "id": "after_two", "label": "After image" },
    { "type": "text", "id": "card_two_title", "label": "Title", "default": "Living room installation" },
    {
      "type": "textarea",
      "id": "card_two_text",
      "label": "Description",
      "default": "Bespoke shelving and cabinetry crafted to fit your wall. Custom proportions. Seamless integration. Timeless finish."
    },
    { "type": "text", "id": "signature", "label": "Signature", "default": "Tailored to you. Crafted to last." }
  ],
  "presets": [{ "name": "Before after gallery" }]
}
{% endschema %}
