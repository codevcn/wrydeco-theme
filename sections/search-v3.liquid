    padding: var(--sp-6) var(--sp-5);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    background-color: color-mix(in srgb, var(--surface-elevated) 72%, transparent);
    text-align: center;
    color: var(--text-secondary);
  }
  .srp-state__icon {
    width: var(--sp-7);
    height: var(--sp-7);
    color: var(--text-tertiary);
    padding: var(--sp-2);
    border: var(--border-width) solid currentColor;
    border-radius: var(--radius-full);
  }
  .srp-state__heading {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--font-size-display-sm);
    font-weight: var(--font-weight-regular);
    color: var(--text-primary);
  }
  .srp-state__text {
    margin: 0;
    max-width: 48ch;
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
  }

  .srp-popular {
    padding: var(--sp-6) 96px var(--section-spacing-desktop);
    margin: 0;
  }
  .srp-popular__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    margin-bottom: var(--sp-4);
  }
  .srp-popular__title {
    margin: 0;
    font-family: var(--font-body);
    word-spacing: 0.2rem;
    font-size: var(--font-size-body-4xl);
    font-weight: var(--font-weight-bold);
    letter-spacing: 0;
    text-transform: uppercase;
    color: var(--text-primary);
    text-align: center;
    width: 100%;
  }
  .srp-popular__view-all {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    color: var(--text-primary);
    text-decoration: none;
    font-size: var(--font-size-body-sm);
    transition: var(--transition-fast);
  }
  .srp-popular__view-all:hover {
    color: var(--color-earth-brown);
  }
  .srp-popular__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--sp-4);
  }
  .srp-popular__grid--fixed {
    grid-template-columns: repeat(auto-fit, minmax(min(100%, calc((var(--sp-12) * 2) + var(--sp-5))), 1fr));
  }

  .srp-popular-card {
    display: flex;
    flex-direction: column;
    min-width: 0;
    padding: var(--sp-2);
    border: var(--border-width) solid var(--border-light);
    border-radius: var(--radius-lg);
    background-color: var(--color-milk);
    box-shadow: var(--shadow-elevation-1);
  }
  .srp-popular-card__media-wrap {
    position: relative;
  }
  .srp-popular-card__media {
    position: relative;
    display: block;
    aspect-ratio: 6 / 5;
    overflow: hidden;
    border-radius: var(--radius-md);
    background-color: var(--bg-secondary);
  }
  .srp-popular-card__image {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: transform var(--timing-long) var(--ease-standard), opacity var(--timing-base) var(--ease-standard);
  }
  .srp-popular-card__image.is-prev,
  .srp-popular-card__image.is-active {
    opacity: 1;
  }
  .srp-popular-card__image.is-active {
    z-index: 2;
  }
  .srp-popular-card__media:hover .srp-popular-card__image {
    transform: scale(1.03);
  }
  .srp-popular-card__new {
    position: absolute;
    top: var(--sp-2);
    left: var(--sp-2);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    min-height: var(--sp-5);
    padding: 0 var(--sp-3);
    border-radius: var(--radius-full);
    background-color: var(--color-milk);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-bold);
  }
  .srp-popular-card__info {
    display: flex;
    flex-direction: column;
    padding: var(--sp-4) var(--sp-1) var(--sp-1);
  }
  .srp-popular-card__pill {
    align-self: flex-start;
    font-family: var(--font-roboto);
