{% comment %}
  Search results page.

  Hero (heading + search field) over a lifestyle background image,
  a sort/view toolbar, a 4-column product grid (flat cards, no border/shadow)
  and pill pagination reusing the same paginate logic as the collection page.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/search
{% endcomment %}

{% liquid
  assign per_page = 24
  assign q_param = search.terms | url_param_escape
  assign current_sort = search.sort_by | default: 'relevance'
  assign show_off_collections_entry = metaobjects.show_off_collections.values | first
  assign popular_collection = blank
  if show_off_collections_entry != blank
    assign popular_collection_handles_value = show_off_collections_entry.collections_handle.value
    assign popular_collection_handles = popular_collection_handles_value | split: ','
    assign popular_collection_handle = popular_collection_handles.first | strip
    assign popular_collection = collections[popular_collection_handle]
  endif
  capture search_base_url
    echo routes.search_url | append: '?q=' | append: q_param | append: '&type=product'
  endcapture
%}

<section class="srp" id="Search-{{ section.id }}">
  <div class="srp-hero">
    <div class="srp-hero__media">
      <img
        class="srp-hero__bg"
        src="{{ 'hero-bg-search.png' | file_url }}"
        alt=""
        width="2169"
        height="725"
        loading="eager"
        fetchpriority="high"
      >
    </div>

    <div class="srp-hero__inner">
      <h1 class="srp-hero__title">{{ section.settings.heading | escape }}</h1>
      <p class="srp-hero__subtitle">{{ section.settings.subtitle | escape }}</p>
    </div>
  </div>

  <div class="srp-discovery">
    <div class="srp-search">
      <form action="{{ routes.search_url }}" method="get" role="search" class="srp-search__form">
        <input type="hidden" name="type" value="product">
        <svg
          class="srp-search__icon"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input
          type="search"
          name="q"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.search_placeholder' | t }}"
          class="srp-search__input"
          aria-label="{{ 'search.title' | t }}"
          autocomplete="off"
        >
        <button type="submit" class="srp-search__submit">
          <span>Search</span>
        </button>
      </form>
    </div>

    <nav class="srp-quick-links" aria-label="Search shortcuts">
      <a class="srp-quick-links__item" href="/pages/showroom">
        <span class="srp-quick-links__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
              <path d="M20 9V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v3"/>
              <path d="M2 16a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2v-5a2 2 0 0 0-4 0v1.5a.5.5 0 0 1-.5.5h-11a.5.5 0 0 1-.5-.5V11a2 2 0 0 0-4 0zm2 2v2m16-2v2M12 4v9"/>
            </g>
          </svg>
        </span>
        <span>Rooms</span>
      </a>
      <a class="srp-quick-links__item" href="{{ routes.collections_url }}">
        <span class="srp-quick-links__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
              <path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/>
              <path d="m6.08 9.5l-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/>
              <path d="m6.08 14.5l-3.5 1.6a1 1 0 0 0 0 1.81l8.6 3.91a2 2 0 0 0 1.65 0l8.58-3.9a1 1 0 0 0 0-1.83l-3.5-1.59"/>
            </g>
          </svg>
        </span>
        <span>Collections</span>
      </a>
      <a class="srp-quick-links__item" href="/collections/new-arrivals">
        <span class="srp-quick-links__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2">
              <path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594zM20 2v4m2-2h-4"/>
              <circle cx="4" cy="20" r="2"/>
            </g>
          </svg>
        </span>
        <span>New Arrivals</span>
      </a>
      <a class="srp-quick-links__item" href="/collections/signature-pieces">
        <span class="srp-quick-links__icon" aria-hidden="true">
          <svg viewBox="0 0 24 24">
            <path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.562 3.266a.5.5 0 0 1 .876 0L15.39 8.87a1 1 0 0 0 1.516.294L21.183 5.5a.5.5 0 0 1 .798.519l-2.834 10.246a1 1 0 0 1-.956.734H5.81a1 1 0 0 1-.957-.734L2.02 6.02a.5.5 0 0 1 .798-.519l4.276 3.664a1 1 0 0 0 1.516-.294zM5 21h14"/>
          </svg>
        </span>
        <span>Signature Pieces</span>
      </a>
    </nav>
  </div>

  {% if search.performed == false or search.terms == blank %}
    <div class="srp-state">
      <svg
        class="srp-state__icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <h2 class="srp-state__heading">{{ 'search.initial_heading' | t }}</h2>
      <p class="srp-state__text">{{ 'search.initial_text' | t }}</p>
    </div>
  {% elsif search.results_count == 0 %}
    <div class="srp-state">
      <svg
        class="srp-state__icon"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <h2 class="srp-state__heading">{{ 'search.no_results_heading' | t }}</h2>
      <p class="srp-state__text">{{ 'search.no_results_text_html' | t: terms: search.terms }}</p>
    </div>
  {% else %}
    <div class="srp-toolbar">
      <div class="srp-sort">
        <span class="srp-sort__label">{{ 'search.sort_label' | t }}</span>
        <div class="srp-sort__list" data-sort-pills>
          <a
            href="{{ search_base_url }}"
            data-sort="relevance"
            class="srp-sort__pill{% if current_sort == 'relevance' %} is-active{% endif %}"
          >
            {{- 'search.sort_relevance' | t -}}
          </a>
          <a
            href="{{ search_base_url }}&sort_by=price-ascending"
            data-sort="price-ascending"
            class="srp-sort__pill{% if current_sort == 'price-ascending' %} is-active{% endif %}"
          >
            {{- 'search.sort_price_low_high' | t -}}
          </a>
          <a
            href="{{ search_base_url }}&sort_by=price-descending"
            data-sort="price-descending"
            class="srp-sort__pill{% if current_sort == 'price-descending' %} is-active{% endif %}"
          >
            {{- 'search.sort_price_high_low' | t -}}
          </a>
        </div>
      </div>

      <div class="srp-meta">
        <span class="srp-meta__count">{{ 'search.results_count' | t: count: search.results_count }}</span>
        <div
          class="srp-view"
          data-view-toggle
          role="group"
          aria-label="{{ 'search.grid_view' | t }} / {{ 'search.list_view' | t }}"
        >
          <button
            type="button"
            class="srp-view__btn is-active"
            data-view="grid"
            aria-pressed="true"
            aria-label="{{ 'search.grid_view' | t }}"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
            </svg>
          </button>
          <button
            type="button"
            class="srp-view__btn"
            data-view="list"
            aria-pressed="false"
            aria-label="{{ 'search.list_view' | t }}"
          >
            <svg
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <line x1="3" y1="12" x2="21" y2="12"></line>
              <line x1="3" y1="18" x2="21" y2="18"></line>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="srp-grid-wrap">
      {% paginate search.results by per_page %}
        <div class="srp-grid" data-srp-grid>
          {% for result in search.results %}
            {% if result.object_type != 'product' %}
              {% continue %}
            {% endif %}
            {% liquid
              assign ptype = result.type
            %}
            <article class="srp-card">
              <a class="srp-card__media" href="{{ result.url }}" aria-label="{{ result.title | escape }}">
                {% if result.featured_image %}
                  {{
                    result.featured_image
                    | image_url: width: 720
                    | image_tag:
                      loading: 'lazy',
                      widths: '280, 420, 560, 720',
                      sizes: '(min-width: 1024px) 24vw, (min-width: 768px) 33vw, 90vw',
                      alt: result.featured_image.alt
                    | default: result.title
                  }}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {% endif %}
              </a>

              <div class="srp-card__info">
                {% if ptype != blank %}
                  <span class="srp-card__pill">{{ ptype | escape }}</span>
                {% endif %}

                <h2 class="srp-card__title">
                  <a href="{{ result.url }}">
                    {{- result.title | split: ',' | first | split: ' - ' | first | strip | escape -}}
                  </a>
                </h2>

                <hr class="srp-card__divider">

                <p class="srp-card__price">
                  <span class="srp-card__price-label">{{ 'search.from_price' | t }}</span> {{ result.price | money }}
                </p>
              </div>
            </article>
          {% endfor %}
        </div>

        {% if paginate.pages > 1 %}
          <nav class="srp-pagination" role="navigation" aria-label="Pagination">
            <div class="srp-pagination__inner">
              {% if paginate.previous %}
                <a
                  href="{{ paginate.previous.url }}"
                  class="srp-pagination__prev"
                  aria-label="{{ 'search.pagination_previous' | t }}"
                >
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <polyline points="15 18 9 12 15 6"></polyline>
                  </svg>
                  <span>{{ 'search.pagination_previous' | t }}</span>
                </a>
              {% else %}
                <span class="srp-pagination__prev is-disabled">
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <polyline points="15 18 9 12 15 6"></polyline>
                  </svg>
                  <span>{{ 'search.pagination_previous' | t }}</span>
                </span>
              {% endif %}

              <div class="srp-pagination__sep"></div>

              <div class="srp-pagination__numbers">
                {% for part in paginate.parts %}
                  {% if part.is_link %}
                    <a href="{{ part.url }}" class="srp-pagination__num" aria-label="Page {{ part.title }}">
                      {{- part.title -}}
                    </a>
                  {% else %}
                    {% if part.title == paginate.current_page %}
                      <span class="srp-pagination__num is-current" aria-current="page">{{ part.title }}</span>
                    {% else %}
                      <span class="srp-pagination__num is-deco">{{ part.title }}</span>
                    {% endif %}
                  {% endif %}
                {% endfor %}
              </div>

              <div class="srp-pagination__sep"></div>

              {% if paginate.next %}
                <a
                  href="{{ paginate.next.url }}"
                  class="srp-pagination__next"
                  aria-label="{{ 'search.pagination_next' | t }}"
                >
                  <span>{{ 'search.pagination_next' | t }}</span>
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <polyline points="9 18 15 12 9 6"></polyline>
                  </svg>
                </a>
              {% else %}
                <span class="srp-pagination__next is-disabled">
                  <span>{{ 'search.pagination_next' | t }}</span>
                  <svg
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <polyline points="9 18 15 12 9 6"></polyline>
                  </svg>
                </span>
              {% endif %}
            </div>
          </nav>
        {% endif %}
      {% endpaginate %}
    </div>
  {% endif %}

  {% if popular_collection != blank and popular_collection.products.size > 0 %}
    <section class="srp-popular" aria-labelledby="SrpPopular-{{ section.id }}">
      <div class="divider"></div>

      <div class="srp-popular__head">
        <h2 id="SrpPopular-{{ section.id }}" class="srp-popular__title">Explore Popular Categories</h2>
      </div>

      <div
        class="srp-popular__grid srp-popular__grid--fixed"
      >
        {% for popular_product in popular_collection.products limit: 6 %}
          {% liquid
            assign artist = ''
            assign author = popular_product.metafields.custom.author_info.value
            if author != blank and author.author_name.value != blank
              assign artist = author.author_name.value
            elsif popular_product.vendor != blank
              assign artist = popular_product.vendor
            endif

            assign material = popular_product.metafields.custom.product_material
            assign ptype = popular_product.type
            assign is_new = false
            for coll in popular_product.collections
              if coll.handle == 'new-arrivals'
                assign is_new = true
                break
              endif
            endfor
          %}
          <article class="srp-popular-card">
            <div class="srp-popular-card__media-wrap">
              <a
                class="srp-popular-card__media"
                href="{{ popular_product.url }}"
                aria-label="{{ popular_product.title | escape }}"
                data-hover-gallery
              >
                {% if popular_product.media.size > 0 %}
                  {% assign img_count = 0 %}
                  {% for media in popular_product.media %}
                    {% if media.media_type == 'image' %}
                      {% assign img_class = 'srp-popular-card__image' %}
                      {% if img_count == 0 %}{% assign img_class = 'srp-popular-card__image is-active' %}{% endif %}
                      {% assign card_alt = media.alt | default: popular_product.title %}
                      {{
                        media.preview_image
                        | image_url: width: 720
                        | image_tag:
                          class: img_class,
                          loading: 'lazy',
                          widths: '280, 420, 560, 720',
                          sizes: '(min-width: 1200px) 16vw, (min-width: 768px) 30vw, 78vw',
                          alt: card_alt
                      }}
                      {% assign img_count = img_count | plus: 1 %}
                      {% if img_count >= 5 %}{% break %}{% endif %}
                    {% endif %}
                  {% endfor %}
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'srp-popular-card__image is-active placeholder-svg' }}
                {% endif %}
              </a>

              {% if is_new %}
                <span class="srp-popular-card__new">New</span>
              {% endif %}
            </div>

            <div class="srp-popular-card__info">
              {% if ptype != blank %}
                <span class="srp-popular-card__pill">{{ ptype | escape }}</span>
              {% endif %}

              <h3 class="srp-popular-card__name">
                <a class="srp-popular-card__name-link" href="{{ popular_product.url }}">
                  {{- popular_product.title | split: ',' | first | split: ' - ' | first | strip | escape -}}
                </a>
              </h3>

              <hr class="srp-popular-card__divider">

              {% if artist != blank %}
                <p class="srp-popular-card__artist">Crafted By {{ artist | escape }}</p>
              {% endif %}

              <p class="srp-popular-card__price"><span>From</span> {{ popular_product.price | money }}</p>

              {% if material != blank %}
                <p class="srp-popular-card__material">{{ material | metafield_text }}</p>
              {% endif %}
            </div>
          </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}
</section>

{% stylesheet %}
  .srp {
    width: 100%;
    background-color: var(--color-cream);
    font-family: var(--font-body);
    color: var(--text-primary);
  }

  /* Hero */
  .srp-hero {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(calc(var(--sp-12) * 3), 50vh, calc(var(--sp-12) * 5));
    overflow: hidden;
    background-color: var(--color-cream);
  }
  .srp-hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .srp-hero__bg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: right center;
    display: block;
  }
  .srp-hero__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      var(--color-cream) 0%,
      color-mix(in srgb, var(--color-cream) 88%, transparent) 32%,
      transparent 62%
    );
  }
  .srp-hero__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    width: 100%;
    max-width: calc(var(--layout-hero-copy-width) - var(--sp-12));
    padding: var(--sp-7) var(--layout-padding-desktop) var(--sp-7) var(--sp-9);
  }
  .srp-hero__title {
    margin: 0;
    font-family: var(--font-display-light);
    font-size: clamp(var(--font-size-display-md), 3.2vw, var(--font-size-display-xl));
    font-weight: 500;
    line-height: var(--line-height-display);
    color: var(--text-primary);
  }
  .srp-hero__subtitle {
    margin: 0;
    max-width: 48ch;
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
    color: var(--text-secondary);
  }

  .srp-discovery {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-4);
    width: min(calc(100% - (var(--layout-padding-desktop) * 2)), var(--layout-max-width));
    margin: calc(var(--sp-6) * -1) auto 0;
  }

  .srp-search {
    width: min(100%, calc(var(--layout-max-width) - var(--sp-12)));
  }
  .srp-search__form {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    min-height: var(--sp-8);
    padding: var(--sp-1);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    background-color: var(--surface-elevated);
    box-shadow: var(--shadow-elevation-1);
  }
  .srp-search__icon {
    flex: 0 0 auto;
    width: var(--sp-5);
    height: var(--sp-5);
    margin-left: var(--sp-5);
    color: var(--text-secondary);
    pointer-events: none;
  }
  .srp-search__input {
    width: 100%;
    min-width: 0;
    min-height: calc(var(--sp-7) + var(--sp-1));
    padding: 0 var(--sp-5);
    border: 0;
    background-color: transparent;
    outline: none;
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    color: var(--text-primary);
  }
  .srp-search__input:focus {
    box-shadow: none;
  }
  .srp-search__input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }
  .srp-search__submit {
    flex: 0 0 auto;
    min-width: calc(var(--sp-12) - var(--sp-4));
    min-height: calc(var(--sp-7) + var(--sp-1));
    padding: 0 var(--sp-6);
    border: 0;
    border-radius: var(--radius-md);
    background-color: var(--color-earth-brown);
    color: var(--color-milk);
    font-family: var(--font-body);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
    transition: var(--transition-fast);
  }
  .srp-search__submit:hover {
    background-color: var(--color-brown-dark);
  }

  .srp-quick-links {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--sp-4);
    width: 100%;
  }
  .srp-quick-links__item {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    min-height: calc(var(--sp-7) - var(--sp-1));
    min-width: calc(var(--sp-12) + var(--sp-6));
    padding: 0 var(--sp-5);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    background-color: var(--surface-elevated);
    color: var(--text-primary);
    text-decoration: none;
    font-size: var(--font-size-body-md);
    box-shadow: var(--shadow-elevation-1);
    transition: var(--transition-fast);
  }
  .srp-quick-links__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: var(--sp-4);
    height: var(--sp-4);
    flex: 0 0 auto;
  }
  .srp-quick-links__icon svg {
