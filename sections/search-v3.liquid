<script>
  (function () {
    function initSearchPage() {
      document.querySelectorAll('[data-hover-gallery]').forEach(function (gallery) {
        if (gallery.dataset.initHover === 'true') return;
        gallery.dataset.initHover = 'true';

        var images = gallery.querySelectorAll('.srp-popular-card__image');
        if (images.length <= 1) return;

        var intervalId = null;
        var currentIndex = 0;

        function showImage(index) {
          images.forEach(function (img) {
            img.classList.remove('is-prev');
            if (img.classList.contains('is-active')) {
              img.classList.remove('is-active');
              img.classList.add('is-prev');
            }
          });
          images[index].classList.add('is-active');
        }

        gallery.addEventListener('mouseenter', function () {
          currentIndex = 1;
          showImage(currentIndex);

          intervalId = setInterval(function () {
            currentIndex = (currentIndex + 1) % images.length;
            showImage(currentIndex);
          }, 2000);
        });

        gallery.addEventListener('mouseleave', function () {
          clearInterval(intervalId);
          currentIndex = 0;
          showImage(0);
        });
      });

      document.querySelectorAll('[data-view-toggle]').forEach(function (toggle) {
        if (toggle.dataset.init === 'true') return;
        toggle.dataset.init = 'true';

        var grid = toggle.closest('.srp').querySelector('[data-srp-grid]');
        if (!grid) return;
        var buttons = toggle.querySelectorAll('[data-view]');

        function setView(view) {
          grid.classList.toggle('is-list', view === 'list');
          buttons.forEach(function (btn) {
            var active = btn.dataset.view === view;
            btn.classList.toggle('is-active', active);
            btn.setAttribute('aria-pressed', active ? 'true' : 'false');
          });
          try {
            window.localStorage.setItem('srpView', view);
          } catch (e) {}
        }

        var stored = null;
        try {
          stored = window.localStorage.getItem('srpView');
        } catch (e) {}
        if (stored === 'list') setView('list');

        buttons.forEach(function (btn) {
          btn.addEventListener('click', function () {
            setView(btn.dataset.view);
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initSearchPage);
    } else {
      initSearchPage();
    }
  })();
</script>

