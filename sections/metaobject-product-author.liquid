{% comment %}
  Author profile page — rendered for the `product_author` metaobject
  (Content → Metaobjects → Product Author, web presence enabled).

  Dynamic fields (single line text): author_name, author_bio,
  author_image_url, author_slogan. The slogan is shown as the pull quote.
  The masthead, role line and craft stats are brand scaffolding.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/metaobject
{% endcomment %}

{% liquid
  assign author = metaobject
  assign a_name = author.author_name.value | default: 'Our Artist'
  assign a_bio = author.author_bio.value
  assign a_img = author.author_image_url.value
  assign a_quote = author.author_slogan.value
%}

{%- capture ap_fingerprint -%}
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.15" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 10.5a1.5 1.5 0 0 1 1.5 1.5c0 2.5-.3 4.4-1 6"/><path d="M9 11a3 3 0 0 1 6 0c0 3-.4 5.5-1.3 7.5"/><path d="M6.6 11.4a5.5 5.5 0 0 1 10.8 0c0 1.2-.05 2.4-.2 3.5"/><path d="M9.2 19.6c.9-2 1.3-4.4 1.3-6.6"/><path d="M4.4 9A9 9 0 0 1 19.6 9"/></svg>
{%- endcapture -%}
{%- capture ap_ornament -%}
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2c.7 3.6 2.7 5.6 6.3 6.3-3.6.7-5.6 2.7-6.3 6.3-.7-3.6-2.7-5.6-6.3-6.3C9.3 7.6 11.3 5.6 12 2Z" transform="translate(0 3.7)"/></svg>
{%- endcapture -%}
{%- capture ap_ico_leaf -%}
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
{%- endcapture -%}
{%- capture ap_ico_hand -%}
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 11V6.5a1.5 1.5 0 0 1 3 0V11"/><path d="M12 11V4.5a1.5 1.5 0 0 1 3 0V11"/><path d="M15 11V6.5a1.5 1.5 0 0 1 3 0V13a6 6 0 0 1-6 6h-1a5 5 0 0 1-3.6-1.5l-2.6-2.7a1.6 1.6 0 0 1 2.3-2.2L6 14"/></svg>
{%- endcapture -%}
{%- capture ap_ico_rings -%}
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="5.5"/><circle cx="12" cy="12" r="2"/></svg>
{%- endcapture -%}
{%- capture ap_ico_sprout -%}
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 20v-9"/><path d="M12 12c0-3.3-2.2-5.5-5.5-5.5C6.5 9.8 8.7 12 12 12Z"/><path d="M12 13.5c0-3.3 2.2-5.5 5.5-5.5C17.5 11.3 15.3 13.5 12 13.5Z"/></svg>
{%- endcapture -%}

<section class="ap" id="AuthorProfile-{{ section.id }}">
  <header class="ap__masthead">
    <span class="ap__mark"
      ><span class="ap__mark-icon">{{ ap_fingerprint }}</span></span
    >
    <p class="ap__eyebrow">Our Makers</p>
    <p class="ap__masthead-title">Meet the Artist</p>
  </header>

  <div class="ap__body">
    <div class="ap__left">
      <figure class="ap__card">
        <div class="ap__photo">
          {% if a_img != blank %}
            <img
              class="ap__photo-img"
              src="{{ a_img }}"
              alt="{{ a_name | escape }}"
              width="1000"
              height="1200"
              loading="eager"
              fetchpriority="high"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'ap__photo-img ap__photo-img--placeholder' }}
          {% endif %}
        </div>
        <figcaption class="ap__card-meta">
          <span class="ap__card-mark">{{ ap_fingerprint }}</span>
          <span class="ap__card-text">
            <span class="ap__card-role">Lead Artist &amp; Craftsman</span>
            <span class="ap__card-tag">20+ Years of Dedication to Wood</span>
          </span>
        </figcaption>
      </figure>
    </div>

    <div class="ap__right">
      <p class="ap__eyebrow ap__eyebrow--rule">Artist Profile</p>
      <h1 class="ap__name">{{ a_name | escape }}</h1>
      <p class="ap__role">Lead Artist &nbsp;&bull;&nbsp; Sculptural Wood Forms</p>

      {% if a_quote != blank %}
        <blockquote class="ap__quote">{{ a_quote | escape }}</blockquote>
      {% endif %}

      <div class="ap__ornament" aria-hidden="true">
        <span class="ap__ornament-icon">{{ ap_ornament }}</span>
      </div>

      {% if a_bio != blank %}
        <div class="ap__bio">{{ a_bio | newline_to_br }}</div>
      {% endif %}

      <ul class="ap__stats">
        <li class="ap__stat">
          <span class="ap__stat-icon">{{ ap_ico_leaf }}</span>
          <span class="ap__stat-label">Solid Teak</span>
          <span class="ap__stat-desc">Premium Natural Wood</span>
        </li>
        <li class="ap__stat">
          <span class="ap__stat-icon">{{ ap_ico_hand }}</span>
          <span class="ap__stat-label">Hand-Shaped</span>
          <span class="ap__stat-desc">By Hand, Not by Machine</span>
        </li>
        <li class="ap__stat">
          <span class="ap__stat-icon">{{ ap_ico_rings }}</span>
          <span class="ap__stat-label">20+ Years</span>
          <span class="ap__stat-desc">Experience Rooted in Craft</span>
        </li>
        <li class="ap__stat">
          <span class="ap__stat-icon">{{ ap_ico_sprout }}</span>
          <span class="ap__stat-label">Rooted in Craft</span>
          <span class="ap__stat-desc">Respect for Wood. Respect for Time.</span>
        </li>
      </ul>
    </div>
  </div>
</section>

<script>
  const mainProductSection = document.getElementById('AuthorProfile-{{ section.id }}');
  if (mainProductSection) {
    mainProductSection.closest('body').querySelector('.header__icon--search').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header__icon--cart').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header').style.border = '1px solid #cfcbc7b4';
  }
</script>

{% stylesheet %}
  .ap {
    box-sizing: border-box;
    width: 100%;
    max-width: 1360px;
    margin: 0 auto;
    padding: clamp(var(--sp-8), 9vh, 112px) var(--layout-padding-desktop) var(--section-spacing-desktop);
    background-color: var(--color-cream);
    font-family: var(--font-body);
    margin-top: 48px;
  }

  /* Masthead */
  .ap__masthead {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: clamp(var(--sp-6), 5vh, var(--sp-8));
  }
  .ap__mark {
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--sp-4);
    color: var(--color-clay);
  }
  .ap__mark::before,
  .ap__mark::after {
    content: '';
    width: clamp(80px, 14vw, 170px);
    height: 1px;
    background-color: var(--border-default);
  }
  .ap__mark-icon {
    display: flex;
    padding: 0 var(--sp-5);
  }
  .ap__mark-icon svg {
    width: 30px;
    height: 30px;
  }
  .ap__eyebrow {
    margin: 0;
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--text-secondary);
  }
  .ap__masthead-title {
    margin: var(--sp-3) 0 0;
    font-family: var(--font-roboto);
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: var(--font-weight-regular);
    line-height: var(--line-height-tight);
    color: var(--color-earth-brown);
  }

  /* Body layout */
  .ap__body {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1fr);
    gap: clamp(var(--sp-6), 4vw, var(--sp-8));
    align-items: start;
  }

  /* Left: photo card */
  .ap__card {
    margin: 0;
    display: flex;
    flex-direction: column;
    padding: var(--sp-3);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-lg);
    background-color: var(--color-milk);
    box-shadow: var(--shadow-elevation-1);
  }
  .ap__photo {
    overflow: hidden;
    border-radius: var(--radius-md);
    background-color: var(--bg-secondary);
    aspect-ratio: 5 / 6;
  }
  .ap__photo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .ap__card-meta {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    padding: var(--sp-5) var(--sp-4) var(--sp-4);
  }
  .ap__card-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-clay);
    color: var(--color-earth-brown);
  }
  .ap__card-mark svg {
    width: 26px;
    height: 26px;
  }
  .ap__card-text {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    min-width: 0;
  }
  .ap__card-role {
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--text-primary);
  }
  .ap__card-tag {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--font-size-body-lg);
    color: var(--color-clay);
  }

  /* Right: profile */
  .ap__right {
    padding-top: var(--sp-3);
  }
  .ap__eyebrow--rule {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .ap__eyebrow--rule::before {
    content: '';
    width: 32px;
    height: 1px;
    background-color: var(--color-clay);
  }
  .ap__name {
    margin: var(--sp-4) 0 var(--sp-3);
    font-family: var(--font-body);
    font-size: clamp(3rem, 4vw, 5.25rem);
    font-weight: var(--font-weight-regular);
    line-height: 1;
    letter-spacing: var(--letter-spacing-tight);
    word-spacing: 0.1em;
    color: var(--color-earth-brown);
  }
  .ap__role {
    margin: 0;
    font-size: var(--font-size-body-lg);
    color: var(--text-secondary);
  }

  .ap__quote {
    position: relative;
    margin: clamp(var(--sp-5), 4vh, var(--sp-7)) 0 0;
    padding-left: var(--sp-6);
    max-width: 42ch;
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.25rem, 1.9vw, 1.85rem);
    line-height: var(--line-height-normal);
    color: var(--text-primary);
  }
  .ap__quote::before {
    content: '\201C';
    position: absolute;
    left: calc(var(--sp-6) * -1);
    top: 0.15em;
    font-size: 2.4em;
    line-height: 1;
    color: var(--color-clay);
  }
  .ap__quote::after {
    content: '\201D';
  }

  .ap__ornament {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin: clamp(var(--sp-4), 3vh, var(--sp-6)) 0;
    color: var(--color-clay);
  }
  .ap__ornament::before,
  .ap__ornament::after {
    content: '';
    flex: 1;
    height: 1px;
    background-color: var(--border-default);
  }
  .ap__ornament-icon svg {
    width: 16px;
    height: 16px;
    display: block;
  }

  .ap__bio {
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
    max-width: 60ch;
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
    color: var(--text-secondary);
  }

  /* Craft stats */
  .ap__stats {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0;
    margin: clamp(var(--sp-6), 5vh, var(--sp-8)) 0 0;
    padding: 0;
    list-style: none;
  }
  .ap__stat {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-2) var(--sp-5);
    border-left: 1px solid var(--border-light);
  }
  .ap__stat:first-child {
    padding-left: 0;
    border-left: none;
  }
  .ap__stat-icon {
    color: var(--color-earth-brown);
    margin-bottom: var(--sp-2);
  }
  .ap__stat-icon svg {
    width: 30px;
    height: 30px;
  }
  .ap__stat-label {
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-primary);
  }
  .ap__stat-desc {
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-normal);
    color: var(--text-secondary);
  }

  @media screen and (max-width: 900px) {
    .ap__body {
      grid-template-columns: 1fr;
      gap: var(--sp-7);
    }
    .ap__left {
      max-width: 460px;
    }
    .ap__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: var(--sp-6) 0;
    }
    .ap__stat:nth-child(odd) {
      padding-left: 0;
      border-left: none;
    }
  }

  @media screen and (max-width: 480px) {
    .ap__stats {
      grid-template-columns: 1fr;
    }
    .ap__stat {
      padding-left: 0;
      border-left: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Author Profile",
  "settings": []
}
{% endschema %}
