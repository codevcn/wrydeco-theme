{% comment %}
  Renders the private consultation request section for the customization page.
  The custom backend receives the required lead fields plus optional schedule
  and attachment data through multipart FormData.
{% endcomment %}

{% liquid
  assign form_id = 'CustomizationConsultation-' | append: section.id
  assign privacy_url = shop.privacy_policy.url | default: routes.root_url
  assign api_endpoint = section.settings.api_endpoint | default: 'https://vnote.io.vn/api/consultations'
%}

<section
  class="custom-inquiry"
  id="custom-inquiry"
  aria-labelledby="CustomInquiryTitle-{{ section.id }}"
  data-consultation-endpoint="{{ api_endpoint | escape }}"
  data-success-message="{{ section.settings.success_message | escape }}"
  data-error-message="{{ section.settings.error_message | escape }}"
>
  <div class="custom-inquiry__media">
    <img
      src="{{ 'custom-inquiry-media.png' | file_url }}"
      alt=""
      width="1672"
      height="941"
      loading="lazy"
    >
  </div>
  <div class="custom-inquiry__inner">
    <div class="custom-inquiry__story" id="custom-inquiry__story-telling">
      <p class="custom-inquiry__eyebrow">
        <span aria-hidden="true">&#10022;</span>
        {{ section.settings.eyebrow | escape }}
      </p>
      <h2 id="CustomInquiryTitle-{{ section.id }}">
        <span>{{ section.settings.heading_first_line | escape }}</span>
        <span>{{ section.settings.heading_second_line | escape }}</span>
      </h2>
      <div class="custom-inquiry__rule" aria-hidden="true"><span></span><b>&#10022;</b><span></span></div>
      <p class="custom-inquiry__description">{{ section.settings.description | escape }}</p>

      <figure class="custom-inquiry__figure">
        <img
          src="{{ 'book-consultation-form-photo.png' | file_url }}"
          alt="Natural wood surface, books, and handcrafted decor selected for a custom interior"
          width="1536"
          height="864"
          loading="lazy"
        >
      </figure>

      <div class="custom-inquiry__benefits" aria-label="Custom design benefits">
        <div class="custom-inquiry__benefit">
          <span aria-hidden="true"
            ><img src="{{ 'icon-plain-variation.svg' | file_url }}" alt="" width="48" height="48"
          ></span>
          <strong>{{ section.settings.benefit_one_title | escape }}</strong>
          <small>{{ section.settings.benefit_one_text | escape }}</small>
        </div>
        <div class="custom-inquiry__benefit">
          <span aria-hidden="true">{% render 'icon-artist-recognition', icon: 'leaf' %}</span>
          <strong>{{ section.settings.benefit_two_title | escape }}</strong>
          <small>{{ section.settings.benefit_two_text | escape }}</small>
        </div>
        <div class="custom-inquiry__benefit">
          <span aria-hidden="true">{% render 'faq-category-icon', icon: 'consultation' %}</span>
          <strong>{{ section.settings.benefit_three_title | escape }}</strong>
          <small>{{ section.settings.benefit_three_text | escape }}</small>
        </div>
      </div>
    </div>

    <div class="custom-inquiry__panel">
      <form id="{{ form_id }}" class="custom-inquiry__form" novalidate>
        <header class="custom-inquiry__form-header">
          <div class="custom-inquiry__form-title">
            <span aria-hidden="true">&#10022;</span>
            <h3>{{ section.settings.form_heading | escape }}</h3>
          </div>
          <div class="custom-inquiry__schedule">
            <input type="hidden" name="consultation_time" data-schedule-value>
            <button
              type="button"
              class="custom-inquiry__schedule-open"
              data-schedule-open
              data-scheduled-label="{{ section.settings.schedule_completed_label | escape }}"
              aria-haspopup="dialog"
              aria-expanded="false"
            >
              <span class="custom-inquiry__schedule-icon" data-schedule-default-icon aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                  <path d="M0 0h24v24H0z" fill="none" />
                  <path fill="currentColor" d="M19 4h-1V3c0-.6-.4-1-1-1s-1 .4-1 1v1H8V3c0-.6-.4-1-1-1s-1 .4-1 1v1H5C3.3 4 2 5.3 2 7v1h20V7c0-1.7-1.3-3-3-3M2 19c0 1.7 1.3 3 3 3h14c1.7 0 3-1.3 3-3v-9H2zm15-7c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m0 4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m-5-4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m0 4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m-5-4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m0 4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1" />
                </svg>
              </span>
              <span data-schedule-button-label>{{ section.settings.schedule_button_label | escape }}</span>
              <span class="custom-inquiry__schedule-icon" data-schedule-complete-icon aria-hidden="true" hidden>
                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                  <path d="M0 0h24v24H0z" fill="none" />
                  <path fill="currentColor" fill-rule="evenodd" d="M12 21a9 9 0 1 0 0-18a9 9 0 0 0 0 18m-.232-5.36l5-6l-1.536-1.28l-4.3 5.159l-2.225-2.226l-1.414 1.414l3 3l.774.774z" clip-rule="evenodd" />
                </svg>
              </span>
            </button>
            <p class="custom-inquiry__schedule-current" data-schedule-current hidden>
              <span>{{ section.settings.schedule_selected_label | escape }}</span>
              <strong data-schedule-current-value></strong>
            </p>
          </div>
        </header>
        <div class="custom-inquiry__field">
          <label for="{{ form_id }}-name">{{ section.settings.name_label | escape }}</label>
          <input
            id="{{ form_id }}-name"
            type="text"
            name="name"
            value="{{ customer.name | escape }}"
            autocomplete="name"
            placeholder="{{ section.settings.name_placeholder | escape }}"
            required
          >
        </div>

        <div class="custom-inquiry__field field-contact">
          <label for="{{ form_id }}-phone-or-email">{{ section.settings.contact_label | escape }}</label>
          <input
            id="{{ form_id }}-phone-or-email"
            type="text"
            name="phone_or_email"
            value="{{ customer.phone | default: customer.email | escape }}"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            placeholder="{{ section.settings.contact_placeholder | escape }}"
            required
          >
        </div>

        <div class="custom-inquiry__field custom-inquiry__field--full field-request">
          <label for="{{ form_id }}-request">{{ section.settings.request_label | escape }}</label>
          <textarea
            id="{{ form_id }}-request"
            name="message"
            placeholder="{{ section.settings.request_placeholder | escape }}"
            required
          ></textarea>
        </div>

        <div class="custom-inquiry__field custom-inquiry__field--full">
          <span class="custom-inquiry__field-label">{{ section.settings.attachment_label | escape }}</span>
          <div class="custom-inquiry__upload-row">
            <label class="custom-inquiry__upload" for="{{ form_id }}-files">
              <input
                id="{{ form_id }}-files"
                type="file"
                name="file"
                accept=".jpg,.jpeg,.png,.pdf"
                multiple
                data-custom-files
              >
              <svg
                class="custom-inquiry__upload-icon"
                xmlns="http://www.w3.org/2000/svg"
                width="1em"
                height="1em"
                viewBox="0 0 48 48"
              >
                <path d="M0 0h48v48H0z" fill="none" />
                <path fill="currentColor" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="4" d="M5 24L24 6l19 18H31v18H17V24z" />
              </svg>
              <span data-custom-file-copy>{{ section.settings.attachment_prompt | escape }}</span>
              <small>{{ section.settings.attachment_help | escape }}</small>
            </label>

            <button
              type="button"
              class="custom-inquiry__file-count"
              data-file-count-trigger
              hidden
              aria-haspopup="dialog"
              aria-expanded="false"
              aria-controls="{{ form_id }}-files-popup"
              aria-label="View selected files"
            >
              <strong data-file-count-number>0</strong>
              <small data-file-count-label>files</small>
            </button>
          </div>

          <div class="custom-inquiry__files-popup" id="{{ form_id }}-files-popup" data-files-popup hidden>
            <div class="custom-inquiry__files-scrim" data-files-popup-close></div>
            <div
              class="custom-inquiry__files-dialog"
              role="dialog"
              aria-modal="true"
              aria-labelledby="{{ form_id }}-files-title"
              tabindex="-1"
            >
              <header class="custom-inquiry__files-head">
                <h4 id="{{ form_id }}-files-title">Selected files</h4>
                <button type="button" class="custom-inquiry__files-close" data-files-popup-close aria-label="Close">
                  <span aria-hidden="true">&times;</span>
                </button>
              </header>
              <ul class="custom-inquiry__files-list" data-files-list></ul>
            </div>
          </div>
        </div>

        <div class="consultation-scheduler" data-schedule-popup hidden>
          <button
            type="button"
            class="consultation-scheduler__scrim"
            data-schedule-close
            aria-label="Close appointment scheduler"
          ></button>
          <div
            class="consultation-scheduler__dialog"
            role="dialog"
            aria-modal="true"
            aria-labelledby="{{ form_id }}-schedule-title"
            tabindex="-1"
          >
            <header class="consultation-scheduler__header">
              <div class="consultation-scheduler__header-content">
                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                  <path d="M0 0h24v24H0z" fill="none" />
                  <path fill="currentColor" d="M19 4h-1V3c0-.6-.4-1-1-1s-1 .4-1 1v1H8V3c0-.6-.4-1-1-1s-1 .4-1 1v1H5C3.3 4 2 5.3 2 7v1h20V7c0-1.7-1.3-3-3-3M2 19c0 1.7 1.3 3 3 3h14c1.7 0 3-1.3 3-3v-9H2zm15-7c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m0 4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m-5-4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m0 4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m-5-4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1m0 4c.6 0 1 .4 1 1s-.4 1-1 1s-1-.4-1-1s.4-1 1-1" />
                </svg>
                <h4 id="{{ form_id }}-schedule-title">{{ section.settings.schedule_heading | escape }}</h4>
              </div>
              <button type="button" class="consultation-scheduler__close" data-schedule-close aria-label="Close">
                <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                  <path d="M0 0h24v24H0z" fill="none" />
                  <path fill="currentColor" d="M6.4 19L5 17.6l5.6-5.6L5 6.4L6.4 5l5.6 5.6L17.6 5L19 6.4L13.4 12l5.6 5.6l-1.4 1.4l-5.6-5.6z" />
                </svg>
              </button>
            </header>

            <div class="consultation-scheduler__body custom-scrollbar">
              <section class="consultation-scheduler__section" aria-labelledby="{{ form_id }}-date-heading">
                <div class="consultation-scheduler__section-head">
                  <span>1</span>
                  <h5 id="{{ form_id }}-date-heading">Choose a preferred date</h5>
                </div>
                <div class="consultation-calendar" data-schedule-calendar>
                  <div class="consultation-calendar__nav">
                    <button type="button" data-calendar-prev aria-label="Previous month">
                      <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                        <path d="M0 0h24v24H0z" fill="none" />
                        <path fill="none" stroke="currentColor" stroke-width="2" d="M17 2L7 12l10 10" />
                      </svg>
                    </button>
                    <strong data-calendar-month aria-live="polite"></strong>
                    <button type="button" data-calendar-next aria-label="Next month">
                      <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24">
                        <path d="M0 0h24v24H0z" fill="none" />
                        <path fill="none" stroke="currentColor" stroke-width="2" d="m7 2l10 10L7 22" />
                      </svg>
                    </button>
                  </div>
                  <div class="consultation-calendar__weekdays" aria-hidden="true">
                    <span>Sun</span><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span
                    ><span>Sat</span>
                  </div>
                  <div class="consultation-calendar__days" data-calendar-days></div>
                </div>
              </section>

              <section class="consultation-scheduler__section" aria-labelledby="{{ form_id }}-time-heading">
                <div class="consultation-scheduler__section-head">
                  <span>2</span>
                  <h5 id="{{ form_id }}-time-heading">Choose a preferred time</h5>
                </div>
                <div class="consultation-clock" data-schedule-clock>
                  <div class="consultation-clock__controls">
                    <div class="consultation-clock__display" aria-live="polite">
                      <button type="button" data-clock-mode="hour" class="is-active" aria-label="Choose hour">
                        --
                      </button>
                      <span>:</span>
                      <button type="button" data-clock-mode="minute" aria-label="Choose minutes">--</button>
                    </div>
                    <div class="consultation-clock__period" role="group" aria-label="Choose AM or PM">
                      <button type="button" data-clock-period="AM" class="is-active">AM</button>
                      <button type="button" data-clock-period="PM">PM</button>
                    </div>
                  </div>
                  <div class="consultation-clock__face" data-clock-face aria-label="Clock time picker"></div>
                </div>
              </section>

              <section
                class="consultation-scheduler__section consultation-scheduler__section--summary"
                aria-live="polite"
              >
                <div class="consultation-scheduler__section-head section-head--summary">
                  <span>3</span>
                  <h5>Selected consultation time</h5>
                </div>
                <p data-schedule-result>Choose a date and time to continue.</p>
              </section>
            </div>

            <footer class="consultation-scheduler__footer">
              <button type="button" class="consultation-scheduler__cancel" data-schedule-close>Cancel</button>
              <button type="button" class="consultation-scheduler__confirm" data-schedule-confirm disabled>
                Confirm appointment time
              </button>
            </footer>
          </div>
        </div>

        <button class="custom-inquiry__submit" type="submit">
          <span>{{ section.settings.button_label | escape }}</span>
          <span aria-hidden="true">&rarr;</span>
        </button>

        <p class="custom-inquiry__privacy">
          {{ section.settings.privacy_prefix | escape }}
          <a href="{{ privacy_url }}">{{ section.settings.privacy_label | escape }}</a>.
        </p>
      </form>
    </div>
  </div>
</section>

<script>
  const customInquiryTitleEle = document.getElementById('CustomInquiryTitle-{{ section.id }}');
  if (customInquiryTitleEle && window.innerWidth < 768) {
    customInquiryTitleEle.closest('body').querySelector('.header__icon--search').style.color =
      'var(--color-earth-brown)';
    customInquiryTitleEle.closest('body').querySelector('.header__icon--cart').style.color = 'var(--color-earth-brown)';
    customInquiryTitleEle.closest('body').querySelector('.header__localization .loc-picker__code').style.color =
      'var(--color-earth-brown)';
    customInquiryTitleEle.closest('body').querySelector('.header__icon--menu').style.color = 'var(--color-earth-brown)';
  }
</script>

{% stylesheet %}
  .custom-inquiry {
    overflow: hidden;
    background: var(--color-cream);
    color: var(--text-primary);
    font-family: var(--font-body);
    position: relative;
  }

  .custom-inquiry__media {
    position: absolute;
    inset: 0;
    z-index: 9;
  }
  .custom-inquiry__media::before {
    content: '';
    position: absolute;
    height: 100%;
    width: 60%;
    background-image: linear-gradient(to right, var(--color-cream) 0%, var(--color-cream) 60%, transparent 100%);
  }

  .custom-inquiry__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.94fr);
    align-items: stretch;
    gap: var(--sp-6);
    inline-size: min(
      calc(100% - (var(--layout-padding-desktop) * 2)),
      calc(var(--layout-showcase-max-width) + (var(--sp-12) * 2))
    );
    margin-inline: auto;
    padding-block: var(--sp-8);
    position: relative;
    z-index: 10;
  }

  .custom-inquiry__story {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-self: start;
    padding-block-start: var(--sp-0);
    height: 100%;
  }

  .custom-inquiry__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin: var(--sp-0) var(--sp-0) var(--sp-2);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 5);
    text-transform: uppercase;
  }

  .custom-inquiry__eyebrow span,
  .custom-inquiry__form-title > span {
    color: var(--color-clay);
    font-size: var(--font-size-display-sm);
  }

  .custom-inquiry__story h2 {
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-display-light);
    font-size: clamp(var(--font-size-display-md), 3.4vw, var(--font-size-display-xl));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
    text-transform: uppercase;
  }

  .custom-inquiry__rule {
    display: grid;
    grid-template-columns: minmax(var(--sp-8), var(--sp-12)) auto minmax(var(--sp-8), var(--sp-12));
    align-items: center;
    gap: var(--sp-2);
    inline-size: fit-content;
    margin-block: var(--sp-3);
    color: var(--color-clay);
  }

  .custom-inquiry__rule span {
    block-size: var(--border-width);
    background: currentcolor;
  }

  .custom-inquiry__rule b {
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-regular);
  }

  .custom-inquiry__description {
    max-inline-size: 48ch;
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-relaxed);
  }

  .custom-inquiry__figure {
    aspect-ratio: 16 / 6;
    margin: var(--sp-3) var(--sp-0) var(--sp-2);
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .custom-inquiry__figure img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: left bottom;
  }

  .custom-inquiry__benefits {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    padding: var(--sp-2);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-milk) 80%, transparent);
  }

  .custom-inquiry__benefit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-1);
    padding-inline: var(--sp-3);
    border-inline-start: var(--border-width) solid var(--border-default);
    text-align: center;
  }

  .custom-inquiry__benefit:first-child {
    border-inline-start: 0;
  }

  .custom-inquiry__benefit > span {
    display: grid;
    place-items: center;
    inline-size: var(--sp-5);
    block-size: var(--sp-5);
    color: var(--color-clay);
  }

  .custom-inquiry__benefit svg,
  .custom-inquiry__benefit img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: contain;
  }

  .custom-inquiry__benefit strong {
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .custom-inquiry__benefit small {
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-normal);
  }

  .custom-inquiry__panel {
    align-self: stretch;
    min-block-size: 0;
    padding: var(--sp-5) var(--sp-6) var(--sp-4);
    border: var(--border-width) solid var(--color-clay);
    border-radius: var(--radius-lg);
    background-color: color-mix(in srgb, var(--color-milk) 90%, transparent);
    box-shadow: var(--shadow-elevation-1);
  }

  .custom-inquiry__form-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    flex: 1 1 100%;
    margin-block-end: var(--sp-4);
  }

  .custom-inquiry__form-title {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    min-inline-size: 0;
  }

  .custom-inquiry__form-header h3 {
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-bold);
    letter-spacing: calc(var(--letter-spacing-wide) * 4);
    text-transform: uppercase;
  }

  .custom-inquiry__form {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4) var(--sp-5);
  }

  .custom-inquiry__field {
    display: flex;
    flex-direction: column;
    gap: var(--sp-1);
    flex: 1 1 calc(50% - (var(--sp-5) / 2));
    min-inline-size: 0;
  }

  .custom-inquiry__field--full,
  .custom-inquiry__security,
  .custom-inquiry__submit,
  .custom-inquiry__privacy {
    flex: 1 1 100%;
  }

  .custom-inquiry__field label:not(.custom-inquiry__upload),
  .custom-inquiry__field-label {
    color: var(--color-earth-brown);
    font-family: var(--font-roboto);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    text-transform: uppercase;
  }

  .custom-inquiry__field input:not([type='file']),
  .custom-inquiry__field textarea {
    inline-size: 100%;
    min-block-size: var(--sp-6);
    padding: var(--sp-2) var(--sp-3);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--bg-tertiary) 68%, transparent);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
  }

  .custom-inquiry__field textarea {
    min-block-size: var(--sp-8);
    resize: vertical;
  }

  .custom-inquiry__field.field-request textarea {
    min-block-size: 130px;
  }

  .custom-inquiry__field input:focus,
  .custom-inquiry__field textarea:focus {
    border-color: var(--color-earth-brown);
    outline: 0;
    box-shadow: var(--shadow-focus);
  }

  .custom-inquiry__field input[aria-invalid='true'] {
    border-color: var(--color-error);
  }

  .custom-inquiry__upload-row {
    display: flex;
    align-items: stretch;
    gap: var(--sp-3);
  }

  .custom-inquiry__upload {
    position: relative;
    display: flex;
    flex: 1 1 auto;
    min-inline-size: 0;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-block-size: var(--sp-8);
    padding: var(--sp-3);
    overflow: hidden;
    border: var(--border-width) dashed var(--color-clay);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    text-align: center;
    cursor: pointer;
  }

  .custom-inquiry__upload input {
    position: absolute;
    inset: var(--sp-0);
    opacity: 0;
    cursor: pointer;
  }

  .custom-inquiry__upload-icon {
    color: var(--color-clay);
    height: var(--sp-6);
    width: var(--sp-6);
  }

  .custom-inquiry__upload small {
    margin-block-start: var(--sp-2);
    font-size: var(--font-size-caption);
  }

  /* Square box showing the number of picked files; opens the files popup. */
  .custom-inquiry__file-count {
    display: flex;
    flex: 0 0 auto;
    align-self: stretch;
    aspect-ratio: 1;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--sp-1);
    padding: var(--sp-2);
    border: var(--border-width) solid var(--color-clay);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-milk) 84%, transparent);
    color: var(--color-earth-brown);
    line-height: var(--line-height-tight);
    cursor: pointer;
    transition: var(--transition-fast);
  }

  .custom-inquiry__file-count[hidden] {
    display: none;
  }

  .custom-inquiry__file-count:hover {
    border-color: var(--color-earth-brown);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .custom-inquiry__file-count:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  .custom-inquiry__file-count strong {
    font-family: var(--font-display);
    font-size: var(--font-size-body-2xl);
    font-weight: var(--font-weight-semibold);
  }

  .custom-inquiry__file-count small {
    font-size: var(--font-size-caption);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    text-transform: uppercase;
  }

  /* Files popup */
  .custom-inquiry__files-popup {
    position: fixed;
    inset: var(--sp-0);
    z-index: var(--z-drawer);
    display: grid;
    place-items: center;
    padding: var(--sp-4);
  }

  .custom-inquiry__files-popup[hidden] {
    display: none;
  }

  .custom-inquiry__files-scrim {
    position: absolute;
    inset: var(--sp-0);
    background: var(--bg-overlay);
    opacity: 0;
    transition: opacity var(--timing-base) var(--ease-standard);
  }

  .custom-inquiry__files-dialog {
    position: relative;
    display: flex;
    flex-direction: column;
    inline-size: min(26rem, 100%);
    max-block-size: min(70vh, 32rem);
    overflow: hidden;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    background: var(--surface-overlay);
    box-shadow: var(--shadow-modal);
    opacity: 0;
    transform: translateY(var(--sp-3)) scale(0.96);
    transition: opacity var(--timing-base) var(--ease-standard), transform var(--timing-base) var(--ease-standard);
  }

  .custom-inquiry__files-popup.is-open .custom-inquiry__files-scrim {
    opacity: 1;
  }

  .custom-inquiry__files-popup.is-open .custom-inquiry__files-dialog {
    opacity: 1;
    transform: none;
  }

  .custom-inquiry__files-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-3) var(--sp-4);
    border-block-end: var(--border-width) solid var(--border-default);
  }

  .custom-inquiry__files-head h4 {
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 3);
    text-transform: uppercase;
  }

  .custom-inquiry__files-close {
    display: grid;
    place-items: center;
    height: var(--sp-6);
    width: var(--sp-6);
    border: 0;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-secondary);
    font-size: var(--font-size-body-2xl);
    line-height: var(--line-height-tight);
    cursor: pointer;
    transition: var(--transition-fast);
  }

  .custom-inquiry__files-close:hover {
    background: var(--bg-secondary);
    color: var(--color-earth-brown);
  }

  .custom-inquiry__files-close:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: calc(var(--border-width) * -2);
  }

  .custom-inquiry__files-list {
    display: grid;
    gap: var(--sp-2);
    margin: var(--sp-0);
    padding: var(--sp-4);
    overflow-y: auto;
    list-style: none;
  }

  .custom-inquiry__files-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--color-milk) 60%, transparent);
  }

  .custom-inquiry__files-item .custom-inquiry__files-name {
    overflow: hidden;
    color: var(--text-primary);
    font-size: var(--font-size-body-sm);
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .custom-inquiry__files-item .custom-inquiry__files-size {
    flex: 0 0 auto;
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    white-space: nowrap;
  }

  .custom-inquiry__security {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-generous);
  }

  .custom-inquiry__security span {
    color: var(--color-clay);
    font-size: var(--font-size-body-lg);
  }

  .custom-inquiry__submit {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    min-block-size: var(--sp-6);
    padding-inline: var(--sp-5);
    padding-block: var(--sp-4);
    border: 0;
    border-radius: var(--radius-md);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
    font-family: var(--font-roboto);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    text-transform: uppercase;
  }

  .custom-inquiry__submit:hover {
    background: var(--color-charcoal);
  }

  .custom-inquiry__schedule {
    display: grid;
    gap: var(--sp-1);
    flex: 0 1 auto;
    min-inline-size: min(23rem, 55%);
  }

  .custom-inquiry__schedule-open {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-3);
    inline-size: 100%;
    min-block-size: var(--sp-7);
    padding: var(--sp-3) var(--sp-4);
    border: var(--border-width) solid var(--color-earth-brown);
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-earth-brown);
    font-family: var(--font-roboto);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    text-transform: uppercase;
    cursor: pointer;
    transition: var(--transition-fast);
  }
  .custom-inquiry__schedule-open [data-schedule-button-label] {
    font-size: var(--font-size-body-sm);
  }

  .custom-inquiry__schedule-open:hover {
    background: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .custom-inquiry__schedule-open.is-scheduled {
    border-color: var(--color-sage);
    background: color-mix(in srgb, var(--color-sage) 12%, transparent);
    color: var(--color-earth-brown);
  }

  .custom-inquiry__schedule-icon {
    display: inline-flex;
    flex: 0 0 auto;
    inline-size: var(--sp-5);
    block-size: var(--sp-5);
  }

  .custom-inquiry__schedule-icon[hidden] {
    display: none;
  }

  .custom-inquiry__schedule-icon svg {
    inline-size: 100%;
    block-size: 100%;
  }

  .custom-inquiry__schedule-current {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--sp-3);
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
  }

  .custom-inquiry__schedule-current[hidden] {
    display: none;
  }

  .custom-inquiry__schedule-current strong {
    color: var(--color-earth-brown);
    font-size: var(--font-size-body-md);
  }

  .consultation-scheduler {
    position: fixed;
    inset: var(--sp-0);
    z-index: calc(var(--z-drawer) + 1);
    display: grid;
    place-items: center;
    padding: var(--sp-4);
  }

  html.consultation-scheduler-open {
    overflow: hidden;
  }

  .consultation-scheduler[hidden] {
    display: none;
  }

  .consultation-scheduler__scrim {
    position: absolute;
    inset: var(--sp-0);
    inline-size: 100%;
    block-size: 100%;
    border: 0;
    background: var(--bg-overlay);
    opacity: 0;
    cursor: default;
    transition: opacity var(--timing-base) var(--ease-standard);
  }

  .consultation-scheduler__dialog {
    position: relative;
    display: flex;
    flex-direction: column;
    inline-size: min(64rem, 100%);
    max-block-size: min(92dvh, 58rem);
    overflow: hidden;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-xl);
    background: var(--surface-overlay);
    box-shadow: var(--shadow-modal);
    opacity: 0;
    transform: translateY(var(--sp-3)) scale(0.98);
    transition: opacity var(--timing-base) var(--ease-standard), transform var(--timing-base) var(--ease-standard);
  }

  .consultation-scheduler.is-open .consultation-scheduler__scrim,
  .consultation-scheduler.is-open .consultation-scheduler__dialog {
    opacity: 1;
  }

  .consultation-scheduler.is-open .consultation-scheduler__dialog {
    transform: none;
  }

  .consultation-scheduler__header,
  .consultation-scheduler__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-2) var(--sp-5);
  }

  .consultation-scheduler__header {
    border-block-end: var(--border-width) solid var(--border-light);
  }

  .consultation-scheduler__header-content {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .consultation-scheduler__header-content svg {
    height: var(--sp-5);
    width: var(--sp-5);
  }

  .consultation-scheduler__header p {
    color: var(--color-clay);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 3);
    text-transform: uppercase;
  }

  .consultation-scheduler__header h4 {
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-body-lg);
    font-weight: var(--font-weight-bold);
  }

  .consultation-scheduler__close {
    display: grid;
    place-items: center;
    min-inline-size: 42px;
    min-block-size: 42px;
    border: 0;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
    color: var(--text-primary);
    font-size: var(--font-size-body-2xl);
    cursor: pointer;
  }

  .consultation-scheduler__body {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-5);
    overflow-y: auto;
  }

  .consultation-scheduler__section {
    min-inline-size: 0;
  }

  .consultation-scheduler__section--summary {
    display: flex;
    gap: var(--sp-8);
    justify-content: space-between;
    grid-column: 1 / -1;
    padding: var(--sp-4);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    background: var(--bg-secondary);
  }

  .consultation-scheduler__section-head {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-block-end: var(--sp-3);
  }
  .consultation-scheduler__section-head.section-head--summary {
    margin-block-end: 0;
  }

  .consultation-scheduler__section-head > span {
    display: grid;
    place-items: center;
    min-inline-size: var(--sp-6);
    min-block-size: var(--sp-6);
    border-radius: var(--radius-full);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
    font-size: var(--font-size-caption);
  }

  .consultation-scheduler__section h5,
  .consultation-scheduler__section--summary p {
    margin: var(--sp-0);
  }

  .consultation-scheduler__section h5 {
    color: var(--color-earth-brown);
    font-size: var(--font-size-body-md);
    font-weight: var(--font-weight-semibold);
  }

  .consultation-scheduler__section--summary p {
    color: var(--color-earth-brown);
    font-family: var(--font-body);
    font-size: var(--font-size-body-lg);
    text-align: center;
  }

  .consultation-calendar {
    padding: var(--sp-3);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
  }

  .consultation-calendar__nav {
    display: grid;
    grid-template-columns: var(--sp-7) minmax(0, 1fr) var(--sp-7);
    align-items: center;
    gap: var(--sp-2);
    margin-block-end: var(--sp-3);
  }

  .consultation-calendar__nav button {
    display: grid;
    place-items: center;
    min-inline-size: var(--sp-7);
    min-block-size: var(--sp-7);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-full);
    background: var(--surface-elevated);
    color: var(--color-earth-brown);
    font-size: var(--font-size-body-2xl);
    cursor: pointer;
  }

  .consultation-calendar__nav button:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .consultation-calendar__nav strong {
    color: var(--color-earth-brown);
    font-size: var(--font-size-body-lg);
    text-align: center;
  }

  .consultation-calendar__weekdays,
  .consultation-calendar__days {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: var(--sp-1);
  }

  .consultation-calendar__weekdays span {
    padding-block: var(--sp-1);
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    text-align: center;
  }

  .consultation-calendar__day {
    display: grid;
    place-items: center;
    min-inline-size: var(--sp-7);
    min-block-size: var(--sp-7);
    padding: var(--sp-0);
    border: 0;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-primary);
    font: inherit;
    cursor: pointer;
  }

  .consultation-calendar__day.is-selected {
    background: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .consultation-calendar__day:not(:disabled):hover {
    background: var(--color-clay);
    color: var(--text-inverse);
  }

  .consultation-calendar__day:disabled {
    color: var(--text-tertiary);
    opacity: 0.45;
    cursor: not-allowed;
  }

  .consultation-calendar__day--blank {
    min-inline-size: var(--sp-7);
    min-block-size: var(--sp-7);
  }

  .consultation-clock {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--sp-3);
  }

  .consultation-clock__controls {
    display: flex;
    gap: var(--sp-6);
    justify-content: center;
    align-items: center;
    width: 100%;
  }

  .consultation-clock__display {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-earth-brown);
    font-family: var(--font-body);
    font-size: var(--font-size-display-sm);
  }

  .consultation-clock__display button,
  .consultation-clock__period button {
    min-block-size: var(--sp-7);
    border: 0;
    border-radius: var(--radius-md);
    background: transparent;
    color: inherit;
    font: inherit;
    cursor: pointer;
    padding-inline: var(--sp-1);
  }

  .consultation-clock__display button.is-active {
    background: var(--bg-secondary);
  }

  .consultation-clock__period {
    display: flex;
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .consultation-clock__period button {
    min-inline-size: var(--sp-7);
    padding-inline: var(--sp-2);
    color: var(--text-secondary);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-sm);
  }

  .consultation-clock__period button.is-active {
    background: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .consultation-clock__face {
    --clock-radius: min(7.2rem, 29vw);
    position: relative;
    grid-column: 1 / -1;
    inline-size: min(19rem, 76vw);
    aspect-ratio: 1;
    margin-inline: auto;
    border-radius: var(--radius-full);
    background: var(--bg-secondary);
  }

  .consultation-clock__face::before {
    content: '';
    position: absolute;
    inset: 50% auto auto 50%;
    inline-size: var(--sp-2);
    block-size: var(--sp-2);
    border-radius: var(--radius-full);
    background: var(--color-earth-brown);
    transform: translate(-50%, -50%);
  }

  .consultation-clock__tick {
    position: absolute;
    inset: 50% auto auto 50%;
    display: grid;
    place-items: center;
    min-inline-size: var(--sp-7);
    min-block-size: var(--sp-7);
    padding: var(--sp-0);
    border: 0;
    border-radius: var(--radius-full);
    background: transparent;
    color: var(--text-primary);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-sm);
    cursor: pointer;
    transform: translate(-50%, -50%) rotate(var(--tick-angle)) translateY(calc(var(--clock-radius) * -1))
      rotate(calc(var(--tick-angle) * -1));
  }

  .consultation-clock__tick.is-selected {
    background: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .consultation-clock__tick:hover {
    background: var(--color-clay);
    color: var(--text-inverse);
  }

  .consultation-scheduler__footer {
    justify-content: flex-end;
    border-block-start: var(--border-width) solid var(--border-light);
  }

  .consultation-scheduler__cancel,
  .consultation-scheduler__confirm {
    min-block-size: var(--sp-7);
    padding-inline: var(--sp-5);
    border-radius: var(--radius-md);
    font-family: var(--font-roboto);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    cursor: pointer;
  }

  .consultation-scheduler__cancel {
    border: var(--border-width) solid var(--border-default);
    background: transparent;
    color: var(--text-primary);
  }

  .consultation-scheduler__confirm {
    border: var(--border-width) solid var(--color-earth-brown);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
  }

  .consultation-scheduler__confirm:disabled {
    opacity: 0.45;
    cursor: not-allowed;
  }

  .custom-inquiry__privacy {
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    text-align: center;
  }

  .custom-inquiry__privacy a {
    color: var(--text-secondary);
    text-decoration: underline;
  }

  @media screen and (max-width: 64rem) {
    .custom-inquiry {
      block-size: auto;
      overflow: visible;
    }

    .custom-inquiry__inner {
      grid-template-columns: minmax(0, 0.84fr) minmax(0, 1.16fr);
      gap: var(--sp-5);
      inline-size: min(calc(100% - (var(--layout-padding-tablet) * 2)), var(--layout-showcase-max-width));
      block-size: auto;
      padding-block: var(--sp-8);
    }

    .custom-inquiry__story h2 {
      font-size: var(--font-size-display-lg);
    }

    .custom-inquiry__panel {
      padding: var(--sp-5);
    }

    .custom-inquiry__field {
      flex: 1 1 100%;
    }

    .custom-inquiry__benefits {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-4);
    }

    .custom-inquiry__benefit {
      display: grid;
      grid-template-columns: var(--sp-7) minmax(0, 1fr);
      justify-items: start;
      border-inline-start: 0;
      text-align: left;
    }

    .custom-inquiry__benefit small {
      grid-column: 2;
    }
  }

  @media screen and (max-width: 48rem) {
    .custom-inquiry__inner {
      grid-template-columns: minmax(0, 1fr);
