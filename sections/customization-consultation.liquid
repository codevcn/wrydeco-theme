{% javascript %}
  const initializeCustomizationInquiry = () => {
    const notify = (message, type) => {
      if (window.showToast) {
        window.showToast({ message, type, position: 'bottom-right', duration: 4000 });
      }
    };

    document.querySelectorAll('.custom-inquiry__form:not([data-submit-initialized])').forEach((form) => {
      form.dataset.submitInitialized = 'true';

      const section = form.closest('.custom-inquiry');
      const endpoint = section?.dataset.consultationEndpoint;
      if (!endpoint) return;

      const successMessage = section.dataset.successMessage || 'Thank you. Your consultation request has been sent.';
      const errorMessage = section.dataset.errorMessage || 'Something went wrong. Please try again.';

      form.addEventListener('submit', async (event) => {
        // Fully AJAX: never let the browser navigate/reload.
        event.preventDefault();

        // Validate in JS (form is novalidate) and surface native hints.
        if (!form.reportValidity()) return;

        const submitButton = form.querySelector('.custom-inquiry__submit');
        const labelSpan = submitButton?.querySelector('span:first-child');
        const originalLabel = labelSpan?.textContent;

        const getValue = (name) => form.querySelector(`[name="${name}"]`)?.value.trim() || '';

        const formData = new FormData();
        formData.append('name', getValue('name'));
        formData.append('email', getValue('email'));
        formData.append('phone', getValue('phone'));
        formData.append('message', getValue('message'));

        const fileInput = form.querySelector('[data-custom-files]');
        if (fileInput?.files?.length) {
          // Send every selected file under the same `file` key (List[UploadFile]).
          Array.from(fileInput.files).forEach((file) => formData.append('file', file));
        }

        if (submitButton) {
          submitButton.disabled = true;
          submitButton.setAttribute('aria-busy', 'true');
        }
        if (labelSpan) labelSpan.textContent = 'Sending…';

        try {
          // Do not set Content-Type: let the browser add the multipart boundary.
          const response = await fetch(endpoint, { method: 'POST', body: formData });

          if (response.ok) {
            notify(successMessage, 'success');
            form.reset();
            // Re-sync the file UI (count box, popup, dropzone copy) to the now-empty input.
            if (fileInput) fileInput.dispatchEvent(new Event('change'));
          } else {
            notify(errorMessage, 'error');
          }
        } catch (error) {
          notify(errorMessage, 'error');
        } finally {
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.removeAttribute('aria-busy');
          }
          if (labelSpan && originalLabel != null) labelSpan.textContent = originalLabel;
        }
      });
    });

    document.querySelectorAll('[data-custom-files]:not([data-file-initialized])').forEach((input) => {
      input.dataset.fileInitialized = 'true';

      const form = input.closest('form');
      const fileCopy = form?.querySelector('[data-custom-file-copy]');
      const countBtn = form?.querySelector('[data-file-count-trigger]');
      const countNumber = form?.querySelector('[data-file-count-number]');
      const countLabel = form?.querySelector('[data-file-count-label]');
      const popup = form?.querySelector('[data-files-popup]');
      const dialog = popup?.querySelector('.custom-inquiry__files-dialog');
      const list = form?.querySelector('[data-files-list]');

      if (fileCopy && !fileCopy.dataset.defaultCopy) {
        fileCopy.dataset.defaultCopy = fileCopy.textContent;
      }

      const plural = (n) => (n === 1 ? 'file' : 'files');

      const formatSize = (bytes) => {
        if (bytes < 1024) return `${bytes} B`;
        if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
        return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
      };

      const renderList = (files) => {
        if (!list) return;
        list.textContent = '';
        files.forEach((file) => {
          const item = document.createElement('li');
          item.className = 'custom-inquiry__files-item';
          const name = document.createElement('span');
          name.className = 'custom-inquiry__files-name';
          name.textContent = file.name;
          const size = document.createElement('span');
          size.className = 'custom-inquiry__files-size';
          size.textContent = formatSize(file.size);
          item.append(name, size);
          list.append(item);
        });
      };

      const onKeydown = (event) => {
        if (event.key === 'Escape') closePopup();
      };

      function openPopup() {
        if (!popup || !popup.hidden) return;
        popup.hidden = false;
        // Two frames so the browser paints the hidden state before transitioning.
        requestAnimationFrame(() => requestAnimationFrame(() => popup.classList.add('is-open')));
        countBtn?.setAttribute('aria-expanded', 'true');
        document.addEventListener('keydown', onKeydown);
        dialog?.focus();
      }

      function closePopup() {
        if (!popup || popup.hidden) return;
        popup.classList.remove('is-open');
        countBtn?.setAttribute('aria-expanded', 'false');
        document.removeEventListener('keydown', onKeydown);

        let done = false;
        const finish = () => {
          if (done) return;
          done = true;
          dialog?.removeEventListener('transitionend', onEnd);
          popup.hidden = true;
        };
        const onEnd = (event) => {
          if (event.target === dialog) finish();
        };
        dialog?.addEventListener('transitionend', onEnd);
        // Fallback when transitionend does not fire (e.g. reduced motion).
        setTimeout(finish, 400);
      }

      const syncUi = () => {
        const files = Array.from(input.files || []);
        const count = files.length;

        if (countNumber) countNumber.textContent = count;
        if (countLabel) countLabel.textContent = plural(count);
        if (countBtn) countBtn.hidden = count === 0;
        if (fileCopy) {
          fileCopy.textContent = count > 0 ? `${count} ${plural(count)} selected` : fileCopy.dataset.defaultCopy || '';
        }
        renderList(files);
        if (count === 0) closePopup();
      };

      countBtn?.addEventListener('click', openPopup);
      popup?.querySelectorAll('[data-files-popup-close]').forEach((el) => el.addEventListener('click', closePopup));

      input.addEventListener('change', () => {
        const files = Array.from(input.files || []);
        const tooBig = files.find((file) => file.size > 10 * 1024 * 1024);
        if (tooBig) {
          input.value = '';
          notify('Each file must be 10MB or smaller.', 'error');
        }
        syncUi();
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeCustomizationInquiry, { once: true });
  } else {
    initializeCustomizationInquiry();
  }

  document.addEventListener('shopify:section:load', initializeCustomizationInquiry);
{% endjavascript %}

