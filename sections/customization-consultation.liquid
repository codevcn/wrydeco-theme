{% javascript %}
  const initializeCustomizationInquiry = () => {
    const notify = (message, type) => {
      if (window.showToast) {
        window.showToast({ message, type, position: 'bottom-left', duration: 4000 });
      }
    };

    document.querySelectorAll('.custom-inquiry__form:not([data-schedule-initialized])').forEach((form) => {
      form.dataset.scheduleInitialized = 'true';

      const popup = form.querySelector('[data-schedule-popup]');
      const dialog = popup?.querySelector('.consultation-scheduler__dialog');
      const openButton = form.querySelector('[data-schedule-open]');
      const confirmButton = form.querySelector('[data-schedule-confirm]');
      const hiddenInput = form.querySelector('[data-schedule-value]');
      const currentSummary = form.querySelector('[data-schedule-current]');
      const currentValue = form.querySelector('[data-schedule-current-value]');
      const scheduleButtonLabel = form.querySelector('[data-schedule-button-label]');
      const scheduleDefaultIcon = form.querySelector('[data-schedule-default-icon]');
      const scheduleCompleteIcon = form.querySelector('[data-schedule-complete-icon]');
      const result = form.querySelector('[data-schedule-result]');
      const monthLabel = form.querySelector('[data-calendar-month]');
      const daysGrid = form.querySelector('[data-calendar-days]');
      const prevButton = form.querySelector('[data-calendar-prev]');
      const nextButton = form.querySelector('[data-calendar-next]');
      const clockFace = form.querySelector('[data-clock-face]');
      const hourDisplay = form.querySelector('[data-clock-mode="hour"]');
      const minuteDisplay = form.querySelector('[data-clock-mode="minute"]');
      const periodButtons = Array.from(form.querySelectorAll('[data-clock-period]'));

      if (!popup || !dialog || !openButton || !confirmButton || !hiddenInput) return;

      const defaultScheduleLabel = scheduleButtonLabel?.textContent || 'Schedule an online consultation';
      const completedScheduleLabel = openButton.dataset.scheduledLabel || 'CONSULTATION SCHEDULED';

      const pad = (value) => String(value).padStart(2, '0');
      const today = new Date();
      today.setHours(0, 0, 0, 0);
      const firstMonth = new Date(today.getFullYear(), today.getMonth(), 1);
      const lastMonth = new Date(today.getFullYear(), today.getMonth() + 2, 1);
      let visibleMonth = new Date(firstMonth);
      let selectedDate = null;
      let selectedHour = null;
      let selectedMinute = null;
      let selectedPeriod = 'AM';
      let clockMode = 'hour';
      let returnFocus = null;
      let committedSelection = null;

      const sameDay = (left, right) =>
        left &&
        right &&
        left.getFullYear() === right.getFullYear() &&
        left.getMonth() === right.getMonth() &&
        left.getDate() === right.getDate();

      const formatSelection = () => {
        if (!selectedDate || selectedHour == null || selectedMinute == null) return '';
        return `${pad(selectedHour)}:${pad(selectedMinute)} ${selectedPeriod}, ${pad(selectedDate.getDate())}/${pad(
          selectedDate.getMonth() + 1
        )}/${selectedDate.getFullYear()}`;
      };

      const syncSelection = () => {
        const formatted = formatSelection();
        if (result) result.textContent = formatted || 'Choose a date and time to continue.';
        confirmButton.disabled = !formatted;
      };

      const renderCalendar = () => {
        if (!daysGrid || !monthLabel) return;
        monthLabel.textContent = new Intl.DateTimeFormat('en-US', { month: 'long', year: 'numeric' }).format(
          visibleMonth
        );
        daysGrid.textContent = '';

        const year = visibleMonth.getFullYear();
        const month = visibleMonth.getMonth();
        const firstWeekday = new Date(year, month, 1).getDay();
        const daysInMonth = new Date(year, month + 1, 0).getDate();

        for (let index = 0; index < firstWeekday; index += 1) {
          const blank = document.createElement('span');
          blank.className = 'consultation-calendar__day--blank';
          blank.setAttribute('aria-hidden', 'true');
          daysGrid.append(blank);
        }

        for (let day = 1; day <= daysInMonth; day += 1) {
          const date = new Date(year, month, day);
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'consultation-calendar__day';
          button.textContent = day;
          button.disabled = date < today;
          button.setAttribute(
            'aria-label',
            new Intl.DateTimeFormat('en-US', {
              weekday: 'long',
              month: 'long',
              day: 'numeric',
              year: 'numeric',
            }).format(date)
          );
          if (sameDay(date, selectedDate)) {
            button.classList.add('is-selected');
            button.setAttribute('aria-pressed', 'true');
          } else {
            button.setAttribute('aria-pressed', 'false');
          }
          button.addEventListener('click', () => {
            selectedDate = date;
            renderCalendar();
            syncSelection();
          });
          daysGrid.append(button);
        }

        if (prevButton) prevButton.disabled = visibleMonth.getTime() <= firstMonth.getTime();
        if (nextButton) nextButton.disabled = visibleMonth.getTime() >= lastMonth.getTime();
      };

      const renderClock = () => {
        if (!clockFace) return;
        clockFace.textContent = '';
        const values =
          clockMode === 'hour'
            ? Array.from({ length: 12 }, (_, index) => index + 1)
            : Array.from({ length: 12 }, (_, index) => index * 5);

        values.forEach((value, index) => {
          const button = document.createElement('button');
          button.type = 'button';
          button.className = 'consultation-clock__tick';
          button.style.setProperty('--tick-angle', `${index * 30}deg`);
          button.textContent = clockMode === 'minute' ? pad(value) : value;
          const isSelected = clockMode === 'hour' ? selectedHour === value : selectedMinute === value;
          if (isSelected) button.classList.add('is-selected');
          button.setAttribute('aria-pressed', isSelected ? 'true' : 'false');
          button.setAttribute('aria-label', clockMode === 'hour' ? `Hour ${value}` : `${value} minutes`);
          button.addEventListener('click', () => {
            if (clockMode === 'hour') {
              selectedHour = value;
              clockMode = 'minute';
            } else {
              selectedMinute = value;
            }
            renderClock();
            syncSelection();
          });
          clockFace.append(button);
        });

        if (hourDisplay) {
          hourDisplay.textContent = selectedHour == null ? '--' : pad(selectedHour);
          hourDisplay.classList.toggle('is-active', clockMode === 'hour');
        }
        if (minuteDisplay) {
          minuteDisplay.textContent = selectedMinute == null ? '--' : pad(selectedMinute);
          minuteDisplay.classList.toggle('is-active', clockMode === 'minute');
        }
      };

      const restoreCommittedSelection = () => {
        selectedDate = committedSelection?.date ? new Date(committedSelection.date) : null;
        selectedHour = committedSelection?.hour ?? null;
        selectedMinute = committedSelection?.minute ?? null;
        selectedPeriod = committedSelection?.period || 'AM';
        clockMode = selectedHour == null ? 'hour' : 'minute';
        periodButtons.forEach((button) =>
          button.classList.toggle('is-active', button.dataset.clockPeriod === selectedPeriod)
        );
        renderCalendar();
        renderClock();
        syncSelection();
      };

      const closePopup = (discardChanges = false) => {
        if (popup.hidden) return;
        if (discardChanges) restoreCommittedSelection();
        popup.classList.remove('is-open');
        document.documentElement.classList.remove('consultation-scheduler-open');
        openButton.setAttribute('aria-expanded', 'false');
        document.removeEventListener('keydown', onKeydown);
        window.setTimeout(() => {
          popup.hidden = true;
          returnFocus?.focus();
        }, 250);
      };

      const onKeydown = (event) => {
        if (event.key === 'Escape') {
          closePopup(true);
          return;
        }
        if (event.key !== 'Tab') return;
        const focusable = Array.from(
          dialog.querySelectorAll(
            'button:not([disabled]), [href], input:not([disabled]), [tabindex]:not([tabindex="-1"])'
          )
        ).filter((element) => element.offsetParent !== null);
        if (!focusable.length) return;
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (event.shiftKey && document.activeElement === first) {
          event.preventDefault();
          last.focus();
        } else if (!event.shiftKey && document.activeElement === last) {
          event.preventDefault();
          first.focus();
        }
      };

      const openPopup = () => {
        returnFocus = document.activeElement;
        popup.hidden = false;
        openButton.setAttribute('aria-expanded', 'true');
        document.documentElement.classList.add('consultation-scheduler-open');
        renderCalendar();
        renderClock();
        syncSelection();
        window.requestAnimationFrame(() => window.requestAnimationFrame(() => popup.classList.add('is-open')));
        document.addEventListener('keydown', onKeydown);
        dialog.focus();
      };

      prevButton?.addEventListener('click', () => {
        if (visibleMonth.getTime() <= firstMonth.getTime()) return;
        visibleMonth = new Date(visibleMonth.getFullYear(), visibleMonth.getMonth() - 1, 1);
        renderCalendar();
      });
      nextButton?.addEventListener('click', () => {
        if (visibleMonth.getTime() >= lastMonth.getTime()) return;
        visibleMonth = new Date(visibleMonth.getFullYear(), visibleMonth.getMonth() + 1, 1);
        renderCalendar();
      });
      hourDisplay?.addEventListener('click', () => {
        clockMode = 'hour';
        renderClock();
      });
      minuteDisplay?.addEventListener('click', () => {
        clockMode = 'minute';
        renderClock();
      });
      periodButtons.forEach((button) => {
        button.addEventListener('click', () => {
          selectedPeriod = button.dataset.clockPeriod;
          periodButtons.forEach((periodButton) => periodButton.classList.toggle('is-active', periodButton === button));
          syncSelection();
        });
      });

      openButton.addEventListener('click', openPopup);
      popup
        .querySelectorAll('[data-schedule-close]')
        .forEach((button) => button.addEventListener('click', () => closePopup(true)));
      confirmButton.addEventListener('click', () => {
        const formatted = formatSelection();
        if (!formatted) return;
        committedSelection = {
          date: selectedDate.getTime(),
          hour: selectedHour,
          minute: selectedMinute,
          period: selectedPeriod,
        };
        hiddenInput.value = formatted;
        if (currentValue) currentValue.textContent = formatted;
        if (currentSummary) currentSummary.hidden = false;
        if (scheduleButtonLabel) scheduleButtonLabel.textContent = completedScheduleLabel;
        if (scheduleDefaultIcon) scheduleDefaultIcon.hidden = true;
        if (scheduleCompleteIcon) scheduleCompleteIcon.hidden = false;
        openButton.classList.add('is-scheduled');
        closePopup();
      });
      form.addEventListener('consultation:schedule-reset', () => {
        selectedDate = null;
        selectedHour = null;
        selectedMinute = null;
        selectedPeriod = 'AM';
        clockMode = 'hour';
        committedSelection = null;
        visibleMonth = new Date(firstMonth);
        hiddenInput.value = '';
        if (currentValue) currentValue.textContent = '';
        if (currentSummary) currentSummary.hidden = true;
        if (scheduleButtonLabel) scheduleButtonLabel.textContent = defaultScheduleLabel;
        if (scheduleDefaultIcon) scheduleDefaultIcon.hidden = false;
        if (scheduleCompleteIcon) scheduleCompleteIcon.hidden = true;
        openButton.classList.remove('is-scheduled');
        periodButtons.forEach((button) => button.classList.toggle('is-active', button.dataset.clockPeriod === 'AM'));
        renderCalendar();
        renderClock();
        syncSelection();
      });

      renderCalendar();
      renderClock();
      syncSelection();
    });

    document.querySelectorAll('.custom-inquiry__form:not([data-submit-initialized])').forEach((form) => {
      form.dataset.submitInitialized = 'true';

      const section = form.closest('.custom-inquiry');
      const endpoint = section?.dataset.consultationEndpoint;
      if (!endpoint) return;

      const successMessage = section.dataset.successMessage || 'Thank you. Your consultation request has been sent.';
      const errorMessage = section.dataset.errorMessage || 'Something went wrong. Please try again.';

      form.addEventListener('submit', async (event) => {
        // Fully AJAX: never let the browser navigate/reload.
        event.preventDefault();

        // Validate in JS (form is novalidate) and surface native hints.
        if (!form.reportValidity()) return;

        const submitButton = form.querySelector('.custom-inquiry__submit');
        const labelSpan = submitButton?.querySelector('span:first-child');
        const originalLabel = labelSpan?.textContent;

        const getValue = (name) => form.querySelector(`[name="${name}"]`)?.value.trim() || '';

        const formData = new FormData();
        formData.append('name', getValue('name'));
        formData.append('phone_or_email', getValue('phone_or_email'));
        formData.append('message', getValue('message'));
        formData.append('consultation_time', getValue('consultation_time'));

        const fileInput = form.querySelector('[data-custom-files]');
        if (fileInput?.files?.length) {
          // Send every selected file under the same `file` key (List[UploadFile]).
          Array.from(fileInput.files).forEach((file) => formData.append('file', file));
        }

        if (submitButton) {
          submitButton.disabled = true;
          submitButton.setAttribute('aria-busy', 'true');
        }
        if (labelSpan) labelSpan.textContent = 'Sending…';

        try {
          // Do not set Content-Type: let the browser add the multipart boundary.
          const response = await fetch(endpoint, { method: 'POST', body: formData });

          if (response.ok) {
            notify(successMessage, 'success');
            form.reset();
            form.dispatchEvent(new CustomEvent('consultation:schedule-reset'));
            // Re-sync the file UI (count box, popup, dropzone copy) to the now-empty input.
            if (fileInput) fileInput.dispatchEvent(new Event('change'));
          } else {
            notify(errorMessage, 'error');
          }
        } catch (error) {
          notify(errorMessage, 'error');
        } finally {
          if (submitButton) {
            submitButton.disabled = false;
            submitButton.removeAttribute('aria-busy');
          }
          if (labelSpan && originalLabel != null) labelSpan.textContent = originalLabel;
        }
      });
    });

    document.querySelectorAll('[data-custom-files]:not([data-file-initialized])').forEach((input) => {
      input.dataset.fileInitialized = 'true';

      const form = input.closest('form');
      const fileCopy = form?.querySelector('[data-custom-file-copy]');
      const countBtn = form?.querySelector('[data-file-count-trigger]');
      const countNumber = form?.querySelector('[data-file-count-number]');
      const countLabel = form?.querySelector('[data-file-count-label]');
      const popup = form?.querySelector('[data-files-popup]');
      const dialog = popup?.querySelector('.custom-inquiry__files-dialog');
      const list = form?.querySelector('[data-files-list]');

      if (fileCopy && !fileCopy.dataset.defaultCopy) {
        fileCopy.dataset.defaultCopy = fileCopy.textContent;
      }

      const plural = (n) => (n === 1 ? 'file' : 'files');

      const formatSize = (bytes) => {
        if (bytes < 1024) return `${bytes} B`;
        if (bytes < 1024 * 1024) return `${(bytes / 1024).toFixed(1)} KB`;
        return `${(bytes / (1024 * 1024)).toFixed(1)} MB`;
      };

      const renderList = (files) => {
        if (!list) return;
        list.textContent = '';
        files.forEach((file) => {
          const item = document.createElement('li');
          item.className = 'custom-inquiry__files-item';
          const name = document.createElement('span');
          name.className = 'custom-inquiry__files-name';
          name.textContent = file.name;
          const size = document.createElement('span');
          size.className = 'custom-inquiry__files-size';
          size.textContent = formatSize(file.size);
          item.append(name, size);
          list.append(item);
        });
      };

      const onKeydown = (event) => {
        if (event.key === 'Escape') closePopup();
      };

      function openPopup() {
        if (!popup || !popup.hidden) return;
        popup.hidden = false;
        // Two frames so the browser paints the hidden state before transitioning.
        requestAnimationFrame(() => requestAnimationFrame(() => popup.classList.add('is-open')));
        countBtn?.setAttribute('aria-expanded', 'true');
        document.addEventListener('keydown', onKeydown);
        dialog?.focus();
      }

      function closePopup() {
        if (!popup || popup.hidden) return;
        popup.classList.remove('is-open');
        countBtn?.setAttribute('aria-expanded', 'false');
        document.removeEventListener('keydown', onKeydown);

        let done = false;
        const finish = () => {
          if (done) return;
          done = true;
          dialog?.removeEventListener('transitionend', onEnd);
          popup.hidden = true;
        };
        const onEnd = (event) => {
          if (event.target === dialog) finish();
        };
        dialog?.addEventListener('transitionend', onEnd);
        // Fallback when transitionend does not fire (e.g. reduced motion).
        setTimeout(finish, 400);
      }

      const syncUi = () => {
        const files = Array.from(input.files || []);
        const count = files.length;

        if (countNumber) countNumber.textContent = count;
        if (countLabel) countLabel.textContent = plural(count);
        if (countBtn) countBtn.hidden = count === 0;
        if (fileCopy) {
          fileCopy.textContent = count > 0 ? `${count} ${plural(count)} selected` : fileCopy.dataset.defaultCopy || '';
        }
        renderList(files);
        if (count === 0) closePopup();
      };

      countBtn?.addEventListener('click', openPopup);
      popup?.querySelectorAll('[data-files-popup-close]').forEach((el) => el.addEventListener('click', closePopup));

      input.addEventListener('change', () => {
        const files = Array.from(input.files || []);
        const tooBig = files.find((file) => file.size > 10 * 1024 * 1024);
        if (tooBig) {
          input.value = '';
          notify('Each file must be 10MB or smaller.', 'error');
        }
        syncUi();
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeCustomizationInquiry, { once: true });
  } else {
    initializeCustomizationInquiry();
  }

  document.addEventListener('shopify:section:load', initializeCustomizationInquiry);
{% endjavascript %}

