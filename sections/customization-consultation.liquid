{% comment %}
  Renders the private consultation request section for the customization page.
  Shopify handles the contact fields. Selected attachment names are included in
  the inquiry; binary file delivery requires a dedicated upload service.
  This section is mounted after the custom process section.
{% endcomment %}

{% liquid
  assign form_id = 'CustomizationConsultation-' | append: section.id
  assign privacy_url = shop.privacy_policy.url | default: routes.root_url
%}

<section class="custom-inquiry" id="custom-inquiry" aria-labelledby="CustomInquiryTitle-{{ section.id }}">
  <div class="custom-inquiry__inner">
    <div class="custom-inquiry__story">
      <p class="custom-inquiry__eyebrow">
        <span aria-hidden="true">&#10022;</span>
        {{ section.settings.eyebrow | escape }}
      </p>
      <h2 id="CustomInquiryTitle-{{ section.id }}">
        <span>{{ section.settings.heading_first_line | escape }}</span>
        <span>{{ section.settings.heading_second_line | escape }}</span>
      </h2>
      <div class="custom-inquiry__rule" aria-hidden="true"><span></span><b>&#10022;</b><span></span></div>
      <p class="custom-inquiry__description">{{ section.settings.description | escape }}</p>

      <figure class="custom-inquiry__figure">
        <img
          src="{{ 'book-consultation-form-photo.png' | asset_url }}"
          alt="Natural wood surface, books, and handcrafted decor selected for a custom interior"
          width="1536"
          height="864"
          loading="lazy"
        >
      </figure>

      <div class="custom-inquiry__benefits" aria-label="Custom design benefits">
        <div class="custom-inquiry__benefit">
          <span aria-hidden="true"><img src="{{ 'icon-plain-variation.svg' | asset_url }}" alt="" width="48" height="48"></span>
          <strong>{{ section.settings.benefit_one_title | escape }}</strong>
          <small>{{ section.settings.benefit_one_text | escape }}</small>
        </div>
        <div class="custom-inquiry__benefit">
          <span aria-hidden="true">{% render 'icon-artist-recognition', icon: 'leaf' %}</span>
          <strong>{{ section.settings.benefit_two_title | escape }}</strong>
          <small>{{ section.settings.benefit_two_text | escape }}</small>
        </div>
        <div class="custom-inquiry__benefit">
          <span aria-hidden="true">{% render 'faq-category-icon', icon: 'consultation' %}</span>
          <strong>{{ section.settings.benefit_three_title | escape }}</strong>
          <small>{{ section.settings.benefit_three_text | escape }}</small>
        </div>
      </div>
    </div>

    <div class="custom-inquiry__panel">
      <header class="custom-inquiry__form-header">
        <span aria-hidden="true">&#10022;</span>
        <h3>{{ section.settings.form_heading | escape }}</h3>
      </header>

      {% form 'contact', id: form_id, class: 'custom-inquiry__form', enctype: 'multipart/form-data' %}
        <input type="hidden" name="contact[tags]" value="custom-design-consultation">
        <input type="hidden" name="contact[attachment_names]" value="" data-custom-file-names>

        {% if form.posted_successfully? %}
          <p
            class="custom-inquiry__visually-hidden"
            role="status"
            data-custom-inquiry-toast
            data-toast-type="success"
            data-toast-message="{{ section.settings.success_message | escape }}"
          >
            {{ section.settings.success_message | escape }}
          </p>
          <noscript><p class="custom-inquiry__noscript-status">{{ section.settings.success_message | escape }}</p></noscript>
        {% endif %}

        {% if form.errors %}
          <div
            class="custom-inquiry__errors"
            role="alert"
            data-custom-inquiry-toast
            data-toast-type="error"
            data-toast-message="{{ section.settings.error_message | escape }}"
          >
            <p>{{ section.settings.error_message | escape }}</p>
            {{ form.errors | default_errors }}
          </div>
        {% endif %}

        <div class="custom-inquiry__field">
          <label for="{{ form_id }}-name">{{ section.settings.name_label | escape }}</label>
          <input
            id="{{ form_id }}-name"
            type="text"
            name="contact[name]"
            value="{{ form.name | default: customer.name | escape }}"
            autocomplete="name"
            placeholder="{{ section.settings.name_placeholder | escape }}"
            required
          >
        </div>

        <div class="custom-inquiry__field">
          <label for="{{ form_id }}-email">{{ section.settings.email_label | escape }}</label>
          <input
            id="{{ form_id }}-email"
            type="email"
            name="contact[email]"
            value="{{ form.email | default: customer.email | escape }}"
            autocomplete="email"
            autocorrect="off"
            autocapitalize="off"
            placeholder="{{ section.settings.email_placeholder | escape }}"
            required
            {% if form.errors contains 'email' %}aria-invalid="true"{% endif %}
          >
        </div>

        <div class="custom-inquiry__field">
          <label for="{{ form_id }}-phone">{{ section.settings.phone_label | escape }}</label>
          <input
            id="{{ form_id }}-phone"
            type="tel"
            name="contact[phone]"
            value="{{ form.phone | default: customer.phone | escape }}"
            autocomplete="tel"
            placeholder="{{ section.settings.phone_placeholder | escape }}"
          >
        </div>

        <div class="custom-inquiry__field">
          <label for="{{ form_id }}-request">{{ section.settings.request_label | escape }}</label>
          <textarea
            id="{{ form_id }}-request"
            name="contact[body]"
            placeholder="{{ section.settings.request_placeholder | escape }}"
            required
          >{{ form.body }}</textarea>
        </div>

        <div class="custom-inquiry__field">
          <span class="custom-inquiry__field-label">{{ section.settings.attachment_label | escape }}</span>
          <label class="custom-inquiry__upload" for="{{ form_id }}-files">
            <input
              id="{{ form_id }}-files"
              type="file"
              name="consultation_files"
              accept=".jpg,.jpeg,.png,.pdf"
              multiple
              data-custom-files
            >
            <span class="custom-inquiry__upload-icon" aria-hidden="true">&#8679;</span>
            <span data-custom-file-copy>{{ section.settings.attachment_prompt | escape }}</span>
            <small>{{ section.settings.attachment_help | escape }}</small>
          </label>
        </div>

        <p class="custom-inquiry__security">
          <span aria-hidden="true">&#9671;</span>
          {{ section.settings.security_text | escape }}
        </p>

        <button class="custom-inquiry__submit" type="submit">
          <span>{{ section.settings.button_label | escape }}</span>
          <span aria-hidden="true">&rarr;</span>
        </button>

        <p class="custom-inquiry__privacy">
          {{ section.settings.privacy_prefix | escape }}
          <a href="{{ privacy_url }}">{{ section.settings.privacy_label | escape }}</a>.
        </p>
      {% endform %}
    </div>
  </div>
</section>

<script>
  const mainProductSection = document.getElementById('CustomInquiryTitle-{{ section.id }}');
  if (mainProductSection && window.innerWidth < 768) {
    mainProductSection.closest('body').querySelector('.header__icon--search').style.color = 'var(--color-earth-brown)';
    mainProductSection.closest('body').querySelector('.header__icon--cart').style.color = 'var(--color-earth-brown)';
  }
</script>
{% stylesheet %}
  .custom-inquiry {
    border-block-start: var(--border-width) solid var(--border-default);
    background: var(--color-cream);
    color: var(--text-primary);
    font-family: var(--font-body);
  }

  .custom-inquiry__inner {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.94fr);
    gap: var(--sp-8);
    inline-size: min(calc(100% - (var(--layout-padding-desktop) * 2)), calc(var(--layout-showcase-max-width) + (var(--sp-12) * 2)));
    margin-inline: auto;
    padding-block: var(--sp-10);
  }

  .custom-inquiry__story {
    align-self: start;
    padding-block-start: var(--sp-5);
  }

  .custom-inquiry__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin: var(--sp-0) var(--sp-0) var(--sp-4);
    color: var(--color-earth-brown);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 5);
    text-transform: uppercase;
  }

  .custom-inquiry__eyebrow span,
  .custom-inquiry__form-header > span {
    color: var(--color-clay);
    font-size: var(--font-size-display-sm);
  }

  .custom-inquiry__story h2 {
    display: flex;
    flex-direction: column;
    max-inline-size: 14ch;
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-display-light);
    font-size: clamp(var(--font-size-display-md), 4vw, calc(var(--font-size-display-xl) + var(--sp-2)));
    font-weight: var(--font-weight-light);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-display);
    text-transform: uppercase;
  }

  .custom-inquiry__rule {
    display: grid;
    grid-template-columns: minmax(var(--sp-8), var(--sp-12)) auto minmax(var(--sp-8), var(--sp-12));
    align-items: center;
    gap: var(--sp-2);
    inline-size: fit-content;
    margin-block: var(--sp-5);
    color: var(--color-clay);
  }

  .custom-inquiry__rule span {
    block-size: var(--border-width);
    background: currentcolor;
  }

  .custom-inquiry__rule b {
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-regular);
  }

  .custom-inquiry__description {
    max-inline-size: 48ch;
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-body-md);
    line-height: var(--line-height-generous);
  }

  .custom-inquiry__figure {
    aspect-ratio: 16 / 9;
    margin: var(--sp-6) var(--sp-0) var(--sp-4);
    overflow: hidden;
    border-radius: var(--radius-lg);
  }

  .custom-inquiry__figure img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    object-position: left bottom;
  }

  .custom-inquiry__benefits {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    padding: var(--sp-5) var(--sp-3);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-milk) 80%, transparent);
  }

  .custom-inquiry__benefit {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--sp-2);
    padding-inline: var(--sp-3);
    border-inline-start: var(--border-width) solid var(--border-default);
    text-align: center;
  }

  .custom-inquiry__benefit:first-child {
    border-inline-start: 0;
  }

  .custom-inquiry__benefit > span {
    display: grid;
    place-items: center;
    inline-size: var(--sp-7);
    block-size: var(--sp-7);
    color: var(--color-clay);
  }

  .custom-inquiry__benefit svg,
  .custom-inquiry__benefit img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: contain;
  }

  .custom-inquiry__benefit strong {
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    line-height: var(--line-height-normal);
    text-transform: uppercase;
  }

  .custom-inquiry__benefit small {
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-normal);
  }

  .custom-inquiry__panel {
    padding: var(--sp-7);
    border: var(--border-width) solid var(--color-clay);
    border-radius: var(--radius-lg);
    background: color-mix(in srgb, var(--color-milk) 84%, transparent);
    box-shadow: var(--shadow-elevation-1);
  }

  .custom-inquiry__form-header {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
    margin-block-end: var(--sp-5);
  }

  .custom-inquiry__form-header h3 {
    margin: var(--sp-0);
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-body-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 4);
    text-transform: uppercase;
  }

  .custom-inquiry__form {
    display: grid;
    gap: var(--sp-4);
  }

  .custom-inquiry__field {
    display: grid;
    gap: var(--sp-2);
  }

  .custom-inquiry__field label:not(.custom-inquiry__upload),
  .custom-inquiry__field-label {
    color: var(--color-earth-brown);
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    text-transform: uppercase;
  }

  .custom-inquiry__field input:not([type='file']),
  .custom-inquiry__field textarea {
    inline-size: 100%;
    min-block-size: calc(var(--sp-7) + var(--sp-3));
    padding: var(--sp-3) var(--sp-4);
    border: var(--border-width) solid var(--border-default);
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--bg-tertiary) 68%, transparent);
    color: var(--text-primary);
    font-family: var(--font-body);
    font-size: var(--font-size-body-sm);
  }

  .custom-inquiry__field textarea {
    min-block-size: calc(var(--sp-12) + var(--sp-5));
    resize: vertical;
  }

  .custom-inquiry__field input:focus,
  .custom-inquiry__field textarea:focus {
    border-color: var(--color-earth-brown);
    outline: 0;
    box-shadow: var(--shadow-focus);
  }

  .custom-inquiry__field input[aria-invalid='true'] {
    border-color: var(--color-error);
  }

  .custom-inquiry__upload {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-block-size: calc(var(--sp-12) + var(--sp-5));
    padding: var(--sp-4);
    overflow: hidden;
    border: var(--border-width) dashed var(--color-clay);
    border-radius: var(--radius-md);
    color: var(--text-secondary);
    text-align: center;
    cursor: pointer;
  }

  .custom-inquiry__upload input {
    position: absolute;
    inset: var(--sp-0);
    opacity: 0;
    cursor: pointer;
  }

  .custom-inquiry__upload:focus-within {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  .custom-inquiry__upload-icon {
    color: var(--color-clay);
    font-size: var(--font-size-display-md);
    line-height: var(--line-height-tight);
  }

  .custom-inquiry__upload > span:not(.custom-inquiry__upload-icon) {
    font-size: var(--font-size-body-sm);
    line-height: var(--line-height-generous);
  }

  .custom-inquiry__upload small {
    margin-block-start: var(--sp-2);
    font-size: var(--font-size-caption);
  }

  .custom-inquiry__security {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-3);
    margin: var(--sp-0);
    color: var(--text-secondary);
    font-size: var(--font-size-caption);
    line-height: var(--line-height-generous);
  }

  .custom-inquiry__security span {
    color: var(--color-clay);
    font-size: var(--font-size-body-lg);
  }

  .custom-inquiry__submit {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-block-size: calc(var(--sp-7) + var(--sp-3));
    padding-inline: var(--sp-5);
    border: 0;
    border-radius: var(--radius-md);
    background: var(--color-earth-brown);
    color: var(--text-inverse);
    font-family: var(--font-display);
    font-size: var(--font-size-caption);
    font-weight: var(--font-weight-semibold);
    letter-spacing: calc(var(--letter-spacing-wide) * 2);
    text-transform: uppercase;
  }

  .custom-inquiry__submit:hover {
    background: var(--color-charcoal);
  }

  .custom-inquiry__submit:focus-visible,
  .custom-inquiry__privacy a:focus-visible {
    outline: calc(var(--border-width) * 2) solid var(--color-sage);
    outline-offset: var(--sp-1);
  }

  .custom-inquiry__privacy {
    margin: var(--sp-0);
    color: var(--text-tertiary);
    font-size: var(--font-size-caption);
    text-align: center;
  }

  .custom-inquiry__privacy a {
    color: var(--text-secondary);
    text-decoration: underline;
  }

  .custom-inquiry__errors,
  .custom-inquiry__noscript-status {
    padding: var(--sp-4);
    border: var(--border-width) solid var(--color-error);
    border-radius: var(--radius-md);
    font-size: var(--font-size-body-sm);
  }

  .custom-inquiry__errors p,
  .custom-inquiry__noscript-status {
    margin: var(--sp-0);
  }

  .custom-inquiry__visually-hidden {
    position: absolute;
    inline-size: var(--border-width);
    block-size: var(--border-width);
    padding: var(--sp-0);
    margin: calc(var(--border-width) * -1);
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media screen and (max-width: 64rem) {
    .custom-inquiry__inner {
      grid-template-columns: minmax(0, 0.84fr) minmax(0, 1.16fr);
      gap: var(--sp-5);
      inline-size: min(calc(100% - (var(--layout-padding-tablet) * 2)), var(--layout-showcase-max-width));
      padding-block: var(--sp-8);
    }

    .custom-inquiry__story h2 {
      font-size: var(--font-size-display-lg);
    }

    .custom-inquiry__panel {
      padding: var(--sp-5);
    }

    .custom-inquiry__benefits {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-4);
    }

    .custom-inquiry__benefit {
      display: grid;
      grid-template-columns: var(--sp-7) minmax(0, 1fr);
      justify-items: start;
      border-inline-start: 0;
      text-align: left;
    }

    .custom-inquiry__benefit small {
      grid-column: 2;
    }
  }

  @media screen and (max-width: 48rem) {
    .custom-inquiry__inner {
      grid-template-columns: minmax(0, 1fr);
      inline-size: min(calc(100% - (var(--layout-padding-mobile) * 2)), var(--layout-showcase-max-width));
      padding-block: var(--sp-6);
    }

    .custom-inquiry__story {
      padding-block-start: var(--sp-0);
    }

    .custom-inquiry__story h2 {
      font-size: var(--font-size-display-lg);
    }

    .custom-inquiry__description {
      font-size: var(--font-size-body-sm);
    }

    .custom-inquiry__benefits {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: var(--sp-0);
    }

    .custom-inquiry__benefit {
      display: flex;
      justify-items: initial;
      padding-inline: var(--sp-2);
      border-inline-start: var(--border-width) solid var(--border-default);
      text-align: center;
    }

    .custom-inquiry__benefit:first-child {
      border-inline-start: 0;
    }

    .custom-inquiry__benefit small {
      grid-column: auto;
    }

    .custom-inquiry__panel {
      padding: var(--sp-4);
    }
  }

  @media screen and (max-width: 30rem) {
    .custom-inquiry__benefits {
      grid-template-columns: minmax(0, 1fr);
      gap: var(--sp-4);
    }

    .custom-inquiry__benefit {
      display: grid;
      grid-template-columns: var(--sp-7) minmax(0, 1fr);
      justify-items: start;
      border-inline-start: 0;
      text-align: left;
    }

    .custom-inquiry__benefit small {
      grid-column: 2;
    }

    .custom-inquiry__submit {
      gap: var(--sp-3);
      padding-inline: var(--sp-4);
    }
  }
{% endstylesheet %}

{% javascript %}
  const initializeCustomizationInquiry = () => {
    document.querySelectorAll('[data-custom-inquiry-toast]:not([data-toast-shown])').forEach((feedback) => {
      if (!window.showToast) return;
      feedback.dataset.toastShown = 'true';
      window.showToast({
        message: feedback.dataset.toastMessage,
        type: feedback.dataset.toastType,
        position: 'bottom-right',
        duration: 4000,
      });
    });

    document.querySelectorAll('[data-custom-files]:not([data-file-initialized])').forEach((input) => {
      input.dataset.fileInitialized = 'true';
      input.addEventListener('change', () => {
        const files = Array.from(input.files || []);
        const invalidFile = files.find((file) => file.size > 10 * 1024 * 1024);
        const form = input.closest('form');
        const fileNames = form?.querySelector('[data-custom-file-names]');
        const fileCopy = form?.querySelector('[data-custom-file-copy]');

        if (invalidFile) {
          input.value = '';
          if (fileNames) fileNames.value = '';
          if (window.showToast) {
            window.showToast({
              message: 'Each file must be 10MB or smaller.',
              type: 'error',
              position: 'bottom-right',
              duration: 4000,
            });
          }
          return;
        }

        const names = files.map((file) => file.name);
        if (fileNames) fileNames.value = names.join(', ');
        if (fileCopy && names.length) fileCopy.textContent = names.join(', ');
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeCustomizationInquiry, { once: true });
  } else {
    initializeCustomizationInquiry();
  }

  document.addEventListener('shopify:section:load', initializeCustomizationInquiry);
{% endjavascript %}

{% schema %}
{
  "name": "Custom consultation",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Custom design service" },
    { "type": "text", "id": "heading_first_line", "label": "Heading first line", "default": "Let's design" },
    { "type": "text", "id": "heading_second_line", "label": "Heading second line", "default": "something exceptional." },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Share your ideas and space details. Our designers will craft a tailored proposal with custom dimensions, premium wood selections, and expert guidance." },
    { "type": "text", "id": "benefit_one_title", "label": "Benefit one title", "default": "Tailored dimensions" },
    { "type": "text", "id": "benefit_one_text", "label": "Benefit one text", "default": "Made to fit your space perfectly." },
    { "type": "text", "id": "benefit_two_title", "label": "Benefit two title", "default": "Premium wood" },
    { "type": "text", "id": "benefit_two_text", "label": "Benefit two text", "default": "Selected for beauty and durability." },
    { "type": "text", "id": "benefit_three_title", "label": "Benefit three title", "default": "Personalized guidance" },
    { "type": "text", "id": "benefit_three_text", "label": "Benefit three text", "default": "Support from concept to completion." },
    { "type": "header", "content": "Consultation form" },
    { "type": "text", "id": "form_heading", "label": "Form heading", "default": "Consultation form" },
